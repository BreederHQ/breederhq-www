---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Screenshot from '../../components/Screenshot.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Workflows', url: '/workflows' },
  { name: 'Offspring & Neonatal Care', url: '/workflows/offspring-care' }
];

const faqs = [
  {
    question: 'Can I enter weights from my phone right after birth?',
    answer: 'Yes. Mobile access means you can enter weights immediately after weighing.'
  },
  {
    question: 'Does it track multiple litters or foaling groups at once?',
    answer: 'Yes. Each litter or birth group has its own record with individual offspring tracking. Whether it is a litter of eight or a single foal, the workflow is the same.'
  },
  {
    question: 'Can I attach photos to each offspring?',
    answer: 'Yes. Photos help with identification and can be shared with buyers.'
  },
  {
    question: 'Does it remind me about deworming and vaccinations?',
    answer: 'Yes. Milestones are tracked and reminders are automatic.'
  },
  {
    question: 'Can buyers access early records for their animal?',
    answer: 'Yes. When you place an offspring with a buyer, they can access birth and growth history through their portal.'
  }
];

const howTo = {
  name: 'How to Manage Birthing and Offspring Records',
  description: 'A step-by-step guide to tracking births, recording offspring data, and managing milestones for litters, singles, and everything in between.',
  steps: [
    { name: 'Calculate due date', text: 'Enter the breeding date and the system calculates the expected birth date based on species-specific gestation periods.' },
    { name: 'Prepare for birth', text: 'Use the countdown to due date to prepare supplies, schedule time off, and set up the birthing area.' },
    { name: 'Record birth details', text: 'Log each offspring as born with birth time, birth weight, sex, color/markings, and any notes about the delivery.' },
    { name: 'Track daily weights', text: 'Weigh offspring daily and record weights. The system tracks weight gain trends and flags those that may need attention.' },
    { name: 'Manage milestones', text: 'Track developmental milestones: eyes opening, ears opening, first solid food, deworming dates, and vaccination schedules.' },
    { name: 'Add photos and identification', text: 'Upload photos for each offspring to help with identification and share progress with waitlist families.' }
  ]
};
---

<BaseLayout
  title="Offspring Care: From Birth to Placement | BreederHQ"
  description="You already track every birth, every weight, every milestone. BreederHQ keeps it all organized, spots problems early, and shares records with buyers automatically."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
  howTo={howTo}
>
  <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
    Skip to content
  </a>

  <main id="main-content">
  <nav class="breadcrumb py-4 px-4 bg-gray-50" aria-label="Breadcrumb">
    <ol class="flex items-center space-x-2 max-w-4xl mx-auto text-sm">
      <li><a href="/" class="text-[hsl(24,95%,53%)] hover:underline">Home</a></li>
      <li class="text-gray-400">›</li>
      <li><a href="/workflows" class="text-[hsl(24,95%,53%)] hover:underline">Workflows</a></li>
      <li class="text-gray-400">›</li>
      <li aria-current="page" class="text-gray-600">Offspring & Neonatal Care</li>
    </ol>
  </nav>

  <!-- Section 1: What This Page Is About -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-bold mb-6">Offspring Care. From Birth to Placement.</h1>

      <aside class="tldr-box bg-gray-100 border-l-4 border-[hsl(24,95%,53%)] p-6 my-8 rounded" role="complementary" aria-label="Page summary">
        <h2 class="text-xl font-bold mb-3">TL;DR</h2>
        <p class="text-gray-700 leading-relaxed">
          You already track birth weights, daily gains, milestones, and vet visits. BreederHQ keeps it all in one place with visual sparklines, batch weight entry, care log timelines, and automatic weight anomaly alerts. Catch problems early. Save more newborns. Connect records to buyer placements automatically.
        </p>
      </aside>
      <p class="text-xl text-gray-700 leading-relaxed">
        You already know how intense birth season gets. Monitoring the mother, tracking individual offspring, documenting weights, watching for problems. Whether you're managing a litter of ten or watching over a single foal or kid, BreederHQ keeps everything organized so you can focus on the animals, even at 3am.
      </p>

      <div class="mt-12">
        <Screenshot
          id="offspring-list"
          alt="Litter view showing each puppy with collar color, sex, placement state, and assigned buyer"
        />
        <p class="text-sm text-gray-500 mt-3 text-center italic">
          Every puppy in the litter: collar color, placement state, paperwork status, and which buyer they're going to.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 2: Why Breeders Search for This -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">You're already tracking all of this. Here's why it gets hard.</h2>
      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        You do the work. The challenge is keeping it all organized:
      </p>
      <ul class="space-y-3 text-lg text-gray-700 mb-6">
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>You can't identify which offspring is which</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Weight trends are invisible without daily tracking</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Vet asks about birth weight and you're digging through papers</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Buyers ask questions about their animal's early days and you have no record</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>You lose track of deworming schedules and vaccination dates</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Critical information is on scraps of paper you can't find</span>
        </li>
      </ul>
      <p class="text-lg text-gray-700 leading-relaxed">
        You already know what's at stake. BreederHQ makes sure the paperwork keeps up with you, even when you're sleep-deprived and running on coffee.
      </p>
    </div>
  </section>

  <!-- Section 3: How Breeders Usually Handle It -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">The systems you've been using</h2>

      <div class="space-y-6">
        <div>
          <h3 class="text-2xl font-bold mb-3">Birth charts on paper</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Printed charts posted near the birthing area. Write weights daily in pencil. Works great in the moment, but hard to search later or share with buyers.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Spreadsheets</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            A sheet per litter or birth. Columns for each offspring. Rows for each day. Data entry after weighing. It works until your laptop isn't nearby. Or until you need to see the chart on your phone.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Notebooks</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Write everything down. Birth times, weights, notes. Finding specific information later means flipping through pages.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Photos with timestamps</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Take a photo of the scale. Works for documentation. Terrible for calculating weight gain or spotting trends.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Memory</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            "The blue collar one was smallest." "I think she weighed about..." You know the information, but pulling it up on the spot is another story when you're exhausted and managing multiple offspring.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: Where That Breaks Down -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Where it starts to get overwhelming</h2>

      <div class="space-y-8">
        <div>
          <h3 class="text-2xl font-bold mb-4">The data adds up fast</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            A large litter, twins, or even a single foal you're monitoring closely. Twice daily weighing. That's dozens of data points per day. Over weeks, that's hundreds of weights. You're doing the weighing. The hard part is keeping it all organized.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">You can see the numbers but not the trends</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Is that offspring gaining appropriately? A list of weights doesn't show you the pattern. You know what to look for, but calculating percentage gain manually across multiple offspring is tedious.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Identification gets tricky as they grow</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Colored collars or markings work great at first. But as offspring grow and change, keeping track of who's who takes more effort. Photos help, but organizing them is another task on top of everything else.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Birth records don't follow the animal</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            You've tracked the blue collar offspring from birth. Now they're going to a buyer. Ideally those birth records become part of their permanent record. In reality, they're usually stuck in a notebook or spreadsheet.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Milestones sneak up on you</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Deworming schedule. First vaccination. Microchipping or ear tagging. Socialization protocols. These are date-driven tasks. If they're not tracked with reminders, they're easy to miss.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Sharing with buyers takes too long</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            A buyer wants to know their animal's birth weight and growth pattern. You know the information exists, but pulling it together means scanning paper charts or digging through spreadsheets.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5: What a Correct System Looks Like -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">What it looks like when it all comes together</h2>

      <div class="space-y-8">
        <div>
          <h3 class="text-2xl font-bold mb-4">Birth records with due dates</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Due date auto-calculated from breeding date</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Birth alerts before expected delivery</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Actual birth date recorded</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Birth record connected to both parents automatically</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Individual offspring tracking</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Each offspring identified with collar color or temporary name</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Birth time and weight recorded</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Sex, color, markings documented</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Photos attached to each offspring record</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Weight tracking with trend visualization</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Daily weights entered quickly (mobile-friendly)</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Weight gain patterns shown visually</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Offspring not gaining appropriately flagged</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Historical weight data accessible</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Milestone and task tracking</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Deworming schedule auto-generated</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Vaccination dates tracked</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Microchipping, ear tags, or tattoos recorded per offspring</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Reminders for upcoming tasks</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Records connected to placement</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Birth data becomes permanent animal record</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>When placed, buyer gets access to history</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Birth weight, growth, and milestones shareable</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>No manual transcription needed</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5.5: Neonatal Care Features -->
  <section class="py-20 px-4 bg-red-50">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-center mb-8">
        <div class="text-5xl mr-4">🍼</div>
        <h2 class="text-4xl font-bold">Neonatal Care: Save More Newborns</h2>
      </div>

      <p class="text-lg text-gray-700 leading-relaxed mb-8">
        The first weeks are critical. Fading newborn syndrome can take a healthy offspring within hours. Early detection is everything. BreederHQ's neonatal care tracking helps you catch problems before it's too late.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">📊 Weight Tracking with Sparklines</h3>
          <p class="text-gray-700 mb-3">
            See each offspring's weight trend at a glance. Sparkline charts show the pattern immediately-steady gains, plateaus, or concerning drops.
          </p>
          <p class="text-sm text-gray-600">
            Visual patterns are faster than reading numbers. A downward sparkline catches your eye before a problem becomes critical.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">⚡ Batch Weight Entry</h3>
          <p class="text-gray-700 mb-3">
            Weighing multiple offspring twice a day? Batch entry lets you log all weights quickly. Enter weights in order, tab to next, done. Works just as well for a litter of ten as for twin kids or a single foal.
          </p>
          <p class="text-sm text-gray-600">
            No navigating between individual records. One screen, all offspring, fast logging.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">📝 Care Log Timeline</h3>
          <p class="text-gray-700 mb-3">
            Document every intervention: tube feeding, supplementing, stimulating, warming. Time-stamped entries create a complete care history.
          </p>
          <p class="text-sm text-gray-600">
            When the vet asks "what have you tried?", you have documented answers.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">🏥 Veterinary Interventions</h3>
          <p class="text-gray-700 mb-3">
            Track vet visits, treatments, and outcomes per offspring. Link to care logs for complete context.
          </p>
          <p class="text-sm text-gray-600">
            Critical for insurance, buyer transparency, and your own records of what worked.
          </p>
        </div>
      </div>

      <div class="bg-white border-l-4 border-red-500 p-6 rounded mb-8">
        <h3 class="text-xl font-bold mb-3 text-red-800">⚠️ Weight Anomaly Alerts</h3>
        <p class="text-gray-700 mb-3">
          BreederHQ automatically flags offspring showing concerning weight patterns:
        </p>
        <ul class="text-gray-700 space-y-2">
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>No weight gain in 24 hours</strong> - needs attention</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Weight loss</strong> - immediate concern, investigate promptly</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Below group average</strong> - may need supplementation</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Rapid unexplained changes</strong> - investigate immediately</span>
          </li>
        </ul>
        <p class="text-sm text-red-700 mt-4 font-medium">
          Alerts don't replace your judgment. They make sure you see what matters when you're exhausted at 3am.
        </p>
      </div>

      <div class="bg-gray-100 p-6 rounded-lg">
        <h3 class="text-xl font-bold mb-3">Neonatal Care Dashboard</h3>
        <p class="text-gray-700 mb-3">
          One screen showing all offspring with status indicators:
        </p>
        <div class="flex flex-wrap gap-3">
          <span class="bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm font-medium">🟢 Thriving</span>
          <span class="bg-yellow-100 text-yellow-800 px-3 py-1 rounded-full text-sm font-medium">🟡 Monitor</span>
          <span class="bg-red-100 text-red-800 px-3 py-1 rounded-full text-sm font-medium">🔴 Attention Needed</span>
        </div>
        <p class="text-sm text-gray-600 mt-3">
          Status is calculated automatically from weight trends, feeding logs, and care interventions.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 6: How BreederHQ Supports This -->
  <section class="py-20 px-4 bg-[hsl(24,95%,53%)] text-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">How BreederHQ keeps you on top of it all</h2>

      <p class="text-xl leading-relaxed mb-8">
        Birth records with automatic due date calculations. Individual offspring tracking with photos and identification. Daily weight entry that works on your phone right where you are. Weight trends visualized with sparklines so problems are obvious. Automatic weight anomaly alerts to catch fading newborns early. Care log timelines documenting every intervention. Milestone reminders for deworming and vaccinations. Records that connect seamlessly to buyer placements.
      </p>

      <p class="text-xl leading-relaxed mb-8">
        You already do the hard work. BreederHQ makes sure nothing falls through the cracks.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="https://accounts.breederhq.com/register?intent=breeder_dashboard" class="inline-block bg-white text-[hsl(24,95%,53%)] px-8 py-4 rounded-lg font-bold text-lg hover:bg-gray-100 transition text-center" style="min-height: 44px;">
          Get Started Free
        </a>
        <a href="/litter-management" class="inline-block bg-transparent border-2 border-white text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-white hover:text-[hsl(24,95%,53%)] transition text-center" style="min-height: 44px;">
          See offspring management →
        </a>
      </div>
    </div>
  </section>

  <!-- Section 7: Who This Is For -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Built for breeders who:</h2>

      <ul class="space-y-3 text-lg text-gray-700">
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Have multiple births per year, whether litters, singles, or twins</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Track offspring weights and growth carefully</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Need to identify individual offspring reliably</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Provide detailed records to buyers</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Want to stop using paper charts and spreadsheets</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Need mobile access to records at the barn, kennel, or wherever you are</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Section 8: Who This Is Not For -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">This might be overkill if:</h2>

      <ul class="space-y-3 text-lg text-gray-700 mb-8">
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>You have one or two births per year</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Small groups or singles that are easy to track by hand</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Paper charts genuinely meet your needs</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>You don't share detailed records with buyers</span>
        </li>
      </ul>

      <p class="text-lg text-gray-700 leading-relaxed">
        If paper works for your program, there's nothing wrong with that. BreederHQ is here when you're ready for something more.
      </p>
    </div>
  </section>

  <!-- Section 9: FAQ -->
  <section class="py-20 px-4 faq-section">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-12">Frequently asked questions</h2>

      <details class="faq-item">
        <summary class="faq-question">
          <span>Can I enter weights from my phone right after birth?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>Yes. Mobile access means you can enter weights immediately after weighing.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          <span>Does it track multiple litters or foaling groups at once?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
