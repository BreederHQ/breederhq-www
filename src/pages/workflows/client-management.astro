---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedWorkflows from '../../components/RelatedWorkflows.astro';
import Screenshot from '../../components/Screenshot.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Workflows', url: '/workflows' },
  { name: 'Client Management', url: '/workflows/client-management' }
];

const faqs = [
  {
    question: 'Is this a real client management system or just a contact list?',
    answer: 'It\'s a full client management system with a visual sales pipeline, lead scoring, deal tracking, email templates, task management, and conversion analytics. Not a generic tool, but built specifically for breeder sales workflows.'
  },
  {
    question: 'What is the sales pipeline?',
    answer: 'A visual Kanban board that shows every buyer\'s stage: Inquiry, Viewing, Negotiation, Vet Check, Contract, through to Closed. Drag and drop buyers between stages as they progress.'
  },
  {
    question: 'How does lead scoring work?',
    answer: 'The system scores buyers based on their engagement, how recently they\'ve been active, budget fit, interest level, and deal progress. Higher-scored buyers are flagged so you focus on the most promising prospects first.'
  },
  {
    question: 'Can I track communication history?',
    answer: 'Yes. Log calls, emails, meetings, viewings, and notes with dates. Every interaction is recorded on a timeline so you have a complete history.'
  },
  {
    question: 'Can I message buyers from my phone?',
    answer: 'Yes. The BreederHQ Mobile Companion app — the on-the-go partner to the BreederHQ web app — lets you message buyers directly so quick questions get quick answers, even when you are in the barn, kennel, or at a vet appointment. Messages are captured on the client\'s timeline automatically, so conversations never live only in a personal text thread.'
  },
  {
    question: 'Can buyers access their animal\'s information?',
    answer: 'Yes. The buyer portal gives clients access to pedigrees, health records, photos, and other information you choose to share.'
  }
];

const howTo = {
  name: 'How to Manage Breeder Clients',
  description: 'A step-by-step guide to professional client management including sales pipeline, lead scoring, communication tracking, contracts, and buyer portal setup.',
  steps: [
    { name: 'Create client records', text: 'Add each buyer with contact information, preferences, budget, and how they found you. Link clients to animals they\'ve purchased or are waiting for.' },
    { name: 'Track buyers through the sales pipeline', text: 'Move buyers through stages on a visual Kanban board: Inquiry, Viewing, Negotiation, Vet Check, Contract, Closed. See your total pipeline value and which deals need attention.' },
    { name: 'Log communication history', text: 'Record calls, emails, meetings, viewings, and notes with dates. Message buyers directly from the BreederHQ Mobile Companion app so you can respond on the go, and every message is added to the client timeline automatically.' },
    { name: 'Upload contracts and documents', text: 'Attach signed purchase agreements, spay/neuter contracts, registration transfer documents, and other paperwork to each client record.' },
    { name: 'Track payments', text: 'Record deposits and final payments with amounts, dates, and payment methods. Link payments to specific animals or services.' },
    { name: 'Set up buyer portal access', text: 'Invite clients to their buyer portal where they can view pedigrees, health records, photos, and documents you choose to share.' },
    { name: 'Review analytics', text: 'Check conversion rates by lead source, average time to placement, and which buyers have gone quiet. Use lead scoring to focus on the most promising prospects.' }
  ]
};
---

<BaseLayout
  title="Client Management, Organized for Breeders | BreederHQ"
  description="You already build strong buyer relationships. BreederHQ keeps every client profile, conversation, contract, and deposit in one place, with a Mobile Companion app for messaging buyers on the go."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
  howTo={howTo}
>
  <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
    Skip to content
  </a>

  <main id="main-content">
  <nav class="breadcrumb py-4 px-4 bg-gray-50" aria-label="Breadcrumb">
    <ol class="flex items-center space-x-2 max-w-4xl mx-auto text-sm">
      <li><a href="/" class="text-[hsl(24,95%,53%)] hover:underline">Home</a></li>
      <li class="text-gray-400">›</li>
      <li><a href="/workflows" class="text-[hsl(24,95%,53%)] hover:underline">Workflows</a></li>
      <li class="text-gray-400">›</li>
      <li aria-current="page" class="text-gray-600">Client Management</li>
    </ol>
  </nav>

  <!-- Section 1: What This Page Is About -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-bold mb-6">Client Management, Organized for Breeders.</h1>

      <aside class="tldr-box bg-gray-100 border-l-4 border-[hsl(24,95%,53%)] p-6 my-8 rounded" role="complementary" aria-label="Page summary">
        <h2 class="text-xl font-bold mb-3">TL;DR</h2>
        <p class="text-gray-700 leading-relaxed">
          You already build strong buyer relationships. BreederHQ keeps every client profile, conversation, contract, deposit, and follow-up in one place, with a visual sales pipeline, lead scoring, and analytics. When you're away from your desk, message buyers from the BreederHQ Mobile Companion app so quick questions get quick answers, even when you're in the barn or at a vet appointment.
        </p>
      </aside>
      <p class="text-xl text-gray-700 leading-relaxed">
        Your reputation is built on client relationships, and you already invest in them. BreederHQ makes the record-keeping side easier so quick follow-ups stay quick, contracts are easy to find, and nothing falls through the cracks as your program grows.
      </p>

      <div class="mt-12">
        <Screenshot
          id="contacts-list"
          alt="Contacts view in BreederHQ showing every buyer and prospect with marketplace activity"
        />
      </div>
    </div>
  </section>

  <!-- Section 2: Why Breeders Search for This -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">You already care about these relationships. Here's where it gets complicated.</h2>
      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        The hard part isn't caring about your clients. It's keeping the details organized as the list grows:
      </p>
      <ul class="space-y-3 text-lg text-gray-700 mb-6">
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Buyer asks a question and you can't remember what you already told them</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Contract terms are unclear because the signed contract is buried in email</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Payment tracking gets messy: who paid what, and when?</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Follow-up reminders missed because they're not systematized</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Buyers frustrated because getting information from you is difficult</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Your professional reputation suffers from disorganization</span>
        </li>
      </ul>
      <p class="text-lg text-gray-700 leading-relaxed">
        You already do the work. BreederHQ makes sure the client side feels as polished as the breeding program behind it.
      </p>
    </div>
  </section>

  <!-- Section 3: How Breeders Usually Handle It -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">The tools you've been using</h2>

      <div class="space-y-6">
        <div>
          <h3 class="text-2xl font-bold mb-3">Email and text messages</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            All communication scattered across platforms. Finding what someone told you six months ago means searching through hundreds of messages.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Spreadsheets</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Client list with phone numbers and email addresses. Maybe payment status. No communication history. No document storage.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Physical folders</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            A folder per client with contracts and paperwork. Good for documents. Terrible for tracking communication or accessing information when you're not home.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Generic sales software</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Business software designed for sales teams, not breeding programs. It doesn't understand litters, foals, kids, lambs, kits, calves, waitlists, or the specific workflows breeders need.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Memory</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            "I remember talking to them about that." You know the conversation happened, but recalling exactly what was said, months later and across dozens of families, is where memory stops being enough.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: Where That Breaks Down -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Where those tools start to stretch thin</h2>

      <div class="space-y-8">
        <div>
          <h3 class="text-2xl font-bold mb-4">Communication history is scattered</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Email, text, Facebook Messenger, phone calls. Every conversation lives somewhere different. When a buyer asks a follow-up question, you're guessing what you already told them.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Contracts are hard to find</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Signed contract is in email. Or maybe a scan is on your desktop. Or in a physical folder. When you need to reference contract terms, you're hunting.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Payment tracking is manual</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Who paid a deposit? Who paid in full? What payment method did they use? This information lives in your bank records, email, or nowhere. Reconciling payments is painful.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Follow-ups are forgotten</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            You meant to check in at six months. You meant to ask for photos at one year. You meant to remind them about annual vet visits. Without a system, follow-ups don't happen.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Buyer information requests are repetitive</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            "Can you send me his pedigree again?" "What was his birth weight?" "Do you have his vaccination records?" You've sent this information before. You're sending it again because it's not in one accessible place.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Relationships don't scale</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Managing five clients with email and memory? Possible. Managing fifty? Chaos. Your program grows but your client management doesn't.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5: What a Correct System Looks Like -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">What it looks like when everything is connected</h2>

      <div class="space-y-8">
        <div>
          <h3 class="text-2xl font-bold mb-4">Complete client profiles</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Contact information in one place</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Which animal(s) they purchased or are waiting for</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Application and screening notes</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Preferences and special requests documented</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">A sales pipeline that shows where every buyer stands</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Visual pipeline from first inquiry through closing</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Drag-and-drop buyers between stages as they progress</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Lead scoring that highlights your most engaged prospects</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>See total pipeline value and which deals need attention</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Communication history tracked</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Notes from every conversation</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>What was discussed and when</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Questions asked and answers given</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Follow-up items flagged</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Message buyers directly from the BreederHQ Mobile Companion app so you can respond on the go, from the barn, kennel, or anywhere</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Contract and document storage</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Signed contracts attached to client record</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Upload your existing contract PDF and turn it into a reusable template in seconds (Pro)</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Registration papers, health records, other documents stored</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Accessible from anywhere</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Shareable with the client when needed</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Payment tracking</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Deposit and final payment amounts recorded</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Payment dates and methods tracked</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Outstanding balances visible</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Payment history per client</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Buyer portal access</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Clients log in to see their animal's information</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Pedigree, health records, photos accessible</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Reduces repetitive information requests</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Professional presentation</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Analytics that show what's working</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Conversion rates by lead source</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Average time from inquiry to placement</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Stale lead detection so buyers don't slip through the cracks</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Win/loss tracking to improve your process</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Automated follow-ups</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Reminders to check in after placement</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Follow-up at milestones (6 months, 1 year, etc.)</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Health testing reminders if co-own or breeding rights</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Auto-generated tasks for stale leads</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 6: How BreederHQ Supports This -->
  <section class="py-20 px-4 bg-[hsl(24,95%,53%)] text-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">How BreederHQ brings it all together</h2>

      <p class="text-xl leading-relaxed mb-8">
        Complete client profiles connected to the animals they purchased. A visual sales pipeline so you see every buyer's stage at a glance. Lead scoring that highlights your most engaged prospects. Communication history, contracts, and documents in one place. Payment tracking per client. Buyer portal so clients can access information themselves. Analytics that show conversion rates, average time to placement, and where leads drop off.
      </p>

      <p class="text-xl leading-relaxed mb-8">
        Message buyers directly from the BreederHQ Mobile Companion app so quick questions get quick answers, whether you are in the barn, at a vet appointment, or at a show. Every message is captured on the client's timeline automatically, so nothing lives only in your text thread.
      </p>

      <p class="text-xl leading-relaxed mb-8">
        Not a generic tool bolted on. Built specifically for how breeders manage buyers, from first inquiry to forever home.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="https://accounts.breederhq.com/register?intent=breeder_dashboard" class="inline-block bg-white text-[hsl(24,95%,53%)] px-8 py-4 rounded-lg font-bold text-lg hover:bg-gray-100 transition text-center" style="min-height: 44px;">
          Get Started Free
        </a>
        <a href="/buyer-portal" class="inline-block bg-transparent border-2 border-white text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-white hover:text-[hsl(24,95%,53%)] transition text-center" style="min-height: 44px;">
          See the buyer portal →
        </a>
      </div>
    </div>
  </section>

  <!-- Section 7: Who This Is For -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Built for breeders who:</h2>

      <ul class="space-y-3 text-lg text-gray-700">
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Manage relationships with multiple buyers</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Want their client side to feel as organized as their breeding program</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Track deposits, payments, and contracts</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Maintain long-term relationships with buyers</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Want to respond to buyers quickly, even when they are away from the desk</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Are growing and need a system that scales with them</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Section 8: Who This Is Not For -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">This might be overkill if:</h2>

      <ul class="space-y-3 text-lg text-gray-700 mb-8">
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>You produce one offspring group every few years</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Your client list is small and email works just fine</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>You don't keep ongoing relationships with buyers after placement</span>
        </li>
      </ul>

      <p class="text-lg text-gray-700 leading-relaxed">
        If your client volume is low, simple methods may be all you need. BreederHQ is here when you're ready for it.
      </p>
    </div>
  </section>

  <!-- Section 9: FAQ -->
  <section class="py-20 px-4 faq-section">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-12">Frequently asked questions</h2>

      <details class="faq-item">
        <summary class="faq-question">
          <span>Is this a real client management system or just a contact list?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>It's a full client management system with a visual sales pipeline, lead scoring, deal tracking, email templates, task management, and conversion analytics. Not a generic tool, but built specifically for breeder sales workflows.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          <span>What is the sales pipeline?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>A visual Kanban board that shows every buyer's stage: Inquiry, Viewing, Negotiation, Vet Check, Contract, through to Closed. Drag and drop buyers between stages as they progress.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          <span>How does lead scoring work?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>The system scores buyers based on their engagement, how recently they've been active, budget fit, interest level, and deal progress. Higher-scored buyers are flagged so you focus on the most promising prospects first.</p>
        </div>
      </details>

