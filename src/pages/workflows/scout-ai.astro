---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Workflows', url: '/workflows' },
  { name: 'Scout AI', url: '/workflows/scout-ai' }
];

const faqs = [
  {
    question: 'What kind of questions can I ask Scout AI?',
    answer: 'Anything about your breeding program. Ask about your animals ("Which of my animals carry the dilute gene?"), your finances ("What is my total outstanding invoice balance?"), your breeding plans ("Show me all plans in the pregnancy phase"), your contacts, your waitlist, your offspring, medications, and more. Scout searches your actual data to answer.'
  },
  {
    question: 'Is my data safe? Does Scout share my information?',
    answer: 'Your data stays private. Scout only accesses your own breeding program data within your account. It cannot see other breeders\' data, and your conversations are not used to train AI models. You can delete your conversation history at any time, and all AI query logs are automatically deleted after 90 days. Your organization admin can also disable Scout entirely if preferred.'
  },
  {
    question: 'How is this different from ChatGPT or other AI tools?',
    answer: 'Generic AI tools don\'t know anything about your breeding program. They can give general advice, but they can\'t tell you which of your animals are due for vaccinations or what your revenue was last month. Scout AI is connected to your actual data (your animals, plans, finances, contacts, offspring, medications, and more) and uses specialized tools to search and retrieve accurate answers.'
  },
  {
    question: 'Do I need to learn special commands or syntax?',
    answer: 'No. Just type naturally, the way you would ask an assistant. "How many litters did I have this year?" or "Show me my animals that are ready to breed" or "What medications is Luna currently on?"'
  },
  {
    question: 'Is there a limit to how many questions I can ask?',
    answer: 'Yes. Usage depends on your plan level. Scout AI is available on Pro and Enterprise plans with generous daily limits. All plans include the Help Assistant for general breeding and platform questions.'
  },
  {
    question: 'Can Scout AI make changes to my data?',
    answer: 'No. Scout is read-only, so it can search and retrieve your data to answer questions, but it cannot create, edit, or delete any records. Your data is always safe.'
  },
  {
    question: 'What if I just have a general breeding question?',
    answer: 'The Help Assistant answers general breeding and platform questions using our knowledge base of help articles. It doesn\'t need access to your data-just ask things like "How do I set up a breeding plan?" or "What\'s the best way to track heat cycles?"'
  },
  {
    question: 'Can I pick up a conversation where I left off?',
    answer: 'Yes. Scout automatically saves your conversations. You can view your conversation history, resume previous threads, and pick up right where you left off, even across different sessions.'
  }
];
---

<BaseLayout
  title="Scout AI - Your Breeding Program Assistant | BreederHQ"
  description="Ask questions about your breeding program in plain English. Scout AI searches your animals, breeding plans, finances, medications, offspring, and contacts to give you instant answers."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
    Skip to content
  </a>

  <main id="main-content">
  <nav class="breadcrumb py-4 px-4 bg-gray-50" aria-label="Breadcrumb">
    <ol class="flex items-center space-x-2 max-w-4xl mx-auto text-sm">
      <li><a href="/" class="text-[hsl(24,95%,53%)] hover:underline">Home</a></li>
      <li class="text-gray-400">></li>
      <li><a href="/workflows" class="text-[hsl(24,95%,53%)] hover:underline">Workflows</a></li>
      <li class="text-gray-400">></li>
      <li aria-current="page" class="text-gray-600">Scout AI</li>
    </ol>
  </nav>

  <!-- Section 1: Hero -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-bold mb-6">Ask Your Breeding Program Anything</h1>

      <aside class="tldr-box bg-gray-100 border-l-4 border-[hsl(24,95%,53%)] p-6 my-8 rounded" role="complementary" aria-label="Page summary">
        <h2 class="text-xl font-bold mb-3">TL;DR</h2>
        <p class="text-gray-700 leading-relaxed">
          BreederHQ includes two built-in AI assistants. The <strong>Help Assistant</strong> answers general breeding and platform questions from a knowledge base of help articles. <strong>Scout AI</strong> goes further by searching your actual animals, breeding plans, finances, contacts, waitlist, offspring, and medications to answer questions about your specific program. Just type a question in plain English and get an instant, sourced answer. No special commands, no exports, no digging through spreadsheets.
        </p>
      </aside>

      <p class="text-xl text-gray-700 leading-relaxed mb-6">
        Your breeding program generates a lot of data. Animal records, breeding plans, health tests, medications, financial transactions, buyer contacts, waitlist entries. The information is there. Finding it when you need it usually means clicking through screens, filtering lists, and piecing things together yourself.
      </p>

      <p class="text-xl text-gray-700 leading-relaxed">
        What if you could just ask?
      </p>
    </div>
  </section>

  <!-- Section 2: The Problem -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">The answers are in your data. Scout just finds them faster.</h2>

      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        You know the information is in your system. Getting a specific answer still takes work the old way:
      </p>

      <ul class="space-y-3 text-lg text-gray-700 mb-8">
        <li class="flex items-start">
          <span class="mr-3">&bull;</span>
          <span>"How many litters did I have this year?" &bull; open breeding plans, filter by date, count manually</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">&bull;</span>
          <span>"Which of my animals carry the dilute gene?" &bull; open each animal's genetics tab, check one by one</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">&bull;</span>
          <span>"What's my total outstanding revenue?" &bull; open finance, look at invoices, add up the numbers</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">&bull;</span>
          <span>"Who's on my waitlist for a female?" &bull; open waitlist, filter by preferences, cross-reference</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">&bull;</span>
          <span>"What medications is my horse on?" &bull; open the animal, find health records, check active courses</span>
        </li>
      </ul>

      <div class="bg-white border-l-4 border-[hsl(24,95%,53%)] p-6 rounded">
        <p class="text-lg text-gray-700 font-semibold">
          Each question has an answer in your data. Scout AI finds it for you in seconds, with no clicking, filtering, or mental math required.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 3: Scout AI -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Scout AI: Your Data, Instant Answers</h2>

      <p class="text-lg text-gray-700 leading-relaxed mb-8">
        Scout AI is connected to your breeding program data. Ask a question in plain English, and it searches across your animals, breeding plans, offspring, contacts, finances, waitlist, and medications to give you a direct answer. Scout uses 13 specialized tools to find exactly what you need.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Animals</h3>
          <p class="text-gray-700 mb-3">
            Search and ask about your animals by name, breed, status, genetics, or any attribute. Get full profiles with health records, vaccinations, genetics, and titles.
          </p>
          <div class="text-sm text-gray-500 space-y-1 italic">
            <p>"Show me all my intact females"</p>
            <p>"Which animals are due for vaccinations?"</p>
            <p>"What's Luna's full health history?"</p>
          </div>
        </div>

        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Breeding Plans</h3>
          <p class="text-gray-700 mb-3">
            Check plan status, timelines, and details across your entire program.
          </p>
          <div class="text-sm text-gray-500 space-y-1 italic">
            <p>"How many litters am I expecting this spring?"</p>
            <p>"What plans are in the pregnancy phase?"</p>
            <p>"When is my next expected due date?"</p>
          </div>
        </div>

        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Finances</h3>
          <p class="text-gray-700 mb-3">
            Get instant financial summaries without opening spreadsheets.
          </p>
          <div class="text-sm text-gray-500 space-y-1 italic">
            <p>"What's my total outstanding invoices?"</p>
            <p>"How much revenue did I make this quarter?"</p>
            <p>"What are my biggest expense categories?"</p>
          </div>
        </div>

        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Contacts & Waitlist</h3>
          <p class="text-gray-700 mb-3">
            Find buyers, check waitlist status, and review your pipeline.
          </p>
          <div class="text-sm text-gray-500 space-y-1 italic">
            <p>"Who's waiting for a female?"</p>
            <p>"How many people are on my waitlist?"</p>
            <p>"Show me contacts I haven't followed up with"</p>
          </div>
        </div>

        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Medications & Health</h3>
          <p class="text-gray-700 mb-3">
            Check medication courses, active treatments, withdrawal periods, and compliance across your program.
          </p>
          <div class="text-sm text-gray-500 space-y-1 italic">
            <p>"When was Daisy's last Banamine?"</p>
            <p>"Which animals have active withdrawal periods?"</p>
            <p>"What medications is Luna currently on?"</p>
          </div>
        </div>

        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Offspring Groups</h3>
          <p class="text-gray-700 mb-3">
            Track offspring records, group health, weights, and life stage across litters, foals, kids, lambs, and kits.
          </p>
          <div class="text-sm text-gray-500 space-y-1 italic">
            <p>"How are my current offspring doing?"</p>
            <p>"Which are ready for placement?"</p>
            <p>"Give me a health summary for the Spring group"</p>
          </div>
        </div>
      </div>

      <div class="bg-white border-2 border-[hsl(24,95%,53%)] rounded-lg p-8 mb-8">
        <h3 class="text-2xl font-bold mb-4">How It Works</h3>
        <ol class="space-y-4 text-lg text-gray-700">
          <li class="flex items-start">
            <span class="bg-[hsl(24,95%,53%)] text-white rounded-full w-8 h-8 flex items-center justify-center mr-4 flex-shrink-0 font-bold">1</span>
            <span><strong>You ask a question</strong> in plain English, with no special syntax needed.</span>
          </li>
          <li class="flex items-start">
            <span class="bg-[hsl(24,95%,53%)] text-white rounded-full w-8 h-8 flex items-center justify-center mr-4 flex-shrink-0 font-bold">2</span>
            <span><strong>Scout searches your data</strong> using specialized tools to query your animals, plans, finances, contacts, offspring, medications, and waitlist.</span>
          </li>
          <li class="flex items-start">
            <span class="bg-[hsl(24,95%,53%)] text-white rounded-full w-8 h-8 flex items-center justify-center mr-4 flex-shrink-0 font-bold">3</span>
            <span><strong>You get a direct answer</strong> with the specific information from your program, not generic advice.</span>
          </li>
        </ol>
      </div>

      <div class="grid md:grid-cols-3 gap-4">
        <div class="bg-gray-50 p-4 rounded-lg text-center">
          <div class="text-3xl mb-2">💬</div>
          <p class="font-semibold text-sm">Natural Language</p>
          <p class="text-xs text-gray-500">Just type like you're texting</p>
        </div>
        <div class="bg-gray-50 p-4 rounded-lg text-center">
          <div class="text-3xl mb-2">🔒</div>
          <p class="font-semibold text-sm">Read-Only</p>
          <p class="text-xs text-gray-500">Can't edit or delete your data</p>
        </div>
        <div class="bg-gray-50 p-4 rounded-lg text-center">
          <div class="text-3xl mb-2">⚡</div>
          <p class="font-semibold text-sm">Instant Answers</p>
          <p class="text-xs text-gray-500">Seconds, not minutes of searching</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: Export & Share -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">More Than Answers: Export, Print, and Share</h2>

      <p class="text-lg text-gray-700 leading-relaxed mb-8">
        Scout doesn't just answer questions. It also helps you get information out of the platform and into the hands of the people who need it.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Export & Print</h3>
          <p class="text-gray-700 mb-3">
            When Scout returns data in a table, you can download it as a CSV file for your records or print a branded report. Useful for vet visits, buyer inquiries, or your own record-keeping.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Shareable Health Reports</h3>
          <p class="text-gray-700 mb-3">
            Ask Scout to generate a health report for any animal or group. It creates a PIN-protected PDF link you can share with your vet, no account needed. Links expire after 72 hours for security.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Conversation History</h3>
          <p class="text-gray-700 mb-3">
            Scout automatically saves your conversations. Pick up where you left off, review past questions, and build on previous answers, even across different sessions.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Context-Aware Suggestions</h3>
          <p class="text-gray-700 mb-3">
            Not sure what to ask? Scout suggests relevant questions based on which part of the platform you're using. Browsing animals? It suggests animal questions. On the finance page? Financial summaries.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5: Help Assistant -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Help Assistant: Breeding Knowledge On Demand</h2>

      <p class="text-lg text-gray-700 leading-relaxed mb-8">
        Not every question is about your data. Sometimes you need to know <em>how</em> to do something. The Help Assistant answers general breeding and platform questions using a built-in knowledge base of help articles covering every major feature.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Platform Questions</h3>
          <ul class="space-y-2 text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">&bull;</span>
              <span>"How do I create a breeding plan?"</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">&bull;</span>
              <span>"How do I set up my waitlist?"</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">&bull;</span>
              <span>"How do I send an invoice?"</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">&bull;</span>
              <span>"What is COI and why does it matter?"</span>
            </li>
          </ul>
        </div>

        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Source Citations</h3>
          <p class="text-gray-700 mb-3">
            Every answer includes links to the relevant help articles so you can read more. No guessing where the information came from.
          </p>
          <p class="text-gray-700">
            Articles cover: animals, breeding plans, genetics, offspring, contacts, finance, waitlist, marketplace, and getting started.
          </p>
        </div>
      </div>

      <div class="bg-gray-50 border-l-4 border-[hsl(24,95%,53%)] p-6 rounded">
        <p class="text-lg text-gray-700">
          <strong>Both assistants are built into the platform.</strong> The Help Assistant is available on all plans. Scout AI with data access is available on Pro and Enterprise plans.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 6: Interactive Tours & Help Center -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Get Up to Speed Fast</h2>

      <p class="text-lg text-gray-700 leading-relaxed mb-8">
        New to BreederHQ? The platform includes interactive guided tours and a searchable Help Center so you never feel lost.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Interactive Tours</h3>
          <p class="text-gray-700 mb-3">
            Step-by-step walkthroughs that highlight each feature as you go. Tours launch automatically the first time you visit a new section, pointing out key buttons, explaining workflows, and getting you productive fast.
          </p>
          <p class="text-sm text-gray-500">
            Dismiss tours at any time. Replay them from Settings whenever you want a refresher.
          </p>
        </div>

        <div class="bg-white p-6 rounded-lg border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Help Center</h3>
          <p class="text-gray-700 mb-3">
            Searchable articles covering every major feature. Browse by module (Animals, Breeding, Offspring, Contacts, Finance, Marketplace, Genetics) or search by keyword.
          </p>
          <p class="text-sm text-gray-500">
            Open the Help Center from any page without losing your place. Articles open in a slide-out panel.
          </p>
        </div>
      </div>

      <div class="bg-white border-l-4 border-[hsl(24,95%,53%)] p-6 rounded">
        <p class="text-lg text-gray-700">
          <strong>Three layers of help:</strong> Interactive tours for visual learners, the Help Center for self-service answers, and the AI assistants for everything else. You'll never need to email support for a "how do I..." question.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 7: Privacy -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Your Data, Your Control</h2>

      <p class="text-lg text-gray-700 leading-relaxed mb-8">
        We take data privacy seriously. Scout AI is designed with transparency and control at every level.
      </p>

      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h3 class="text-lg font-bold mb-3">Consent First</h3>
          <p class="text-gray-700 text-sm">
            Scout requires explicit consent before first use. You're always informed about how your data is used.
          </p>
        </div>

        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h3 class="text-lg font-bold mb-3">Organization Control</h3>
          <p class="text-gray-700 text-sm">
            Admins can enable or disable Scout for their entire organization. Staff members only get access if the admin allows it.
          </p>
        </div>

        <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
          <h3 class="text-lg font-bold mb-3">Delete Anytime</h3>
          <p class="text-gray-700 text-sm">
            Delete your entire conversation history and AI query logs at any time. Logs are also automatically deleted after 90 days.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 8: Who This Is For -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <h2 class="text-3xl font-bold mb-6">Scout AI Helps If You:</h2>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">&#10003;</span>
              <span>Manage a large program and need quick answers</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">&#10003;</span>
              <span>Want financial summaries without building reports</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">&#10003;</span>
              <span>Need to quickly find animals by genetics or status</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">&#10003;</span>
              <span>Get asked questions by buyers and want fast answers</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">&#10003;</span>
              <span>Need to share health records with your vet quickly</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">&#10003;</span>
              <span>Prefer asking over clicking through menus</span>
            </li>
          </ul>
        </div>

        <div>
          <h2 class="text-3xl font-bold mb-6">You Might Not Need This If:</h2>
          <ul class="space-y-3 text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">&bull;</span>
              <span>You have a small program and know where everything is</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">&bull;</span>
              <span>You prefer navigating menus and dashboards directly</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">&bull;</span>
              <span>You don't generate enough data to need AI-powered search</span>
            </li>
          </ul>
          <p class="text-sm text-gray-600 mt-4 italic">
            Even then, the Help Assistant is included on all plans and makes getting started much easier.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-primary text-white">
    <div class="max-w-4xl mx-auto text-center px-4">
      <h2 class="text-4xl font-bold mb-6">Stop Searching. Start Asking.</h2>
      <p class="text-xl mb-8 opacity-90">
        Your breeding data, answered in seconds. Not minutes.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://accounts.breederhq.com/register?intent=breeder_dashboard" class="bg-white text-primary px-8 py-4 rounded-lg text-lg font-semibold hover:opacity-90 inline-block">
          Get Started Free
        </a>
        <a href="/workflows/breeding-intelligence" class="bg-transparent border-2 border-white text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-white hover:text-primary inline-block">
          See Breeding Intelligence →
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 px-4 faq-section">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-12">Frequently Asked Questions</h2>

      {faqs.map(faq => (
        <details class="faq-item">
          <summary class="faq-question">
            <span>{faq.question}</span>
            <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </summary>
          <div class="faq-answer">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- Related Resources -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold mb-6">Related Workflows</h2>
      <div class="space-y-3 text-lg">
        <div>
          <a href="/workflows/breeding-intelligence" class="text-[hsl(24,95%,53%)] hover:underline">
            → Breeding Intelligence Tools
          </a>
        </div>
        <div>
