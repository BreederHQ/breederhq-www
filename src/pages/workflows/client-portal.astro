---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Workflows', url: '/workflows' },
  { name: 'Client Portal', url: '/workflows/client-portal' }
];

const faqs = [
  {
    question: 'What can clients see in the portal?',
    answer: 'You control what\'s visible. Clients can access pedigrees, health records, photos, contracts, payment history, and messages, based on permissions you set.'
  },
  {
    question: 'Can clients make payments through the portal?',
    answer: 'Yes. Clients can view their payment history, outstanding balances, and make payments directly through the portal using secure payment processing.'
  },
  {
    question: 'Do clients need to download an app?',
    answer: 'No. The portal is web-based and works on any device with a browser. Clients receive a secure link to access their portal.'
  },
  {
    question: 'Can I message clients through the portal?',
    answer: 'Yes. Built-in messaging keeps all communication in one place. Clients receive notifications when you send updates.'
  },
  {
    question: 'Is client data secure?',
    answer: 'Yes. Each client has their own secure login and can only see information about their own animals and transactions. All data is encrypted.'
  }
];
---

<BaseLayout
  title="Client Portal, Built for Breeders | BreederHQ"
  description="Give buyers secure 24/7 access to their animal's pedigree, health records, photos, contracts, and payment history. Keeps everything organized and reduces repeat requests."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
    Skip to content
  </a>

  <main id="main-content">
  <nav class="breadcrumb py-4 px-4 bg-gray-50" aria-label="Breadcrumb">
    <ol class="flex items-center space-x-2 max-w-4xl mx-auto text-sm">
      <li><a href="/" class="text-[hsl(24,95%,53%)] hover:underline">Home</a></li>
      <li class="text-gray-400">›</li>
      <li><a href="/workflows" class="text-[hsl(24,95%,53%)] hover:underline">Workflows</a></li>
      <li class="text-gray-400">›</li>
      <li aria-current="page" class="text-gray-600">Client Portal</li>
    </ol>
  </nav>

  <!-- Section 1: What This Page Is About -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-bold mb-6">A Client Portal, Built for Breeders.</h1>

      <aside class="tldr-box bg-gray-100 border-l-4 border-[hsl(24,95%,53%)] p-6 my-8 rounded" role="complementary" aria-label="Page summary">
        <h2 class="text-xl font-bold mb-3">TL;DR</h2>
        <p class="text-gray-700 leading-relaxed">
          Give every buyer a secure portal where they can see their animal's pedigree, health records, photos, contracts, payment history, and messages, any time, from any device. You control what is visible, and routine questions are answered before they even come up.
        </p>
      </aside>
      <p class="text-xl text-gray-700 leading-relaxed">
        You already send buyers pedigrees, health records, photos, and payment reminders. A client portal keeps all of that in one secure place so buyers can find what they need on their own, whenever they need it, while you focus on the animals.
      </p>
    </div>
  </section>

  <!-- Section 2: Why Breeders Search for This -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">You already answer these questions. A portal just answers them for you.</h2>
      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        These are the requests that fill up every breeder's week:
      </p>
      <ul class="space-y-3 text-lg text-gray-700 mb-6">
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>"Can you send the health records again?" and you dig through files</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>"What's my remaining balance?" and you check your records</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>"Do you have photos from last week?" and you search your phone</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>"Where's my contract?" and you hunt through email</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>"Any updates on my animal?" and you type out the same status to each buyer, whether it's a puppy, kitten, foal, kid, lamb, or kit</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Clients wait for you to respond before they can access anything</span>
        </li>
      </ul>
      <p class="text-lg text-gray-700 leading-relaxed">
        These interruptions add up. A client portal handles most of them automatically, so your time stays focused on the animals.
      </p>
    </div>
  </section>

  <!-- Section 3: How Breeders Usually Handle It -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">The tools you've been using</h2>

      <div class="space-y-6">
        <div>
          <h3 class="text-2xl font-bold mb-3">Email attachments</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            You send documents, photos, and updates via email. Clients lose them and ask again. You re-send. Repeat.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Text messages</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Quick updates go through text. Photos get buried in the conversation. Finding that specific photo from three weeks ago takes a lot of scrolling.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Social media groups</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Some breeders create Facebook groups to share updates on litters, foals, kids, or lambs. Great for photos, but not a great home for contracts, payments, or private information.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Dropbox or Google Drive folders</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Shared folders for documents. Better than email for files, but no messaging, no payments, no structure. Clients can view files but cannot interact.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Manual responses to every request</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            The most common approach is to personally answer every question. It works, until the volume catches up with you.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: Where That Breaks Down -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Where those tools start to stretch thin</h2>

      <div class="space-y-8">
        <div>
          <h3 class="text-2xl font-bold mb-4">You're always the first point of contact</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            A buyer needs something at 9pm and messages you. Because there is no self-service option, the default is to interrupt you, even for things as simple as pulling up a pedigree.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Information gets lost</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            You sent the pedigree three times and the buyer still cannot find it. Email and text threads are not designed for document access, so even attentive buyers lose track.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Payment tracking gets awkward</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            "What's my balance?" shouldn't require a conversation every time. Without a portal, you are manually calculating and communicating payment status for each buyer.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Communication is scattered across platforms</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Some clients text, some email, some message on social media. You are checking multiple platforms constantly, and important messages can slip through.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">The experience doesn't match the price</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Buyers investing thousands of dollars expect a professional experience from start to finish. A dedicated portal matches the quality of the animals you are placing.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">More clients, more juggling</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Five clients are manageable with texts and emails. Fifteen is a lot to hold together. Your program grows, and your communication tools need to grow with it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5: What a Correct System Looks Like -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">What it looks like when everything is connected</h2>

      <div class="space-y-8">
        <div>
          <h3 class="text-2xl font-bold mb-4">Document access</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Contracts viewable and downloadable anytime</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Health records, vaccination certificates, medication history, registration papers</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Pedigree documents</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Any document you choose to share</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Contracts & E-signatures</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Contract templates with auto-fill (animal name, buyer info, price)</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Digital signatures so clients can sign from any device</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Signature audit trail with timestamps</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Auto-send contracts when deposit is received</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Signed contracts stored permanently in client portal</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Document bundles: send contract + health guarantee + care guide together</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Photo and update access</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Photos organized by date, not buried in messages</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Growth updates, weight tracking, milestone photos</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Clients can view anytime without asking</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Notifications when new content is added</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Payment visibility</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Payment history visible to client</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Outstanding balance clearly displayed</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Option to make payments through portal</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Payment receipts automatically available</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Centralized messaging</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>All communication in one thread</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Message history preserved</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Notifications for both parties</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>No more hunting across email/text/social</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Secure, individual access</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Each client has their own login</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Only sees their animals and information</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>You control what's visible per client</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Professional, branded experience</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 6: How BreederHQ Supports This -->
  <section class="py-20 px-4 bg-[hsl(24,95%,53%)] text-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">How BreederHQ brings it all together</h2>

      <p class="text-xl leading-relaxed mb-8">
        When you add a client, they get secure access to their own portal. Pedigrees, health records, contracts, photos, and payment history, all accessible 24/7. Built-in messaging keeps communication organized. You upload once, and they can access it anytime.
      </p>

      <p class="text-xl leading-relaxed mb-8">
        Buyers get the information they need on their own schedule. You keep more of your day focused on the animals.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="https://accounts.breederhq.com/register?intent=breeder_dashboard" class="inline-block bg-white text-[hsl(24,95%,53%)] px-8 py-4 rounded-lg font-bold text-lg hover:bg-gray-100 transition text-center" style="min-height: 44px;">
          Get Started Free
        </a>
        <a href="/workflows/client-management" class="inline-block bg-transparent border-2 border-white text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-white hover:text-[hsl(24,95%,53%)] transition text-center" style="min-height: 44px;">
          See client management →
        </a>
      </div>
    </div>
  </section>

  <!-- Section 7: Who This Is For -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Built for breeders who:</h2>

      <ul class="space-y-3 text-lg text-gray-700">
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Field repetitive requests for documents and updates</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Want to provide professional, always-available service</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Track payments and need clients to see their balance</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Share photos and updates without endless texting</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Value their time and want to reduce interruptions</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Manage more than a few clients at a time</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Section 8: Who This Is Not For -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">You might not need this if:</h2>

      <ul class="space-y-3 text-lg text-gray-700 mb-8">
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>You only have a few clients per year</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>You prefer personal, one-on-one communication for everything</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Your clients don't ask for documents or updates</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Email and text work fine for your volume</span>
        </li>
      </ul>

      <p class="text-lg text-gray-700 leading-relaxed">
        For very small operations, personal communication may be all you need. BreederHQ is here when you're ready for it.
      </p>
    </div>
  </section>

  <!-- Section 9: FAQ -->
  <section class="py-20 px-4 faq-section">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-12">Frequently asked questions</h2>

      <details class="faq-item">
        <summary class="faq-question">
          <span>What can clients see in the portal?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>You control what's visible. Clients can access pedigrees, health records, photos, contracts, payment history, and messages, based on permissions you set.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          <span>Can clients make payments through the portal?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>Yes. Clients can view their payment history, outstanding balances, and make payments directly through the portal using secure payment processing.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          <span>Do clients need to download an app?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>No. The portal is web-based and works on any device with a browser. Clients receive a secure link to access their portal.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          <span>Can I message clients through the portal?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>Yes. Built-in messaging keeps all communication in one place. Clients receive notifications when you send updates.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          <span>Is client data secure?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>Yes. Each client has their own secure login and can only see information about their own animals and transactions. All data is encrypted.</p>
        </div>
      </details>
    </div>
  </section>

  <!-- Section 10: Related Resources -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold mb-6">Learn more</h2>
      <div class="space-y-3 text-lg">
        <div>
          <a href="/workflows/client-management" class="text-[hsl(24,95%,53%)] hover:underline">
            → Client Management for Breeders
          </a>
        </div>
        <div>
          <a href="/workflows/waitlists-and-placement" class="text-[hsl(24,95%,53%)] hover:underline">
            → Waitlist and Placement Management
          </a>
        </div>
        <div>
          <a href="/workflows/marketplace" class="text-[hsl(24,95%,53%)] hover:underline">
            → BreederHQ Marketplace
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sticky Mobile CTA -->
  <div class="fixed bottom-0 left-0 right-0 p-4 bg-white border-t-2 border-gray-200 shadow-lg md:hidden z-50">
    <a href="https://accounts.breederhq.com/register?intent=breeder_dashboard" class="block w-full text-center bg-[hsl(24,95%,53%)] text-white px-6 py-4 rounded-lg font-bold text-lg hover:bg-[hsl(24,95%,48%)] transition" style="min-height: 44px;">
      Get Started Free
    </a>
  </div>
  </main>

  <style>
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border-width: 0;
    }

    .faq-item {
      border-bottom: 1px solid #e5e7eb;
      padding: 1.5rem 0;
    }

    .faq-question {
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      font-size: 1.25rem;
      font-weight: 600;
      list-style: none;
    }

    .faq-question::-webkit-details-marker {
      display: none;
    }

    .faq-icon {
      transition: transform 200ms ease;
      flex-shrink: 0;
      margin-left: 1rem;
    }

    details[open] .faq-icon {
      transform: rotate(180deg);
    }

    .faq-answer {
      padding-top: 1rem;
      color: #4b5563;
      line-height: 1.6;
    }

    .faq-answer p {
      font-size: 1.125rem;
    }
  </style>
</BaseLayout>
