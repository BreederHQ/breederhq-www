---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Screenshot from '../../components/Screenshot.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Workflows', url: '/workflows' },
  { name: 'Genetics and Health Testing', url: '/workflows/genetics-and-health-testing' }
];

const faqs = [
  {
    question: 'Can I store actual documents (PDFs, images)?',
    answer: 'Yes. Attach certificates, lab reports, and exam results directly to the animal\'s record. You can also use Scout AI to scan genetics documents - upload any lab PDF or photo and Scout AI extracts every test result automatically with confidence scores.'
  },
  {
    question: 'Does it remind me when tests expire?',
    answer: 'Yes. Tests with renewal requirements are tracked and flagged.'
  },
  {
    question: 'Can buyers see health testing?',
    answer: 'Yes. The buyer portal shows what you choose to share. You control visibility.'
  },
  {
    question: 'Does it track genetics?',
    answer: 'Yes. Color genetics, health markers, carrier status.'
  },
  {
    question: 'Can Scout AI scan my genetics lab results?',
    answer: 'Yes. Upload any genetics PDF or photo from any lab, any species. Dog labs like Embark or Wisdom Panel, equine panels from UC Davis, goat and sheep testing from veterinary labs. Scout AI extracts every test result with confidence scores (High, Medium, Low). You review a preview table, include or exclude individual results, and save. Each saved result links back to the source document. Unknown markers are flagged for review.'
  },
  {
    question: 'What about OFA or breed registry integration?',
    answer: 'You enter registry results manually. BreederHQ doesn\'t pull from OFA, ADGA, AQHA, or other registries automatically, but your records can link to them for verification.'
  }
];

const howTo = {
  name: 'How to Track Genetics and Health Testing',
  description: 'A step-by-step guide to organizing health testing records, genetic markers, and renewal tracking for breeding animals.',
  steps: [
    { name: 'Set up breed-specific health tests', text: 'Configure which health tests are required or recommended for your breed. Common tests include OFA, PennHIP, eye exams, genetic panels, FAMACHA (goats/sheep), Coggins (horses), and CAE/CL (goats).' },
    { name: 'Enter test results', text: 'Record each test with the date performed, result, and expiration date if applicable. Link to official registry numbers when available.' },
    { name: 'Attach documentation', text: 'Upload certificates, lab reports, and exam results as PDFs or images. Keep original documentation linked to each test record.' },
    { name: 'Scan genetics documents with Scout AI', text: 'Upload any genetics PDF or photo from any lab, any species. Scout AI reads the document and extracts every test result with confidence scores. Review, edit, and save. Two clicks instead of manual entry.' },
    { name: 'Track genetic markers', text: 'Enter genetic test results including coat color genetics, health markers, and carrier status. Use this data for breeding compatibility checks.' },
    { name: 'Monitor expiration dates', text: 'Review upcoming test expirations regularly. The system flags tests that need renewal before breeding.' },
    { name: 'Configure buyer visibility', text: 'Choose which health testing results to share with buyers through the client portal. Transparency builds trust.' }
  ]
};
---

<BaseLayout
  title="Genetics and Health Testing, Finally Organized | BreederHQ"
  description="You already do the testing. BreederHQ keeps it organized, reminds you about renewals, and shares results with buyers through your portal."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
  howTo={howTo}
>
  <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
    Skip to content
  </a>

  <main id="main-content">
  <nav class="breadcrumb py-4 px-4 bg-gray-50" aria-label="Breadcrumb">
    <ol class="flex items-center space-x-2 max-w-4xl mx-auto text-sm">
      <li><a href="/" class="text-[hsl(24,95%,53%)] hover:underline">Home</a></li>
      <li class="text-gray-400">›</li>
      <li><a href="/workflows" class="text-[hsl(24,95%,53%)] hover:underline">Workflows</a></li>
      <li class="text-gray-400">›</li>
      <li aria-current="page" class="text-gray-600">Genetics and Health Testing</li>
    </ol>
  </nav>

  <!-- Section 1: What This Page Is About -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-bold mb-6">Genetics and Health Testing. Finally Organized.</h1>

      <aside class="tldr-box bg-gray-100 border-l-4 border-[hsl(24,95%,53%)] p-6 my-8 rounded" role="complementary" aria-label="Page summary">
        <h2 class="text-xl font-bold mb-3">TL;DR</h2>
        <p class="text-gray-700 leading-relaxed">
          You already do the testing. BreederHQ keeps it all organized in one place, reminds you about renewals, tracks genetics, and makes sharing documentation with buyers effortless through your portal.
        </p>
      </aside>
      <p class="text-xl text-gray-700 leading-relaxed">
        You invest the time and money in health testing because you care about your program. BreederHQ makes sure that investment pays off by keeping everything organized, accessible, and easy to share.
      </p>

      <div class="mt-12">
        <Screenshot
          id="animal-genetics"
          alt="Animal genetics tab in BreederHQ showing coat color loci and Embark health panel results"
        />
        <p class="text-sm text-gray-500 mt-3 text-center italic">
          Every coat color locus, every health panel result, every test certificate, attached to the animal and visible at a glance.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 2: Why Breeders Search for This -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">You do the testing. The paperwork is the hard part.</h2>
      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        The testing itself isn't the problem. It's managing all of it afterward:
      </p>
      <ul class="space-y-3 text-lg text-gray-700 mb-6">
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Different tests for different breeds</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Some tests are one-time (DNA), some need renewal (eyes, cardiac)</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Results live in different places (breed registries, lab reports, vet records)</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Buyers want proof, but finding it takes time</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Breeding decisions depend on having current information</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Forgetting a renewal can affect sales and reputation</span>
        </li>
      </ul>
      <p class="text-lg text-gray-700 leading-relaxed">
        You've done the work. You deserve to get credit for it without spending 30 minutes digging through files every time someone asks.
      </p>
    </div>
  </section>

  <!-- Section 3: How Breeders Usually Handle It -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">The systems you've been making work</h2>

      <div class="space-y-6">
        <div>
          <h3 class="text-2xl font-bold mb-3">Paper files</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            A folder per animal with test results stuffed inside. It works, but finding a specific result means digging, and sharing with a buyer means scanning or photographing.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Email folders</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Lab results in email. Registry certificates in another email. Scattered across years of messages.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Breed registries and databases</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            OFA, ADGA, AQHA, ARBA and others keep official records. But they don't include everything, and you can't attach your own notes or track pending tests.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Memory</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            "I know she's been tested." "I think that was last year?" You know the information, but pulling it up on the spot is another story.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-3">Spreadsheets</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            A list of tests and dates. No connection to the animal's other records. No attached documents. No reminders.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 4: Where That Breaks Down -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Where those systems start to stretch thin</h2>

      <div class="space-y-8">
        <div>
          <h3 class="text-2xl font-bold mb-4">Results end up everywhere</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            DNA results from one lab. Registry results from another. Specialist exams from the vet. FAMACHA scores in a notebook. Coggins in your email. You know where everything is, but it's in six different places.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Renewals sneak up on you</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Eye exams need annual renewal. Cardiac clearances may need renewal. When you're managing multiple animals with different test dates, it's easy for one to slip past.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Sharing takes too long</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            A buyer asks for proof of health testing. You spend 30 minutes finding documents, scanning them, and sending them. You've done this enough times to know it shouldn't be this hard.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">The information exists, just not at your fingertips</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            You're planning a breeding. What's the genetic compatibility? Is her cardiac clearance current? When was his last eye exam? You know the answers, but pulling them all together in one place takes time.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Genetics data is hard to keep organized</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Coat color genetics. Health markers. Carrier status. You track all of it, but keeping it organized and connected to breeding decisions is a lot to manage on your own.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 5: What a Correct System Looks Like -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">What it looks like when everything is in one place</h2>

      <div class="space-y-8">
        <div>
          <h3 class="text-2xl font-bold mb-4">All results in one place per animal</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>DNA panel results attached to the animal</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Registry and certification results with dates</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Specialist exam results (eyes, cardiac, patella, FAMACHA, Coggins, CAE/CL)</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Expiration dates tracked where applicable</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Documents attached</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Actual certificates and reports stored</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Accessible without digging</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Shareable with a link or download</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Reminders for renewals</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Tests that expire flagged before expiration</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>No manual reminder setting</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Proactive notification, not reactive panic</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Genetics organized</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Coat color genetics recorded</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Health marker status (clear, carrier, affected)</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Breeding compatibility visible</span>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-4">Buyer access</h3>
          <ul class="space-y-2 text-lg text-gray-700">
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Share relevant documentation through buyer portal</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>Professional presentation</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3">•</span>
              <span>No scanning and emailing for each inquiry</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 6: How BreederHQ Supports This -->
  <section class="py-20 px-4 bg-[hsl(24,95%,53%)] text-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">How BreederHQ takes the busywork off your plate</h2>

      <p class="text-xl leading-relaxed mb-8">
        All test results attached to the animal. Documents stored and accessible. Renewal reminders automated. Genetics tracked and visible. Buyer portal access so you're not scanning documents for every inquiry. You keep doing what you're already doing. We just make it easier to find, share, and stay on top of.
      </p>

      <p class="text-xl leading-relaxed mb-8">
        <strong>New: Scout AI Genetics Scanner.</strong> Upload any genetics PDF or photo from any lab, any species. Dog panels, equine genetic tests, goat and sheep lab results, cat DNA profiles, rabbit color genetics. Scout AI reads the document and extracts every test result with confidence scores. You see a preview table with each result, matched marker, status, and confidence level. Review, adjust if needed, and save. Two clicks instead of manual entry. Each scanned result links back to the source document.
      </p>

      <p class="text-xl leading-relaxed mb-8">
        You already do the hard part. Let BreederHQ handle the rest.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="https://accounts.breederhq.com/register?intent=breeder_dashboard" class="inline-block bg-white text-[hsl(24,95%,53%)] px-8 py-4 rounded-lg font-bold text-lg hover:bg-gray-100 transition text-center" style="min-height: 44px;">
          Get Started Free
        </a>
        <a href="/animal-records" class="inline-block bg-transparent border-2 border-white text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-white hover:text-[hsl(24,95%,53%)] transition text-center">
          See animal records →
        </a>
      </div>
    </div>
  </section>

  <!-- Section 7: Who This Is For -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Built for breeders who:</h2>

      <ul class="space-y-3 text-lg text-gray-700">
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Do health testing (obviously)</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Have multiple animals with different test schedules</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Share results with buyers</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Make breeding decisions based on genetics</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>Want to stop losing track of documents</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Section 8: Who This Is Not For -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">This might be overkill if:</h2>

      <ul class="space-y-3 text-lg text-gray-700">
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>You don't do health testing</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>You have one or two animals and paper files work</span>
        </li>
        <li class="flex items-start">
          <span class="mr-3">•</span>
          <span>You're not sharing documentation with buyers</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- Section 9: FAQ -->
  <section class="py-20 px-4 faq-section">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-12">Frequently asked questions</h2>

      <details class="faq-item">
        <summary class="faq-question">
          <span>Can I store actual documents (PDFs, images)?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>Yes. Attach certificates, lab reports, and exam results directly to the animal's record.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          <span>Does it remind me when tests expire?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>Yes. Tests with renewal requirements are tracked and flagged.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          <span>Can buyers see health testing?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>Yes. The buyer portal shows what you choose to share. You control visibility.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          <span>Does it track genetics?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>Yes. Color genetics, health markers, carrier status.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          <span>Can Scout AI scan my genetics lab results?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>Yes. Upload any genetics PDF or photo from any lab - GenSol, Paw Print, Wisdom Panel, UC Davis, Embark, and more. Scout AI extracts every test result with confidence scores (High, Medium, Low). You review a preview table, include or exclude individual results, and save. Each saved result links back to the source document. Unknown markers are flagged for review.</p>
        </div>
      </details>

      <details class="faq-item">
        <summary class="faq-question">
          <span>What about OFA or breed registry integration?</span>
          <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="faq-answer">
          <p>You enter registry results manually. BreederHQ doesn't pull from OFA, ADGA, AQHA, or other registries automatically, but your records can link to them for verification.</p>
        </div>
      </details>
    </div>
  </section>

  <!-- Section 10: Related Resources -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold mb-6">Learn more</h2>
      <div class="space-y-3 text-lg">
        <div>
          <a href="/for-breeders" class="text-[hsl(24,95%,53%)] hover:underline">
            → BreederHQ for Breeders
          </a>
        </div>
        <div>
          <a href="/workflows/breeding-cycles" class="text-[hsl(24,95%,53%)] hover:underline">
            → How to Track Breeding Cycles
          </a>
        </div>
        <div>
          <a href="/compare/breederhq-vs-spreadsheets" class="text-[hsl(24,95%,53%)] hover:underline">
            → BreederHQ vs. Spreadsheets
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sticky Mobile CTA -->
  <div class="fixed bottom-0 left-0 right-0 p-4 bg-white border-t-2 border-gray-200 shadow-lg md:hidden z-50">
    <a href="https://accounts.breederhq.com/register?intent=breeder_dashboard" class="block w-full text-center bg-[hsl(24,95%,53%)] text-white px-6 py-4 rounded-lg font-bold text-lg hover:bg-[hsl(24,95%,48%)] transition" style="min-height: 44px;">
      Get Started Free
    </a>
  </div>
  </main>

  <style>
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border-width: 0;
    }

    .faq-item {
      border-bottom: 1px solid #e5e7eb;
      padding: 1.5rem 0;
    }

    .faq-question {
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      font-size: 1.25rem;
      font-weight: 600;
      list-style: none;
    }

    .faq-question::-webkit-details-marker {
      display: none;
    }

