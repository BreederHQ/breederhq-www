---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedWorkflows from '../../components/RelatedWorkflows.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Workflows', url: '/workflows' },
  { name: 'Nutrition & Feeding', url: '/workflows/nutrition-tracking' }
];

const faqs = [
  {
    question: 'Can I track multiple food brands for different animals?',
    answer: 'Yes. BreederHQ maintains a food product catalog where you can add any brand, type, and formulation. Each animal can have its own feeding plan with different products, portions, and schedules.'
  },
  {
    question: 'How does cost tracking work?',
    answer: 'When you add a food product, you enter the bag size and price. BreederHQ calculates cost-per-ounce automatically. Then, based on your feeding plans, it projects daily and monthly food costs per animal and across your entire program.'
  },
  {
    question: 'Can I track food for young animals separately from adults?',
    answer: 'Yes. Each animal has its own feeding plan, so growing animals (puppies, kittens, foals, kids, lambs, kits) can be on growth formulas with different portions while adults are on maintenance rations. When you transition foods, the change is documented with outcome tracking.'
  },
  {
    question: 'What if I feed raw, home-prepared diets, or forage-based programs?',
    answer: 'BreederHQ supports all food types: dry kibble, wet food, raw, fresh, freeze-dried, hay, grain, pellets, forage, supplements, and treats. You can track ingredients, costs, and portions for any feeding approach across any species.'
  },
  {
    question: 'Can I share feeding information with buyers?',
    answer: 'Yes. Feeding plans and food recommendations can be included in the client portal, so buyers know exactly what their new animal has been eating and can maintain consistency during the transition home.'
  },
  {
    question: 'Does this integrate with health tracking?',
    answer: 'Yes. Appetite scores logged during feedings can flag potential health issues. Weight tracking in health records helps you adjust portions. Food changes are documented so vets can see dietary history when needed.'
  }
];
---

<BaseLayout
  title="Nutrition & Feeding, Organized by Animal | BreederHQ"
  description="BreederHQ keeps feeding plans, costs, transitions, and appetite history organized and tied to each animal’s record. See nutrition tracking."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
    Skip to content
  </a>

  <main id="main-content">
  <nav class="breadcrumb py-4 px-4 bg-gray-50" aria-label="Breadcrumb">
    <ol class="flex items-center space-x-2 max-w-4xl mx-auto text-sm">
      <li><a href="/" class="text-[hsl(24,95%,53%)] hover:underline">Home</a></li>
      <li class="text-gray-400">›</li>
      <li><a href="/workflows" class="text-[hsl(24,95%,53%)] hover:underline">Workflows</a></li>
      <li class="text-gray-400">›</li>
      <li aria-current="page" class="text-gray-600">Nutrition & Feeding</li>
    </ol>
  </nav>

  <!-- Section 1: Hero -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-bold mb-6">Nutrition & Feeding, Organized by Animal.</h1>

      <aside class="tldr-box bg-gray-100 border-l-4 border-[hsl(24,95%,53%)] p-6 my-8 rounded" role="complementary" aria-label="Page summary">
        <h2 class="text-xl font-bold mb-3">Quick Summary</h2>
        <p class="text-gray-700 leading-relaxed">
          You already make careful decisions about what each animal eats. BreederHQ keeps the record organized: a food product catalog with automatic cost calculation, per-animal feeding plans, optional feeding logs with appetite scores, documented food transitions, and cost analytics across your entire program.
        </p>
      </aside>

      <p class="text-xl text-gray-700 leading-relaxed mb-6">
        What are you spending on feed each month? Which animals are picky eaters? How did that food transition go last time? BreederHQ keeps all of that in one place, so the information is there when you need it.
      </p>

      <p class="text-xl text-gray-700 leading-relaxed">
        The nutrition knowledge is already in your head. BreederHQ makes sure it is captured, connected, and easy to share.
      </p>
    </div>
  </section>

  <!-- Section 2: The Problem -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">You already watch what they eat. Here's where it gets complicated.</h2>

      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        You know nutrition matters. The challenge is keeping everything straight across multiple animals, age groups, and life stages: who's eating what, how much you're spending, and what worked (or didn't) last time.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white p-6 rounded border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Without Tracking:</h3>
          <ul class="space-y-2 text-gray-700">
            <li class="flex items-start">
              <span class="mr-3 text-red-500">✗</span>
              <span>"What food was Rex on before the stomach issues?"</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-red-500">✗</span>
              <span>"How much am I actually spending on food per month?"</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-red-500">✗</span>
              <span>"Did Luna's appetite drop before she got sick?"</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-red-500">✗</span>
              <span>"What did I tell the last buyer about feeding?"</span>
            </li>
          </ul>
        </div>

        <div class="bg-white p-6 rounded border border-gray-200">
          <h3 class="text-xl font-bold mb-3">With BreederHQ:</h3>
          <ul class="space-y-2 text-gray-700">
            <li class="flex items-start">
              <span class="mr-3 text-green-500">✓</span>
              <span>Complete food history for every animal</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-green-500">✓</span>
              <span>Automatic cost calculations and projections</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-green-500">✓</span>
              <span>Appetite scores that flag potential issues</span>
            </li>
            <li class="flex items-start">
              <span class="mr-3 text-green-500">✓</span>
              <span>Feeding plans shared automatically with buyers</span>
            </li>
          </ul>
        </div>
      </div>

      <p class="text-lg text-gray-700 leading-relaxed font-semibold">
        Good nutrition data supports the decisions you are already making, for animal health, program budgeting, and buyer education.
      </p>
    </div>
  </section>

  <!-- Section 3: Food Product Catalog -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Food Product Catalog</h2>

      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        Build a catalog of every food product you use. BreederHQ calculates cost-per-ounce automatically, so you always know what you're spending.
      </p>

      <div class="bg-gray-50 p-6 rounded mb-8">
        <h3 class="text-xl font-bold mb-4">For each product, track:</h3>
        <ul class="space-y-2 text-lg text-gray-700">
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Brand and product name</strong> &mdash; Any commercial food, raw supplier, hay variety, grain, pellet, or mix you use.</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Food type</strong> &mdash; Dry kibble, wet food, raw, fresh, freeze-dried, hay, grain, pellets, forage, supplements, treats.</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Life stage</strong> &mdash; Growth (puppies, kittens, foals, kids, lambs, kits), adult, senior, breeding, gestation, lactation, performance, or all stages.</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Species support</strong> &mdash; Which species this product is appropriate for (dogs, cats, horses, goats, alpacas, llamas, sheep, rabbits, or cattle).</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Package size and price</strong> &mdash; Automatic cost-per-unit calculation (per ounce, pound, bale, etc.).</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Nutritional info</strong> &mdash; Protein, fat, fiber percentages, calories per serving.</span>
          </li>
        </ul>
      </div>

      <p class="text-lg text-gray-700 leading-relaxed">
        Once products are in your catalog, assigning them to feeding plans is instant. Change suppliers or prices? Update once, and all cost projections recalculate automatically.
      </p>
    </div>
  </section>

  <!-- Section 4: Feeding Plans -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Per-Animal Feeding Plans</h2>

      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        Every animal can have its own feeding plan. Youngsters on growth formula. Adults on maintenance. Pregnant or lactating females on higher-calorie rations. Working or performance animals on their own program. Each plan is tailored and tracked separately.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white p-6 rounded border border-gray-200">
          <h3 class="text-xl font-bold mb-4">Plan Details</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Food product (from your catalog)</li>
            <li>• Portion size per feeding</li>
            <li>• Feedings per day</li>
            <li>• Feeding times (optional)</li>
            <li>• Special instructions or notes</li>
          </ul>
        </div>

        <div class="bg-white p-6 rounded border border-gray-200">
          <h3 class="text-xl font-bold mb-4">Automatic Calculations</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Daily food consumption</li>
            <li>• Daily cost per animal</li>
            <li>• Monthly cost projection</li>
            <li>• Total program food cost</li>
          </ul>
        </div>
      </div>

      <div class="bg-white p-6 rounded border-l-4 border-[hsl(24,95%,53%)]">
        <h3 class="text-xl font-bold mb-4">Why This Matters</h3>
        <p class="text-gray-700">
          When you know exactly what each animal costs to feed, you can price placements accurately, identify cost-saving opportunities, and budget for growth. Replace "roughly $X per month for food" with a real number.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 5: Feeding Logs -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Feeding Logs & Appetite Tracking</h2>

      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        Optionally log individual feedings to build a detailed history. Quick logging takes seconds and captures valuable health data.
      </p>

      <div class="bg-gray-50 p-6 rounded mb-8">
        <h3 class="text-xl font-bold mb-4">What you can log:</h3>
        <ul class="space-y-3 text-lg text-gray-700">
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Date and time</strong> - When the feeding occurred</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Appetite score (1-5)</strong> - Did they eat everything? Pick at it? Refuse?</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Portion adjustment</strong> - If you gave more or less than usual</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Skipped feeding</strong> - With a reason (illness, vet visit, etc.)</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Notes</strong> - Any observations worth recording</span>
          </li>
        </ul>
      </div>

      <div class="bg-yellow-50 border-l-4 border-yellow-500 p-6 rounded">
        <h3 class="text-xl font-bold mb-4">Early Warning System</h3>
        <p class="text-gray-700">
          Appetite changes are often the first sign of illness. When you log appetite scores, BreederHQ can help you spot patterns, like an animal that has been eating less for several days in a row. It is the kind of shift you might notice in the moment but forget about a week later, now captured automatically.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 6: Food Transitions -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Food Change Documentation</h2>

      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        Changing foods can be risky: digestive upset, refusal, allergic reactions. BreederHQ helps you document transitions so you know what works for each animal next time.
      </p>

      <div class="bg-white p-6 rounded border border-gray-200 mb-8">
        <h3 class="text-xl font-bold mb-4">When you change foods, document:</h3>
        <ul class="space-y-2 text-gray-700">
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Reason for change</strong> - Life stage, health issue, vet recommendation, cost, availability, preference</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Previous food</strong> - What they were eating before</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>New food</strong> - What you're transitioning to</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Transition protocol</strong> - How you're phasing in the new food</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Outcome rating</strong> - Excellent, good, fair, or poor</span>
          </li>
          <li class="flex items-start">
            <span class="mr-3">•</span>
            <span><strong>Notes</strong> - Any reactions, adjustments, or observations</span>
          </li>
        </ul>
      </div>

      <p class="text-lg text-gray-700 leading-relaxed">
        Next time you need to change an animal's food, you'll have history to reference. "Last time we switched Luna to Brand X, she had loose stool for a week, so try Brand Y instead."
      </p>
    </div>
  </section>

  <!-- Section 7: Cost Analytics -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Cost Analytics Dashboard</h2>

      <p class="text-lg text-gray-700 leading-relaxed mb-6">
        See the full financial picture of your feeding program. BreederHQ aggregates costs across all animals to show you exactly where your money goes.
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-gray-50 p-6 rounded">
          <h3 class="text-xl font-bold mb-4">Summary Metrics</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Total food cost (period)</li>
            <li>• Average cost per feeding</li>
            <li>• Total feedings logged</li>
            <li>• Feeding adherence rate</li>
          </ul>
        </div>

        <div class="bg-gray-50 p-6 rounded">
          <h3 class="text-xl font-bold mb-4">Visual Charts</h3>
          <ul class="space-y-2 text-gray-700">
            <li>• Cost trend over time</li>
            <li>• Cost breakdown by animal</li>
            <li>• Top 10 animals by food cost</li>
            <li>• Cost comparison by food type</li>
          </ul>
        </div>
      </div>

      <div class="bg-white p-6 rounded border-l-4 border-[hsl(24,95%,53%)]">
        <h3 class="text-xl font-bold mb-4">Date Range Filtering</h3>
        <p class="text-gray-700">
          View analytics for the last 7 days, 30 days, 90 days, or custom date ranges. The date range is saved in the URL, so you can bookmark or share specific reports.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 8: Integration -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-8">Integrated with Everything Else</h2>

      <p class="text-lg text-gray-700 leading-relaxed mb-8">
        Nutrition tracking isn't isolated. It connects to the rest of your breeding program.
      </p>

      <div class="space-y-6">
        <div class="bg-white p-6 rounded border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Animal Profiles</h3>
          <p class="text-gray-700">
            Each animal's Nutrition tab shows their current feeding plan, recent feeding logs, food change history, and cost analytics. Everything in one place.
          </p>
        </div>

        <div class="bg-white p-6 rounded border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Health Records</h3>
          <p class="text-gray-700">
            Appetite scores from feeding logs can correlate with health events. Weight tracking helps you adjust portions. Vets can see dietary history when diagnosing issues.
          </p>
        </div>

        <div class="bg-white p-6 rounded border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Client Portal</h3>
          <p class="text-gray-700">
            Feeding plans can be shared with buyers through the portal, so they know exactly what their new animal has been eating. Consistent nutrition during the transition home reduces stress.
          </p>
        </div>

        <div class="bg-white p-6 rounded border border-gray-200">
          <h3 class="text-xl font-bold mb-3">Financial Dashboard</h3>
          <p class="text-gray-700">
            Food costs roll up into your overall program financials. See feeding expenses alongside vet costs, supplies, and other categories for a complete picture.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-primary text-white">
    <div class="max-w-4xl mx-auto text-center px-4">
      <h2 class="text-4xl font-bold mb-6">Know What You're Feeding, and What It Costs.</h2>
      <p class="text-xl mb-8 opacity-90">
        All the nutrition knowledge you already have, organized by animal and connected to the rest of your program.
      </p>
      <a href="https://accounts.breederhq.com/register?intent=breeder_dashboard" class="bg-white text-primary px-8 py-4 rounded-lg text-lg font-semibold hover:opacity-90 inline-block">
        Get Started Free
      </a>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-12">Frequently Asked Questions</h2>
      <div class="space-y-8">
        {faqs.map(faq => (
          <div class="border-b border-gray-200 pb-8 last:border-0">
            <h3 class="faq-question">{faq.question}</h3>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sticky Mobile CTA -->
  <div class="fixed bottom-0 left-0 right-0 p-4 bg-white border-t-2 border-gray-200 shadow-lg md:hidden z-50">
    <a href="https://accounts.breederhq.com/register?intent=breeder_dashboard" class="block w-full text-center bg-[hsl(24,95%,53%)] text-white px-6 py-4 rounded-lg font-bold text-lg hover:bg-[hsl(24,95%,48%)] transition" style="min-height: 44px;">
      Get Started Free
    </a>
  </div>
  <RelatedWorkflows
    heading="Related Workflows"
    links={[
      { title: "Offspring Care", description: "Weight tracking, anomaly alerts, neonatal dashboard.", url: "/workflows/offspring-care" },
      { title: "Medication Tracking", description: "Treatment courses, dose logging, withdrawal countdowns.", url: "/workflows/medication-tracking" },
      { title: "Rearing Protocols", description: "ENS, ESI, Volhard PAT, Gun Dog Aptitude testing, plus custom protocols for any species.", url: "/workflows/rearing-protocols" },
      { title: "Free Puppy Weight Tracker", description: "Log daily weights and see growth curves vs. breed averages (works for any species).", url: "/tools/puppy-weight-tracker" }
    ]}
  />


  </main>

  <style>
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border-width: 0;
    }

    .skip-link:focus {
      position: absolute;
      top: 1rem;
      left: 1rem;
      z-index: 50;
      padding: 1rem;
      background: white;
      color: black;
      box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);
      border-radius: 0.5rem;
    }

    .faq-question {
      font-size: 1.25rem;
      font-weight: 700;
      color: #1f2937;
      margin-bottom: 0.75rem;
    }

    .faq-answer {
      color: #4b5563;
      line-height: 1.6;
    }

    .faq-answer p {
      font-size: 1.125rem;
    }
  </style>
</BaseLayout>
