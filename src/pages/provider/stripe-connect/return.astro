---
// Universal-Link bridge for the BreederHQ mobile app's Stripe Connect
// onboarding return path. Stripe's in-app browser (SFSafariViewController /
// Chrome Custom Tabs) does NOT honor Universal Links the same way Safari
// does — a navigation to https://breederhq.com/provider/stripe-connect/return
// from inside that browser will NOT hand off to the app automatically.
//
// To get back into the app we serve a real page at this path that
// immediately redirects to the custom-scheme deep link. Custom-scheme
// URIs DO trigger the app from inside the Stripe browser.
//
// This page is intentionally tiny — no Layout, no analytics — to minimize
// the visible flash between Stripe's redirect and the app reopening.
//
// AASA registers this path so a NORMAL Safari navigation (e.g. user
// shared the URL) still hands off to the app via Universal Links.

const noindex = true;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Returning to BreederHQ…</title>
    <style>
      html, body { background: #0b0b0d; color: #e7e7ea; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; margin: 0; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
      .card { text-align: center; padding: 2rem 1.5rem; max-width: 22rem; }
      .spinner { width: 1.5rem; height: 1.5rem; border: 2px solid rgba(255,255,255,0.2); border-top-color: hsl(24,95%,53%); border-radius: 999px; animation: spin 0.7s linear infinite; margin: 0 auto 1rem; }
      @keyframes spin { to { transform: rotate(360deg); } }
      a { color: hsl(24,95%,53%); }
      .fallback { margin-top: 1.5rem; font-size: 0.875rem; color: rgba(231,231,234,0.7); }
    </style>
  </head>
  <body>
    <main class="card">
      <div class="spinner" aria-hidden="true"></div>
      <h1 style="font-size:1rem;font-weight:600;margin:0 0 0.25rem;">Returning to BreederHQ…</h1>
      <p style="margin:0;font-size:0.875rem;color:rgba(231,231,234,0.7);">Hang tight — finishing up your Stripe setup.</p>
      <p class="fallback" id="fallback" hidden>
        Didn't hop back into the app? <a id="manual" href="#">Tap here</a> to open BreederHQ.
      </p>
    </main>

    <script is:inline>
      (function () {
        // Preserve the original query string so the app's deep-link router
        // gets the session correlation token + any Stripe-appended params.
        var search = window.location.search || "";
        var deepLink = "breederhq://provider/stripe-connect/return" + search;

        var manual = document.getElementById("manual");
        if (manual) manual.setAttribute("href", deepLink);

        // Fire the deep link. Use location.replace so the bridge doesn't
        // sit in browser history — back-button-to-here would be confusing.
        try { window.location.replace(deepLink); } catch (e) { /* fall through */ }

        // If the app didn't intercept within ~1.2s, surface the manual link.
        // 1.2s is long enough that a successful handoff has already swapped
        // out of the browser tab on both iOS and Android.
        setTimeout(function () {
          var el = document.getElementById("fallback");
          if (el) el.hidden = false;
        }, 1200);
      })();
    </script>
  </body>
</html>
