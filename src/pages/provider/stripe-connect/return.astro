---
// Universal-Link bridge for the BreederHQ mobile app's Stripe Connect
// return path. Stripe's in-app browser (SFSafariViewController / Chrome
// Custom Tabs) does NOT honor Universal Links the same way native Safari
// does, so a navigation to https://breederhq.com/provider/stripe-connect/
// return from inside Stripe won't auto-hand-off to the app. We fire the
// custom-scheme deep link from a real page; the OS swaps to the app in
// the happy path. Only if that fails do we surface a manual reopen
// button after a short delay.
//
// No spinner, no "hang tight" copy — this page does ONE thing and
// either it works (we vanish) or it doesn't (user taps the button).
// Anything more would imply background work that isn't happening.

---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <title>BreederHQ</title>
    <style>
      html, body { background: #0b0b0d; color: #e7e7ea; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; margin: 0; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
      .reopen { display: none; padding: 0.75rem 1.25rem; background: hsl(24,95%,53%); color: #fff; font-weight: 600; font-size: 0.95rem; border: 0; border-radius: 0.5rem; text-decoration: none; }
      .reopen.visible { display: inline-block; }
    </style>
  </head>
  <body>
    <a id="reopen" class="reopen" href="#">Reopen BreederHQ</a>

    <script is:inline>
      (function () {
        var search = window.location.search || "";
        var deepLink = "breederhq://provider/stripe-connect/return" + search;

        var reopen = document.getElementById("reopen");
        if (reopen) reopen.setAttribute("href", deepLink);

        try { window.location.replace(deepLink); } catch (e) {}

        // If the OS handed off, this timer never fires — the page is
        // already gone. Otherwise surface the button so the user has a
        // one-tap path back.
        setTimeout(function () {
          if (reopen) reopen.classList.add("visible");
        }, 1200);
      })();
    </script>
  </body>
</html>
