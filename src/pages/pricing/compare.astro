---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { planCategories } from '../../lib/planFeatures';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Pricing', url: '/pricing' },
  { name: 'Compare Plans', url: '/pricing/compare' }
];

const faqs = [
  { question: 'Can I change plans later?', answer: 'Yes. You can upgrade or downgrade your plan at any time from your account settings. Changes take effect at the start of your next billing cycle.' },
  { question: 'Is there a free trial?', answer: 'Yes! Every plan includes a 14-day free trial with full access. You will enter payment details when you start your trial, but you won\'t be charged until the trial ends.' },
  { question: 'Do all plans include marketplace access?', answer: 'Yes. Every subscription tier can list and sell on the marketplace. Tiers gate tools (genetics, AI, protocols), not the ability to sell. Marketplace listing fees are separate from subscription pricing.' },
  { question: 'What species does BreederHQ support?', answer: 'BreederHQ supports Dogs, Cats, Horses, Goats, Alpacas, Llamas, Rabbits, Sheep, and Cattle with species-specific workflows for each.' },
];

const categories = planCategories;

---

<BaseLayout
  title="Compare Plans - Full Feature Breakdown | BreederHQ"
  description="Compare every feature across BreederHQ's Standard, Pro, and Enterprise plans. See exactly what's included at each tier."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <main>
    <!-- Hero + Pricing Cards -->
    <section class="bg-gradient-to-b from-amber-50 to-white py-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-5xl font-bold tracking-tight text-stone-800 mb-4">
          Compare Plans
        </h1>
        <p class="text-xl text-stone-600 max-w-2xl mx-auto mb-3">
          The complete breakdown of what's included at every level.
        </p>
        <p class="text-sm text-stone-500 mb-10">
          Try any plan free for 14 days. No commitment, cancel anytime.
        </p>

        <!-- Pricing Cards -->
        <div class="grid grid-cols-3 gap-6 max-w-2xl mx-auto">
          <div>
            <h3 class="text-lg font-bold text-stone-800">Standard</h3>
            <p class="text-3xl font-bold text-stone-800">$29<span class="text-base font-normal text-stone-500">/mo</span></p>
            <p class="text-xs text-stone-500">or $290/yr</p>
            <p class="text-xs text-stone-500 mt-1">Manage your records & sell</p>
          </div>
          <div class="relative pt-4">
            <span class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-amber-500 text-white text-[10px] font-bold px-3 py-0.5 rounded-full uppercase tracking-wider">Most Popular</span>
            <h3 class="text-lg font-bold text-stone-800">Pro</h3>
            <p class="text-stone-400 text-sm line-through mb-0">$79/mo</p>
            <p class="text-3xl font-bold text-amber-600">$39.50<span class="text-base font-normal text-stone-500">/mo</span></p>
            <p class="text-xs text-amber-600 font-semibold">with FOUNDER50</p>
            <p class="text-xs text-stone-500 mt-1">Breed smarter & grow</p>
          </div>
          <div>
            <h3 class="text-lg font-bold text-stone-800">Enterprise</h3>
            <p class="text-stone-400 text-sm line-through mb-0">$159/mo</p>
            <p class="text-3xl font-bold text-amber-600">$79.50<span class="text-base font-normal text-stone-500">/mo</span></p>
            <p class="text-xs text-amber-600 font-semibold">with FOUNDER50</p>
            <p class="text-xs text-stone-500 mt-1">The platform thinks for you</p>
          </div>
        </div>

        <p class="text-xs text-stone-500 mt-6">
          Founders pricing: 50% off Pro or Enterprise for 12 months for the first 100 subscribers. <a href="/founders" class="text-amber-600 hover:underline">Learn more &rarr;</a>
        </p>
      </div>
    </section>

    <!-- Feature Matrix -->
    <section class="py-12 bg-white">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">

        {categories.map((category, catIdx) => (
          <div class="mb-10">
            <h2 class="text-xl font-bold text-stone-800 mb-4 pb-2 border-b-2 border-amber-500">
              {category.name}
            </h2>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                {catIdx === 0 ? (
                  <thead>
                    <tr class="border-b border-stone-200">
                      <th class="py-2.5 px-3 text-left w-1/2"></th>
                      <th class="py-2.5 px-3 text-center w-1/6 text-xs font-bold text-stone-500 uppercase tracking-wider">Standard</th>
                      <th class="py-2.5 px-3 text-center w-1/6 text-xs font-bold text-stone-500 uppercase tracking-wider">Pro</th>
                      <th class="py-2.5 px-3 text-center w-1/6 text-xs font-bold text-stone-500 uppercase tracking-wider">Enterprise</th>
                    </tr>
                  </thead>
                ) : (
                  <thead class="sr-only">
                    <tr>
                      <th>Feature</th>
                      <th>Standard</th>
                      <th>Pro</th>
                      <th>Enterprise</th>
                    </tr>
                  </thead>
                )}
                <tbody>
                  {category.features.map((feature, idx) => (
                    <tr class={idx % 2 === 0 ? 'bg-stone-50' : 'bg-white'}>
                      <td class="py-2.5 px-3 text-stone-700 w-1/2">
                        {feature.name}
                        {'note' in feature && feature.note && (
                          <span class="block text-xs text-stone-400 mt-0.5">{feature.note}</span>
                        )}
                      </td>
                      <td class="py-2.5 px-3 text-center w-1/6">
                        {typeof feature.standard === 'string' ? (
                          <span class="text-stone-700 font-medium text-xs">{feature.standard}</span>
                        ) : feature.standard ? (
                          <svg class="w-5 h-5 text-amber-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                          </svg>
                        ) : (
                          <span class="text-stone-300">&mdash;</span>
                        )}
                      </td>
                      <td class="py-2.5 px-3 text-center w-1/6">
                        {typeof feature.pro === 'string' ? (
                          <span class="text-stone-700 font-medium text-xs">{feature.pro}</span>
                        ) : feature.pro ? (
                          <svg class="w-5 h-5 text-amber-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                          </svg>
                        ) : (
                          <span class="text-stone-300">&mdash;</span>
                        )}
                      </td>
                      <td class="py-2.5 px-3 text-center w-1/6">
                        {typeof feature.enterprise === 'string' ? (
                          <span class="text-stone-700 font-medium text-xs">{feature.enterprise}</span>
                        ) : feature.enterprise ? (
                          <svg class="w-5 h-5 text-amber-500 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                          </svg>
                        ) : (
                          <span class="text-stone-300">&mdash;</span>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}


      </div>
    </section>

    <!-- CTA -->
    <section class="py-16 bg-stone-800">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">
          Ready to get started?
        </h2>
        <p class="text-lg text-stone-300 mb-8">
          Start your 14-day free trial with full access. Cancel anytime.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://accounts.breederhq.com/register?intent=breeder_dashboard" class="inline-block bg-amber-500 text-white font-semibold py-3 px-8 rounded-lg hover:bg-amber-600 transition">
            Start Free Trial
          </a>
          <a href="/pricing" class="inline-block border-2 border-stone-400 text-stone-300 font-semibold py-3 px-8 rounded-lg hover:bg-stone-700 transition">
            View Pricing &rarr;
          </a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-16 bg-stone-50">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-center text-stone-800 mb-12">Frequently Asked Questions</h2>
        <div class="space-y-8">
          {faqs.map((faq) => (
            <div class="border-b border-stone-200 pb-6">
              <h3 class="text-lg font-semibold text-stone-800 mb-2">{faq.question}</h3>
              <p class="text-stone-600 leading-relaxed">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
