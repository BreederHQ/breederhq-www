---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Pricing', url: '/pricing' }
];

const registerUrl = 'https://accounts.breederhq.com/register?intent=breeder_dashboard';

const plans = [
  {
    name: 'Standard',
    slug: 'standard',
    price: 29,
    yearlyPrice: 290,
    description: 'Everything you need to manage your breeding program',
    popular: false,
    foundersEligible: false,
    features: [
      'Unlimited animals & contacts',
      'Breeding plans & calendar',
      'Financial suite (invoices, expenses)',
      'Document management',
      'Health records',
      'Waitlist management',
      'Buyer portal (1 seat)',
      'Marketplace listings',
      'Free Breeder Service listings',
      '500 MB storage',
      'Email support',
    ],
  },
  {
    name: 'Pro',
    slug: 'pro',
    price: 79,
    yearlyPrice: 790,
    description: 'Advanced tools for growing breeding operations',
    popular: true,
    foundersEligible: true,
    foundersPrice: 39.50,
    foundersYearlyPrice: 395,
    features: [
      'Everything in Standard',
      'Full Genetics Lab (incl. Goal-Based Breeding & Offspring Simulator)',
      'E-signatures for contracts',
      'AI Contract Import (upload your existing PDF)',
      'Advanced reporting & analytics',
      'Auto-replies (rule-based automation)',
      'Help Assistant',
      'Scout AI',
      '5 GB storage',
      'Priority support',
    ],
  },
  {
    name: 'Enterprise',
    slug: 'enterprise',
    price: 159,
    yearlyPrice: 1590,
    description: 'Full-scale breeding management with AI and automation',
    popular: false,
    foundersEligible: true,
    foundersPrice: 79.50,
    foundersYearlyPrice: 795,
    features: [
      'Everything in Pro',
      'Automated follow-ups',
      'Team management with role-based access',
      'Unlimited marketplace listings',
      'Multi-location management',
      '25 GB storage',
      'Dedicated support',
    ],
  },
];

const faqs = [
  { question: 'Can I change plans later?', answer: 'Yes. You can upgrade or downgrade your plan at any time from your account settings. Changes take effect at the start of your next billing cycle.' },
  { question: 'Is there a free trial?', answer: 'Yes! Every plan includes a 14-day free trial. You will enter payment details when you start your trial.' },
  { question: 'What happens when my trial ends?', answer: 'Your data is saved. Simply choose a plan and subscribe to pick up right where you left off.' },
  { question: 'Can I cancel anytime?', answer: 'Absolutely. Cancel from your account settings at any time. You will retain access through the end of your paid period.' },
  { question: 'What species does BreederHQ support?', answer: 'BreederHQ supports Dogs, Cats, Horses, Goats, Alpacas, Llamas, Rabbits, Sheep, and Cattle with species-specific workflows for each.' },
  { question: 'What is the Founders discount?', answer: 'The first 100 subscribers who use code FOUNDER50 at checkout get 50% off Pro or Enterprise for 12 months. One redemption per customer.' },
];
---

<BaseLayout
  title="Pricing - BreederHQ Breeding Management Software"
  description="Simple, transparent pricing for professional breeders. Start your 14-day free trial today. Plans from $29/month. Founders get 50% off Pro & Enterprise."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <main>
    <!-- Hero -->
    <section class="bg-gradient-to-b from-amber-50 to-white py-20">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-5xl font-bold tracking-tight text-stone-800 mb-4">
          Simple, transparent pricing
        </h1>
        <p class="text-xl text-stone-600 max-w-2xl mx-auto mb-3">
          Start your 14-day free trial today.
        </p>
        <p class="text-sm text-stone-500">
          All plans include unlimited animals, contacts, and breeding plans.
        </p>
        <a href="/pricing/compare" class="inline-block mt-4 text-amber-600 hover:text-amber-700 font-medium text-sm">
          See full feature comparison &rarr;
        </a>
        <p class="text-sm text-stone-500 mt-3">
          Shopping around? See how we stack up in our
          <a href="/compare/best-dog-breeding-software" class="text-amber-600 hover:text-amber-700 font-medium underline">dog breeding software</a>
          comparison.
        </p>
      </div>
    </section>

    <!-- Pricing Cards -->
    <section class="py-16 bg-white">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {plans.map((plan) => (
            <div
              class={`relative rounded-2xl border p-8 flex flex-col ${
                plan.popular
                  ? 'border-amber-500 bg-amber-50/30 shadow-xl shadow-amber-500/15 ring-1 ring-amber-500/20'
                  : 'border-stone-300 bg-white shadow-md shadow-stone-900/8'
              }`}
            >
              {plan.popular && (
                <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                  <span class="bg-amber-500 text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider shadow-sm">
                    Most Popular
                  </span>
                </div>
              )}

              <div class="text-center mb-6">
                <h3 class="text-2xl font-bold text-stone-800 mb-2">{plan.name}</h3>
                <p class="text-stone-500 text-sm mb-6">{plan.description}</p>

                {plan.foundersEligible ? (
                  <div class="mb-2">
                    <div class="flex items-baseline justify-center gap-2 mb-1">
                      <span class="text-2xl text-stone-400 line-through">${plan.price}</span>
                      <span class="text-5xl font-bold text-amber-600">${plan.foundersPrice.toFixed(2)}</span>
                      <span class="text-stone-500 text-lg">/mo</span>
                    </div>
                    <p class="text-xs text-amber-600 font-semibold mb-1">
                      with FOUNDER50 for 12 months
                    </p>
                    <p class="text-sm text-stone-500">
                      or ${plan.foundersYearlyPrice}/yr (normally ${plan.yearlyPrice}/yr)
                    </p>
                  </div>
                ) : (
                  <div class="mb-2">
                    <span class="text-5xl font-bold text-stone-800">${plan.price}</span>
                    <span class="text-stone-500 text-lg">/mo</span>
                    <p class="text-sm text-stone-500 mt-1">
                      or ${plan.yearlyPrice}/yr (save ${plan.price * 12 - plan.yearlyPrice}/yr)
                    </p>
                  </div>
                )}
              </div>

              <a
                href={registerUrl}
                class={`block w-full text-center py-3 px-6 rounded-lg font-semibold mb-8 transition ${
                  plan.popular
                    ? 'bg-amber-500 text-white hover:bg-amber-600'
                    : 'bg-stone-800 text-white hover:bg-stone-900'
                }`}
              >
                Start Free Trial
              </a>

              <ul class="space-y-3 flex-1">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-2.5 text-sm text-stone-600">
                    <svg class="w-5 h-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Marketplace Listing Fees -->
    <section class="py-16 bg-stone-50">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-center text-stone-800 mb-4">Marketplace Listing Fees</h2>
        <p class="text-center text-stone-500 mb-8 max-w-2xl mx-auto">
          Listing fees are separate from your subscription. Every tier can list and sell on the marketplace.
        </p>

        <div class="bg-amber-500/10 border border-amber-500/30 rounded-lg px-4 py-3 mb-6 text-center">
          <p class="text-amber-700 font-semibold text-sm">
            All marketplace listing fees are <strong>free during the early access period</strong>. Standard fees will apply later.
          </p>
        </div>

        <div class="bg-white rounded-xl border border-stone-200 shadow-sm overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-stone-200 bg-stone-50">
                <th class="py-3 px-4 text-left text-stone-700 font-semibold">Listing Type</th>
                <th class="py-3 px-4 text-center text-stone-700 font-semibold">Horses</th>
                <th class="py-3 px-4 text-center text-stone-700 font-semibold">Dogs & Cats</th>
                <th class="py-3 px-4 text-center text-stone-700 font-semibold">Goats, Sheep & Rabbits</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-stone-100">
                <td class="py-3 px-4 text-stone-600">Animal Sale (until sold)</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$49</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$25</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$9</td>
              </tr>
              <tr class="border-b border-stone-100">
                <td class="py-3 px-4 text-stone-600">Breeding Booking (monthly)</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$19/mo</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$9/mo</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$5/mo</td>
              </tr>
              <tr class="border-b border-stone-100">
                <td class="py-3 px-4 text-stone-600">Breeding Program (per offspring at weaning)</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$49</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$25</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$9</td>
              </tr>
              <tr class="border-b border-stone-100">
                <td class="py-3 px-4 text-stone-600">Breeder Services (subscribers)</td>
                <td class="py-3 px-4 text-center font-medium text-amber-600" colspan="3">Free - unlimited</td>
              </tr>
              <tr>
                <td class="py-3 px-4 text-stone-600">Breeder Services (non-subscribers)</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through" colspan="3">$5/mo per listing</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-xs text-stone-500 mt-3 text-center">
          No percentage of your sales, ever. You handle your own transactions. We never broker your deals.
        </p>
      </div>
    </section>

    <!-- Marketplace Upgrades -->
    <section class="py-16 bg-white">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-center text-stone-800 mb-4">Optional Marketplace Upgrades</h2>
        <p class="text-center text-stone-500 mb-8">
          Boost your visibility when it matters. Never required.
        </p>

        <div class="bg-white rounded-xl border border-stone-200 shadow-sm overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-stone-200 bg-stone-50">
                <th class="py-3 px-4 text-left text-stone-700 font-semibold">Upgrade</th>
                <th class="py-3 px-4 text-center text-stone-700 font-semibold">Horses</th>
                <th class="py-3 px-4 text-center text-stone-700 font-semibold">Dogs & Cats</th>
                <th class="py-3 px-4 text-center text-stone-700 font-semibold">Goats, Sheep & Rabbits</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-stone-100">
                <td class="py-3 px-4 text-stone-600">Boost (7-day)</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$10</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$5</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$3</td>
              </tr>
              <tr class="border-b border-stone-100">
                <td class="py-3 px-4 text-stone-600">Boost (30-day)</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$25</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$15</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$5</td>
              </tr>
              <tr>
                <td class="py-3 px-4 text-stone-600">Featured Listing (monthly)</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$39/mo</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$19/mo</td>
                <td class="py-3 px-4 text-center font-medium text-stone-400 line-through">$9/mo</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-16 bg-stone-50">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-center text-stone-800 mb-12">Frequently Asked Questions</h2>
        <div class="space-y-8">
          {faqs.map((faq) => (
            <div class="border-b border-stone-200 pb-6">
              <h3 class="text-lg font-semibold text-stone-800 mb-2">{faq.question}</h3>
              <p class="text-stone-600 leading-relaxed">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 bg-stone-800">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">
          Ready to get started?
        </h2>
        <p class="text-lg text-stone-300 mb-8">
          Join breeders who trust BreederHQ to manage their programs. Start your free trial today.
        </p>
        <a
          href={registerUrl}
          class="inline-block bg-amber-500 text-white font-semibold py-3 px-8 rounded-lg hover:bg-amber-600 transition"
        >
          Start Free Trial
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
