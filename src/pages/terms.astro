---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Terms of Service', url: '/terms' }
];

const canonicalUrl = 'https://marketplace.breederhq.com/terms';
---

<BaseLayout
  title="Terms of Service - BreederHQ"
  description="BreederHQ Terms of Service govern use of the platform. The current canonical Terms are published on the BreederHQ Marketplace at marketplace.breederhq.com."
  breadcrumbs={breadcrumbs}
>

  <main>
    <section class="py-16 bg-white">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl font-bold tracking-tight text-gray-900 mb-6">
          Terms of Service
        </h1>

        <p class="text-lg text-gray-700 mb-6">
          The current Terms of Service that govern your use of BreederHQ are
          published and maintained on the BreederHQ Marketplace.
        </p>

        <p class="text-base text-gray-700 mb-8">
          <a
            href={canonicalUrl}
            class="inline-flex items-center gap-2 px-5 py-3 rounded-md bg-[hsl(24,95%,53%)] text-white font-semibold hover:bg-[hsl(24,95%,47%)] transition-colors"
          >
            Read the current Terms of Service
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </p>

        <div class="mt-12 pt-8 border-t border-gray-200 text-sm text-gray-600 space-y-3">
          <p>
            The canonical Terms of Service are also presented for review and
            acceptance when you register or sign in to BreederHQ, and are
            available in the app under <strong>Account &rarr; Legal</strong>.
          </p>
          <p>
            Related documents (Privacy Policy, Acceptable Use Policy, Provider
            Agreements, Buyer Terms, Marketplace Transaction Terms) are linked
            from the Terms of Service page on the Marketplace.
          </p>
          <p>
            Questions about the Terms? Contact us at
            <a href="mailto:legal@breederhq.com" class="text-[hsl(24,95%,53%)] hover:underline">legal@breederhq.com</a>.
          </p>
        </div>
      </div>
    </section>
  </main>

</BaseLayout>
