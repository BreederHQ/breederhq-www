---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Facilities', url: '/facilities' }
];

const facilityTypes = [
  {
    emoji: '🌳',
    name: 'Dog Parks & Play Spots',
    slug: 'dog-parks',
    href: '/facilities/dog-parks',
    summary: 'Private fenced yards, training fields, agility areas, swim spots, and indoor play spaces booked by the hour.',
    subtypes: ['Yard', 'Field', 'Trail', 'Swim', 'Agility', 'Indoor', 'Multi-use'],
    bookingNote: 'Real-time slot booking, one party at a time.'
  },
  {
    emoji: '🐎',
    name: 'Equine Facilities',
    slug: 'equine',
    href: '/facilities/equine',
    summary: 'Arenas, round pens, wash racks, pasture, and trail access for horse owners, trainers, and clinicians.',
    subtypes: ['Indoor arena', 'Outdoor arena', 'Round pen', 'Boarding', 'Pasture rental', 'Wash rack', 'Trail access'],
    bookingNote: 'Inquiry-to-book. Per hour, per night, or per month pricing.'
  },
  {
    emoji: '🐄',
    name: 'Livestock Facilities',
    slug: 'livestock',
    href: '/facilities/livestock',
    summary: 'Handling, sorting, AI/repro spaces, scales, and pasture for cattle, goats, sheep, alpacas, and llamas.',
    subtypes: ['Handling/sorting alley', 'Working chute', 'Pasture rental', 'Show prep area', 'Scale', 'AI/repro space', 'Loading facility'],
    bookingNote: 'Inquiry-to-book. Per session, per head, per day, or per acre.'
  },
  {
    emoji: '🏟️',
    name: 'Indoor Training Halls',
    slug: 'indoor-training',
    href: '/facilities/indoor-training',
    summary: 'Indoor halls and rooms for dog sports, agility, scent work, obedience, cat play, and small-animal training.',
    subtypes: ['Dog sport', 'Agility', 'Flyball', 'Scent work', 'Obedience', 'Multi-species', 'Cat play', 'Small animal'],
    bookingNote: 'Inquiry-to-book. Per hour or per handler.'
  },
  {
    emoji: '🏠',
    name: 'Boarding Facilities',
    slug: 'boarding',
    href: '/facilities/boarding',
    summary: 'Kennels, catteries, exotic boarding, livestock boarding, equine boarding, and in-home boarding arrangements.',
    subtypes: ['Dog kennel', 'Cat boarding/cattery', 'Exotic boarding', 'Livestock boarding', 'Equine boarding', 'In-home boarding'],
    bookingNote: 'Inquiry-to-book. Per night per animal.'
  },
  {
    emoji: '🛁',
    name: 'Wash & Grooming Spaces',
    slug: 'wash-grooming',
    href: '/facilities/wash-grooming',
    summary: 'Self-wash, pro grooming bay rentals, and dedicated wash racks for dogs, livestock, and horses.',
    subtypes: ['Self-wash', 'Pro grooming bay rental', 'Dog wash', 'Livestock wash rack', 'Equine wash rack'],
    bookingNote: 'Inquiry-to-book. Per session or per hour.'
  },
  {
    emoji: '🏆',
    name: 'Event & Show Spaces',
    slug: 'events-shows',
    href: '/facilities/events-shows',
    summary: 'Trial venues, conformation rings, agility trial sites, clinics, photo studios, and breed club meeting spaces.',
    subtypes: ['Trial venue', 'Conformation ring', 'Agility trial site', 'Fun match', 'Education/seminar', 'Clinic', 'Photo studio', 'Breed club meeting'],
    bookingNote: 'Per-event inquiry-to-book. Full-day and multi-day blocks.'
  },
  {
    emoji: '✨',
    name: 'Specialty Facilities',
    slug: 'specialty',
    href: '/facilities/specialty',
    summary: 'Hydrotherapy, treadmills, rehab and PT, sensory rooms, scent work, fitness, and whelping or neonatal spaces.',
    subtypes: ['Hydrotherapy/swim', 'Underwater treadmill', 'Land treadmill', 'Rehab/PT', 'Sensory/calming room', 'Scent work', 'Fitness/conditioning', 'Whelping/neonatal'],
    bookingNote: 'Inquiry-to-book. Per session or per hour.'
  }
];
---

<BaseLayout
  title="Animal Facilities on BreederHQ Marketplace | Bookable Spaces for Dogs, Horses, Livestock"
  description="Browse bookable animal facilities on BreederHQ Marketplace: private dog parks, equine arenas, indoor training halls, boarding kennels, wash bays, event venues, livestock handling, and specialty spaces. Booking by the hour, day, or month."
  breadcrumbs={breadcrumbs}
>
  <main>
    <nav class="breadcrumb py-4 px-4 bg-stone-50 border-b border-stone-200" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 max-w-5xl mx-auto text-sm">
        <li><a href="/" class="text-amber-700 hover:underline">Home</a></li>
        <li class="text-gray-400" aria-hidden="true">›</li>
        <li aria-current="page" class="text-gray-600">Facilities</li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="py-14 px-4 bg-gradient-to-b from-amber-50 to-white">
      <div class="max-w-4xl mx-auto">
        <p class="text-sm font-semibold text-amber-700 uppercase tracking-wide mb-3">BreederHQ Marketplace</p>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 mb-5">
          Animal Facilities — Bookable Spaces for Every Species
        </h1>
        <p class="text-lg text-gray-700 leading-relaxed mb-6">
          Find bookable animal facilities on BreederHQ Marketplace. Eight first-class facility categories spanning dog exercise areas, equine arenas, livestock handling, training halls, boarding, wash bays, event venues, and specialty rehab spaces. Book by the hour, the night, the session, or the month.
        </p>
        <p class="text-base text-gray-600 leading-relaxed mb-8">
          Generic marketplaces lump facilities into "amenities" lists or leave them out entirely. BreederHQ models facilities as first-class marketplace infrastructure with their own taxonomy, identity-confirmation flow, and booking workflow.
        </p>
        <a href="https://marketplace.breederhq.com/services/facilities" class="inline-flex items-center gap-2 bg-amber-700 text-white px-5 py-3 rounded-lg font-semibold hover:bg-amber-600 transition">
          Browse All Facilities
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    <!-- Facility types grid -->
    <section class="py-12 px-4 bg-white">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">The Eight Facility Types</h2>
        <p class="text-gray-600 mb-8">Each facility type has its own subtypes, capacity model, and booking workflow. Click through for the buyer-side detail page.</p>
        <div class="grid md:grid-cols-2 gap-5">
          {facilityTypes.map((f) => (
            <a href={f.href} class="block bg-stone-50 border border-stone-200 rounded-xl p-5 hover:border-amber-500 hover:shadow-sm transition">
              <div class="flex items-start gap-3 mb-3">
                <div class="text-2xl shrink-0">{f.emoji}</div>
                <div class="flex-1">
                  <h3 class="text-lg font-semibold text-gray-900">{f.name}</h3>
                  <p class="text-sm text-gray-700 leading-relaxed mt-1">{f.summary}</p>
                </div>
              </div>
              <div class="mb-3">
                <p class="text-xs uppercase tracking-wide text-gray-500 font-semibold mb-2">Subtypes</p>
                <div class="flex flex-wrap gap-1.5">
                  {f.subtypes.map((s) => (
                    <span class="text-xs bg-white border border-stone-200 text-gray-700 rounded-full px-2.5 py-1">{s}</span>
                  ))}
                </div>
              </div>
              <p class="text-xs text-gray-500 italic mb-2">{f.bookingNote}</p>
              <p class="text-sm font-semibold text-amber-700">Browse {f.name} →</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- How booking works -->
    <section class="py-12 px-4 bg-stone-50">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">How Facility Booking Works</h2>
        <p class="text-gray-600 mb-8">Facility booking is different from booking a provider. The facility has fixed inventory (space + time), and the booking is for a specific slot.</p>
        <div class="grid md:grid-cols-3 gap-5">
          <div class="bg-white border border-stone-200 rounded-xl p-5">
            <div class="text-2xl font-bold text-amber-700 mb-2">1.</div>
            <h3 class="font-semibold text-gray-900 mb-2">Filter by facility type and area</h3>
            <p class="text-sm text-gray-600 leading-relaxed">Pick the facility category that matches what you need. Filter by species, subtype, amenities, and distance.</p>
          </div>
          <div class="bg-white border border-stone-200 rounded-xl p-5">
            <div class="text-2xl font-bold text-amber-700 mb-2">2.</div>
            <h3 class="font-semibold text-gray-900 mb-2">Check requirements and policies</h3>
            <p class="text-sm text-gray-600 leading-relaxed">Vaccination requirements, waiver forms, capacity limits, and species rules show on the listing before you book.</p>
          </div>
          <div class="bg-white border border-stone-200 rounded-xl p-5">
            <div class="text-2xl font-bold text-amber-700 mb-2">3.</div>
            <h3 class="font-semibold text-gray-900 mb-2">Book the slot or send an inquiry</h3>
            <p class="text-sm text-gray-600 leading-relaxed">Dog parks support real-time slot booking, one party at a time. Other facility types use inquiry-to-book so the host can confirm fit.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- What buyers should know -->
    <section class="py-12 px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">What to Know Before You Book</h2>
        <ul class="space-y-3 text-gray-700">
          <li><strong class="text-gray-900">Read the listing carefully.</strong> Facility listings show capacity, equipment, species supported, vaccination requirements, and waiver forms. Self-qualify before sending an inquiry.</li>
          <li><strong class="text-gray-900">One-party-at-a-time is the norm.</strong> Most facility types — especially dog parks, indoor halls, and equine arenas — book exclusively. You're paying for private use, not shared access.</li>
          <li><strong class="text-gray-900">Subtypes matter.</strong> An indoor training hall set up for agility is not the same as one set up for scent work. Subtype filters are how you find the right space.</li>
          <li><strong class="text-gray-900">Cancellation policy is the host's call.</strong> Hosts set flexible, moderate, or strict cancellation policies. Confirm before booking, especially for weather-sensitive outdoor facilities.</li>
          <li><strong class="text-gray-900">Bring what's required.</strong> Many facilities require proof of current vaccinations, signed waivers, or appropriate equipment (e.g., your own jumps, your own grooming supplies).</li>
        </ul>
      </div>
    </section>

    <!-- Related services -->
    <section class="py-12 px-4 bg-stone-50">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-5">Facilities + Services on BreederHQ</h2>
        <p class="text-gray-600 mb-6">Facilities and services are designed to work together. If you're renting a facility and also need a provider, browse the matching service category.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
          <a href="/services/dog-training" class="block bg-white border border-stone-200 rounded-lg p-4 hover:border-amber-400 transition">
            <div class="text-xl mb-1">🎓</div>
            <div class="font-semibold text-gray-900 text-sm">Dog Training</div>
            <p class="text-xs text-gray-600 mt-1">Pairs with Indoor Training Halls, Dog Parks.</p>
          </a>
          <a href="/services/grooming" class="block bg-white border border-stone-200 rounded-lg p-4 hover:border-amber-400 transition">
            <div class="text-xl mb-1">✂️</div>
            <div class="font-semibold text-gray-900 text-sm">Grooming</div>
            <p class="text-xs text-gray-600 mt-1">Pairs with Wash & Grooming Spaces.</p>
          </a>
          <a href="/services/boarding" class="block bg-white border border-stone-200 rounded-lg p-4 hover:border-amber-400 transition">
            <div class="text-xl mb-1">🏠</div>
            <div class="font-semibold text-gray-900 text-sm">Boarding</div>
            <p class="text-xs text-gray-600 mt-1">Pairs with Boarding Facilities.</p>
          </a>
          <a href="/services/equine-boarding" class="block bg-white border border-stone-200 rounded-lg p-4 hover:border-amber-400 transition">
            <div class="text-xl mb-1">🏇</div>
            <div class="font-semibold text-gray-900 text-sm">Equine Boarding</div>
            <p class="text-xs text-gray-600 mt-1">Pairs with Equine Facilities.</p>
          </a>
        </div>
      </div>
    </section>

    <!-- Provider cross-link -->
    <section class="py-10 px-4 bg-white border-t border-stone-200">
      <div class="max-w-4xl mx-auto">
        <a href="/list-your-facility" class="flex items-center justify-between gap-4 bg-emerald-50 border border-emerald-200 rounded-lg p-5 hover:border-emerald-400 transition">
          <div>
            <p class="font-semibold text-gray-900">Do you own a facility?</p>
            <p class="text-sm text-gray-600">List your space on BreederHQ — $5/month per live listing, all eight facility types.</p>
          </div>
          <span class="text-emerald-700 font-semibold whitespace-nowrap">List Your Facility →</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
