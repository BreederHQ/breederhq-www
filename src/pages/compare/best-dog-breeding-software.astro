              <td class="px-3 py-3">No</td>
              <td class="px-3 py-3">Mobile-first</td>
            </tr>
            <tr>
              <th scope="row" class="px-3 py-3 font-semibold text-left">ZooEasy</th>
              <td class="px-3 py-3">Subscription (multi-tier)</td>
              <td class="px-3 py-3">Trial only</td>
              <td class="px-3 py-3">Multi-species (dog, cat, horse, rabbit, others)</td>
              <td class="px-3 py-3">No</td>
              <td class="px-3 py-3">No</td>
