            <tr>
              <th scope="row" class="px-3 py-3 font-semibold text-left">Kintraks</th>
              <td class="px-3 py-3">Annual license</td>
              <td class="px-3 py-3">No</td>
              <td class="px-3 py-3">Multi-species</td>
              <td class="px-3 py-3">Limited</td>
              <td class="px-3 py-3">No</td>
              <td class="px-3 py-3">Web / desktop</td>
            </tr>
            <tr>
              <th scope="row" class="px-3 py-3 font-semibold text-left">PedFast</th>
              <td class="px-3 py-3">One-time license (desktop)</td>
