            "@type": "UnitPriceSpecification",
            "price": "13.99",
            "priceCurrency": "USD",
            "unitCode": "MON"
          },
          "url": "https://breedercloudpro.com/pricing",
          "availability": "https://schema.org/InStock"
        },
        {
          "@type": "Offer",
          "name": "Pro (annual)",
          "price": "130.00",
          "priceCurrency": "USD",
          "priceSpecification": {
            "@type": "UnitPriceSpecification",
            "price": "130.00",
            "priceCurrency": "USD",
            "unitCode": "ANN"
          },
          "url": "https://breedercloudpro.com/pricing",
          "availability": "https://schema.org/InStock"
        }
      ]
    },
    {
      "@type": "Review",
      "itemReviewed": { "@id": "https://breedercloudpro.com/#software" },
      "author": { "@type": "Person", "name": "Amanda D." },
      "datePublished": "2026-01-01",
      "reviewBody": "makes it difficult to see comparison of expenses vs income",
      "publisher": { "@type": "Organization", "name": "Capterra", "url": "https://www.capterra.com/p/176356/Breeder-Cloud-Pro/reviews/" },
      "url": "https://www.capterra.com/p/176356/Breeder-Cloud-Pro/reviews/"
    },
    {
      "@type": "Review",
      "itemReviewed": { "@id": "https://breedercloudpro.com/#software" },
      "author": { "@type": "Person", "name": "Kira M." },
      "datePublished": "2026-05-04",
      "reviewBody": "quarterly tax reports are really difficult",
      "publisher": { "@type": "Organization", "name": "Capterra", "url": "https://www.capterra.com/p/176356/Breeder-Cloud-Pro/reviews/" },
      "url": "https://www.capterra.com/p/176356/Breeder-Cloud-Pro/reviews/"
    },
    {
      "@type": "Review",
      "itemReviewed": { "@id": "https://breedercloudpro.com/#software" },
      "author": { "@type": "Person", "name": "Kalisha B." },
      "datePublished": "2026-05-14",
      "reviewBody": "wish you could track expenses by litter, or dog",
      "publisher": { "@type": "Organization", "name": "Capterra", "url": "https://www.capterra.com/p/176356/Breeder-Cloud-Pro/reviews/" },
      "url": "https://www.capterra.com/p/176356/Breeder-Cloud-Pro/reviews/"
    },
    {
      "@type": "Review",
      "itemReviewed": { "@id": "https://breedercloudpro.com/#software" },
      "author": { "@type": "Person", "name": "Jena S." },
      "datePublished": "2026-04-27",
      "reviewBody": "wish there was a way to upload or put in OFA testing results",
      "publisher": { "@type": "Organization", "name": "Capterra", "url": "https://www.capterra.com/p/176356/Breeder-Cloud-Pro/reviews/" },
      "url": "https://www.capterra.com/p/176356/Breeder-Cloud-Pro/reviews/"
    },
    {
      "@type": "Review",
      "itemReviewed": { "@id": "https://breedercloudpro.com/#software" },
      "author": { "@type": "Person", "name": "Chelsea L." },
      "reviewBody": "to much data entry that could be streamlined but is not... Redundant time consuming data entry that could be streamlined with connection to major registrys",
      "publisher": { "@type": "Organization", "name": "SoftwareAdvice", "url": "https://www.softwareadvice.com/kennel/breeder-cloud-pro-profile/" },
      "url": "https://www.softwareadvice.com/kennel/breeder-cloud-pro-profile/"
    },
    {
      "@type": "Review",
      "itemReviewed": { "@id": "https://breedercloudpro.com/#software" },
      "author": { "@type": "Person", "name": "Roy H." },
      "datePublished": "2026-04-28",
      "reviewBody": "does not currently integrate well with personal websites",
      "publisher": { "@type": "Organization", "name": "Capterra", "url": "https://www.capterra.com/p/176356/Breeder-Cloud-Pro/reviews/" },
      "url": "https://www.capterra.com/p/176356/Breeder-Cloud-Pro/reviews/"
    },
    {
      "@type": "Review",
      "itemReviewed": { "@id": "https://breedercloudpro.com/#software" },
      "author": { "@type": "Person", "name": "Amy J." },
      "reviewBody": "Wld also be nice if I cld download my existing shot records from PDF vet rcpt vs manually typing it in",
      "publisher": { "@type": "Organization", "name": "SoftwareAdvice", "url": "https://www.softwareadvice.com/kennel/breeder-cloud-pro-profile/" },
