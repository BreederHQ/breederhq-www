      "publisher": { "@type": "Organization", "name": "Better Business Bureau", "url": "https://www.bbb.org/us/ny/new-york/profile/pet-services/good-dog-inc-0121-184247/complaints" },
      "url": "https://www.bbb.org/us/ny/new-york/profile/pet-services/good-dog-inc-0121-184247/complaints"
