---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Compare', url: '/compare' }
];

const comparisons = [
  {
    title: 'BreederHQ vs Breeder Cloud Pro',
    description: 'Honest 2026 head-to-head: pricing, species, marketplace, OFA Sync, CHIC Readiness, Scout AI, buyer portal, and mobile. Cited customer reviews.',
    url: '/compare/breederhq-vs-breedercloudpro'
  },
  {
    title: 'BreederHQ vs EasyKeeper',
    description: 'Honest 2026 head-to-head for goat breeders: pricing, dairy production tracking, marketplace, buyer portal, native mobile, and multi-species coverage.',
    url: '/compare/breederhq-vs-easykeeper'
  },
  {
    title: 'BreederHQ vs Everbreed',
    description: 'Honest 2026 head-to-head for rabbit breeders: pricing, mobile apps, marketplace reach, per-buyer client portal, financial attribution, and multi-species coverage.',
    url: '/compare/breederhq-vs-everbreed'
  },
  {
    title: 'BreederHQ vs Good Dog',
    description: 'Honest 2026 comparison: fees, breeder operations, buyer experience, and marketplace revenue model. Includes cited BBB and ComplaintsBoard buyer quotes.',
    url: '/compare/breederhq-vs-gooddog'
  },
  {
    title: 'BreederHQ vs Spreadsheets',
    description: 'Why professional breeders are moving from spreadsheets to purpose-built breeding software.',
    url: '/compare/breederhq-vs-spreadsheets'
  },
  {
    title: 'Sniffspot Alternative',
    description: 'Side-by-side comparison of BreederHQ Marketplace and Sniffspot for private dog park hosts and bookers. Fees, guest access, payout terms, and the multi-category ecosystem.',
    url: '/compare/sniffspot-alternative'
  },
  {
    title: 'Best Breeding Software',
    description: 'Comprehensive comparison of breeding management software options across all species.',
    url: '/compare/best-breeding-software'
  },
  {
    title: 'Best Dog Breeding Software',
    description: 'The top breeding management platforms for professional dog breeders.',
    url: '/compare/best-dog-breeding-software'
  },
  {
    title: 'Best Cat Breeding Software',
    description: 'Compare breeding management tools designed specifically for cat breeders.',
    url: '/compare/best-cat-breeding-software'
  },
  {
    title: 'Best Horse Breeding Software',
    description: 'Mare reproductive tracking, stallion services, semen inventory, and foaling management for professional equine breeders.',
    url: '/compare/best-horse-breeding-software'
  },
  {
    title: 'Best Goat Breeding Software',
    description: 'Dairy production tracking, breeding groups, DHIA records, and CAE/CL testing for professional goat breeders.',
    url: '/compare/best-goat-breeding-software'
  },
  {
    title: 'Best Rabbit Breeding Software',
    description: 'ARBA pedigrees, kindling management, show tracking with Grand Champion legs, and variety genetics for rabbit breeders.',
    url: '/compare/best-rabbit-breeding-software'
  },
  {
    title: 'Best Sheep Breeding Software',
    description: 'Fiber production tracking, tupping groups, fleece analysis, scrapie genotyping, and lambing management for sheep breeders.',
    url: '/compare/best-sheep-breeding-software'
  },
  {
    title: 'Breeder Cloud Pro Alternative',
    description: 'Honest comparison: BreederHQ vs. Breeder Cloud Pro on pricing, species support, marketplace, and buyer portal.',
    url: '/compare/breedercloudpro-alternative'
  },
  {
    title: 'BreederBuddy Alternative',
    description: 'Honest comparison: BreederHQ vs. BreederBuddy on multi-species support, marketplace, trial length, and pricing.',
    url: '/compare/breederbuddy-alternative'
  },
  {
    title: 'Dog Breeder Pro Alternative',
    description: 'Honest comparison: BreederHQ vs. Dog Breeder Pro on operations, buyer portal, marketplace, and trial length.',
    url: '/compare/dogbreederpro-alternative'
  },
  {
    title: "Breeder's Assistant Alternative",
    description: "Honest comparison: BreederHQ (cloud + mobile-first) vs. Tenset Breeder's Assistant (Windows desktop, one-time license).",
    url: '/compare/breeders-assistant-alternative'
  },
  {
    title: 'ZooEasy Alternative',
    description: 'Honest comparison: BreederHQ (working breeders) vs. ZooEasy (breed clubs and registries) — different tools for different jobs.',
    url: '/compare/zooeasy-alternative'
  }
];
---

<BaseLayout
  title="Compare Breeding Software | BreederHQ"
  description="Compare BreederHQ with other breeding management solutions. See why professional breeders choose purpose-built software over spreadsheets."
  breadcrumbs={breadcrumbs}
>
  <main>
    <section class="py-20 px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-5xl font-bold mb-6">Compare Breeding Software</h1>
        <p class="text-xl text-gray-600 mb-12">
          Choosing the right breeding management software is an important decision. Compare BreederHQ with other solutions to find the best fit for your breeding program.
        </p>

        <div class="space-y-6">
          {comparisons.map(comparison => (
            <a
              href={comparison.url}
              class="block bg-white border border-gray-200 rounded-lg p-6 hover:border-primary hover:shadow-md transition-all"
            >
              <h2 class="text-2xl font-bold mb-2 text-gray-900">
                {comparison.title}
              </h2>
              <p class="text-gray-600">
                {comparison.description}
              </p>
              <div class="mt-4 text-primary font-medium">
                Read comparison →
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
