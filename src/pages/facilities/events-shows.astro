---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ListingsSection from '../../components/ListingsSection.astro';
import { fetchFacilityListings } from '../../lib/marketplaceListings';
const listings = await fetchFacilityListings('events-shows');

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Facilities', url: '/facilities' },
  { name: 'Event & Show Spaces', url: '/facilities/events-shows' }
];
---

<BaseLayout
  title="Event & Show Spaces: Trial Venues, Conformation Rings, Clinic Sites | BreederHQ"
  description="Book event and show spaces on BreederHQ Marketplace. Trial venues, conformation rings, agility trial sites, fun matches, clinic and seminar spaces, photo studios, and breed club meeting spaces."
  breadcrumbs={breadcrumbs}
>
  <main>
    <nav class="breadcrumb py-4 px-4 bg-stone-50 border-b border-stone-200" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 max-w-5xl mx-auto text-sm">
        <li><a href="/" class="text-amber-700 hover:underline">Home</a></li>
        <li class="text-gray-400" aria-hidden="true">›</li>
        <li><a href="/facilities" class="text-amber-700 hover:underline">Facilities</a></li>
        <li class="text-gray-400" aria-hidden="true">›</li>
        <li aria-current="page" class="text-gray-600">Event & Show Spaces</li>
      </ol>
    </nav>

    <section class="py-14 px-4 bg-gradient-to-b from-amber-50 to-white">
      <div class="max-w-4xl mx-auto">
        <p class="text-sm font-semibold text-amber-700 uppercase tracking-wide mb-3">Facilities on BreederHQ Marketplace</p>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 mb-5">Event & Show Spaces</h1>
        <p class="text-lg text-gray-700 leading-relaxed mb-6">
          Book event and show spaces on BreederHQ Marketplace. Trial venues, conformation rings, agility trial sites, fun matches, clinic and seminar spaces, photo studios, and breed club meeting spaces. Full-day and multi-day blocks for trial secretaries, club officers, clinicians, and photographers.
        </p>
        <a href={listings.browseUrl} class="inline-flex items-center gap-2 bg-amber-700 text-white px-5 py-3 rounded-lg font-semibold hover:bg-amber-600 transition">
          Browse Event & Show Spaces
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>


    <ListingsSection listings={listings} noun="Event & Show Spaces" unit="facility" bg="white" />

    <section class="py-12 px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">What This Category Covers</h2>
        <p class="text-gray-600 mb-6">Eight event-day subtypes for clubs, clinicians, and photographers.</p>
        <ul class="grid sm:grid-cols-2 gap-3 text-sm text-gray-700">
          <li class="flex gap-2"><span class="text-amber-700">●</span> <strong>Trial venue:</strong> AKC, UKC, ASCA, CPE, NADAC, and similar trial-grade venues</li>
          <li class="flex gap-2"><span class="text-amber-700">●</span> <strong>Conformation ring:</strong> show-quality ring space for conformation events</li>
          <li class="flex gap-2"><span class="text-amber-700">●</span> <strong>Agility trial site:</strong> full-spec agility trial with measuring and judging space</li>
          <li class="flex gap-2"><span class="text-amber-700">●</span> <strong>Fun match:</strong> informal practice events and B-match venues</li>
          <li class="flex gap-2"><span class="text-amber-700">●</span> <strong>Education / seminar:</strong> classroom-style spaces for lectures with optional working dogs</li>
          <li class="flex gap-2"><span class="text-amber-700">●</span> <strong>Clinic:</strong> riding clinics, training intensives, breed-specific clinics</li>
          <li class="flex gap-2"><span class="text-amber-700">●</span> <strong>Photo studio:</strong> natural-light or studio spaces for litter, show, and equine photography</li>
          <li class="flex gap-2"><span class="text-amber-700">●</span> <strong>Breed club meeting:</strong> meeting spaces for breed clubs, kennel clubs, and species associations</li>
        </ul>
      </div>
    </section>

    <section class="py-12 px-4 bg-stone-50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">How to Browse on the Marketplace</h2>
        <p class="text-gray-600 mb-6">Filters that matter for finding the right venue:</p>
        <ul class="space-y-3 text-gray-700">
          <li><strong class="text-gray-900">Subtype.</strong> Trial venue vs. clinic vs. seminar: same building can serve all three, but the listing should disclose what setups they support.</li>
          <li><strong class="text-gray-900">Capacity and parking.</strong> Show entries plus spectators plus crating space. Confirm parking can handle a full entry day.</li>
          <li><strong class="text-gray-900">Ring dimensions and footing.</strong> Sanctioning bodies have specific requirements. Confirm the venue meets AKC/UKC/relevant body specs before booking.</li>
          <li><strong class="text-gray-900">Multi-day capability.</strong> Two-day and three-day trials are the norm. Confirm setup-the-day-before and overnight access policies.</li>
        </ul>
      </div>
    </section>

    <section class="py-12 px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">What to Look For Before You Book</h2>
        <ul class="space-y-3 text-gray-700">
          <li><strong class="text-gray-900">Sanctioning compatibility.</strong> If you're holding an AKC trial, the venue needs to meet AKC's ring, footing, and safety specs. Confirm with the host that they've hosted sanctioned events before.</li>
          <li><strong class="text-gray-900">Crating, grooming, and exhibitor space.</strong> Trial day needs more than ring footage. Where do exhibitors crate, groom, and warm up?</li>
          <li><strong class="text-gray-900">Power, water, and waste.</strong> Show day needs reliable power for grooming and exhibitor RVs; water for animals; waste management for dog/horse waste at scale.</li>
          <li><strong class="text-gray-900">Liability and insurance.</strong> Confirm host's general liability coverage and your club's event insurance requirements. Most sanctioning bodies require event insurance.</li>
          <li><strong class="text-gray-900">Cancellation and weather policy.</strong> Outdoor trials get weather-cancelled. Confirm what happens to the deposit if the event has to move or cancel.</li>
          <li><strong class="text-gray-900">RV / overnight parking.</strong> Many exhibitors travel by RV. Confirm overnight RV parking and hookups.</li>
        </ul>
      </div>
    </section>

    <section class="py-12 px-4 bg-stone-50">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl font-bold text-gray-900 mb-5">Related on BreederHQ</h2>
        <div class="grid sm:grid-cols-3 gap-4">
          <a href="/services/show-handling" class="block bg-white border border-stone-200 rounded-lg p-4 hover:border-amber-400 transition">
            <div class="text-xl mb-1">🏅</div>
            <div class="font-semibold text-gray-900">Show Handling</div>
            <p class="text-xs text-gray-600 mt-1">Pro handlers for conformation and performance events.</p>
          </a>
          <a href="/services/photography" class="block bg-white border border-stone-200 rounded-lg p-4 hover:border-amber-400 transition">
            <div class="text-xl mb-1">📸</div>
            <div class="font-semibold text-gray-900">Photography</div>
            <p class="text-xs text-gray-600 mt-1">Event photographers, show photographers, and studio specialists.</p>
          </a>
          <a href="/facilities/indoor-training" class="block bg-white border border-stone-200 rounded-lg p-4 hover:border-amber-400 transition">
            <div class="text-xl mb-1">🏟️</div>
            <div class="font-semibold text-gray-900">Indoor Training Halls</div>
            <p class="text-xs text-gray-600 mt-1">Halls for practice and prep ahead of an event.</p>
          </a>
        </div>
      </div>
    </section>

    <section class="py-10 px-4 bg-white border-t border-stone-200">
      <div class="max-w-4xl mx-auto">
        <a href="/list-your-facility" class="flex items-center justify-between gap-4 bg-emerald-50 border border-emerald-200 rounded-lg p-5 hover:border-emerald-400 transition">
          <div>
            <p class="font-semibold text-gray-900">Have a venue that can host a trial, clinic, or show?</p>
            <p class="text-sm text-gray-600">List your event space on BreederHQ. Full-day and multi-day blocks.</p>
          </div>
          <span class="text-emerald-700 font-semibold whitespace-nowrap">List Your Venue →</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
