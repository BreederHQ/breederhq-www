---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'For Breeders', url: '/#for-breeders' },
  { name: 'Alpaca Breeding', url: '/alpacas' }
];

const faqs = [
  {
    question: 'Does BreederHQ work for both Huacaya and Suri alpaca breeders?',
    answer: 'Yes. BreederHQ supports Huacaya and Suri programs, including pedigree tracking, breeding records, cria tracking, health records, fiber-related notes, and marketplace visibility for breeders who want a more professional public presence.'
  },
  {
    question: 'How does breeding work for alpacas — they are induced ovulators?',
    answer: 'Alpacas are induced ovulators, meaning they do not have a predictable heat cycle like dogs or horses. BreederHQ supports the actual camelid breeding workflow: breeding events trigger ovulation, so the platform tracks breeding date, expected cria due date (approximately 345 days), birthing, and cria outcomes without forcing alpacas through a cycle-detection model that does not apply to them.'
  },
  {
    question: 'Can I track fiber and fleece information in BreederHQ?',
    answer: 'Yes. Alpaca breeders can record fleece and fiber details — micron data, handle, color, shearing notes, and production context — alongside pedigree, breeding history, and health records. That keeps all the information buyers care about in one place instead of scattered across spreadsheets and notebooks.'
  },
  {
    question: 'Can I manage cria records and buyer communication?',
    answer: 'Yes. Breeding plans, cria records, documents, and buyer communication all connect inside one platform so breeders can move from breeding decisions to follow-up and sales without re-entering the same information in multiple places.'
  },
  {
    question: 'Does BreederHQ support semen and embryo inventory for alpacas?',
    answer: 'Yes. The reproductive inventory system tracks semen lots (straw count, sire identity, storage location, motility) and embryo lots (donor dam, sire, flush date, stage and grade, freeze method) with a complete quantity ledger. Storage is tracked across multiple facilities down to individual tank, cane, and goblet positions.'
  },
  {
    question: 'Can I publish my alpaca program publicly on the marketplace?',
    answer: 'Yes. BreederHQ breeders can publish verified marketplace profiles and available animals backed by the records they actually maintain inside the platform. Alpaca programs are publicly listed on the marketplace now.'
  },
  {
    question: 'Does it handle AOBA and ARI registration records?',
    answer: 'BreederHQ maintains records and documentation for registration. Official submission goes through AOBA, ARI, or other registry systems directly. The platform keeps your pedigrees, registration numbers, and supporting records organized so the submission process is easier.'
  }
];

const featureCards = [
  { id: 'herd-records', icon: '🦙', title: 'Herd Records', desc: 'Pedigrees, registration, cria history, photos' },
  { id: 'breeding', icon: '📅', title: 'Breeding Plans', desc: 'Induced-ovulator workflow, due dates, birthing records' },
  { id: 'cria', icon: '🐣', title: 'Cria Care', desc: 'Birth records, neonatal health, weaning, outcomes' },
  { id: 'fiber', icon: '🧶', title: 'Fiber and Fleece', desc: 'Shearing records, micron data, production context' },
  { id: 'health', icon: '🏥', title: 'Health and Genetics', desc: 'Testing, medications, documents, pedigrees' },
  { id: 'inventory', icon: '🧪', title: 'Reproductive Inventory', desc: 'Semen and embryo lots with storage tracking' },
  { id: 'clients', icon: '👥', title: 'Buyers and Clients', desc: 'Waitlists, inquiries, contracts, communications' },
  { id: 'marketplace', icon: '🌐', title: 'Marketplace', desc: 'Verified profile, available animals, public credibility' }
];
---

<BaseLayout
  title="Alpaca Breeding Software | BreederHQ"
  description="Alpaca breeding software for Huacaya and Suri programs. Camelid-aware breeding plans, pedigrees, cria records, induced-ovulator workflows, fiber notes, reproductive inventory, buyer communication, and marketplace visibility for camelid breeders."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
    Skip to content
  </a>

  <main id="main-content">
    <nav class="breadcrumb py-4 px-4 bg-gray-50" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 max-w-4xl mx-auto text-sm">
        <li><a href="/" class="text-[hsl(24,95%,53%)] hover:underline">Home</a></li>
        <li class="text-gray-400">›</li>
        <li><a href="/#for-breeders" class="text-[hsl(24,95%,53%)] hover:underline">For Breeders</a></li>
        <li class="text-gray-400">›</li>
        <li aria-current="page" class="text-gray-600">Alpaca Breeding</li>
      </ol>
    </nav>

    <!-- Hero + TL;DR -->
    <section class="py-12 px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-5xl font-bold mb-6">Alpaca Breeding Software for Modern Camelid Programs</h1>

        <aside class="tldr-box bg-gray-100 border-l-4 border-[hsl(24,95%,53%)] p-6 my-8 rounded" role="complementary" aria-label="Page summary">
          <h2 class="text-xl font-bold mb-3">TL;DR</h2>
          <p class="text-gray-700 leading-relaxed">
            BreederHQ gives alpaca breeders one place to manage pedigrees, induced-ovulator breeding records,
            cria tracking, fiber notes, health documents, reproductive inventory, and buyer communication. Built
            for Huacaya and Suri programs that need real records — not just a basic listing page.
          </p>
        </aside>

        <p class="text-xl text-gray-700 leading-relaxed">
          Track your alpacas from breeding through cria records and post-weaning decisions, then publish a
          marketplace presence backed by the same records you use to run the herd every day. Alpaca programs
          are now publicly listed on the BreederHQ Marketplace.
        </p>
      </div>
    </section>

    <!-- Feature Cards Grid -->
    <section class="py-8 px-4 bg-gray-50">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl font-bold mb-6 text-center">Everything Your Alpaca Program Needs</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {featureCards.map(card => (
            <a href={`#${card.id}`} class="feature-card block p-4 bg-white rounded-lg shadow-sm hover:shadow-md transition border border-gray-200 hover:border-[hsl(24,95%,53%)]">
              <div class="text-3xl mb-2">{card.icon}</div>
              <h3 class="font-bold text-lg mb-1">{card.title}</h3>
              <p class="text-sm text-gray-600">{card.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Sticky Navigation -->
    <nav class="sticky-nav hidden md:block sticky top-0 bg-white border-b border-gray-200 z-40 shadow-sm">
      <div class="max-w-5xl mx-auto px-4">
        <ul class="flex space-x-6 overflow-x-auto py-3 text-sm">
          {featureCards.map(card => (
            <li>
              <a href={`#${card.id}`} class="nav-link whitespace-nowrap text-gray-600 hover:text-[hsl(24,95%,53%)] transition pb-2">
                {card.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>

    <!-- Accordion Sections -->
    <section class="py-12 px-4">
      <div class="max-w-4xl mx-auto space-y-4">

        <!-- Herd Records -->
        <details id="herd-records" class="accordion-section border border-gray-200 rounded-lg" open>
          <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
            <div class="flex items-center gap-4">
              <span class="text-3xl">🦙</span>
              <div>
                <h3 class="text-2xl font-bold">Herd Records and Pedigrees</h3>
                <p class="text-gray-600">Complete profiles, lineage, and herd organization</p>
              </div>
            </div>
            <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="accordion-content p-6 border-t border-gray-200">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">For Every Alpaca</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Registration numbers (AOBA, ARI, and other registries)</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Microchip IDs and tattoos</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Photos, fiber type (Huacaya or Suri), color, and phenotype</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Birth date, dam and sire, purchase information</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Multi-generation pedigrees with lineage depth</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Custom notes for program-specific context</li>
                </ul>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-3">Herd Organization</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Active females, herdsires, crias, and fiber animals</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Sold, retired, and historical records</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Custom tags and herd categories</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Breeding history linked to each animal</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Show records and performance documentation</li>
                </ul>
              </div>
            </div>
          </div>
        </details>

        <!-- Breeding Plans -->
        <details id="breeding" class="accordion-section border border-gray-200 rounded-lg">
          <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
            <div class="flex items-center gap-4">
              <span class="text-3xl">📅</span>
              <div>
                <h3 class="text-2xl font-bold">Breeding Plans Built for Camelids</h3>
                <p class="text-gray-600">Induced-ovulator workflow, due dates, and birthing records</p>
              </div>
            </div>
            <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="accordion-content p-6 border-t border-gray-200">
            <p class="text-gray-700 mb-4">
              Alpacas do not fit a dog-style heat-cycle workflow. They are induced ovulators — ovulation is triggered
              by the breeding event itself, not a predictable cycle. BreederHQ supports the actual camelid breeding
              process without forcing the wrong lifecycle model onto your program.
            </p>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">Breeding Workflow</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Breeding events with male (herdsire) and female pairing</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Expected due date calculation (~345-day gestation)</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Pregnancy confirmation and recheck records</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Breeding attempt history per female</li>
                  <li class="flex items-start"><span class="mr-2">•</span>No heat-cycle detection required — matches real alpaca biology</li>
                </ul>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-3">Birthing and After</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Birthing records tied to the breeding plan</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Cria gender, color, fiber type, and birth weight</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Weaning milestone tracking</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Post-weaning outcome recording</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Full breeding history per animal for future decisions</li>
                </ul>
              </div>
            </div>
          </div>
        </details>

        <!-- Cria Care -->
        <details id="cria" class="accordion-section border border-gray-200 rounded-lg">
          <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
            <div class="flex items-center gap-4">
              <span class="text-3xl">🐣</span>
              <div>
                <h3 class="text-2xl font-bold">Cria Care and Early Development</h3>
                <p class="text-gray-600">Birth outcomes, neonatal health, nursing, and growth</p>
              </div>
            </div>
            <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="accordion-content p-6 border-t border-gray-200">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">Birth Records</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Birth date, time, and presentation</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Birth weight tracking</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Sex, fiber type, and color at birth</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Dam and sire linkage to pedigree</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Assistance level and delivery notes</li>
                </ul>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-3">Neonatal Health</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Nursing status: nursing well, assisted, bottle fed, orphaned</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Neonatal health: thriving, watch, critical</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Early vaccinations and treatments</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Veterinary care notes and follow-up records</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Weight milestones through weaning</li>
                </ul>
              </div>
            </div>
          </div>
        </details>

        <!-- Fiber and Fleece -->
        <details id="fiber" class="accordion-section border border-gray-200 rounded-lg">
          <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
            <div class="flex items-center gap-4">
              <span class="text-3xl">🧶</span>
              <div>
                <h3 class="text-2xl font-bold">Fiber and Fleece Records</h3>
                <p class="text-gray-600">Shearing notes, micron data, and production context</p>
              </div>
            </div>
            <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="accordion-content p-6 border-t border-gray-200">
            <p class="text-gray-700 mb-4">
              Fiber is one of the primary value drivers in alpaca programs. BreederHQ keeps fleece information
              connected to the same animal record as pedigree and breeding history — so the context buyers care
              about stays organized and accessible.
            </p>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">Fiber Records</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Shearing records with date, weight, and notes</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Micron data and fiber diameter records over time</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Handle, luster, crimp density, and staple length notes</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Fiber type (Huacaya fleece vs. Suri lock structure)</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Show ribbon and fiber evaluation results</li>
                </ul>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-3">Production Context</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Historical clip weight per animal per year</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Fleece quality trend over the animal's lifetime</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Fiber notes published to public marketplace profile</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Linked to breeding history for genetic selection context</li>
                </ul>
              </div>
            </div>
          </div>
        </details>

        <!-- Health and Genetics -->
        <details id="health" class="accordion-section border border-gray-200 rounded-lg">
          <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
            <div class="flex items-center gap-4">
              <span class="text-3xl">🏥</span>
              <div>
                <h3 class="text-2xl font-bold">Health, Documents, and Genetics</h3>
                <p class="text-gray-600">Testing, medications, vet records, and pedigree genetics</p>
              </div>
            </div>
            <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="accordion-content p-6 border-t border-gray-200">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">Health Records</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Vaccination schedules and administration history</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Medication treatment courses with dose logging</li>
                  <li class="flex items-start"><span class="mr-2">•</span>BVD and disease testing documentation</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Fecal egg counts and parasite management records</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Uploaded health certificates, Coggins, and vet records</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Body weight and body condition score tracking</li>
                </ul>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-3">Genetics and Registration</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>DNA typing and parentage verification records</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Genetic testing documentation</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Multi-generation pedigree with lineage depth</li>
                  <li class="flex items-start"><span class="mr-2">•</span>AOBA, ARI registration number storage</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Show record and halter class results</li>
                </ul>
              </div>
            </div>
          </div>
        </details>

        <!-- Reproductive Inventory -->
        <details id="inventory" class="accordion-section border border-gray-200 rounded-lg">
          <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
            <div class="flex items-center gap-4">
              <span class="text-3xl">🧪</span>
              <div>
                <h3 class="text-2xl font-bold">Reproductive Inventory</h3>
                <p class="text-gray-600">Semen and embryo lots with storage tracking and quantity ledger</p>
              </div>
            </div>
            <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="accordion-content p-6 border-t border-gray-200">
            <p class="text-gray-700 mb-4">
              Programs using AI or embryo transfer for high-value herdsires can track all reproductive assets
              in one system — replacing handwritten tank notes and disconnected spreadsheets.
            </p>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">Semen Lots</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Sire identity, collection date, and collection method</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Straw count, format, and extender</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Pre-freeze and post-thaw motility percentages</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Health testing documentation per lot</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Accession number and lot number tracking</li>
                </ul>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-3">Embryo Lots</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Donor dam and sire linkage</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Collection date and fertilization type</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Embryo stage and grade per lot</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Freeze method and freeze date</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Genetic testing status and results</li>
                </ul>
              </div>
            </div>
            <div class="mt-4 grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">Storage Tracking</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Multiple storage providers: vet clinics, IVF labs, owner tanks</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Container and position tracking (cane, canister, goblet)</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Active and inactive container status</li>
                </ul>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-3">Quantity Ledger</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Append-only transaction history per lot</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Events: received, used, transferred, shipped, disposed</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Auto-depletes lot when quantity reaches zero</li>
                </ul>
              </div>
            </div>
          </div>
        </details>

        <!-- Buyers and Clients -->
        <details id="clients" class="accordion-section border border-gray-200 rounded-lg">
          <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
            <div class="flex items-center gap-4">
              <span class="text-3xl">👥</span>
              <div>
                <h3 class="text-2xl font-bold">Buyers and Client Communication</h3>
                <p class="text-gray-600">Inquiries, waitlists, contracts, and sales pipeline</p>
              </div>
            </div>
            <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="accordion-content p-6 border-t border-gray-200">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">Sales Pipeline</h4>
                <ul class="space-y-2 text-gray-700">
