---
import BaseLayout from '../layouts/BaseLayout.astro';
import Screenshot from '../components/Screenshot.astro';
import PaidTrafficHero from '../components/PaidTrafficHero.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'For Breeders', url: '/for-breeders' }
];

// FAQ block: drives FAQPage schema via BaseLayout, gives AI engines extractable Q&A.
const faqs = [
  {
    question: 'What is BreederHQ?',
    answer: 'BreederHQ is breeding-program management software for dogs, cats, horses, goats, sheep, cattle, alpacas, llamas, and rabbits. It combines herd records, pedigree and genetics tools, a phase-based breeding planner, offspring tracking, finances, an e-signature buyer portal, waitlist management, and a public marketplace in one platform with a 14-day free trial.',
  },
  {
    question: 'What species does BreederHQ support?',
    answer: 'Nine species, all available on every plan: dogs, cats, horses, goats, sheep, cattle, alpacas, llamas, and rabbits. Each species has species-specific workflows for breeding cycles, gestation, offspring stages, and registry support (AKC, ADGA, AOBA, AQHA, Jockey Club, APHA, AHA, USEF, NSIP, and more).',
  },
  {
    question: 'How much does BreederHQ cost?',
    answer: 'BreederHQ pricing is $29/mo Standard, $79/mo Pro, or $159/mo Enterprise. Every plan includes a 14-day free trial, unlimited animals, unlimited contacts, and unlimited breeding plans. Founders get 50% off Pro and Enterprise for 12 months with code FOUNDER50 (first 100 subscribers).',
  },
  {
    question: 'Is there a free trial?',
    answer: 'Yes. Every plan includes a 14-day free trial. You enter payment details to start the trial and can cancel anytime before it ends at no charge.',
  },
  {
    question: 'Does BreederHQ replace my spreadsheets?',
    answer: 'Yes. BreederHQ replaces scattered spreadsheets, drive folders, and single-purpose apps with one connected system: health records, pedigrees, breeding plans, finances, client communications, and your marketplace listings all share the same underlying program data.',
  },
  {
    question: 'Does BreederHQ include a buyer-facing marketplace?',
    answer: 'Yes. Every subscription tier includes a public marketplace presence at marketplace.breederhq.com. Listings are powered by your real program data — health testing, pedigrees, and identity confirmation surface automatically without re-entry. We never take a percentage of your sales.',
  },
  {
    question: 'How does BreederHQ compare to dog-only breeder software?',
    answer: 'BreederHQ supports nine species under one account, while most breeder software (BreederBuddy, Dog Breeder Pro) supports one or two species. BreederHQ also includes an integrated public marketplace, OFA Sync, CHIC Readiness, and Scout AI document extraction. See our full comparison at /compare/best-dog-breeding-software.',
  },
  {
    question: 'Who built BreederHQ?',
    answer: 'BreederHQ was founded in 2024 by Aaron Payne and Carie Chapman Barber. The company is independent and not owned by a registry, breed club, or marketplace operator.',
  },
];
---

<BaseLayout
  title="BreederHQ for Breeders - Professional Breeding Management Software"
  description="Breeding-program management software for nine species: dogs, cats, horses, goats, sheep, cattle, alpacas, llamas, rabbits. Health records, breeding planner, finances, buyer portal, and a public marketplace in one platform. 14-day free trial from $29/mo."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>

  <main>

    {/*
      Mounts the paid-search query-string forwarder in script-only mode.
      This page already has a strong above-the-fold hero CTA, so we do NOT
      render the reveal-block — we only install the inline script that
      appends gclid + utm_* from window.location.search onto every
      accounts.breederhq.com/register anchor on the page. Without this,
      Google Ads loses keyword-level attribution even though GA4's _gl
      linker still carries the client_id.
    */}
    <PaidTrafficHero scriptOnly />

    <!-- ============================================ -->
    <!-- HERO                                         -->
    <!-- ============================================ -->
    <section class="bg-gradient-to-b from-stone-50 to-white py-20">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h1 class="text-5xl font-bold tracking-tight text-gray-900 sm:text-6xl leading-tight mb-6">
            Your Entire Breeding Operation.<br />
            <span class="text-primary">One Platform.</span>
          </h1>

          <!-- Quick answer block: optimized for AI extraction (40-60 word self-contained answer). -->
          <p class="text-lg text-gray-700 max-w-3xl mx-auto mb-6 leading-relaxed">
            <strong>BreederHQ is breeding-program management software for nine species</strong> — dogs, cats, horses, goats, sheep, cattle, alpacas, llamas, and rabbits. One account combines herd records, breeding planner, offspring tracking, finances, e-signature buyer portal, waitlist management, and a public marketplace, with a 14-day free trial from $29/month.
          </p>

          <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-10 leading-relaxed">
            BreederHQ replaces the spreadsheets, scattered tools, and disconnected apps
            you've been stitching together. Health records, genetics, breeding plans, finances,
            client portals, and your marketplace listing, all connected and all in one place.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="https://accounts.breederhq.com/register?intent=breeder_dashboard"
              class="bg-primary text-white px-8 py-4 rounded-lg text-lg font-semibold hover:opacity-90 w-full sm:w-auto"
            >
              Start Your Free Trial
            </a>
            <a
              href="https://accounts.breederhq.com/login"
              class="text-gray-600 px-8 py-4 text-lg font-medium hover:text-primary w-full sm:w-auto"
            >
              Already a member? Sign In &rarr;
            </a>
          </div>
          <p class="mt-4 text-sm text-gray-400">14-day free trial. Cancel anytime.</p>

          <!-- Hero screenshot: real platform dashboard -->
          <div class="mt-14">
            <Screenshot
              id="platform-dashboard"
              alt="BreederHQ dashboard for a breeder showing active breeding plans, current offspring in care, and finance rollups — works for dogs, cats, horses, goats, rabbits, sheep, alpacas, llamas, and cattle"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>


    <!-- ============================================ -->
    <!-- THE PROBLEM                                  -->
    <!-- ============================================ -->
    <section class="py-16 bg-white">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">
            Sound Familiar?
          </h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
            <div class="text-2xl mb-3">📁</div>
            <h3 class="font-semibold text-gray-900 mb-2">Scattered Data</h3>
            <p class="text-sm text-gray-600">
              Pedigrees in one place, health records in another, finances in a third.
              Nothing talks to anything else.
            </p>
          </div>
          <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
            <div class="text-2xl mb-3">🔄</div>
            <h3 class="font-semibold text-gray-900 mb-2">Manual Everything</h3>
            <p class="text-sm text-gray-600">
              Tracking cycles by hand, texting buyer updates one-by-one,
              copying the same data into three different tools.
            </p>
          </div>
          <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
            <div class="text-2xl mb-3">🤷</div>
            <h3 class="font-semibold text-gray-900 mb-2">Invisible to Buyers</h3>
            <p class="text-sm text-gray-600">
              You do everything right (health testing, documentation, responsible practices),
              but buyers can't see any of it.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ============================================ -->
    <!-- WHAT IT LOOKS LIKE - Real Product Screenshots -->
    <!-- ============================================ -->
    <section class="py-20 bg-white border-t border-stone-100">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">
            Here's What It Actually Looks Like
          </h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            These are real screens from a working BreederHQ account. No mockups, no marketing renders.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <Screenshot
              id="animals-list"
              alt="Your animals at a glance, every animal with breed, status, and health record links"
            />
            <h3 class="mt-4 text-lg font-bold text-gray-900">Every Animal, At a Glance</h3>
            <p class="text-sm text-gray-600 mt-1">
              Every animal with breed, sex, status, and tags. Click any card for the full profile, pedigree, health records, and breeding history.
            </p>
          </div>

          <div>
            <Screenshot
              id="breeding-plans-list"
              alt="Breeding plans showing phase progress for each pairing"
            />
            <h3 class="mt-4 text-lg font-bold text-gray-900">Breeding Plans, Phase By Phase</h3>
            <p class="text-sm text-gray-600 mt-1">
              Plan and track every breeding from heat detection through placement. The system tracks the phase automatically based on the dates you record.
            </p>
          </div>

          <div>
            <Screenshot
              id="offspring-list"
              alt="Offspring view with identifiers, placement state, and buyer assignments"
            />
            <h3 class="mt-4 text-lg font-bold text-gray-900">Track Every Newborn Through Placement</h3>
            <p class="text-sm text-gray-600 mt-1">
              Identifiers, weights, photos, paperwork status, and which buyer each one is going to, all in one place.
            </p>
          </div>

          <div>
            <Screenshot
              id="finance-invoices"
              alt="Invoice ledger with paid invoices, deposits, and outstanding balances"
            />
            <h3 class="mt-4 text-lg font-bold text-gray-900">Invoicing Without The Spreadsheet</h3>
            <p class="text-sm text-gray-600 mt-1">
              Generate invoices from the breeding program data you already have. Track deposits, payments, and outstanding balances per buyer.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ============================================ -->
    <!-- WHAT YOU GET - High Level Capabilities       -->
    <!-- ============================================ -->
    <section class="py-20 bg-stone-50">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">
            Everything You Need to Run a Professional Breeding Operation
          </h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Nine public species. One platform. Every tool connected.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">

          <!-- Breeding Management -->
          <div class="bg-white rounded-xl border border-stone-200 p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center">
                <span class="text-xl">🧬</span>
              </div>
              <h3 class="text-lg font-bold text-gray-900">Breeding &amp; Genetics</h3>
            </div>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Breeding cycle tracking with species-specific timelines
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                8-phase breeding plan lifecycle (Planning through Complete)
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Scout AI Genetics Scanner: upload any lab PDF, results extracted in seconds
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Multi-locus coat color genetics &amp; Punnett square analysis
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Best Match Finder with COI calculation &amp; lethal gene warnings
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Offspring simulator, breeding goal planner, Gantt timelines
              </li>
            </ul>
            <a href="/workflows/breeding-cycles" class="inline-block mt-4 text-primary text-sm font-medium hover:underline">Learn more &rarr;</a>
          </div>

          <!-- Animal Health -->
          <div class="bg-white rounded-xl border border-stone-200 p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-red-50 flex items-center justify-center">
                <span class="text-xl">❤️</span>
              </div>
              <h3 class="text-lg font-bold text-gray-900">Health &amp; Records</h3>
            </div>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Health testing records (OFA, PennHIP, genetics reports, breed-specific)
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Medication tracking with dose compliance &amp; withdrawal periods
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Vaccination schedules with expiration alerts
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Pedigree trees with COI calculation &amp; common ancestor tracking
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Shareable health report PDFs for your vet
              </li>
            </ul>
            <a href="/workflows/medication-tracking" class="inline-block mt-4 text-primary text-sm font-medium hover:underline">Learn more &rarr;</a>
          </div>

          <!-- Offspring & Rearing -->
          <div class="bg-white rounded-xl border border-stone-200 p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-amber-50 flex items-center justify-center">
                <span class="text-xl">🐾</span>
              </div>
              <h3 class="text-lg font-bold text-gray-900">Offspring &amp; Rearing</h3>
            </div>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Weight tracking with anomaly alerts (fading newborn detection)
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                ENS, ESI, Rule of 7s, Puppy Culture &amp; custom protocol tracking
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Volhard PAT &amp; Gun Dog Aptitude testing with radar charts
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Working-dog role suitability analysis
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Protocol completion certificates for buyers
              </li>
            </ul>
            <a href="/workflows/offspring-care" class="inline-block mt-4 text-primary text-sm font-medium hover:underline">Learn more &rarr;</a>
          </div>

          <!-- Business & Finance -->
          <div class="bg-white rounded-xl border border-stone-200 p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-green-50 flex items-center justify-center">
                <span class="text-xl">💰</span>
              </div>
              <h3 class="text-lg font-bold text-gray-900">Business &amp; Finances</h3>
            </div>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Invoicing with deposits, line items, tax &amp; 9 payment methods
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Expense tracking across 12 categories with receipt capture
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Financial dashboard with MTD revenue, deposits, and trends
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                E-signature contracts (pet, breeding rights, co-ownership, guardian)
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                CSV export for your accountant
              </li>
            </ul>
            <a href="/workflows/invoicing-expenses" class="inline-block mt-4 text-primary text-sm font-medium hover:underline">Learn more &rarr;</a>
          </div>

          <!-- Client & Buyer Management -->
          <div class="bg-white rounded-xl border border-stone-200 p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center">
                <span class="text-xl">👥</span>
              </div>
              <h3 class="text-lg font-bold text-gray-900">Clients &amp; Buyers</h3>
            </div>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Waitlist management with applications &amp; position tracking
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Buyer portal with payments, contracts, messaging, and photo updates
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Communications hub (unified inbox for email &amp; DMs)
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Visual sales pipeline with lead scoring &amp; deal tracking
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Templates, document bundles, and follow-up reminders
              </li>
            </ul>
            <a href="/workflows/client-management" class="inline-block mt-4 text-primary text-sm font-medium hover:underline">Learn more &rarr;</a>
          </div>

          <!-- Marketplace & Visibility -->
          <div class="bg-white rounded-xl border border-stone-200 p-8">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-purple-50 flex items-center justify-center">
                <span class="text-xl">🌐</span>
              </div>
              <h3 class="text-lg font-bold text-gray-900">Marketplace &amp; Visibility</h3>
            </div>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Your real data populates your public marketplace profile
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Profile Indicators reflect your account history (response time, completed transactions)
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                List animals, offspring, stud services &amp; more
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Inquiry management tied to your waitlist &amp; contacts
              </li>
              <li class="flex items-start gap-2">
                <span class="text-primary mt-0.5 font-bold">&#10003;</span>
                Buyers see health tests, pedigrees, and breeding history
              </li>
            </ul>
            <a href="/workflows/marketplace" class="inline-block mt-4 text-primary text-sm font-medium hover:underline">Learn more &rarr;</a>
          </div>

        </div>
      </div>
    </section>


    <!-- ============================================ -->
    <!-- IDENTITY & CREDENTIALS                       -->
    <!-- ============================================ -->
    <section class="py-20 bg-white">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">
            Identity and Credentials on Your Profile
          </h2>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto">
            BreederHQ does not verify or vouch for breeders. What appears on your profile comes from three layers buyers can see and weigh for themselves.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 mb-10">
          <div class="bg-stone-50 rounded-xl border border-stone-200 p-6">
            <div class="text-xs uppercase tracking-wider text-gray-500 font-semibold mb-2">Layer 1</div>
            <h3 class="font-bold text-gray-900 mb-2">Identity confirmation (Stripe Identity)</h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              Complete identity verification through Stripe Identity, a service operated by Stripe, Inc. Your profile shows <em>&ldquo;Identity confirmed via Stripe Identity&rdquo;</em> with the date Stripe returned the result.
            </p>
          </div>
          <div class="bg-stone-50 rounded-xl border border-stone-200 p-6">
            <div class="text-xs uppercase tracking-wider text-gray-500 font-semibold mb-2">Layer 2</div>
            <h3 class="font-bold text-gray-900 mb-2">Public-registry passthrough</h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              For credentials issued by organizations with a public registry (OFA, AKC, AFA, state licensing boards), BreederHQ may query the registry and display <em>&ldquo;Confirmed via [registry] registry&rdquo;</em> with the query date and a link to the source record. The issuing body is the authoritative source.
            </p>
          </div>
          <div class="bg-stone-50 rounded-xl border border-stone-200 p-6">
            <div class="text-xs uppercase tracking-wider text-gray-500 font-semibold mb-2">Layer 3</div>
            <h3 class="font-bold text-gray-900 mb-2">Your own attestation</h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              Health testing records, breeding program history, business policies, and any credential without a Layer 2 passthrough are your own attestation. You may upload supporting documents. BreederHQ does not open, read, or vouch for any uploaded document.
            </p>
          </div>
        </div>

        <div class="bg-stone-50 rounded-xl border border-stone-200 p-6">
          <h3 class="font-bold text-gray-900 mb-3">Profile Indicators</h3>
          <p class="text-sm text-gray-600 leading-relaxed mb-3">
            Separately, BreederHQ may display Profile Indicators based on your account history on the platform. These are facts about how you have used BreederHQ, not endorsements.
          </p>
          <ul class="text-sm text-gray-600 space-y-1.5 list-disc list-inside">
            <li><strong>Joined date</strong> — when your account was created</li>
            <li><strong>Typical response time</strong> — rolling average for buyer inquiries through the platform</li>
            <li><strong>Completed transactions</strong> — count of platform transactions closed without a pending dispute</li>
            <li><strong>Open disputes</strong> — count of unresolved platform disputes at time of display</li>
          </ul>
          <p class="text-sm text-gray-600 mt-4">
            <a href="/trust" class="text-emerald-700 hover:underline">Read the full Identity &amp; Credentials policy &rarr;</a>
          </p>
        </div>

      </div>
    </section>


    <!-- ============================================ -->
    <!-- SCOUT AI + MOBILE - Quick hits               -->
    <!-- ============================================ -->
    <section class="py-16 bg-stone-50">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-8">

          <div class="bg-stone-50 rounded-xl p-8 border border-stone-200">
            <img src="/images/scout/scout-emoji-front.png" alt="Scout AI" class="h-12 w-12 object-contain mb-4" width="48" height="48" />
            <h3 class="text-xl font-bold text-gray-900 mb-3">Scout AI</h3>
            <p class="text-gray-600 mb-4">
              Ask questions about your animals, breeding plans, finances, and medications in plain English.
              Scout connects directly to your data and gives you instant answers without searching through records.
            </p>
            <p class="text-sm text-gray-500 italic">
              "Which of my females are due for health testing renewal?"<br />
              "What's my revenue this quarter compared to last?"
            </p>
            <a href="/workflows/scout-ai" class="inline-block mt-4 text-primary text-sm font-medium hover:underline">Learn more &rarr;</a>
