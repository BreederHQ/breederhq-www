            LinkedIn
          </a>
          <a
            href="https://www.facebook.com/BreederHQ/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 border border-gray-200 rounded-lg px-5 py-3 text-gray-700 hover:border-primary hover:text-primary transition"
