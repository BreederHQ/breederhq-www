---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarketplaceBreedersList from '../../components/MarketplaceBreedersList.astro';
import Screenshot from '../../components/Screenshot.astro';
import { fetchBreeders } from '../../lib/marketplaceData';

const breeders = await fetchBreeders('HORSE');

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Find Breeders', url: '/find-breeders' },
  { name: 'Horse Breeders', url: '/find-breeders/horses' },
];

const faqs = [
  {
    question: 'How are horse breeders verified on BreederHQ?',
    answer: 'BreederHQ uses progressive verification (ID Verified, Verified, Accredited) plus earned behavioral badges. Verification works independently of registry: Jockey Club, AQHA, KWPN, AHA, USEF, or independently registered horses are all welcome. Quick Responder, Health Tested, and Experienced badges are auto-granted from real platform activity, not purchased.',
  },
  {
    question: 'What documentation can I see on a horse breeder profile?',
    answer: 'Profiles can include genetic testing results (HYPP, HERDA, OLWS for Frame Overo, GBED, PSSM, MH, others depending on breed), pedigrees with COI calculation, performance records, foaling history, current and upcoming foals, breeding stock, and stud service availability. The breeder controls per-item visibility.',
  },
  {
    question: 'How do I contact a horse breeder I find on BreederHQ?',
    answer: 'Click into any breeder profile and use the Contact button to start a conversation. For breeding services (stud bookings, embryo transfer arrangements, foal reservations), you can request availability and pricing directly through the platform. Conversations stay in BreederHQ so you have a record.',
  },
  {
    question: 'Do you list stallions standing at stud?',
    answer: 'Yes. Many breeders publish their stallions with stud fees, breeding methods (live cover, fresh AI, frozen AI, ICSI), genetic clearance, and current contracts. Browse the breeders page or use the breeding-services category to find stallions accepting outside mares.',
  },
  {
    question: 'Are sport horse, race, and stock breed programs all welcome?',
    answer: 'Yes. BreederHQ is breed-agnostic. Thoroughbreds, Quarter Horses, Warmbloods, Arabians, draft horses, mustangs, gaited breeds, miniatures, and more are all supported. Coverage depends on which breeders have joined.',
  },
];
---

<BaseLayout
  title="Find Verified Horse Breeders | BreederHQ"
  description="Find verified horse breeders with documented genetic testing, registered pedigrees, and breeding history. Foals, broodmares, and stallions from trusted programs."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <main class="min-h-screen bg-white">
    <a href="#main" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
      Skip to content
    </a>

    <section id="main" class="py-16 px-4 bg-gradient-to-b from-stone-50 to-white">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Find verified horse breeders
        </h1>
        <p class="text-xl text-gray-700 mb-8 max-w-2xl mx-auto">
          Genetic clearance for HYPP, HERDA, OLWS, and breed-specific markers. Registered pedigrees.
          Documented foaling and performance history. Breeders publish from inside the same platform
          they use to manage their programs.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="https://marketplace.breederhq.com/breeders"
            class="bg-[hsl(24,95%,53%)] text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-[hsl(24,95%,48%)] transition w-full sm:w-auto"
          >
            Browse Horse Breeders
          </a>
          <a
            href="https://marketplace.breederhq.com/animals"
            class="bg-white border-2 border-stone-300 text-stone-800 px-8 py-4 rounded-lg text-lg font-semibold hover:border-[hsl(24,95%,53%)] transition w-full sm:w-auto"
          >
            Browse Foals & Stock
          </a>
        </div>

        <div class="mt-16 max-w-3xl mx-auto">
          <Screenshot
            id="horse-marketplace-profile"
            alt="Public horse breeder profile in BreederHQ Marketplace showing AQHA registry, health practices, and placement policies"
          />
          <p class="text-sm text-gray-500 mt-3 text-center italic">
            Every breeder profile is published from the same software they use to manage their program, not a self-written ad.
          </p>
        </div>
      </div>
    </section>

    <MarketplaceBreedersList breeders={breeders} speciesLabel="horse" />

    <section class="py-16 px-4">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-10 text-center">
          What "verified" actually means
        </h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-stone-50 border border-stone-200 rounded-xl p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Identity verified</h3>
            <p class="text-gray-700 text-sm">Government-issued ID is on file. The Verified badge means identity AND program documentation has been reviewed.</p>
          </div>
          <div class="bg-stone-50 border border-stone-200 rounded-xl p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Genetic testing on file</h3>
            <p class="text-gray-700 text-sm">Health Tested badge requires real documentation: HYPP, HERDA, OLWS Frame, GBED, PSSM, MH, breed-specific panels. Not self-attested.</p>
          </div>
          <div class="bg-stone-50 border border-stone-200 rounded-xl p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Earned, not bought</h3>
            <p class="text-gray-700 text-sm">Quick Responder and Experienced badges are auto-granted from real platform activity. Breeders cannot purchase any badge.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-16 px-4 bg-stone-50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-8">
          What you can see on a horse breeder profile
        </h2>
        <ul class="space-y-3 text-lg text-gray-700">
          <li><strong>Genetic clearance</strong>: HYPP, HERDA, GBED, PSSM, MH, OLWS Frame Overo, breed-specific markers (e.g. WFFS in Warmbloods, JEB in Belgian Drafts).</li>
          <li><strong>Pedigrees</strong>: multi-generation registered pedigrees with performance and color genetics on ancestors.</li>
          <li><strong>Foaling history</strong>: past foals, current pregnancies, due dates, and reservation status.</li>
          <li><strong>Stud services</strong>: stallions standing at stud with fees, breeding methods, and contract terms.</li>
          <li><strong>Performance records</strong>: race records, show results, futurity earnings, sport horse evaluations.</li>
          <li><strong>Photos and video</strong>: gallery of horses in motion, conformation shots, performance footage.</li>
        </ul>
      </div>
    </section>

    <section class="py-16 px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-8">
          How to evaluate the horse breeders you find
        </h2>
        <div class="grid md:grid-cols-2 gap-6">
          <a href="/buyers/evaluate-breeders" class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-[hsl(24,95%,53%)] hover:shadow-sm transition">
            <h3 class="text-lg font-bold text-gray-900 mb-2">How to Evaluate Breeders</h3>
            <p class="text-sm text-gray-600">Questions to ask when buying a foal, breeding to a stallion, or buying breeding stock.</p>
          </a>
          <a href="/buyers/health-tests" class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-[hsl(24,95%,53%)] hover:shadow-sm transition">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Understanding Health Testing</h3>
            <p class="text-sm text-gray-600">Why genetic clearance matters, especially for color breeding and performance lines.</p>
          </a>
          <a href="/buyers/red-flags" class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-[hsl(24,95%,53%)] hover:shadow-sm transition">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Red Flags to Avoid</h3>
            <p class="text-sm text-gray-600">Warning signs of unethical breeding practices and how to protect yourself.</p>
          </a>
          <a href="/buyers/contracts-and-agreements" class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-[hsl(24,95%,53%)] hover:shadow-sm transition">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Contracts and Agreements</h3>
            <p class="text-sm text-gray-600">Stallion service contracts, foal sale contracts, and what should be in each.</p>
          </a>
        </div>
      </div>
    </section>

    <section class="py-16 px-4 bg-gradient-to-br from-stone-900 to-stone-800">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-white mb-4">
          Ready to find your horse?
        </h2>
        <p class="text-lg text-stone-300 mb-8">
          Browse verified horse breeders on the BreederHQ Marketplace.
        </p>
        <a
          href="https://marketplace.breederhq.com/breeders"
          class="inline-block bg-[hsl(24,95%,53%)] text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-[hsl(24,95%,48%)] transition"
        >
          Browse Horse Breeders
        </a>
      </div>
    </section>

  </main>
</BaseLayout>
