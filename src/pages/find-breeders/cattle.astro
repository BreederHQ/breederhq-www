---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarketplaceBreedersList from '../../components/MarketplaceBreedersList.astro';
import { fetchBreeders } from '../../lib/marketplaceData';

const breeders = await fetchBreeders('CATTLE');

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Find Breeders', url: '/find-breeders' },
  { name: 'Cattle Breeders', url: '/find-breeders/cattle' },
];

const faqs = [
  {
    question: 'What kinds of cattle breeders are on BreederHQ?',
    answer: 'BreederHQ supports seedstock and registered cattle programs, Highland and miniature breed operations, show programs, and pet-placement breeders. These are programs that maintain individual animal records (pedigrees, health testing, breeding history) and want to connect with buyers through a more credible platform than generic listing sites.',
  },
  {
    question: 'Can I see pedigrees and health records on cattle breeder profiles?',
    answer: 'Yes. Cattle breeders can publish the records they actually maintain in BreederHQ: pedigrees, health testing documentation, vaccination records, and breeding history. What you see on a profile is grounded in the data the breeder uses to run their program.',
  },
  {
    question: 'What breeds can I find on BreederHQ?',
    answer: 'BreederHQ supports all registered and heritage cattle breeds, including Angus, Hereford, Simmental, Charolais, Limousin, Highland, Dexter, miniature breeds, and more. Coverage depends on which breeders have joined, but the platform is open to any registered cattle program.',
  },
  {
    question: 'Can I contact a cattle breeder directly through BreederHQ?',
    answer: 'Yes. Buyers can contact breeders through the marketplace profile and manage the conversation inside the platform instead of moving immediately to scattered texts and emails.',
  },
];
---

<BaseLayout
  title="Find Responsible Cattle Breeders | BreederHQ"
  description="Find responsible cattle breeders with pedigrees, health documentation, and breeding records on the BreederHQ Marketplace. Seedstock, registered breeds, Highland, Dexter, and miniature cattle programs."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <main class="min-h-screen bg-white">
    <a href="#main" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">Skip to content</a>

    <section id="main" class="py-16 px-4 bg-gradient-to-b from-stone-50 to-white">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Find verified cattle breeders</h1>
        <p class="text-xl text-gray-700 mb-8 max-w-2xl mx-auto">
          Pedigrees, health documentation, and breeding records, published from the same software
          breeders use to run their cattle program day to day.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="https://marketplace.breederhq.com/breeders" class="bg-[hsl(24,95%,53%)] text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-[hsl(24,95%,48%)] transition w-full sm:w-auto">Browse Cattle Breeders</a>
          <a href="https://marketplace.breederhq.com/animals" class="bg-white border-2 border-stone-300 text-stone-800 px-8 py-4 rounded-lg text-lg font-semibold hover:border-[hsl(24,95%,53%)] transition w-full sm:w-auto">Browse Available Cattle</a>
        </div>
      </div>
    </section>

    <MarketplaceBreedersList breeders={breeders} speciesLabel="cattle" />

    <section class="py-16 px-4 bg-stone-50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-8">What you can see on a cattle breeder profile</h2>
        <ul class="space-y-3 text-lg text-gray-700">
          <li><strong>Pedigrees and lineage:</strong> documented sire and dam records with registration numbers from AHA, AAA, ABBA, and other associations instead of vague breeding claims.</li>
          <li><strong>Health documentation:</strong> BVD (PI testing), Johne's, vaccination records, and the health testing the breeder actually keeps inside BreederHQ.</li>
          <li><strong>Breeding history:</strong> AI and natural service records, calving history, and herd-development context when breeders choose to publish it.</li>
          <li><strong>Program story:</strong> herd goals, breed focus, photos, and the kind of cattle the breeder is working to produce.</li>
          <li><strong>Available animals:</strong> for-sale calves, heifers, cows, and bulls with pedigree and health details linked directly to the listing.</li>
        </ul>
      </div>
    </section>

    <section class="py-16 px-4 bg-gradient-to-br from-stone-900 to-stone-800">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-white mb-4">Ready to find your cattle breeder?</h2>
        <p class="text-lg text-stone-300 mb-8">
          Browse verified cattle breeders on the BreederHQ Marketplace.
        </p>
        <a href="https://marketplace.breederhq.com/breeders" class="inline-block bg-[hsl(24,95%,53%)] text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-[hsl(24,95%,48%)] transition">Browse Cattle Breeders</a>
      </div>
    </section>
  </main>
</BaseLayout>
