---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarketplaceBreedersList from '../../components/MarketplaceBreedersList.astro';
import { fetchBreeders } from '../../lib/marketplaceData';

const breeders = await fetchBreeders('GOAT');

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Find Breeders', url: '/find-breeders' },
  { name: 'Goat Breeders', url: '/find-breeders/goats' },
];

const faqs = [
  {
    question: 'What goat breeds and operations are on BreederHQ?',
    answer: 'Dairy operations (Nigerian Dwarf, Nubian, LaMancha, Saanen, Alpine, Toggenburg, Oberhasli) and meat operations (Boer, Kiko, Spanish, Myotonic) are all welcome. ADGA, AGS, NPGA, ABGA, and other registries are supported. Pet/companion goat breeders are also welcome.',
  },
  {
    question: 'Can I see DHIA milk records on dairy goat profiles?',
    answer: 'Yes. Dairy goat breeders on BreederHQ can publish DHIA records — 305-day lactation totals, butterfat and protein percentages, peak production. This is the kind of documented production data you cannot get from a self-written profile.',
  },
  {
    question: 'What about disease testing — CAE, CL, Johnes?',
    answer: 'Health Tested badge requires real documentation. Goat breeders can publish CAE (Caprine Arthritis Encephalitis), CL (Caseous Lymphadenitis), and Johnes (Mycobacterium avium paratuberculosis) test results, biosecurity practices, and herd health history.',
  },
  {
    question: 'Can I find registered breeding stock or just kids?',
    answer: 'Both. Browse for registered does, bucks, and breeding-quality kids. Breeders publish what is currently available, what is upcoming, and waitlist status.',
  },
];
---

<BaseLayout
  title="Find Verified Goat Breeders | BreederHQ"
  description="Find verified goat breeders for dairy, meat, and pet operations. DHIA records, disease testing, ADGA pedigrees, and breeding history on the BreederHQ Marketplace."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <main class="min-h-screen bg-white">
    <a href="#main" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">Skip to content</a>

    <section id="main" class="py-16 px-4 bg-gradient-to-b from-stone-50 to-white">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">Find verified goat breeders</h1>
        <p class="text-xl text-gray-700 mb-8 max-w-2xl mx-auto">
          DHIA milk records. Documented disease testing (CAE, CL, Johnes). Registered ADGA, AGS, and ABGA pedigrees.
          Dairy and meat operations on the same trustworthy platform.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="https://marketplace.breederhq.com/breeders" class="bg-[hsl(24,95%,53%)] text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-[hsl(24,95%,48%)] transition w-full sm:w-auto">Browse Goat Breeders</a>
          <a href="https://marketplace.breederhq.com/animals" class="bg-white border-2 border-stone-300 text-stone-800 px-8 py-4 rounded-lg text-lg font-semibold hover:border-[hsl(24,95%,53%)] transition w-full sm:w-auto">Browse Available Goats</a>
        </div>
      </div>
    </section>

    <MarketplaceBreedersList breeders={breeders} speciesLabel="goat" />

    <section class="py-16 px-4 bg-stone-50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-8">What you can see on a goat breeder profile</h2>
        <ul class="space-y-3 text-lg text-gray-700">
          <li><strong>DHIA milk records</strong> — 305-day lactation totals, butterfat and protein percentages, peak production for dairy operations.</li>
          <li><strong>Disease testing</strong> — CAE, CL, Johnes test results and biosecurity protocols.</li>
          <li><strong>Registered pedigrees</strong> — ADGA, AGS, NPGA, ABGA, and breed-specific registries.</li>
          <li><strong>Kidding history</strong> — past kidding records, current pregnancies, expected kids, waitlist status.</li>
          <li><strong>Performance data</strong> — linear appraisal scores, show records, weaning weights for meat goats.</li>
          <li><strong>Photos and program story</strong> — herd photos, breeding philosophy, what makes the operation distinctive.</li>
        </ul>
      </div>
    </section>

    <section class="py-16 px-4 bg-gradient-to-br from-stone-900 to-stone-800">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-white mb-4">Ready to find your goat?</h2>
        <p class="text-lg text-stone-300 mb-8">Browse verified goat breeders on the BreederHQ Marketplace.</p>
        <a href="https://marketplace.breederhq.com/breeders" class="inline-block bg-[hsl(24,95%,53%)] text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-[hsl(24,95%,48%)] transition">Browse Goat Breeders</a>
      </div>
    </section>
  </main>
</BaseLayout>
