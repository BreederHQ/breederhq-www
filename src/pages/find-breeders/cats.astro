---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarketplaceBreedersList from '../../components/MarketplaceBreedersList.astro';
import { fetchBreeders } from '../../lib/marketplaceData';

const breeders = await fetchBreeders('CAT');

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Find Breeders', url: '/find-breeders' },
  { name: 'Cat Breeders', url: '/find-breeders/cats' },
];

const faqs = [
  {
    question: 'Does BreederHQ verify cat breeders?',
    answer: 'No. BreederHQ does not verify, vet, or vouch for breeders. Each profile may show three kinds of indicators: identity confirmation via Stripe Identity (operated by Stripe, Inc.), public-registry passthrough where supported (TICA, CFA, FIFe, etc.) with a link to the source record, and the breeder\u2019s own attestations for everything else. Independently registered cats and breeders without a registry passthrough are welcome \u2014 their information appears as Layer 3 attestation. See /trust for the full policy.',
  },
  {
    question: 'What documentation can I see on a cat breeder profile?',
    answer: 'Profiles can include health testing (HCM screening, PKD, FELV/FIV status, breed-specific genetic panels), pedigrees, kitten availability, parent cats with titles, and program details. The breeder controls per-item visibility, and what you see is grounded in real records the breeder maintains in BreederHQ.',
  },
  {
    question: 'How do I contact a cat breeder I find on BreederHQ?',
    answer: 'Click into any breeder profile and use the Contact button or join their waitlist. All inquiries flow through BreederHQ so the breeder gets organized leads, you get a record of the conversation, and your contact information is not shared until you choose to share it.',
  },
  {
    question: 'Are all cat breeds represented?',
    answer: 'Any pedigreed cat breed is welcome: Maine Coon, Bengal, Siamese, Persian, Ragdoll, British Shorthair, Sphynx, and many more. Coverage depends on which catteries have joined. Use the breed filter on the breeders page to see what is available now.',
  },
  {
    question: 'Does BreederHQ list rescue cats or shelters?',
    answer: 'No. BreederHQ is purpose-built for catteries running structured breeding programs. For rescue cats, use Petfinder, Adopt-a-Pet, or your local shelter. For pedigreed cats from professional catteries with documented health testing and lineage, BreederHQ is the right place.',
  },
];
---

<BaseLayout
  title="Find Verified Cat Breeders | BreederHQ"
  description="Find verified cat breeders with documented health testing, registered pedigrees, and breeding history. Browse trusted catteries on the BreederHQ Marketplace."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <main class="min-h-screen bg-white">
    <a href="#main" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
      Skip to content
    </a>

    <section id="main" class="py-16 px-4 bg-gradient-to-b from-stone-50 to-white">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
          Find verified cat breeders
        </h1>
        <p class="text-xl text-gray-700 mb-8 max-w-2xl mx-auto">
          Documented health screening. Registered pedigrees. Real breeding history. The catteries
          on BreederHQ publish from inside the same platform they use to manage their programs.
          Their profiles reflect actual records, not marketing claims.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="https://marketplace.breederhq.com/breeders"
            class="bg-[hsl(24,95%,53%)] text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-[hsl(24,95%,48%)] transition w-full sm:w-auto"
          >
            Browse Cat Breeders
          </a>
          <a
            href="https://marketplace.breederhq.com/animals"
            class="bg-white border-2 border-stone-300 text-stone-800 px-8 py-4 rounded-lg text-lg font-semibold hover:border-[hsl(24,95%,53%)] transition w-full sm:w-auto"
          >
            Browse Available Kittens
          </a>
        </div>
      </div>
    </section>

    <MarketplaceBreedersList breeders={breeders} speciesLabel="cat" />

    <section class="py-16 px-4">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-10 text-center">
          What the indicators on a breeder profile mean
        </h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-stone-50 border border-stone-200 rounded-xl p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Identity confirmation</h3>
            <p class="text-gray-700 text-sm">"Identity confirmed via Stripe Identity" means Stripe (not BreederHQ) confirmed the breeder\u2019s government-issued ID matched the legal name on file. BreederHQ does not perform the verification itself.</p>
          </div>
          <div class="bg-stone-50 border border-stone-200 rounded-xl p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Registry passthrough (where supported)</h3>
            <p class="text-gray-700 text-sm">"Confirmed via [registry] registry" means BreederHQ queried that public registry and got a matching record. The registry is the authoritative source; click through to confirm current status directly.</p>
          </div>
          <div class="bg-stone-50 border border-stone-200 rounded-xl p-6">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">Breeder\u2019s own attestation</h3>
            <p class="text-gray-700 text-sm">Health testing results (HCM, PKD, FELV/FIV, breed-specific panels), program history, and any credential without registry passthrough are the breeder\u2019s own attestation. BreederHQ does not open, read, or vouch for any uploaded document.</p>
          </div>
        </div>
        <p class="text-center mt-6">
          <a href="/trust" class="text-emerald-700 hover:underline text-sm font-medium">Read the full Identity &amp; Credentials policy &rarr;</a>
        </p>
      </div>
    </section>

    <section class="py-16 px-4 bg-stone-50">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-8">
          What you can see on a cat breeder profile
        </h2>
        <ul class="space-y-3 text-lg text-gray-700">
          <li><strong>Health screening</strong>: HCM ultrasound results, PKD genetic test, FELV/FIV status, breed-specific panels (e.g. PRA in Bengals, GSD-IV in Norwegian Forest Cats).</li>
          <li><strong>Pedigrees</strong>: multi-generation registered pedigrees with title visibility on ancestors.</li>
          <li><strong>Breeding history</strong>: past litters, current pregnancies, upcoming planned litters, and waitlist status.</li>
          <li><strong>Kitten availability</strong>: kittens currently available, expected litters, and reservation/deposit terms.</li>
          <li><strong>Photos and program story</strong>: gallery of cats and kittens, what makes the cattery distinctive.</li>
          <li><strong>Contracts and guarantees</strong>: health guarantee terms, spay/neuter requirements, return policies.</li>
        </ul>
      </div>
    </section>

    <section class="py-16 px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-8">
          How to evaluate the cat breeders you find
        </h2>
        <div class="grid md:grid-cols-2 gap-6">
          <a href="/buyers/evaluate-breeders" class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-[hsl(24,95%,53%)] hover:shadow-sm transition">
            <h3 class="text-lg font-bold text-gray-900 mb-2">How to Evaluate Breeders</h3>
            <p class="text-sm text-gray-600">The questions to ask, what separates responsible catteries from the rest.</p>
          </a>
          <a href="/buyers/health-tests" class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-[hsl(24,95%,53%)] hover:shadow-sm transition">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Understanding Health Testing</h3>
            <p class="text-sm text-gray-600">Why HCM screening and genetic panels matter for cat breeds.</p>
          </a>
          <a href="/buyers/red-flags" class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-[hsl(24,95%,53%)] hover:shadow-sm transition">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Red Flags to Avoid</h3>
            <p class="text-sm text-gray-600">Warning signs of backyard breeding and kitten mills.</p>
          </a>
          <a href="/buyers/contracts-and-agreements" class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-[hsl(24,95%,53%)] hover:shadow-sm transition">
            <h3 class="text-lg font-bold text-gray-900 mb-2">Contracts and Agreements</h3>
            <p class="text-sm text-gray-600">What should be in your kitten purchase contract.</p>
          </a>
        </div>
      </div>
    </section>

    <section class="py-16 px-4 bg-gradient-to-br from-stone-900 to-stone-800">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold text-white mb-4">
          Ready to find your kitten?
        </h2>
        <p class="text-lg text-stone-300 mb-8">
          Browse verified cat breeders on the BreederHQ Marketplace.
        </p>
        <a
          href="https://marketplace.breederhq.com/breeders"
          class="inline-block bg-[hsl(24,95%,53%)] text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-[hsl(24,95%,48%)] transition"
        >
          Browse Cat Breeders
        </a>
      </div>
    </section>

  </main>
</BaseLayout>
