                </tr>
                <tr class="border-b border-gray-200">
                  <td class="py-3 pr-4">Listing sites</td>
                  <td class="py-3 px-4 text-center">None or self-reported</td>
                  <td class="py-3 px-4 text-center">None</td>
                  <td class="py-3 px-4 text-center">None</td>
                  <td class="py-3 px-4 text-center">Built-in</td>
                  <td class="py-3 pl-4 text-center">Yes</td>
                </tr>
                <tr class="border-b border-gray-200">
                  <td class="py-3 pr-4">Legacy desktop software</td>
                  <td class="py-3 px-4 text-center">Yes</td>
                  <td class="py-3 px-4 text-center">Some</td>
                  <td class="py-3 px-4 text-center">Limited</td>
                  <td class="py-3 px-4 text-center">None</td>
                  <td class="py-3 pl-4 text-center">No</td>
                </tr>
                <tr>
                  <td class="py-3 pr-4">Modern genetic history platforms</td>
                  <td class="py-3 px-4 text-center">Yes, linked</td>
                  <td class="py-3 px-4 text-center">Automatic</td>
