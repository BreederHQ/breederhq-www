                  <th class="py-3 px-4 font-semibold text-center">Marketplace integration</th>
                  <th class="py-3 pl-4 font-semibold text-center">Mobile access</th>
                </tr>
              </thead>
              <tbody class="text-gray-700">
                <tr class="border-b border-gray-200">
                  <td class="py-3 pr-4">Spreadsheets</td>
                  <td class="py-3 px-4 text-center">Manual, error-prone</td>
