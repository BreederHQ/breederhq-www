import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Articles', url: '/articles' },
  { name: 'Puppy Health Guarantee: What It Actually Covers', url: '/articles/puppy-health-guarantee-what-it-covers' }
];

// Single source of truth for the article's last-reviewed date.
// Update this when the content is re-verified; every visible date and the
// JSON-LD dateModified read from these constants.
const lastReviewedISO = '2026-05-13';
const lastReviewedDate = new Date(lastReviewedISO + 'T00:00:00Z');
const lastReviewedMonthYear = lastReviewedDate.toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
  timeZone: 'UTC'
});

const faqs = [
  {
    question: 'What Does a Puppy Health Guarantee Usually Cover?',
    answer: 'Most puppy health guarantees cover a narrow list of congenital and hereditary conditions that appear within a defined window after purchase. Common examples include severe hip or elbow dysplasia, certain cardiac defects, and a small set of breed-specific genetic conditions. Most contracts do not cover infectious illness diagnosed after a short initial window, behavioral issues, allergies, weight-related joint problems, or any condition the breeder classifies as environmental or owner-caused. The remedy is usually a replacement puppy, a partial refund, or a capped contribution toward vet costs, not an open-ended promise to cover whatever goes wrong.'
  },
  {
    question: 'How Long Does a Puppy Health Guarantee Last?',
    answer: 'Coverage windows vary widely by condition class and by contract. Typical patterns are short windows of seven to fourteen days for infectious illness from the time of pickup, six to twelve months for cardiac conditions, one to two years for hip and elbow dysplasia, and two to three years (or rarely "lifetime") for a narrow list of named hereditary conditions. "Lifetime" guarantees almost always carry the most exclusions and voiding triggers, so longer is not automatically better. Read the per-condition windows and the list of named conditions, not just the headline duration.'
  },
  {
    question: 'Can a Breeder Require Me to Use Their Vet?',
    answer: 'Many contracts include a "vet of choice" clause stating that the breeder\'s veterinarian, or a board-certified specialist of the breeder\'s choosing, must confirm any covered diagnosis. These clauses are generally enforceable as written. The buyer is still free to use their own veterinarian for ordinary care, but a covered diagnosis usually has to be verified by the breeder\'s vet (or pathologist, in the case of necropsy) before the remedy is triggered. If the breeder\'s designated vet is hours away or the diagnostic standard is unusually high, that is a meaningful term to negotiate before signing.'
  },
  {
    question: 'What is the Difference Between a Replacement Puppy and a Refund?',
    answer: 'A replacement puppy clause obligates the breeder to provide a future puppy from a future litter (often without a defined timeline) if a covered condition is diagnosed. The buyer typically keeps the original puppy or returns it, depending on the contract. A refund clause returns some or all of the purchase price. Refund clauses are usually capped at the purchase price and often require returning the puppy. Neither clause covers the vet bills, surgeries, or ongoing care costs the buyer has already paid. Capped vet-cost contribution clauses are a third pattern that contributes a fixed dollar amount toward documented vet bills, separate from refund or replacement.'
  },
  {
    question: 'What Voids a Puppy Health Guarantee?',
    answer: 'Common voiding triggers include: failing a required initial vet check within a short window after pickup, missing vaccinations or worming on the contract\'s schedule, spaying or neutering outside a specified age window, feeding a food brand or protein not approved by the contract, not maintaining specific supplements, transferring or rehoming the puppy, allowing the puppy to become overweight, failing to notify the breeder within a contractual window after diagnosis, and failing to submit a necropsy by a board-certified pathologist if the puppy dies. The contract usually lists every trigger explicitly. Buyers miss them because the list is long and many are unrelated to the condition itself.'
  },
  {
    question: 'Do I Have to Return the Puppy to Get the Guarantee Honored?',
    answer: 'It depends on the contract. Some replacement-puppy clauses require returning the original puppy to receive a replacement. Some refund clauses require returning the puppy as a condition of the refund. Capped vet-cost contribution clauses generally do not require return. For buyers who have already bonded with the puppy, a return-required remedy is effectively no remedy at all. Read this term carefully before signing. If returning the puppy is unacceptable to you, negotiate for a vet-cost contribution or partial refund without return as the remedy.'
  },
  {
    question: 'Are Puppy Health Guarantees Regulated by Law?',
    answer: 'Lightly, and mostly only when the seller qualifies as a "pet dealer" or "pet store" under a state statute. A handful of states (California, New York, New Jersey, Connecticut, Florida, Pennsylvania, Massachusetts, Minnesota, Virginia, and others) have pet purchaser protection statutes that set a floor for remedies when a puppy is sick or congenitally defective. Those statutes typically require a defined notification window, a veterinary diagnosis, and a remedy menu that includes some combination of refund, replacement, or vet-cost recovery up to the purchase price. In states without a specific statute, the contract controls under general contract law. Private hobby breeders are often outside the statutory definition of "pet dealer," so the statute may not apply at all even in covered states.'
  },
  {
    question: 'Can I Negotiate a Breeder\'s Health Guarantee?',
    answer: 'Sometimes, and it costs nothing to ask. Established breeders with a strong waitlist usually offer a standard contract on a take-it-or-leave-it basis. Smaller breeders or breeders earlier in their program may be more open to negotiation. The most negotiable terms are usually: the per-condition coverage window, the list of named conditions, the vet-of-choice requirement, the voiding triggers around food and supplements, and whether the remedy requires returning the puppy. Make any agreed changes in writing as a contract amendment, signed by both parties, not as a side conversation or text message.'
  }
];
