---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Articles', url: '/articles' },
  { name: 'Buyer Screening Tools', url: '/articles/buyer-screening-tools' }
];

const faqs = [
  {
    question: 'What are examples of buyer screening tools for breeders?',
    answer: 'Application forms, questionnaires, reference check templates, buyer pipelines, and waitlist management software all qualify. Some breeders use spreadsheets while others use integrated platforms that combine applications, contracts, and communication in one system.'
  },
  {
    question: 'What are the four common types of animal buyers?',
    answer: 'Companion seekers, show or competition buyers, working or sport buyers, and breeding program buyers. Each type has different priorities and requires different screening questions.'
  },
  {
    question: 'How long does a buyer screening process typically take?',
    answer: 'Most screening processes take between one and four weeks depending on breeder responsiveness, reference availability, and whether interviews are required. Rushing the process increases placement risk.'
  },
  {
    question: 'Can breeders legally decline a buyer based on lifestyle answers?',
    answer: 'Breeders are private sellers and generally have broad discretion to decline buyers for any non-discriminatory reason related to animal welfare or program fit. Consult local counsel for jurisdiction-specific guidance.'
  }
];
