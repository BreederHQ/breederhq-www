                  <td class="py-3 px-4 text-center">Basic</td>
                  <td class="py-3 px-4 text-center">No</td>
                  <td class="py-3 pl-4 text-center">Yes</td>
                </tr>
                <tr class="border-b border-gray-200">
                  <td class="py-3 pr-4">MailerLite</td>
                  <td class="py-3 px-4">Beginners</td>
                  <td class="py-3 px-4 text-center">Basic</td>
                  <td class="py-3 px-4 text-center">No</td>
                  <td class="py-3 px-4 text-center">No</td>
                  <td class="py-3 pl-4 text-center">Yes</td>
                </tr>
                <tr class="border-b border-gray-200">
                  <td class="py-3 pr-4">HubSpot</td>
                  <td class="py-3 px-4">All-in-one CRM + marketing</td>
