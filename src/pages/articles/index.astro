---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { articles as allArticles } from '../../data/articles';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Articles', url: '/articles' }
];

const featuredData = allArticles.find(a => a.featured)!;
const featured = {
  slug: featuredData.slug,
  title: featuredData.title,
  subtitle: featuredData.featuredSubtitle ?? '',
  excerpt: featuredData.excerpt,
  author: featuredData.author,
  role: featuredData.role,
  date: featuredData.date,
  readTime: featuredData.readTime,
  tag: featuredData.tag,
};

const articles = allArticles.filter(a => !a.featured);
---

<BaseLayout
  title="Articles | BreederHQ"
  description="Founder essays and deep-dives on breeding software, data, and running a responsible program across nine species. Read the thinking behind BreederHQ."
  breadcrumbs={breadcrumbs}
>
  <main>
    <nav class="breadcrumb py-4 px-4 bg-gray-50" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 max-w-4xl mx-auto text-sm">
        <li><a href="/" class="text-[hsl(24,95%,53%)] hover:underline">Home</a></li>
        <li class="text-gray-400">›</li>
        <li aria-current="page" class="text-gray-600">Articles</li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="bg-gradient-to-b from-stone-50 to-white pt-12 pb-8 px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-5xl font-bold tracking-tight text-gray-900 leading-tight mb-3">
          Articles
        </h1>
        <p class="text-lg text-gray-600 max-w-3xl leading-relaxed">
          Founder perspectives, deep-dives, and the thinking behind BreederHQ. Long-form writing on breeding, data, AI, and the business of responsible breeding, across dogs, cats, horses, goats, rabbits, sheep, alpacas, llamas, and cattle.
        </p>
      </div>
    </section>

    <!-- Featured: Founder's Perspective -->
    <section class="pt-4 pb-4 px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <div class="featured-frame relative rounded-xl p-[2px] group">
          <a
            href={`/articles/${featured.slug}`}
            class="block bg-white rounded-[10px] shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 p-8 relative"
            aria-label={`Featured: ${featured.title}`}
          >
            <div class="flex items-center gap-2 mb-3">
              <span class="featured-chip inline-flex items-center text-[10px] font-bold uppercase tracking-widest text-amber-800 border border-amber-300 px-2 py-0.5 rounded">
                Featured
              </span>
              <p class="text-xs font-semibold uppercase tracking-wider text-gray-500">{featured.tag}</p>
            </div>
            <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-1 group-hover:text-gray-700 transition">
              {featured.title}
            </h2>
            <p class="text-lg md:text-xl text-gray-500 font-medium mb-3">
              {featured.subtitle}
            </p>
            <p class="text-gray-700 leading-relaxed mb-6">
              {featured.excerpt}
            </p>
            <div class="flex items-center gap-3 text-sm text-gray-500 border-t border-gray-200 pt-4">
              <div>
                <p class="font-semibold text-gray-900">{featured.author}</p>
                <p class="text-xs">{featured.role}</p>
              </div>
              <span class="text-gray-300">&middot;</span>
              <p>{featured.date}</p>
              <span class="text-gray-300">&middot;</span>
              <p>{featured.readTime}</p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <style>
      .featured-frame {
        background: linear-gradient(
          110deg,
          #b45309 0%,
          #f59e0b 20%,
          #fbbf24 35%,
          #fef3c7 50%,
          #fbbf24 65%,
          #f59e0b 80%,
          #b45309 100%
        );
        background-size: 250% 100%;
        animation: featured-frame-pan 5s linear infinite;
        box-shadow:
          0 0 0 1px rgba(245, 158, 11, 0.18),
          0 4px 14px -4px rgba(245, 158, 11, 0.35);
      }
      @keyframes featured-frame-pan {
        0%   { background-position:   0% 50%; }
        100% { background-position: 250% 50%; }
      }
      .featured-chip {
        background: linear-gradient(
          110deg,
          #fef3c7 0%,
          #fef3c7 38%,
          #fffbeb 50%,
          #fef3c7 62%,
          #fef3c7 100%
        );
        background-size: 250% 100%;
        animation: chip-shimmer 2.4s linear infinite;
      }
      @keyframes chip-shimmer {
        0%   { background-position: 250% 50%; }
        100% { background-position:   0% 50%; }
      }
    </style>

    <!-- Section divider -->
    <section class="px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 py-4">
          <div class="flex-1 h-px bg-gray-200"></div>
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-500">More Articles</p>
          <div class="flex-1 h-px bg-gray-200"></div>
        </div>
      </div>
    </section>

    <!-- Articles List -->
    <section class="pt-2 pb-16 px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <div class="space-y-6">
          {articles.map(article => (
            <a href={`/articles/${article.slug}`} class="block bg-white rounded-xl border border-gray-300 shadow-sm hover:shadow-lg hover:border-[hsl(24,95%,53%)] hover:-translate-y-0.5 transition-all duration-200 p-8 group">
              <p class="text-xs font-semibold uppercase tracking-wider text-[hsl(24,95%,53%)] mb-3">{article.tag}</p>
              <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3 group-hover:text-[hsl(24,95%,53%)] transition">
                {article.title}
              </h2>
              <p class="text-gray-700 leading-relaxed mb-6">
                {article.excerpt}
              </p>
              <div class="flex items-center gap-3 text-sm text-gray-500 border-t border-gray-200 pt-4">
                <div>
                  <p class="font-semibold text-gray-900">{article.author}</p>
                  <p class="text-xs">{article.role}</p>
                </div>
                <span class="text-gray-300">&middot;</span>
                <p>{article.date}</p>
                <span class="text-gray-300">&middot;</span>
                <p>{article.readTime}</p>
              </div>
            </a>
          ))}
        </div>

        <!-- Coming soon teaser -->
        <div class="mt-12 text-center text-gray-500 text-sm">
          More articles coming soon.
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
