---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Articles', url: '/articles' }
];

const featured = {
  slug: 'breeder-software-has-a-data-problem',
  title: 'Breeder Software Has a Data Problem (And We\'re Here to Solve It)',
  excerpt: 'Why we built BreederHQ around a unified data layer first, and Scout AI second. Records-management software stops at storing your data. The real problem is connecting it and making it answer real business questions.',
  author: 'Aaron Payne',
  role: 'Founder, BreederHQ',
  date: 'April 29, 2026',
  readTime: '7 min read',
  tag: 'Founder\u2019s Perspective'
};

const articles = [
  {
    slug: 'puppy-health-guarantee-what-it-covers',
    title: 'Puppy Health Guarantee: What It Actually Covers (and What It Doesn\'t)',
    excerpt: 'A teardown of the four most common health-guarantee clause types in US puppy contracts, what each one really commits the breeder to, what the fine print usually excludes, and the questions to ask before you sign.',
    author: 'BreederHQ Editorial',
    role: 'Last Reviewed May 2026',
    date: 'May 13, 2026',
    readTime: '13 min read',
    tag: 'Buyer Guide'
  },
  {
    slug: 'puppy-deposit-refund-rules-by-state',
    title: 'Puppy Deposit Refund Rules by State',
    excerpt: 'A 50-state reference for when puppy deposits are refundable, what state pet purchaser protection statutes actually cover, and sample contract clauses for buyers and breeders.',
    author: 'BreederHQ Editorial',
    role: 'Last Reviewed May 2026',
    date: 'May 13, 2026',
    readTime: '14 min read',
    tag: 'Buyer Guide'
  }
];
---

<BaseLayout
  title="Articles | BreederHQ"
  description="Founder perspectives, deep-dives on breeding software, and the thinking behind BreederHQ. Long-form writing on breeding programs, data, AI, and the business of responsible breeding."
  breadcrumbs={breadcrumbs}
>
  <main>
    <nav class="breadcrumb py-4 px-4 bg-gray-50" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 max-w-4xl mx-auto text-sm">
        <li><a href="/" class="text-[hsl(24,95%,53%)] hover:underline">Home</a></li>
        <li class="text-gray-400">›</li>
        <li aria-current="page" class="text-gray-600">Articles</li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="bg-gradient-to-b from-stone-50 to-white pt-12 pb-8 px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-5xl font-bold tracking-tight text-gray-900 leading-tight mb-3">
          Articles
        </h1>
        <p class="text-lg text-gray-600 max-w-3xl leading-relaxed">
          Founder perspectives, deep-dives, and the thinking behind BreederHQ. Long-form writing on breeding, data, AI, and the business of responsible breeding.
        </p>
      </div>
    </section>

    <!-- Featured: Founder's Perspective -->
    <section class="pt-4 pb-8 px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <a
          href={`/articles/${featured.slug}`}
          class="block relative rounded-2xl overflow-hidden border-2 border-[hsl(24,95%,53%)] shadow-md hover:shadow-2xl hover:-translate-y-1 transition-all duration-200 group"
          aria-label={`Featured: ${featured.title}`}
        >
          <!-- Accent ribbon -->
          <div class="absolute top-0 left-0 right-0 bg-[hsl(24,95%,53%)] text-white text-center text-xs font-bold uppercase tracking-widest py-2 z-10">
            Featured &middot; Founder&rsquo;s Perspective
          </div>

          <div class="bg-gradient-to-br from-stone-900 via-stone-800 to-stone-900 text-white pt-14 pb-10 px-8 md:px-12">
            <p class="text-xs font-semibold uppercase tracking-wider text-[hsl(24,95%,63%)] mb-4">
              {featured.tag}
            </p>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight mb-5 group-hover:text-[hsl(24,95%,63%)] transition">
              {featured.title}
            </h2>
            <p class="text-lg text-stone-200 leading-relaxed mb-8 max-w-3xl">
              {featured.excerpt}
            </p>
            <div class="flex flex-wrap items-center gap-3 text-sm text-stone-300 border-t border-stone-700 pt-5">
              <div>
                <p class="font-semibold text-white">{featured.author}</p>
                <p class="text-xs text-stone-400">{featured.role}</p>
              </div>
              <span class="text-stone-600">&middot;</span>
              <p>{featured.date}</p>
              <span class="text-stone-600">&middot;</span>
              <p>{featured.readTime}</p>
              <span class="ml-auto inline-flex items-center gap-1 text-[hsl(24,95%,63%)] font-semibold group-hover:gap-2 transition-all">
                Read the essay
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </div>
        </a>
      </div>
    </section>

    <!-- Section divider -->
    <section class="px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <div class="flex items-center gap-4 py-6">
          <div class="flex-1 h-px bg-gray-200"></div>
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-500">More From BreederHQ Editorial</p>
          <div class="flex-1 h-px bg-gray-200"></div>
        </div>
      </div>
    </section>

    <!-- Articles List -->
    <section class="pt-2 pb-16 px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <div class="space-y-6">
          {articles.map(article => (
            <a href={`/articles/${article.slug}`} class="block bg-white rounded-xl border border-gray-300 shadow-sm hover:shadow-lg hover:border-[hsl(24,95%,53%)] hover:-translate-y-0.5 transition-all duration-200 p-8 group">
              <p class="text-xs font-semibold uppercase tracking-wider text-[hsl(24,95%,53%)] mb-3">{article.tag}</p>
              <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3 group-hover:text-[hsl(24,95%,53%)] transition">
                {article.title}
              </h2>
              <p class="text-gray-700 leading-relaxed mb-6">
                {article.excerpt}
              </p>
              <div class="flex items-center gap-3 text-sm text-gray-500 border-t border-gray-200 pt-4">
                <div>
                  <p class="font-semibold text-gray-900">{article.author}</p>
                  <p class="text-xs">{article.role}</p>
                </div>
                <span class="text-gray-300">&middot;</span>
                <p>{article.date}</p>
                <span class="text-gray-300">&middot;</span>
                <p>{article.readTime}</p>
              </div>
            </a>
          ))}
        </div>

        <!-- Coming soon teaser -->
        <div class="mt-12 text-center text-gray-500 text-sm">
          More articles coming soon.
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
