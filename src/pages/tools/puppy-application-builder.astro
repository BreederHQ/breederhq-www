      margin-bottom: 1.25rem;
    }

    .pab-cta-buttons {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    .pab-cta-primary {
      display: inline-block;
      padding: 0.75rem 1.5rem;
      background: hsl(24, 95%, 53%);
      color: #ffffff;
      border-radius: 8px;
      font-weight: 600;
      text-decoration: none;
      min-height: 44px;
      line-height: 1.4;
      transition: background 150ms ease;
    }

    .pab-cta-primary:hover {
      background: hsl(24, 95%, 48%);
    }

    .pab-cta-secondary {
      display: inline-block;
      padding: 0.75rem 1.5rem;
      background: transparent;
      color: hsl(24, 95%, 40%);
      border: 1px solid #d1d5db;
      border-radius: 8px;
      font-weight: 600;
      text-decoration: none;
      min-height: 44px;
      line-height: 1.4;
    }

    .pab-cta-secondary:hover {
      background: #ffffff;
    }

    .pab-ol-num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      background: hsl(24, 95%, 53%);
      color: #ffffff;
      font-weight: 700;
      font-size: 0.9rem;
      margin-right: 0.75rem;
      flex-shrink: 0;
      margin-top: 0.15rem;
    }

    /* FAQ styles (match other cornerstone pages) */
    .faq-item {
      border-bottom: 1px solid #e5e7eb;
      padding: 1.5rem 0;
    }

    .faq-question {
      display: flex;
      justify-content: space-between;
      align-items: center;
      cursor: pointer;
      font-size: 1.25rem;
      font-weight: 600;
      list-style: none;
    }

    .faq-question::-webkit-details-marker {
      display: none;
    }

    .faq-icon {
      transition: transform 200ms ease;
      flex-shrink: 0;
      margin-left: 1rem;
    }

    details[open] .faq-icon {
      transform: rotate(180deg);
    }

    .faq-answer {
      padding-top: 1rem;
      color: #4b5563;
      line-height: 1.6;
    }

    .faq-answer p {
      font-size: 1.125rem;
    }

    /* Print styles */
    @media print {
      .no-print { display: none !important; }
      .breadcrumb,
      .faq-section,
      .pab-cta,
      header,
      footer { display: none !important; }
      .pab-card {
        border: 0;
        box-shadow: none;
        padding: 0;
      }
      .pab-template {
        max-height: none;
        overflow: visible;
        border: 0;
        background: transparent;
        padding: 0;
        font-size: 0.85rem;
      }
    }
  </style>
</BaseLayout>
