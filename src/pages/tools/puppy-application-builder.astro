    @media (min-width: 640px) {
      .pab-options {
        grid-template-columns: 1fr 1fr;
      }
    }

    .pab-option {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      padding: 0.65rem 0.8rem;
      border: 1px solid #e5e7eb;
