      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border-width: 0;
    }

    .pab-card {
      background: #ffffff;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      padding: 2rem;
      box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    }

    .pab-form {
      margin-bottom: 1.5rem;
    }

    .pab-fieldset {
      border: 0;
      padding: 0;
      margin: 0 0 1.25rem;
    }

    .pab-legend {
      display: block;
      font-size: 1.125rem;
      font-weight: 600;
      color: #111827;
      margin-bottom: 0.25rem;
      padding: 0;
    }

    .pab-help {
      font-size: 0.95rem;
      color: #6b7280;
      margin-bottom: 0.75rem;
    }

    .pab-options {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.5rem;
