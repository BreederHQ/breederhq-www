      background: #fafafa;
      cursor: pointer;
      min-height: 44px;
      transition: border-color 150ms ease, background 150ms ease;
    }

    .pab-option:hover {
      border-color: hsl(24, 95%, 70%);
      background: #ffffff;
    }

    .pab-checkbox {
      margin-top: 0.2rem;
      width: 18px;
      height: 18px;
      flex-shrink: 0;
      accent-color: hsl(24, 95%, 53%);
      cursor: pointer;
    }

    .pab-option-text {
      display: flex;
      flex-direction: column;
      line-height: 1.3;
    }

    .pab-option-label {
      font-size: 0.98rem;
      font-weight: 600;
      color: #111827;
    }

    .pab-option-count {
      font-size: 0.8rem;
      color: #6b7280;
      margin-top: 0.1rem;
    }

    .pab-toggle-row {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.9rem;
      color: #6b7280;
    }

    .pab-link-button {
      background: transparent;
      border: 0;
      color: hsl(24, 95%, 40%);
      font-weight: 600;
      cursor: pointer;
      padding: 0.25rem 0;
      font-size: 0.9rem;
    }

    .pab-link-button:hover {
      text-decoration: underline;
    }

    .pab-toggle-sep {
      color: #d1d5db;
    }

    .pab-field {
      margin-bottom: 1.25rem;
    }

    .pab-label {
      display: block;
      font-size: 1.05rem;
      font-weight: 600;
      color: #111827;
      margin-bottom: 0.25rem;
    }

    .pab-optional {
      font-weight: 400;
      font-size: 0.95rem;
      color: #6b7280;
    }

    .pab-input {
      width: 100%;
      max-width: 480px;
      padding: 0.75rem 1rem;
      border: 1px solid #d1d5db;
      border-radius: 8px;
      font-size: 1rem;
      color: #111827;
      background: #ffffff;
      min-height: 44px;
    }

    .pab-input:focus {
      outline: 2px solid hsl(24, 95%, 53%);
      outline-offset: 1px;
    }

    .pab-results {
      border-top: 1px solid #e5e7eb;
      padding-top: 1.5rem;
    }

    .pab-results-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 1.25rem;
      flex-wrap: wrap;
    }

    .pab-results-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: #111827;
      margin-bottom: 0.25rem;
    }

    .pab-results-subtitle {
      color: #6b7280;
      font-size: 0.95rem;
      max-width: 540px;
    }

    .pab-results-actions {
      display: flex;
