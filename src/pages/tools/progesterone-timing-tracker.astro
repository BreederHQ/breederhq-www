---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Tools', url: '/tools' },
  { name: 'Progesterone Timing Tracker', url: '/tools/progesterone-timing-tracker' }
];

const lastReviewedISO = '2026-05-16';

const faqs = [
  {
    question: 'What does this progesterone tracker actually do?',
    answer: 'You enter the first day of heat and your progesterone test results as they come back. The tool plots them on a trend chart, estimates the LH surge date (where P4 crossed ~2 ng/mL), estimates the ovulation date (where P4 crossed ~5 ng/mL), and projects a breeding window based on method (natural, fresh chilled, or frozen). With only a couple of readings these are interpolated estimates that refine as you add more data. It is a planning and visualization aid built around standard canine reproductive ranges. It is not a veterinary diagnostic, and your reproductive vet is the source of truth on the actual breeding date.'
  },
  {
    question: 'What do the progesterone ranges mean?',
    answer: 'Under 1 ng/mL is generally considered baseline or very early in the cycle. Around 2 ng/mL is the range where the LH surge often occurs in dogs. Roughly 4 to 10 ng/mL is the range where ovulation commonly happens. Above that, the eggs continue maturing and become fertilizable a few days after ovulation. These are general framing values, not decision thresholds. Different labs, sample handling, and individual dams all shift the numbers. Your reproductive vet is the source of truth on what your specific results mean.'
  },
  {
    question: 'Why does the tool not just tell me when to breed?',
    answer: 'Because that is a veterinary judgment call, not a calculator output. The optimal breeding day depends on the progesterone trend across multiple draws, the breeding method (natural, fresh chilled, or frozen), the male\u2019s availability, the lab\u2019s reference ranges, and any history specific to your dam. A single number out of context is not enough. The tool surfaces the trend and the general interpretation. Your vet decides the timing.'
  },
  {
    question: 'How does breeding method change the timing?',
    answer: 'Natural breedings are forgiving, since live cover spans several days and sperm survive in the reproductive tract. Fresh chilled semen is less forgiving and is typically used closer to peak fertility. Frozen semen is the most timing-sensitive, since thawed sperm have a very short lifespan and need to be deposited very close to the fertile window, often via surgical or trans-cervical insemination. The tracker lets you note the method so your vet has full context, but the actual timing decision still comes from your repro vet.'
  },
  {
    question: 'How many tests should I run during a cycle?',
    answer: 'Most programs start with a baseline draw early in proestrus and then test every two to three days, tightening to daily as values rise. Frozen-semen cycles tend to test more often to catch the LH surge precisely. Your repro vet will recommend a cadence based on the trend they are seeing. The tracker can hold as many readings as you log.'
  },
  {
    question: 'Does this tool save my data?',
    answer: 'No. Everything you enter stays in your browser tab and disappears when you close it. Nothing is sent to a server, nothing is saved to an account, and nothing is shared. If you want to keep a progesterone history per dam across cycles, log the values in BreederHQ. That way they live alongside her heat cycle history, breeding records, and litter outcomes for next time.'
  }
];

const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  '@id': 'https://breederhq.com/tools/progesterone-timing-tracker#tool',
  'name': 'Progesterone Timing Tracker for Dogs',
  'description': 'Free progesterone timing tracker for dog breeders. Enter the first day of heat and your P4 test results to visualize the trend, see general interpretation language, and bring organized data to your reproductive vet. Educational planning tool only. Not veterinary advice.',
  'url': 'https://breederhq.com/tools/progesterone-timing-tracker',
  'applicationCategory': 'BusinessApplication',
  'applicationSubCategory': 'Dog Breeding Calculator',
  'operatingSystem': 'Any (web browser)',
  'browserRequirements': 'Requires JavaScript. Requires HTML5.',
  'offers': {
    '@type': 'Offer',
    'price': '0',
    'priceCurrency': 'USD'
  },
  'publisher': {
    '@id': 'https://breederhq.com/#organization'
  },
  'isPartOf': {
    '@id': 'https://breederhq.com/tools#collection'
  },
  'datePublished': lastReviewedISO,
  'dateModified': lastReviewedISO,
  'featureList': [
    'Log progesterone (P4) test results in cycle order',
    'Visualize the P4 trend across readings',
    'Tag readings with day of cycle relative to heat start',
    'Show general interpretation bands (baseline, LH surge, ovulation, maturation)',
    'Optional breeding method context (natural, fresh chilled, frozen, not sure)',
    'Anonymous, no signup, no data saved'
  ]
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  'headline': 'Progesterone Timing Tracker for Dogs',
  'description': 'Free progesterone timing tracker for dog breeders. Log P4 results, visualize the trend, and bring organized data to your reproductive vet.',
  'datePublished': lastReviewedISO,
  'dateModified': lastReviewedISO,
  'author': {
    '@id': 'https://breederhq.com/#organization'
  },
  'publisher': {
    '@id': 'https://breederhq.com/#organization'
  },
  'mainEntityOfPage': 'https://breederhq.com/tools/progesterone-timing-tracker'
};
---

<BaseLayout
  title="Free Progesterone Timing Tracker for Dogs | BreederHQ"
  description="Free progesterone timing tracker for dog breeders. Log P4 test results, see the trend across readings, and bring organized data to your reproductive vet. Educational planning tool. Not veterinary advice."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(softwareAppSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
    Skip to content
  </a>

  <main id="main-content">
  <nav class="breadcrumb py-4 px-4 bg-gray-50" aria-label="Breadcrumb">
    <ol class="flex items-center space-x-2 max-w-4xl mx-auto text-sm">
      <li><a href="/" class="text-[hsl(24,95%,53%)] hover:underline">Home</a></li>
      <li class="text-gray-400">›</li>
      <li><a href="/tools" class="text-[hsl(24,95%,53%)] hover:underline">Tools</a></li>
      <li class="text-gray-400">›</li>
      <li aria-current="page" class="text-gray-600">Progesterone Timing Tracker</li>
    </ol>
  </nav>

  <!-- Intro -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-bold mb-6">Progesterone Timing Tracker for Dogs</h1>
      <p class="text-sm text-gray-500 mb-6">
        <strong class="text-gray-700">Last Reviewed: May 16, 2026.</strong> Built and reviewed by the BreederHQ Operations Team, working with active dog breeders and reproductive veterinarians.
      </p>
      <p class="text-xl text-gray-700 leading-relaxed">
        Log your P4 results in cycle order, see the trend across readings, and bring organized data to your reproductive vet. This is a planning and visualization tool, not a veterinary diagnostic. The actual breeding decision belongs to your vet, working from the full P4 trend and your dam&rsquo;s history.
      </p>

      <div class="ptt-banner-disclaimer">
        <strong>Important.</strong> This tracker does not replace progesterone interpretation by a veterinarian. Lab assays, sample handling, and individual dams all shift the numbers. Treat all guidance here as general framing. Your reproductive vet is the source of truth on what your specific results mean and when to breed.
      </div>
    </div>
  </section>

  <!-- The Tracker -->
  <section class="px-4 pb-8">
    <div class="max-w-4xl mx-auto">
      <div class="ptt-card">
        <div class="ptt-card-header">
          <div class="ptt-card-header-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17l6-6 4 4 8-8"/><path d="M14 7h7v7"/></svg>
          </div>
          <div>
            <div class="ptt-card-header-title">Log a Progesterone Cycle</div>
            <div class="ptt-card-header-sub">Anchor with the heat-start date, then add P4 readings as they come back from the lab.</div>
          </div>
        </div>

        <form id="ptt-form" class="ptt-form" novalidate>
          <div class="ptt-grid-two">
            <div class="ptt-field">
              <label for="ptt-heat-start" class="ptt-label">First Day of Heat <span aria-hidden="true" class="ptt-req">*</span></label>
              <p class="ptt-help">The day you first noticed swelling, spotting, or behavior change. This becomes Day 1.</p>
              <input
                type="date"
                id="ptt-heat-start"
                name="heat-start"
                class="ptt-input"
                required
              />
            </div>

            <div class="ptt-field">
              <label for="ptt-method" class="ptt-label">Breeding Method <span class="ptt-optional">(optional)</span></label>
              <p class="ptt-help">Phrases the general timing context. Your vet still decides the actual day.</p>
              <div class="ptt-select-wrap">
                <select id="ptt-method" name="method" class="ptt-input ptt-select">
                  <option value="unsure">Not sure yet</option>
                  <option value="natural">Natural (live cover)</option>
                  <option value="fresh-chilled">Fresh chilled semen</option>
                  <option value="frozen">Frozen semen</option>
                </select>
              </div>
            </div>
          </div>

          <fieldset class="ptt-rows-fieldset">
            <div class="ptt-rows-header">
              <div>
                <legend class="ptt-label ptt-rows-legend">Progesterone Test Results</legend>
                <p class="ptt-help">One row per test. Date of draw and P4 value in ng/mL.</p>
              </div>
              <button type="button" id="ptt-add-row" class="ptt-button-secondary">
                <span aria-hidden="true" class="ptt-plus">+</span>
                <span>Add Test Row</span>
              </button>
            </div>

            <div id="ptt-rows" class="ptt-rows" role="group" aria-label="Progesterone test rows">
              <!-- Rows injected by script -->
            </div>
          </fieldset>

          <div class="ptt-form-actions">
            <button type="submit" class="ptt-button">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12l5 5L20 7"/></svg>
              <span>Update Timeline</span>
            </button>
          </div>

          <p id="ptt-error" class="ptt-error" role="alert" hidden></p>
        </form>

        <div id="ptt-results" class="ptt-results" hidden aria-live="polite">
          <h2 class="ptt-results-title">Cycle Projection</h2>
          <p class="ptt-results-subtitle">Estimated based on your P4 trend and standard canine reproductive ranges. Your reproductive vet decides actual breeding timing.</p>

          <div class="ptt-projection-wrap">
            <h3 class="ptt-section-title ptt-section-title--inset">Projection Cards</h3>
            <div id="ptt-projection" class="ptt-projection">
              <!-- Projection cards injected by script -->
            </div>
          </div>

          <div id="ptt-chart-wrap" class="ptt-chart-wrap">
            <h3 class="ptt-section-title">Trend Chart</h3>
            <div id="ptt-chart" class="ptt-chart" role="img" aria-label="Progesterone trend chart">
              <!-- SVG injected by script -->
            </div>
            <div class="ptt-chart-legend">
              <span class="ptt-legend-item"><span class="ptt-legend-dot ptt-legend-baseline"></span>Baseline (under 1)</span>
              <span class="ptt-legend-item"><span class="ptt-legend-dot ptt-legend-lh"></span>LH surge range (~2)</span>
              <span class="ptt-legend-item"><span class="ptt-legend-dot ptt-legend-ovulation"></span>Ovulation range (4-10)</span>
              <span class="ptt-legend-item"><span class="ptt-legend-dot ptt-legend-maturation"></span>Maturation (10+)</span>
            </div>
          </div>

          <div class="ptt-timeline-wrap">
            <h3 class="ptt-section-title ptt-section-title--inset">Reading Detail</h3>
            <div id="ptt-timeline" class="ptt-timeline">
              <!-- Timeline rows injected by script -->
            </div>
          </div>

          <div class="ptt-summary" id="ptt-summary">
            <!-- Trend summary injected by script -->
          </div>

          <div class="ptt-bands">
            <h3 class="ptt-bands-title">General Interpretation Bands</h3>
            <ul class="ptt-bands-list">
              <li><strong>Under 1 ng/mL.</strong> Baseline. Often early in the cycle, before things start moving.</li>
              <li><strong>Around 2 ng/mL.</strong> LH surge often occurs in this general range. Watch closely from here.</li>
              <li><strong>Roughly 4 to 10 ng/mL.</strong> Ovulation commonly occurs in this range. Eggs need time to mature after ovulation.</li>
              <li><strong>Higher values.</strong> Continued maturation. Optimal breeding window depends on method and the full P4 trend, which is a veterinary call.</li>
            </ul>
            <p class="ptt-bands-note">These are general framing values, not decision thresholds. Defer to your reproductive vet on what your specific numbers mean.</p>
          </div>

          <div class="ptt-disclaimer">
            <strong>Important.</strong> This is an educational planning tool. It does not replace progesterone interpretation by a veterinarian. Use your vet&rsquo;s reading of the full trend, lab reference ranges, and your dam&rsquo;s history as the source of truth on timing.
          </div>

          <div class="ptt-cta">
            <p class="ptt-cta-text">
              Want this trend saved alongside the dam&rsquo;s heat history, breeding records, and litter outcomes? BreederHQ keeps progesterone readings per cycle, per dam, so next year&rsquo;s planning starts with real history instead of a blank page.
            </p>
            <div class="ptt-cta-buttons">
              <a href="https://accounts.breederhq.com/register?intent=breeder_dashboard" class="ptt-cta-primary">
                Track Cycles in BreederHQ Free
              </a>
              <a href="/progesterone-testing-dogs" class="ptt-cta-secondary">
                Learn About Progesterone Testing →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How to Use -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-6">How to Use This Tracker</h2>
      <ol class="space-y-4 text-lg text-gray-700">
        <li class="flex items-start">
          <span class="ptt-ol-num">1</span>
          <span><strong>Set the first day of heat.</strong> That anchors the day-of-cycle on every reading. If you&rsquo;re between two possible dates, use the earlier one.</span>
        </li>
        <li class="flex items-start">
          <span class="ptt-ol-num">2</span>
          <span><strong>Add each test result.</strong> Enter the date of the draw and the P4 value in ng/mL. Add a new row for each test as they come back.</span>
        </li>
        <li class="flex items-start">
          <span class="ptt-ol-num">3</span>
          <span><strong>Read the trend, not a single number.</strong> Direction and rate of change matter more than any one value. The timeline shows readings in cycle order so the trend is visible at a glance.</span>
        </li>
        <li class="flex items-start">
          <span class="ptt-ol-num">4</span>
          <span><strong>Share the trend with your vet.</strong> Optimal breeding timing is a veterinary judgment call based on the full trend, the method, and your dam&rsquo;s history. Bring the data, let them call the day.</span>
        </li>
      </ol>
    </div>
  </section>

  <!-- Interpretation Detail -->
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-8">What the Numbers Generally Mean</h2>

      <div class="space-y-6">
        <div>
          <h3 class="text-2xl font-bold mb-2">Baseline (Under 1 ng/mL)</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Early in the cycle. Often consistent with proestrus or the start of testing. The job here is to establish a baseline, not to decide anything yet.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-2">LH Surge Range (Around 2 ng/mL)</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Values often consistent with the LH surge in dogs. This is the point most repro vets use as a reference for counting forward to peak fertility. Sample cadence usually tightens to daily here.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-2">Ovulation Range (Roughly 4 to 10 ng/mL)</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Values commonly consistent with ovulation. The eggs released still need to mature before they are fertilizable, which is why optimal breeding usually comes a couple of days after ovulation, not on the same day.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-2">Post-Ovulation Maturation (Higher Values)</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Continued rise. Timing within this window depends heavily on method (natural vs fresh chilled vs frozen) and on the full P4 trend leading in. This is where your reproductive vet earns their fee.
          </p>
        </div>
      </div>

      <div class="mt-8 text-base text-gray-600 leading-relaxed">
        Values, units, and reference ranges vary by lab assay and by sample handling. A 5 ng/mL on one assay is not always equivalent to a 5 on another. Use the trend across multiple readings from the same lab, and let your vet calibrate to that lab&rsquo;s reference ranges.
      </div>
    </div>
  </section>

  <!-- Method-specific framing -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-6">How Method Changes the Conversation</h2>
      <div class="space-y-5 text-lg text-gray-700 leading-relaxed">
        <p>
          <strong>Natural breeding.</strong> The most forgiving. Live cover typically spans several days, and viable sperm persist in the reproductive tract for a meaningful window. Most repro vets are comfortable with a wider day-range here.
        </p>
        <p>
          <strong>Fresh chilled semen.</strong> Less forgiving. Sperm motility and viability drop with chilling and transport time. Timing usually targets a tighter window closer to peak fertility.
        </p>
        <p>
          <strong>Frozen semen.</strong> The most timing-sensitive. Thawed frozen sperm have a short lifespan, often only hours. Cycles using frozen typically test more often, and inseminations are often surgical or trans-cervical, placed close to the fertile peak.
        </p>
        <p>
          <strong>Not sure yet.</strong> That&rsquo;s fine. Test, log the trend, and discuss method with your vet alongside the data. You don&rsquo;t need to have method decided to start tracking.
        </p>
      </div>
    </div>
  </section>

  <!-- Why this isn't a breeding decision tool -->
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-6">Why This Isn&rsquo;t a Breeding Decision Tool</h2>
      <p class="text-lg text-gray-700 leading-relaxed mb-4">
        Optimal breeding timing depends on the shape of the entire P4 curve, the rate of change between draws, the lab&rsquo;s reference ranges, the method, the male&rsquo;s availability, and anything specific to this dam&rsquo;s history. A single number, or even a calculator&rsquo;s opinion, cannot replace that.
      </p>
      <p class="text-lg text-gray-700 leading-relaxed mb-4">
        The job of this tracker is to make the trend visible and the data organized. The job of your reproductive vet is to interpret it and call the day. Treat your vet&rsquo;s interpretation as the source of truth.
      </p>
      <p class="text-lg text-gray-700 leading-relaxed">
        Read more in <a href="/progesterone-testing-dogs" class="text-[hsl(24,95%,53%)] hover:underline">Progesterone Testing in Dogs</a> and the <a href="/heat-cycle-tracking" class="text-[hsl(24,95%,53%)] hover:underline">Heat Cycle Tracking guide</a>.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 px-4 faq-section bg-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-12">Frequently Asked Questions</h2>

      {faqs.map((faq) => (
        <details class="faq-item">
          <summary class="faq-question">
            <span>{faq.question}</span>
            <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </summary>
          <div class="faq-answer">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- Related -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold mb-6">Related Resources</h2>
      <div class="space-y-3 text-lg">
        <div>
          <a href="/progesterone-testing-dogs" class="text-[hsl(24,95%,53%)] hover:underline">
            → Progesterone Testing in Dogs
          </a>
        </div>
        <div>
          <a href="/heat-cycle-tracking" class="text-[hsl(24,95%,53%)] hover:underline">
            → Heat Cycle Tracking, Explained
          </a>
        </div>
        <div>
          <a href="/dog-heat-cycle-calculator" class="text-[hsl(24,95%,53%)] hover:underline">
            → Dog Heat Cycle Calculator (Educational Guide)
          </a>
        </div>
        <div>
          <a href="/tools/heat-cycle-calculator" class="text-[hsl(24,95%,53%)] hover:underline">
            → Free Heat Cycle Calculator
          </a>
        </div>
        <div>
          <a href="/dog-breeding-software" class="text-[hsl(24,95%,53%)] hover:underline">
            → Dog Breeding Software Overview
          </a>
        </div>
        <div>
          <a href="/tools" class="text-[hsl(24,95%,53%)] hover:underline">
            → All Free Tools
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sticky Mobile CTA -->
  <div class="fixed bottom-0 left-0 right-0 p-4 bg-white border-t-2 border-gray-200 shadow-lg md:hidden z-50">
    <a href="https://accounts.breederhq.com/register?intent=breeder_dashboard" class="block w-full text-center bg-[hsl(24,95%,53%)] text-white px-6 py-4 rounded-lg font-bold text-lg hover:bg-[hsl(24,95%,48%)] transition" style="min-height: 44px;">
      Track Cycles in BreederHQ Free
    </a>
  </div>
  </main>

  <script is:inline>
    (function () {
      var form = document.getElementById('ptt-form');
      var heatInput = document.getElementById('ptt-heat-start');
      var methodInput = document.getElementById('ptt-method');
      var rowsEl = document.getElementById('ptt-rows');
      var addRowBtn = document.getElementById('ptt-add-row');
      var error = document.getElementById('ptt-error');
      var results = document.getElementById('ptt-results');
      var timelineEl = document.getElementById('ptt-timeline');
      var summaryEl = document.getElementById('ptt-summary');
      var projectionEl = document.getElementById('ptt-projection');
      var chartEl = document.getElementById('ptt-chart');
      var chartWrapEl = document.getElementById('ptt-chart-wrap');
      if (!form || !heatInput || !rowsEl || !addRowBtn || !error || !results || !timelineEl || !summaryEl || !projectionEl || !chartEl || !chartWrapEl) return;

      var rowSeq = 0;

      try {
        var today = new Date();
        var iso = today.toISOString().slice(0, 10);
        heatInput.max = iso;
      } catch (e) { /* noop */ }

      function renumberRows() {
        var all = rowsEl.querySelectorAll('.ptt-row');
        for (var i = 0; i < all.length; i++) {
          var chip = all[i].querySelector('.ptt-row-num');
          if (chip) chip.textContent = String(i + 1);
        }
      }

      function addRow(prefillDate, prefillValue) {
        rowSeq += 1;
        var id = 'ptt-row-' + rowSeq;
        var wrap = document.createElement('div');
        wrap.className = 'ptt-row';
        wrap.setAttribute('data-row-id', id);
        wrap.setAttribute('style',
          'display:flex;flex-direction:row;align-items:flex-end;gap:0.75rem;' +
          'background:#ffffff;border:1px solid #e5e7eb;border-radius:10px;' +
          'padding:0.85rem 0.9rem;flex-wrap:nowrap;'
        );

        var numStyle =
          'display:inline-flex;align-items:center;justify-content:center;' +
          'width:28px;height:28px;border-radius:50%;background:hsl(24,95%,95%);' +
          'color:hsl(24,95%,40%);font-weight:700;font-size:0.85rem;flex-shrink:0;' +
          'line-height:1;margin-bottom:6px;';

        var fieldStyle = 'display:flex;flex-direction:column;flex:1 1 0;min-width:0;margin:0;';

        var labelStyle =
          'display:block;font-size:0.7rem;font-weight:700;color:#6b7280;' +
          'margin:0 0 0.3rem 0;text-transform:uppercase;letter-spacing:0.05em;line-height:1.2;';

        var inputStyle =
          'display:block;width:100%;padding:0.55rem 0.7rem;border:1px solid #d1d5db;' +
          'border-radius:8px;font-size:0.95rem;color:#111827;background:#ffffff;' +
          'min-height:40px;box-sizing:border-box;font-family:inherit;';

        var trashStyle =
          'display:inline-flex;align-items:center;justify-content:center;' +
          'width:36px;height:36px;padding:0;background:#ffffff;color:#b91c1c;' +
          'border:1px solid #fecaca;border-radius:8px;cursor:pointer;' +
          'flex-shrink:0;margin:0 0 2px 0;';

        wrap.innerHTML =
          '<span class="ptt-row-num" style="' + numStyle + '" aria-hidden="true">1</span>' +
          '<div class="ptt-row-field" style="' + fieldStyle + '">' +
          '  <label class="ptt-row-label" style="' + labelStyle + '" for="' + id + '-date">Test Date</label>' +
          '  <input type="date" id="' + id + '-date" class="ptt-row-date" style="' + inputStyle + '" />' +
          '</div>' +
          '<div class="ptt-row-field" style="' + fieldStyle + '">' +
          '  <label class="ptt-row-label" style="' + labelStyle + '" for="' + id + '-value">P4 (ng/mL)</label>' +
          '  <input type="number" min="0" step="0.1" id="' + id + '-value" class="ptt-row-value" style="' + inputStyle + '" placeholder="e.g. 2.3" inputmode="decimal" />' +
          '</div>' +
          '<button type="button" class="ptt-row-remove" style="' + trashStyle + '" aria-label="Remove row" title="Remove row">' +
          '  <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
          '    <polyline points="3 6 5 6 21 6"/>' +
          '    <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>' +
          '    <path d="M10 11v6"/>' +
          '    <path d="M14 11v6"/>' +
          '    <path d="M9 6V4a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v2"/>' +
          '  </svg>' +
          '</button>';

        var dateEl = wrap.querySelector('.ptt-row-date');
        var valEl = wrap.querySelector('.ptt-row-value');
        if (prefillDate && dateEl) dateEl.value = prefillDate;
        if (prefillValue != null && valEl) valEl.value = String(prefillValue);

        var removeBtn = wrap.querySelector('.ptt-row-remove');
        removeBtn.addEventListener('click', function () {
          if (wrap.parentNode) wrap.parentNode.removeChild(wrap);
          renumberRows();
        });

        rowsEl.appendChild(wrap);
        renumberRows();
      }

      // Seed with one empty row
      addRow();

      addRowBtn.addEventListener('click', function () {
        addRow();
      });

      function parseLocalDate(str) {
        if (!str) return null;
        var parts = str.split('-');
        if (parts.length !== 3) return null;
        var y = parseInt(parts[0], 10);
        var m = parseInt(parts[1], 10) - 1;
        var d = parseInt(parts[2], 10);
        var dt = new Date(y, m, d);
        if (isNaN(dt.getTime())) return null;
        return dt;
      }

      function diffDays(a, b) {
        var ms = a.getTime() - b.getTime();
        return Math.round(ms / 86400000);
      }

      function fmtDate(date) {
        try {
          return date.toLocaleDateString(undefined, {
            weekday: 'short',
            year: 'numeric',
            month: 'short',
            day: 'numeric'
          });
        } catch (e) {
          return date.toDateString();
        }
      }

      function classifyValue(v) {
        if (v < 1) return { band: 'baseline', label: 'Baseline range', note: 'Often early in the cycle.' };
        if (v < 2.5) return { band: 'lh', label: 'LH surge range', note: 'Often consistent with the LH surge in dogs. Cadence typically tightens here.' };
        if (v <= 10) return { band: 'ovulation', label: 'Ovulation range', note: 'Commonly consistent with ovulation. Eggs need time to mature.' };
        return { band: 'maturation', label: 'Post-ovulation maturation', note: 'Continued rise. Optimal breeding window depends on method and full trend, a veterinary call.' };
      }

      function methodLanguage(method) {
        if (method === 'natural') {
          return 'With natural breeding, timing is generally the most forgiving. Your vet may suggest a wider day-range based on the full trend.';
        }
        if (method === 'fresh-chilled') {
          return 'With fresh chilled semen, timing is tighter. Your vet will usually aim for a narrower window closer to peak fertility, based on the full trend.';
        }
        if (method === 'frozen') {
          return 'With frozen semen, timing is the most critical. Your vet will usually want frequent draws and may place insemination close to the fertile peak.';
        }
        return 'Once method is decided (natural, fresh chilled, or frozen), your vet will narrow the suggested window. The trend you log here is the input for that decision.';
      }

      function escapeHtml(s) {
        return String(s)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function buildSummary(readings, method) {
        if (readings.length === 0) {
          return '<p class="ptt-summary-text">No test results entered yet. Add a row and update the timeline.</p>';
        }

        var first = readings[0];
        var last = readings[readings.length - 1];
        var direction = 'flat';
        if (readings.length >= 2) {
          if (last.value > first.value + 0.2) direction = 'rising';
          else if (last.value < first.value - 0.2) direction = 'falling';
        }

        var lastClass = classifyValue(last.value);
        var guidance = '';

        if (lastClass.band === 'baseline') {
          guidance = 'The latest reading is still in the baseline range. Cycle may be approaching the LH surge but is not there yet. Continue per your vet&rsquo;s recommended cadence.';
        } else if (lastClass.band === 'lh') {
          guidance = 'The latest reading is in the LH surge range. Many programs tighten test cadence to daily from this point. Discuss next-step timing with your vet.';
        } else if (lastClass.band === 'ovulation') {
          guidance = 'The latest reading is in the range often consistent with ovulation. Optimal breeding timing usually comes a couple of days after ovulation, but the actual day is your vet&rsquo;s call.';
        } else {
          guidance = 'The latest reading is in the post-ovulation maturation range. Eggs are typically fertilizable in this window for a limited time. Discuss timing with your vet based on method.';
        }

        var trendNote = '';
        if (readings.length === 1) {
          trendNote = 'Only one reading logged so far. Trend becomes more informative with additional draws over the next few days.';
        } else if (direction === 'rising') {
          trendNote = 'P4 has risen across logged readings. Trend direction is consistent with cycle progression.';
        } else if (direction === 'falling') {
          trendNote = 'P4 appears to have dropped between readings. Recheck sample handling, lab, and timing with your vet. Drops mid-cycle can also reflect lab assay variation.';
        } else {
          trendNote = 'P4 has been relatively flat across readings. May still be early. Discuss cadence with your vet.';
        }

        var headingStyle =
          'display:flex;align-items:center;gap:0.6rem;' +
          'font-size:1.15rem;font-weight:800;color:#111827;' +
          'letter-spacing:-0.01em;margin:0 0 0.85rem 0;padding:0;line-height:1.2;';

        var accentStyle =
          'display:inline-block;width:3px;height:18px;border-radius:2px;' +
          'background:hsl(24,95%,53%);flex-shrink:0;';

        var paraStyle =
          'display:block;color:#1f2937;line-height:1.6;font-size:1rem;' +
          'margin:0 0 0.6rem 0;padding:0;';

        var vetParaStyle = paraStyle + 'padding-top:0.6rem;border-top:1px solid #e5e7eb;margin-bottom:0;';

        return (
          '<h3 style="' + headingStyle + '"><span style="' + accentStyle + '" aria-hidden="true"></span>Trend Summary</h3>' +
          '<p style="' + paraStyle + '"><strong>Latest reading:</strong> ' + escapeHtml(last.value.toFixed(1)) + ' ng/mL on ' + escapeHtml(fmtDate(last.date)) + ' (Day ' + last.day + '). ' + escapeHtml(lastClass.label) + '.</p>' +
          '<p style="' + paraStyle + '">' + escapeHtml(trendNote) + '</p>' +
          '<p style="' + paraStyle + '">' + escapeHtml(guidance) + '</p>' +
          '<p style="' + paraStyle + '"><strong>Method context.</strong> ' + escapeHtml(methodLanguage(method)) + '</p>' +
          '<p style="' + vetParaStyle + '"><strong>Suggested next action.</strong> Share this trend with your reproductive vet. Your vet&rsquo;s interpretation of the full curve is the source of truth on when to breed.</p>'
        );
      }

      // Method-specific breeding window math, measured in days from ovulation estimate
      function breedingWindowDays(method) {
        if (method === 'natural') return { startOffset: 2, endOffset: 5, label: 'Natural (live cover)' };
        if (method === 'fresh-chilled') return { startOffset: 3, endOffset: 5, label: 'Fresh chilled semen' };
        if (method === 'frozen') return { startOffset: 4, endOffset: 6, label: 'Frozen semen' };
        return { startOffset: 2, endOffset: 6, label: 'Method not selected' };
      }

      // Linear interpolation across the trend to estimate the date when P4 first crossed a threshold.
      function crossingDate(readings, threshold) {
        for (var i = 0; i < readings.length; i++) {
          if (readings[i].value >= threshold) {
            if (i === 0) {
              return { date: readings[i].date, day: readings[i].day, exact: true, atOrBefore: true };
            }
            var prev = readings[i - 1];
            var curr = readings[i];
            if (curr.value === prev.value) {
              return { date: curr.date, day: curr.day, exact: true, atOrBefore: false };
            }
            var frac = (threshold - prev.value) / (curr.value - prev.value);
            if (frac < 0) frac = 0;
            if (frac > 1) frac = 1;
            var dayDelta = (curr.day - prev.day) * frac;
            var estDay = prev.day + dayDelta;
            var estMs = prev.date.getTime() + (curr.date.getTime() - prev.date.getTime()) * frac;
            return { date: new Date(estMs), day: Math.round(estDay), exact: false, atOrBefore: false };
          }
        }
        return null;
      }

      function addDays(date, n) {
        var d = new Date(date.getTime());
        d.setDate(d.getDate() + Math.round(n));
        return d;
      }

      function buildProjection(readings, method) {
        if (readings.length === 0) {
          return '<div style="padding:1rem;background:#f9fafb;border:1px dashed #e5e7eb;border-radius:8px;color:#6b7280;text-align:center;">Add at least one P4 reading to see a projection.</div>';
        }

        var lhEst = crossingDate(readings, 2);
        var ovuEst = crossingDate(readings, 5);
        var last = readings[readings.length - 1];
        var win = breedingWindowDays(method);

        var cardBase =
          'display:flex;flex-direction:column;gap:0.4rem;' +
          'padding:1rem 1.15rem 1rem 1.4rem;border-radius:12px;' +
          'border-width:1px;border-style:solid;background:#ffffff;' +
          'box-shadow:0 1px 3px rgba(17,24,39,0.05);' +
          'position:relative;overflow:hidden;';

        var accentBase =
          'position:absolute;top:0;left:0;bottom:0;width:5px;display:block;';

        var labelStyle =
          'display:block;font-size:0.72rem;font-weight:800;color:#6b7280;' +
          'text-transform:uppercase;letter-spacing:0.08em;margin:0 0 0.2rem 0;' +
          'padding:0;line-height:1.2;';

        var valueStyle =
          'display:block;font-size:1.2rem;font-weight:800;color:#111827;' +
          'line-height:1.25;letter-spacing:-0.01em;margin:0 0 0.25rem 0;padding:0;';

        var noteStyle =
          'display:block;font-size:0.875rem;color:#4b5563;line-height:1.5;' +
          'margin:0;padding:0;';

        function card(variant, labelText, valueText, noteText) {
          var bg, border, accent;
          if (variant === 'lh') {
            bg = 'linear-gradient(180deg,#fffbeb 0%,#ffffff 70%)';
            border = '#fde68a';
            accent = '#f59e0b';
          } else if (variant === 'ovulation') {
            bg = 'linear-gradient(180deg,#f0fdf4 0%,#ffffff 70%)';
            border = '#bbf7d0';
            accent = '#16a34a';
          } else if (variant === 'window') {
            bg = 'linear-gradient(180deg,hsl(24,95%,96%) 0%,#ffffff 70%)';
            border = 'hsl(24,95%,80%)';
            accent = 'hsl(24,95%,53%)';
          } else {
            bg = '#f9fafb';
            border = '#e5e7eb';
            accent = '#d1d5db';
          }
          var cardStyle = cardBase + 'background:' + bg + ';border-color:' + border + ';' +
            (variant === 'pending' ? 'border-style:dashed;' : '');
          var accentStyle = accentBase + 'background:' + accent + ';';
          return (
            '<div style="' + cardStyle + '">' +
            '<span style="' + accentStyle + '" aria-hidden="true"></span>' +
            '<h4 style="' + labelStyle + '">' + escapeHtml(labelText) + '</h4>' +
            '<div style="' + valueStyle + '">' + valueText + '</div>' +
            '<div style="' + noteStyle + '">' + noteText + '</div>' +
            '</div>'
          );
        }

        var lhBlock, ovuBlock, winBlock;

        if (lhEst) {
          var lhPrefix = lhEst.atOrBefore ? 'On or before ' : 'Estimated ';
          var lhExactNote = lhEst.exact ? '' : ' (interpolated)';
          lhBlock = card('lh', 'LH surge estimate',
            escapeHtml(fmtDate(lhEst.date)),
            escapeHtml(lhPrefix) + 'P4 crossed ~2 ng/mL near Day ' + lhEst.day + escapeHtml(lhExactNote) + '.'
          );
        } else {
          lhBlock = card('pending', 'LH surge estimate', 'Not reached yet',
            'Latest reading is ' + escapeHtml(last.value.toFixed(1)) + ' ng/mL. Watch for the cross near ~2 ng/mL.'
          );
        }

        if (ovuEst) {
          var ovuPrefix = ovuEst.atOrBefore ? 'On or before ' : 'Estimated ';
          var ovuExactNote = ovuEst.exact ? '' : ' (interpolated)';
          ovuBlock = card('ovulation', 'Ovulation estimate',
            escapeHtml(fmtDate(ovuEst.date)),
            escapeHtml(ovuPrefix) + 'P4 crossed ~5 ng/mL near Day ' + ovuEst.day + escapeHtml(ovuExactNote) + '.'
          );
        } else {
          ovuBlock = card('pending', 'Ovulation estimate', 'Not reached yet',
            'Watch for P4 to cross ~5 ng/mL. Eggs mature for ~2 days after ovulation.'
          );
        }

        if (ovuEst) {
          var winStart = addDays(ovuEst.date, win.startOffset);
          var winEnd = addDays(ovuEst.date, win.endOffset);
          winBlock = card('window', 'Projected breeding window',
            escapeHtml(fmtDate(winStart)) + ' to ' + escapeHtml(fmtDate(winEnd)),
            escapeHtml(win.label) + '. Day ' + win.startOffset + ' to Day ' + win.endOffset + ' post-ovulation, when eggs are typically fertilizable. Your vet sets the actual day.'
          );
        } else {
          winBlock = card('pending', 'Projected breeding window', 'Pending ovulation',
            'Once P4 crosses ~5 ng/mL the window projects from there. ' + escapeHtml(win.label) + '.'
          );
        }

        var cardsGridStyle =
          'display:grid;grid-template-columns:1fr 1fr 1fr;' +
          'gap:0.85rem;margin:0 0 0.85rem 0;';

        var caveatStyle =
          'display:block;width:100%;box-sizing:border-box;' +
          'padding:1rem 1.15rem;background:#fffbeb;' +
          'border:1px solid #fde68a;border-radius:10px;' +
          'color:#78350f;font-size:0.875rem;line-height:1.55;margin:0;';

        var caveat =
          '<div style="' + caveatStyle + '">' +
          '<strong>How these estimates work.</strong> The LH surge is estimated as the point P4 crosses ~2 ng/mL. Ovulation is estimated at ~5 ng/mL. With only a few draws these are interpolated between readings, so they shift as you add data. Lab assays vary. Treat these as planning estimates, not vet-grade timing. Your reproductive vet&rsquo;s read of the full curve is the source of truth.' +
          '</div>';

        // Responsive: collapse to 1 column under 640px via inline media-query style trick (just stack)
        var wrapStyle = 'display:block;';

        return (
          '<style>@media(max-width:640px){.ptt-proj-cards-grid{grid-template-columns:1fr !important;}}</style>' +
          '<div class="ptt-proj-cards-grid" style="' + cardsGridStyle + '">' + lhBlock + ovuBlock + winBlock + '</div>' +
          caveat
        );
      }

      function buildChart(readings) {
        if (readings.length === 0) return '';

        var w = 720;
        var h = 280;
        var padL = 44;
        var padR = 16;
        var padT = 16;
        var padB = 36;
        var innerW = w - padL - padR;
        var innerH = h - padT - padB;

        var minDay = readings[0].day;
        var maxDay = readings[readings.length - 1].day;
        if (minDay === maxDay) maxDay = minDay + 1;
        var dayPad = Math.max(1, Math.round((maxDay - minDay) * 0.08));
        minDay = minDay - dayPad;
        maxDay = maxDay + dayPad;

        var maxV = 12;
        for (var i = 0; i < readings.length; i++) {
          if (readings[i].value > maxV) maxV = Math.ceil(readings[i].value / 5) * 5;
        }

        function xFor(day) {
          return padL + ((day - minDay) / (maxDay - minDay)) * innerW;
        }
        function yFor(val) {
          return padT + innerH - (val / maxV) * innerH;
        }

        function bandRect(yTop, yBot, fill) {
          var y = Math.min(yTop, yBot);
          var height = Math.abs(yBot - yTop);
          return '<rect x="' + padL + '" y="' + y + '" width="' + innerW + '" height="' + height + '" fill="' + fill + '" opacity="0.45"/>';
        }

        var svg = '';
        svg += '<svg viewBox="0 0 ' + w + ' ' + h + '" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet" class="ptt-chart-svg">';

        // Bands (under 1, 1-2.5, 2.5-10, 10+)
        svg += bandRect(yFor(0), yFor(1), '#f3f4f6');
        svg += bandRect(yFor(1), yFor(2.5), '#fef3c7');
        svg += bandRect(yFor(2.5), yFor(10), '#dcfce7');
        svg += bandRect(yFor(10), yFor(maxV), '#dbeafe');

        // Threshold lines at 2 and 5
        svg += '<line x1="' + padL + '" x2="' + (padL + innerW) + '" y1="' + yFor(2) + '" y2="' + yFor(2) + '" stroke="#f59e0b" stroke-width="1.5" stroke-dasharray="4 4"/>';
        svg += '<text x="' + (padL + innerW - 4) + '" y="' + (yFor(2) - 4) + '" text-anchor="end" font-size="11" fill="#92400e" font-family="system-ui, sans-serif">LH surge ~2</text>';
        svg += '<line x1="' + padL + '" x2="' + (padL + innerW) + '" y1="' + yFor(5) + '" y2="' + yFor(5) + '" stroke="#16a34a" stroke-width="1.5" stroke-dasharray="4 4"/>';
        svg += '<text x="' + (padL + innerW - 4) + '" y="' + (yFor(5) - 4) + '" text-anchor="end" font-size="11" fill="#166534" font-family="system-ui, sans-serif">Ovulation ~5</text>';

        // Y-axis ticks
        var ticks = [0, 2, 5, 10];
        if (maxV > 15) ticks.push(Math.round(maxV / 5) * 5);
        for (var t = 0; t < ticks.length; t++) {
          if (ticks[t] > maxV) continue;
          var yy = yFor(ticks[t]);
          svg += '<text x="' + (padL - 8) + '" y="' + (yy + 4) + '" text-anchor="end" font-size="11" fill="#6b7280" font-family="system-ui, sans-serif">' + ticks[t] + '</text>';
        }
        svg += '<text x="10" y="' + (padT + innerH / 2) + '" text-anchor="middle" font-size="11" fill="#6b7280" font-family="system-ui, sans-serif" transform="rotate(-90 10 ' + (padT + innerH / 2) + ')">ng/mL</text>';

        // X-axis ticks (every ~3 days)
        var dayRange = maxDay - minDay;
        var step = dayRange <= 8 ? 1 : (dayRange <= 16 ? 2 : 3);
        for (var d = Math.ceil(minDay); d <= maxDay; d++) {
          if ((d - Math.ceil(minDay)) % step !== 0) continue;
          var xx = xFor(d);
          svg += '<line x1="' + xx + '" x2="' + xx + '" y1="' + (padT + innerH) + '" y2="' + (padT + innerH + 4) + '" stroke="#9ca3af" stroke-width="1"/>';
          svg += '<text x="' + xx + '" y="' + (padT + innerH + 18) + '" text-anchor="middle" font-size="11" fill="#6b7280" font-family="system-ui, sans-serif">D' + d + '</text>';
        }
        svg += '<text x="' + (padL + innerW / 2) + '" y="' + (h - 4) + '" text-anchor="middle" font-size="11" fill="#6b7280" font-family="system-ui, sans-serif">Day of cycle</text>';

        // Axis lines
        svg += '<line x1="' + padL + '" x2="' + padL + '" y1="' + padT + '" y2="' + (padT + innerH) + '" stroke="#d1d5db" stroke-width="1"/>';
        svg += '<line x1="' + padL + '" x2="' + (padL + innerW) + '" y1="' + (padT + innerH) + '" y2="' + (padT + innerH) + '" stroke="#d1d5db" stroke-width="1"/>';

        // Trend line
        if (readings.length >= 2) {
          var pathD = '';
          for (var p = 0; p < readings.length; p++) {
            var px = xFor(readings[p].day);
            var py = yFor(readings[p].value);
            pathD += (p === 0 ? 'M' : 'L') + px.toFixed(1) + ' ' + py.toFixed(1) + ' ';
          }
          svg += '<path d="' + pathD + '" fill="none" stroke="hsl(24, 95%, 53%)" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>';
        }

        // Data points
        for (var k = 0; k < readings.length; k++) {
          var c = classifyValue(readings[k].value);
          var fill = '#6b7280';
          if (c.band === 'baseline') fill = '#9ca3af';
          else if (c.band === 'lh') fill = '#f59e0b';
          else if (c.band === 'ovulation') fill = '#16a34a';
          else if (c.band === 'maturation') fill = '#2563eb';
          var cx = xFor(readings[k].day);
          var cy = yFor(readings[k].value);
          svg += '<circle cx="' + cx + '" cy="' + cy + '" r="5.5" fill="' + fill + '" stroke="#ffffff" stroke-width="2"/>';
          svg += '<text x="' + cx + '" y="' + (cy - 10) + '" text-anchor="middle" font-size="11" font-weight="600" fill="#111827" font-family="system-ui, sans-serif">' + readings[k].value.toFixed(1) + '</text>';
        }

        svg += '</svg>';
        return svg;
      }

      function buildTimeline(readings) {
        if (readings.length === 0) {
          return '<div style="padding:1rem;background:#f9fafb;border:1px dashed #e5e7eb;border-radius:8px;color:#6b7280;text-align:center;">No test rows with both a date and a value yet.</div>';
        }

        var bandAccent = {
          baseline: '#9ca3af',
          lh: '#f59e0b',
          ovulation: '#16a34a',
          maturation: '#2563eb'
        };

        var html = '<div style="display:flex;flex-direction:column;gap:0.55rem;">';

        for (var i = 0; i < readings.length; i++) {
          var r = readings[i];
          var c = classifyValue(r.value);
          var accent = bandAccent[c.band] || '#9ca3af';

          var rowStyle =
            'display:grid;grid-template-columns:74px 160px 110px 1fr;' +
            'align-items:center;column-gap:1rem;row-gap:0.35rem;' +
            'padding:0.85rem 1rem;background:#ffffff;' +
            'border:1px solid #e5e7eb;border-left:4px solid ' + accent + ';' +
            'border-radius:10px;box-shadow:0 1px 2px rgba(17,24,39,0.03);';

          var dayStyle =
            'display:inline-flex;align-items:center;justify-content:center;' +
            'padding:0.2rem 0.6rem;background:#f3f4f6;color:#111827;' +
            'font-weight:700;font-size:0.8rem;border-radius:999px;' +
            'width:fit-content;line-height:1.2;letter-spacing:0.02em;';

          var dateStyle = 'color:#4b5563;font-size:0.9rem;';
          var valueStyle = 'font-weight:700;color:#111827;font-size:1.05rem;';
          var bandStyle =
            'display:flex;flex-direction:column;gap:0.15rem;' +
            'color:#1f2937;font-size:0.9rem;font-weight:600;';
          var noteStyle =
            'display:block;color:#6b7280;font-size:0.8rem;font-weight:400;' +
            'line-height:1.4;';

          html +=
            '<div style="' + rowStyle + '">' +
            '<span style="' + dayStyle + '">Day ' + r.day + '</span>' +
            '<span style="' + dateStyle + '">' + escapeHtml(fmtDate(r.date)) + '</span>' +
            '<span style="' + valueStyle + '">' + escapeHtml(r.value.toFixed(1)) + ' ng/mL</span>' +
            '<div style="' + bandStyle + '">' +
            '<span>' + escapeHtml(c.label) + '</span>' +
            '<span style="' + noteStyle + '">' + escapeHtml(c.note) + '</span>' +
            '</div>' +
            '</div>';
        }

        html += '</div>';
        return html;
      }

      form.addEventListener('submit', function (ev) {
        ev.preventDefault();
        error.hidden = true;
        error.textContent = '';

        var heatStart = parseLocalDate(heatInput.value);
        if (!heatStart) {
          error.textContent = 'Enter a valid first day of heat to anchor the cycle.';
          error.hidden = false;
          heatInput.focus();
          return;
        }

        var method = methodInput && methodInput.value ? methodInput.value : 'unsure';

        var rowEls = rowsEl.querySelectorAll('.ptt-row');
        var readings = [];
        for (var i = 0; i < rowEls.length; i++) {
          var dEl = rowEls[i].querySelector('.ptt-row-date');
          var vEl = rowEls[i].querySelector('.ptt-row-value');
          var dateStr = dEl ? dEl.value : '';
          var valStr = vEl ? vEl.value : '';
          if (!dateStr && !valStr) continue; // skip fully-empty rows
          if (!dateStr || !valStr) {
            error.textContent = 'Each test row needs both a date and a P4 value. Remove empty rows or fill them in.';
            error.hidden = false;
            return;
          }
          var dt = parseLocalDate(dateStr);
          if (!dt) {
            error.textContent = 'One of the test dates is not valid. Check the date pickers.';
            error.hidden = false;
            return;
          }
          var v = parseFloat(valStr);
          if (isNaN(v) || v < 0) {
            error.textContent = 'P4 values must be a number of 0 or greater (ng/mL).';
            error.hidden = false;
            return;
          }
          if (v > 100) {
            error.textContent = 'A P4 value above 100 ng/mL is outside expected range for this tool. Double-check the entry.';
            error.hidden = false;
            return;
          }
          var dayOfCycle = diffDays(dt, heatStart) + 1;
          readings.push({ date: dt, value: v, day: dayOfCycle });
        }

        readings.sort(function (a, b) { return a.date.getTime() - b.date.getTime(); });

        projectionEl.innerHTML = buildProjection(readings, method);
        chartEl.innerHTML = buildChart(readings);
        chartWrapEl.style.display = readings.length === 0 ? 'none' : '';
        timelineEl.innerHTML = buildTimeline(readings);
        summaryEl.innerHTML = buildSummary(readings, method);

        results.hidden = false;
        try {
          results.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } catch (e) { /* noop */ }
      });
    })();
  </script>

