  <!--
    COI calculator logic. Wright's path method.
    For each ancestor that appears on both the sire's subtree and the dam's
    subtree, contribution = (1/2)^(n_sire + n_dam + 1) * (1 + F_ancestor).
    F_ancestor defaults to 0 when not supplied (standard assumption).

    Pedigree positions are encoded as strings of S/D characters describing
    the path from the planned offspring down to that ancestor:
      "S"   = sire of planned offspring
      "SD"  = dam of sire
      "DSS" = sire of sire of dam
    Generation = length of the path. Sire-side = starts with "S".
    Dam-side  = starts with "D".

    Same-name match across the sire subtree and dam subtree = common ancestor.
  -->
  <script is:inline>
    (function () {
      var form = document.getElementById('coi-form');
      if (!form) return;
      var resultsEl = document.getElementById('coi-results');
      var errorEl = document.getElementById('coi-error');

      // Mapping: input element id -> pedigree path string (S/D from planned offspring).
      // Generation 1 = parents (path length 1). Generation 2 = grandparents (length 2). etc.
      // Generation-3 fields are intentionally named in plain English in the UI
      // but encoded here as their canonical SSS/SSD/... path. The label text
      // doesn't need to match the path encoding (the calculator reads the id).
      var positions = [
        // Sire side - gen 1
        { id: 'coi-sire', path: 'S' },
        { id: 'coi-dam',  path: 'D' },
        // Sire's parents (gen 2 from offspring)
        { id: 's-s', path: 'SS' },
        { id: 's-d', path: 'SD' },
        // Dam's parents (gen 2 from offspring)
        { id: 'd-s', path: 'DS' },
        { id: 'd-d', path: 'DD' },
        // Sire's grandparents (gen 3 from offspring)
        { id: 's-ss', path: 'SSS' },
        { id: 's-sd', path: 'SSD' },
        { id: 's-ds', path: 'SDS' },
        { id: 's-dd', path: 'SDD' },
        // Dam's grandparents (gen 3 from offspring)
        { id: 'd-ss', path: 'DSS' },
        { id: 'd-sd', path: 'DSD' },
        { id: 'd-ds', path: 'DDS' },
        { id: 'd-dd', path: 'DDD' },
        // Sire's great-grandparents (gen 4 from offspring)
        { id: 's-sss', path: 'SSSS' },
        { id: 's-ssd', path: 'SSSD' },
        { id: 's-sds', path: 'SSDS' },
        { id: 's-sdd', path: 'SSDD' },
        { id: 's-dss', path: 'SDSS' },
        { id: 's-dsd', path: 'SDSD' },
        { id: 's-dds', path: 'SDDS' },
        { id: 's-ddd', path: 'SDDD' },
        // Dam's great-grandparents (gen 4 from offspring)
        { id: 'd-sss', path: 'DSSS' },
        { id: 'd-ssd', path: 'DSSD' },
        { id: 'd-sds', path: 'DSDS' },
        { id: 'd-sdd', path: 'DSDD' },
        { id: 'd-dss', path: 'DDSS' },
        { id: 'd-dsd', path: 'DDSD' },
        { id: 'd-dds', path: 'DDDS' },
        { id: 'd-ddd', path: 'DDDD' }
      ];

      function normalize(name) {
        if (!name) return '';
        return String(name).trim().toLowerCase().replace(/\s+/g, ' ');
      }

      function readForm() {
        // Build map: normalized name -> array of { path, displayName }
        // (one ancestor name can appear at multiple pedigree positions)
        var map = Object.create(null);
        var sireName = '';
        var damName = '';

        for (var i = 0; i < positions.length; i++) {
          var pos = positions[i];
          var el = document.getElementById(pos.id);
          if (!el) continue;
          var raw = el.value || '';
          var norm = normalize(raw);
          if (!norm) continue;
          if (pos.path === 'S') sireName = raw.trim();
          if (pos.path === 'D') damName = raw.trim();
          if (!map[norm]) map[norm] = { displayName: raw.trim(), occurrences: [] };
          map[norm].occurrences.push(pos.path);
        }

        // Generation 4/5 textareas (one name per line, treated as gen-4 depth).
        // Lines listed in s-deep are placed on the sire side at path "SXXXX",
        // and on d-deep on the dam side at path "DXXXX". The exact branch
        // beyond that doesn't matter for Wright's formula \u2014 only the
        // generational distance to the common ancestor matters. We pick a
        // stable, distinct placeholder path so a name appearing in both
        // textareas registers as a common ancestor at gen-4-from-offspring.
        var sDeep = document.getElementById('s-deep');
        var dDeep = document.getElementById('d-deep');

        function appendDeep(textareaEl, sideChar) {
          if (!textareaEl) return;
          var lines = (textareaEl.value || '').split(/\r?\n/);
          for (var j = 0; j < lines.length; j++) {
            var raw = lines[j];
            var norm = normalize(raw);
            if (!norm) continue;
            // Fabricate a unique gen-4 path on the right side. The path string
            // length is what the algorithm uses for generation distance; the
            // specific branch is irrelevant for the formula.
            var path = sideChar + 'XXX'; // length 4 = generation 4
            if (!map[norm]) map[norm] = { displayName: raw.trim(), occurrences: [] };
            map[norm].occurrences.push(path);
          }
        }
        appendDeep(sDeep, 'S');
        appendDeep(dDeep, 'D');

        return { map: map, sireName: sireName, damName: damName };
      }

      // For each ancestor, find every (sire-side path, dam-side path) pair
      // and compute its contribution to F(planned offspring) per Wright's
      // formula.
      function computeCOI(state) {
        var map = state.map;
        var common = [];
        var totalF = 0;

        // Walk every ancestor that appears at least once on each side.
        for (var name in map) {
          var entry = map[name];
          // Skip the planned sire and dam themselves \u2014 they are the parents,
          // not ancestors of the offspring. (But: if the SAME name appears as
          // both the sire AND something on the dam side, that IS a common
          // ancestor \u2014 we cover that by including the "S" path below.)
          var siresidePaths = [];
          var damsidePaths = [];
          for (var k = 0; k < entry.occurrences.length; k++) {
            var p = entry.occurrences[k];
            if (p.charAt(0) === 'S') siresidePaths.push(p);
            else if (p.charAt(0) === 'D') damsidePaths.push(p);
          }
          if (!siresidePaths.length || !damsidePaths.length) continue;

          // Wright's formula: sum over all (sire-path, dam-path) pairs
          // of (1/2)^(g_sire + g_dam - 1), where g_sire is the generation
          // distance from the PLANNED SIRE to the ancestor, g_dam is from
          // the PLANNED DAM. With path notation rooted at the planned
          // offspring, g_sire = path.length - 1 (the leading "S" is the
          // step from offspring to sire), same for dam side.
          //
          // Equivalent: contribution per pair = (1/2)^(n1 + n2 + 1) using
          // n1, n2 = generations from each PARENT to the ancestor.
          //
          // F_ancestor default = 0 (no F input supported in this UI).
          var ancestorContribution = 0;
          for (var a = 0; a < siresidePaths.length; a++) {
            for (var b = 0; b < damsidePaths.length; b++) {
              var n1 = siresidePaths[a].length - 1; // gens from sire to ancestor
              var n2 = damsidePaths[b].length - 1;  // gens from dam to ancestor
              var pairContribution = Math.pow(0.5, n1 + n2 + 1);
              ancestorContribution += pairContribution;
            }
          }
          totalF += ancestorContribution;

          // Pick a representative depth for display: shortest sire-side gen + shortest dam-side gen.
          var minSireGen = Infinity, minDamGen = Infinity;
          for (var s2 = 0; s2 < siresidePaths.length; s2++) {
            var g = siresidePaths[s2].length - 1;
            if (g < minSireGen) minSireGen = g;
          }
          for (var d2 = 0; d2 < damsidePaths.length; d2++) {
            var g2 = damsidePaths[d2].length - 1;
            if (g2 < minDamGen) minDamGen = g2;
          }

          common.push({
            name: entry.displayName,
            sireGen: minSireGen,
            damGen: minDamGen,
            contribution: ancestorContribution,
            occurrences: siresidePaths.length * damsidePaths.length
          });
        }

        common.sort(function (a, b) { return b.contribution - a.contribution; });
        return { coi: totalF, common: common };
      }

      function interpret(coi) {
        var pct = coi * 100;
        if (pct === 0) {
          return 'No shared ancestry detected in the pedigree you entered. The COI is 0% at this depth. If your registry uses a deeper pedigree, its number may read higher.';
        }
        if (pct < 3.125) {
          return 'Mild line-breeding or distant shared ancestry. Roughly equivalent to a second-cousin mating or weaker.';
        }
        if (pct < 6.25) {
          return 'Moderate line-breeding. Roughly equivalent to a first-cousin-once-removed mating.';
        }
        if (pct < 12.5) {
          return 'First-cousin range. Many breed clubs treat this as a meaningful diversity cost; check your breed-specific guidance.';
        }
        if (pct < 25) {
          return 'Close line-breeding. Comparable to a half-sibling mating. Most breed clubs flag this depth.';
        }
        return 'Very close mating, comparable to a parent-to-offspring or full-sibling pairing (25%). Treat any value at or above 25% as requiring serious justification.';
      }

      function renderCommonList(common) {
        var listEl = document.getElementById('coi-common-list');
        if (!listEl) return;
        if (!common.length) {
          listEl.innerHTML = '<p class="coi-common-empty">No common ancestors detected in the pedigree you entered. COI is 0% at this pedigree depth. If you know there is shared ancestry further back, your registry\u2019s deep-pedigree COI may read higher.</p>';
          return;
        }
        var html = '<ul class="coi-common-ul">';
        for (var i = 0; i < common.length; i++) {
          var c = common[i];
          var contribPct = (c.contribution * 100).toFixed(2);
          var occLabel = c.occurrences === 1
            ? '1 sire\u00d7dam path'
            : c.occurrences + ' sire\u00d7dam paths';
          // Escape the display name minimally to avoid HTML injection from input
          var safeName = String(c.name).replace(/[&<>"]/g, function (ch) {
            return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[ch];
          });
          html += '<li class="coi-common-item">' +
            '<div class="coi-common-name">' + safeName + '</div>' +
            '<div class="coi-common-meta">' +
              'Closest path: gen ' + c.sireGen + ' (sire side) \u00d7 gen ' + c.damGen + ' (dam side). ' +
              occLabel + '.' +
            '</div>' +
            '<div class="coi-common-contrib">Contributes <strong>' + contribPct + '%</strong> to total COI.</div>' +
          '</li>';
        }
        html += '</ul>';
        listEl.innerHTML = html;
      }

      function render(state) {
        var result = computeCOI(state);
        var pct = (result.coi * 100).toFixed(2);
        var pctEl = document.getElementById('coi-percent');
        if (pctEl) pctEl.textContent = pct + '%';
        var interpEl = document.getElementById('coi-interpretation');
        if (interpEl) interpEl.textContent = interpret(result.coi);
        renderCommonList(result.common);
        resultsEl.hidden = false;
        try { resultsEl.scrollIntoView({ behavior: 'smooth', block: 'start' }); } catch (e) { /* noop */ }
      }

      form.addEventListener('submit', function (ev) {
        ev.preventDefault();
        errorEl.hidden = true;
        errorEl.textContent = '';
        var sireEl = document.getElementById('coi-sire');
        var damEl = document.getElementById('coi-dam');
        if (!sireEl.value.trim() || !damEl.value.trim()) {
          errorEl.textContent = 'Enter a name for the planned sire and the planned dam.';
          errorEl.hidden = false;
          (sireEl.value.trim() ? damEl : sireEl).focus();
          return;
        }
        var state = readForm();
        render(state);
      });

      // Clear all fields and hide results.
      var resetBtn = document.getElementById('coi-reset');
      if (resetBtn) {
        resetBtn.addEventListener('click', function () {
          form.reset();
          if (resultsEl) resultsEl.hidden = true;
          errorEl.hidden = true;
        });
      }

      // Load a worked example: full-sibling mating (same sire AND dam as parents).
      // Expected result: COI = 25%, common ancestors = both parents at gen 1 x gen 1.
      var exampleBtn = document.getElementById('coi-example');
      if (exampleBtn) {
        exampleBtn.addEventListener('click', function () {
          form.reset();
          // Two full siblings being mated to each other. Their shared parents
          // are "Apollo" (sire) and "Brisa" (dam). The planned mating is
          // therefore Apollo+Brisa pup x Apollo+Brisa pup, with both pups
          // having the same parents.
          document.getElementById('coi-sire').value = 'Pup A';
          document.getElementById('coi-dam').value = 'Pup B';
          document.getElementById('s-s').value = 'Apollo';
          document.getElementById('s-d').value = 'Brisa';
          document.getElementById('d-s').value = 'Apollo';
          document.getElementById('d-d').value = 'Brisa';
          var state = readForm();
          render(state);
        });
      }
    })();
  </script>

