---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Tools', url: '/tools' },
  { name: 'Puppy Vaccination Schedule Generator', url: '/tools/puppy-vaccination-schedule-generator' }
];

const lastReviewedISO = '2026-05-16';

const faqs = [
  {
    question: 'Is this an official puppy vaccination protocol?',
    answer: 'No. This generator returns a calendar of common planning milestones at 6, 8, 10, 12, 14, and 16 weeks of age. It does not prescribe vaccines, doses, or routes. The actual protocol for a litter is decided by your veterinarian based on breed, region, lifestyle, exposure risk, dam antibody status, and local regulations. Treat the output as a planning skeleton, not a medical recommendation.'
  },
  {
    question: 'Which vaccines should puppies get?',
    answer: 'That is a veterinary decision, not a calendar decision. Many puppy protocols include a core series in the 6-to-16 week age window, plus boosters that vary by region and risk. Bring this calendar to your vet appointment and ask them to map the actual vaccine plan onto the dates. Local rabies regulations, breed considerations, and disease exposure in your area all affect what belongs in the protocol.'
  },
  {
    question: 'Why does the schedule run from 6 to 16 weeks?',
    answer: 'The 6-to-16 week window is when most planning milestones cluster for newborn puppies, before maternal antibodies fully fade. Many veterinary protocols schedule visits at 6, 8, 10, 12, 14, and 16 weeks of age, with the final visit often being the most operationally important for breeders because it tends to line up with go-home dates. Your vet may use a slightly different cadence.'
  },
  {
    question: 'What if my puppies go home before 16 weeks?',
    answer: 'Common breeder practice is to release puppies somewhere in the 8-to-12 week window, which means the last one or two scheduled visits transfer to the new family. Enter the planned go-home date and the generator flags which milestones fall before handoff (breeder responsibility) and which fall after (buyer responsibility). Use this to build a clean handoff packet so the new family knows exactly which visits remain.'
  },
  {
    question: 'Can I save or print this schedule?',
    answer: 'This generator is anonymous and does not save anything. Use the Print or Copy buttons on the result card to capture the schedule for your records or for a buyer handoff packet. For per-puppy records that persist across the litter\u2019s lifetime (visits, weights, documents, buyer handoff), use BreederHQ.'
  },
  {
    question: 'Does this work for all breeds?',
    answer: 'The age-based milestones are general. Specific breeds, lines, or working dogs may need adjusted protocols (toy breeds with smaller immune responses, breeds with documented vaccine sensitivities, working or sporting dogs with different exposure profiles). Always confirm the actual protocol with a veterinarian who knows the breed and the dam\u2019s history.'
  }
];

const softwareAppSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  '@id': 'https://breederhq.com/tools/puppy-vaccination-schedule-generator#tool',
  'name': 'Puppy Vaccination Schedule Generator',
  'description': 'Free puppy vaccination schedule generator for dog breeders. Enter a litter\u2019s birth date and an optional go-home date to generate a general planning calendar of common vaccination milestones from 6 to 16 weeks of age. Planning tool only. Specific vaccines and protocols should be confirmed with a veterinarian.',
  'url': 'https://breederhq.com/tools/puppy-vaccination-schedule-generator',
  'applicationCategory': 'BusinessApplication',
  'applicationSubCategory': 'Dog Breeding Calculator',
  'operatingSystem': 'Any (web browser)',
  'browserRequirements': 'Requires JavaScript. Requires HTML5.',
  'offers': {
    '@type': 'Offer',
    'price': '0',
    'priceCurrency': 'USD'
  },
  'publisher': {
    '@id': 'https://breederhq.com/#organization'
  },
  'datePublished': lastReviewedISO,
  'dateModified': lastReviewedISO,
  'featureList': [
    'Generate a 6 to 16 week puppy vaccination planning calendar from a litter birth date',
    'Show calendar dates and age in weeks for each milestone',
    'Flag breeder vs. buyer responsibility based on planned go-home date',
    'Print or copy the schedule for buyer handoff packets',
    'Anonymous, no signup, no data saved'
  ]
};

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': 'https://breederhq.com/tools/puppy-vaccination-schedule-generator#article',
  'headline': 'Puppy Vaccination Schedule Generator for Breeders',
  'description': 'Free planning calendar of common puppy vaccination milestones from 6 to 16 weeks of age, with optional go-home handoff flagging. For breeder operational planning. Confirm specific vaccines and protocols with your veterinarian.',
  'url': 'https://breederhq.com/tools/puppy-vaccination-schedule-generator',
  'datePublished': lastReviewedISO,
  'dateModified': lastReviewedISO,
  'author': {
    '@type': 'Organization',
    'name': 'BreederHQ Operations Team',
    'url': 'https://breederhq.com/about'
  },
  'publisher': {
    '@id': 'https://breederhq.com/#organization'
  },
  'mainEntityOfPage': {
    '@type': 'WebPage',
    '@id': 'https://breederhq.com/tools/puppy-vaccination-schedule-generator'
  }
};
---

<BaseLayout
  title="Free Puppy Vaccination Schedule Generator for Breeders | BreederHQ"
  description="Free puppy vaccination schedule generator for dog breeders. Enter a litter's birth date to get a planning calendar from 6 to 16 weeks, with optional go-home handoff dates. Planning tool only. Confirm specific vaccines and protocols with your veterinarian."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(softwareAppSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
    Skip to content
  </a>

  <main id="main-content">
  <nav class="breadcrumb py-4 px-4 bg-gray-50" aria-label="Breadcrumb">
    <ol class="flex items-center space-x-2 max-w-4xl mx-auto text-sm">
      <li><a href="/" class="text-[hsl(24,95%,53%)] hover:underline">Home</a></li>
      <li class="text-gray-400">›</li>
      <li><a href="/tools" class="text-[hsl(24,95%,53%)] hover:underline">Tools</a></li>
      <li class="text-gray-400">›</li>
      <li aria-current="page" class="text-gray-600">Puppy Vaccination Schedule Generator</li>
    </ol>
  </nav>

  <!-- Section 1: Intro -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-bold mb-6">Generate a Puppy Vaccination Planning Schedule from One Date</h1>
      <p class="text-sm text-gray-500 mb-6">
        <strong class="text-gray-700">Last Reviewed: May 16, 2026.</strong> Built and reviewed by the BreederHQ Operations Team, working with active dog breeders. Reviewed against general veterinary planning conventions. Not a medical protocol.
      </p>
      <p class="text-xl text-gray-700 leading-relaxed">
        Enter a litter&rsquo;s birth date. This free generator returns a calendar of common puppy vaccination planning milestones at 6, 8, 10, 12, 14, and 16 weeks of age. Optionally enter a planned go-home date and the generator will flag which visits fall on the breeder and which transfer to the buyer. Specific vaccines and the actual protocol are decided by your veterinarian based on breed, region, exposure risk, and local regulations.
      </p>
    </div>
  </section>

  <!-- The Generator -->
  <section class="px-4 pb-8">
    <div class="max-w-4xl mx-auto">
      <div class="pvg-card">
        <form id="pvg-form" class="pvg-form" novalidate>
          <div class="pvg-field">
            <label for="pvg-birth" class="pvg-label">Litter Birth Date</label>
            <p class="pvg-help">The day the litter was born. This becomes Day 0 of the planning calendar.</p>
            <input
              type="date"
              id="pvg-birth"
              name="birth-date"
              class="pvg-input"
              required
            />
          </div>

          <div class="pvg-field">
            <label for="pvg-gohome" class="pvg-label">Planned Go-Home Date <span class="pvg-optional">(optional)</span></label>
            <p class="pvg-help">If you have a target placement date, we&rsquo;ll flag which milestones fall before handoff (breeder) and which fall after (buyer).</p>
            <input
              type="date"
              id="pvg-gohome"
              name="go-home-date"
              class="pvg-input"
            />
          </div>

          <div class="pvg-actions">
            <button type="submit" class="pvg-button">Generate Schedule</button>
          </div>

          <p id="pvg-error" class="pvg-error" role="alert" hidden></p>
        </form>

        <div id="pvg-results" class="pvg-results" hidden aria-live="polite">
          <div class="pvg-results-header">
            <div>
              <h2 class="pvg-results-title">Planning Schedule</h2>
              <p class="pvg-results-subtitle" id="pvg-results-subtitle"></p>
            </div>
            <div class="pvg-results-actions no-print">
              <button type="button" id="pvg-copy" class="pvg-action-button">Copy</button>
              <button type="button" id="pvg-print" class="pvg-action-button">Print</button>
            </div>
          </div>

          <div id="pvg-schedule" class="pvg-schedule"></div>

          <div class="pvg-disclaimer">
            <strong>Important.</strong> This is a general planning calendar of age-based milestones. It is not a veterinary protocol and does not name specific vaccines or doses. Many veterinary protocols include core puppy vaccines somewhere in this age window plus regionally appropriate boosters, but the actual protocol for a litter is a veterinary decision. Local regulations and risk factors vary. Confirm with your veterinarian.
          </div>

          <div class="pvg-cta">
            <p class="pvg-cta-text">
              Want to track each puppy&rsquo;s actual visits, weights, and documents across the whole litter and hand a clean record to the buyer at placement? BreederHQ keeps per-puppy records, attaches visit notes and documents, and builds the handoff packet for you.
            </p>
            <div class="pvg-cta-buttons">
              <a href="https://accounts.breederhq.com/register?intent=breeder_dashboard" class="pvg-cta-primary">
                Track Puppy Records in BreederHQ Free
              </a>
              <a href="/puppy-application-management" class="pvg-cta-secondary">
                Learn About Puppy Application Management →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- How To Use -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-6">How to Use This Generator</h2>
      <ol class="space-y-4 text-lg text-gray-700">
        <li class="flex items-start">
          <span class="pvg-ol-num">1</span>
          <span><strong>Enter the litter&rsquo;s birth date.</strong> If puppies were born across two days, use the first day. That becomes Day 0 of the planning calendar.</span>
        </li>
        <li class="flex items-start">
          <span class="pvg-ol-num">2</span>
          <span><strong>Add a planned go-home date if you have one.</strong> The generator will mark each milestone as breeder responsibility or buyer responsibility based on whether it falls before or after handoff.</span>
        </li>
        <li class="flex items-start">
          <span class="pvg-ol-num">3</span>
          <span><strong>Take the schedule to your vet.</strong> Ask them to map the actual vaccine protocol onto the calendar. The dates are general; the vaccines, doses, and boosters are theirs to decide.</span>
        </li>
        <li class="flex items-start">
          <span class="pvg-ol-num">4</span>
          <span><strong>Use the post-go-home rows in the buyer handoff packet.</strong> Buyers consistently underestimate how many visits remain after pickup. Showing them the remaining dates up front reduces missed boosters and follow-up confusion.</span>
        </li>
      </ol>
    </div>
  </section>

  <!-- What the Schedule Means -->
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-8">What the Schedule Means</h2>

      <div class="space-y-6">
        <div>
          <h3 class="text-2xl font-bold mb-2">Common Planning Milestones (6 to 16 Weeks)</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Many veterinary protocols cluster puppy visits at 6, 8, 10, 12, 14, and 16 weeks of age. The cadence is driven by how maternal antibodies fade across the first several weeks of life and the windows in which puppies tend to respond to vaccination. The exact ages and how many visits are needed depend on the protocol your vet runs.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-2">Why We Don&rsquo;t List Specific Vaccines</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            Listing specific vaccines as &ldquo;mandatory&rdquo; on a calendar would be wrong. Protocols vary by region, by breed, by lifestyle, by exposure risk, and by individual puppy. Local rabies regulations vary by state and country. Some veterinary teams use a different visit cadence entirely. This tool gives you the calendar skeleton; your vet decides what goes on it.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-2">Breeder vs. Buyer Responsibility</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            If the litter goes home before 16 weeks (typical for most breeds), one or two of the final scheduled visits transfer to the new family. Making that boundary explicit in the handoff packet prevents the &ldquo;I thought you already did that one&rdquo; conversation later. The generator flags it for you when you enter a go-home date.
          </p>
        </div>

        <div>
          <h3 class="text-2xl font-bold mb-2">When to Re-check the Schedule</h3>
          <p class="text-lg text-gray-700 leading-relaxed">
            If a planned vet visit slips by more than a few days, regenerate the calendar from the actual birth date and re-confirm the remaining cadence with your vet. The exact spacing between boosters matters more than the absolute dates in some protocols.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why This Isn't a Medical Protocol -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold mb-6">Why This Isn&rsquo;t a Medical Protocol</h2>
      <p class="text-lg text-gray-700 leading-relaxed mb-4">
        A calendar can tell you when a puppy turns 8 weeks old. A calendar cannot tell you which vaccines that puppy needs, at what dose, or whether your region requires anything additional. Vaccination is a clinical decision that takes into account the dam&rsquo;s antibody status, breed considerations, local disease prevalence, and the puppy&rsquo;s individual health on the day of the visit.
      </p>
      <p class="text-lg text-gray-700 leading-relaxed mb-4">
        This generator is an operational planning tool. It tells you which dates to put on the litter&rsquo;s calendar, which to put on the buyer handoff packet, and which to confirm with the vet ahead of time so you can book the visits early. The actual protocol is theirs.
      </p>
      <p class="text-lg text-gray-700 leading-relaxed">
        Read more in <a href="/puppy-application-management" class="text-[hsl(24,95%,53%)] hover:underline">Puppy Application Management</a> and the <a href="/dog-breeding-software" class="text-[hsl(24,95%,53%)] hover:underline">Dog Breeding Software</a> overview.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 px-4 faq-section bg-gray-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold mb-12">Frequently Asked Questions</h2>

      {faqs.map((faq) => (
        <details class="faq-item">
          <summary class="faq-question">
            <span>{faq.question}</span>
            <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </summary>
          <div class="faq-answer">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </section>

  <!-- Related -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold mb-6">Related Resources</h2>
      <div class="space-y-3 text-lg">
        <div>
          <a href="/tools" class="text-[hsl(24,95%,53%)] hover:underline">
            → Free Tools for Breeders
          </a>
        </div>
        <div>
          <a href="/tools/heat-cycle-calculator" class="text-[hsl(24,95%,53%)] hover:underline">
            → Free Heat Cycle Calculator
          </a>
        </div>
        <div>
          <a href="/tools/whelping-date-calculator" class="text-[hsl(24,95%,53%)] hover:underline">
            → Free Whelping Date Calculator
          </a>
        </div>
        <div>
          <a href="/tools/breeding-planner" class="text-[hsl(24,95%,53%)] hover:underline">
            → Free Breeding Planner (Multi-Species)
          </a>
        </div>
        <div>
          <a href="/puppy-application-management" class="text-[hsl(24,95%,53%)] hover:underline">
            → Puppy Application Management
          </a>
        </div>
        <div>
          <a href="/dog-breeding-software" class="text-[hsl(24,95%,53%)] hover:underline">
            → Dog Breeding Software Overview
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sticky Mobile CTA -->
  <div class="fixed bottom-0 left-0 right-0 p-4 bg-white border-t-2 border-gray-200 shadow-lg md:hidden z-50 no-print">
    <a href="https://accounts.breederhq.com/register?intent=breeder_dashboard" class="block w-full text-center bg-[hsl(24,95%,53%)] text-white px-6 py-4 rounded-lg font-bold text-lg hover:bg-[hsl(24,95%,48%)] transition" style="min-height: 44px;">
      Track Puppy Records in BreederHQ Free
    </a>
  </div>
  </main>

  <script is:inline>
    (function () {
      var form = document.getElementById('pvg-form');
      var birthInput = document.getElementById('pvg-birth');
      var goHomeInput = document.getElementById('pvg-gohome');
      var error = document.getElementById('pvg-error');
      var results = document.getElementById('pvg-results');
      var schedule = document.getElementById('pvg-schedule');
      var subtitle = document.getElementById('pvg-results-subtitle');
      var copyBtn = document.getElementById('pvg-copy');
      var printBtn = document.getElementById('pvg-print');
      if (!form || !birthInput || !error || !results || !schedule || !subtitle) return;

      // Default birth date to today
      try {
        var today = new Date();
        var iso = today.toISOString().slice(0, 10);
        birthInput.value = iso;
      } catch (e) { /* noop */ }

      var MILESTONES = [
        { weeks: 6, note: 'Many veterinary protocols include an initial puppy visit around this age.' },
        { weeks: 8, note: 'Often the first vet visit attended by buyers if go-home falls at 8 weeks.' },
        { weeks: 10, note: 'Many veterinary protocols include a booster visit around this age.' },
        { weeks: 12, note: 'Often paired with regionally appropriate boosters. Confirm with your vet.' },
        { weeks: 14, note: 'A later booster point. Confirm whether this visit is needed under your vet\u2019s protocol.' },
        { weeks: 16, note: 'Often the final puppy series visit and a typical age for rabies eligibility in many US jurisdictions. Confirm local rules with your vet.' }
      ];

      function parseLocalDate(str) {
        if (!str) return null;
        var parts = str.split('-');
        if (parts.length !== 3) return null;
        var year = parseInt(parts[0], 10);
        var month = parseInt(parts[1], 10) - 1;
        var day = parseInt(parts[2], 10);
        var d = new Date(year, month, day);
        if (isNaN(d.getTime())) return null;
        return d;
      }

      function addDays(date, n) {
        var d = new Date(date.getTime());
        d.setDate(d.getDate() + n);
        return d;
      }

      function fmtLong(date) {
        try {
          return date.toLocaleDateString(undefined, {
            weekday: 'short',
            year: 'numeric',
            month: 'short',
            day: 'numeric'
          });
        } catch (e) {
          return date.toDateString();
        }
      }

      function fmtShort(date) {
        try {
          return date.toLocaleDateString(undefined, {
            year: 'numeric',
            month: 'short',
            day: 'numeric'
          });
        } catch (e) {
          return date.toDateString();
        }
      }

      function buildSchedule(birthDate, goHomeDate) {
        return MILESTONES.map(function (m) {
          var date = addDays(birthDate, m.weeks * 7);
          var owner = null;
          if (goHomeDate) {
            owner = date.getTime() < goHomeDate.getTime() ? 'breeder' : 'buyer';
          }
          return {
            weeks: m.weeks,
            date: date,
            note: m.note,
            owner: owner
          };
        });
      }

      function renderSchedule(rows, goHomeDate) {
        var html = '';
        rows.forEach(function (row) {
          var ownerBadge = '';
          if (row.owner === 'breeder') {
            ownerBadge = '<span class="pvg-badge pvg-badge--breeder">Breeder</span>';
          } else if (row.owner === 'buyer') {
            ownerBadge = '<span class="pvg-badge pvg-badge--buyer">Buyer (after go-home)</span>';
          }

          html += '' +
            '<tr class="pvg-row">' +
              '<td class="pvg-cell-age">' +
                '<div class="pvg-weeks">' + row.weeks + ' wks</div>' +
              '</td>' +
              '<td class="pvg-cell-date">' +
                '<div class="pvg-date">' + fmtLong(row.date) + '</div>' +
                (ownerBadge ? '<div class="pvg-badge-wrap">' + ownerBadge + '</div>' : '') +
              '</td>' +
              '<td class="pvg-cell-note">' + row.note + '</td>' +
            '</tr>';
        });
        html = '' +
          '<table class="pvg-table"><thead><tr>' +
            '<th scope="col" class="pvg-th pvg-th-age">Age</th>' +
            '<th scope="col" class="pvg-th pvg-th-date">Date</th>' +
            '<th scope="col" class="pvg-th pvg-th-note">Planning note</th>' +
          '</tr></thead><tbody>' + html + '</tbody></table>';

        if (goHomeDate) {
          html += '' +
            '<div class="pvg-handoff">' +
              '<strong>Go-home date:</strong> ' + fmtLong(goHomeDate) + '. ' +
              'Visits before this date are typically the breeder\u2019s responsibility. Visits on or after this date transfer to the buyer and belong in the handoff packet.' +
            '</div>';
        }

        return html;
      }

      function buildPlainText(rows, birthDate, goHomeDate) {
        var lines = [];
        lines.push('Puppy Vaccination Planning Schedule');
        lines.push('Litter birth date: ' + fmtLong(birthDate));
        if (goHomeDate) {
          lines.push('Planned go-home date: ' + fmtLong(goHomeDate));
        }
        lines.push('');
        rows.forEach(function (row) {
          var line = row.weeks + ' weeks  ' + fmtShort(row.date);
          if (row.owner === 'breeder') line += '  [Breeder]';
          if (row.owner === 'buyer') line += '  [Buyer (after go-home)]';
          lines.push(line);
          lines.push('  ' + row.note);
        });
        lines.push('');
        lines.push('Planning tool only. Confirm specific vaccines and protocols with your veterinarian.');
        lines.push('Generated by BreederHQ: https://breederhq.com/tools/puppy-vaccination-schedule-generator');
        return lines.join('\n');
      }

      var currentPlainText = '';

      form.addEventListener('submit', function (ev) {
        ev.preventDefault();
        error.hidden = true;
        error.textContent = '';

        var birthStr = birthInput.value;
        if (!birthStr) {
          error.textContent = 'Enter the litter\u2019s birth date.';
          error.hidden = false;
          birthInput.focus();
          return;
        }

        var birthDate = parseLocalDate(birthStr);
        if (!birthDate) {
          error.textContent = 'That birth date doesn\u2019t look valid. Try again.';
          error.hidden = false;
          birthInput.focus();
          return;
        }

        var goHomeStr = goHomeInput && goHomeInput.value ? goHomeInput.value : '';
        var goHomeDate = null;
        if (goHomeStr) {
          goHomeDate = parseLocalDate(goHomeStr);
          if (!goHomeDate) {
            error.textContent = 'That go-home date doesn\u2019t look valid. Leave it blank or try again.';
            error.hidden = false;
            goHomeInput.focus();
            return;
          }
          if (goHomeDate.getTime() < birthDate.getTime()) {
            error.textContent = 'Go-home date can\u2019t be before the birth date.';
            error.hidden = false;
            goHomeInput.focus();
            return;
          }
        }

        var rows = buildSchedule(birthDate, goHomeDate);
        schedule.innerHTML = renderSchedule(rows, goHomeDate);

        var subtitleText = 'Birth date: ' + fmtLong(birthDate) + '.';
        if (goHomeDate) {
          subtitleText += ' Go-home: ' + fmtLong(goHomeDate) + '.';
        }
        subtitleText += ' Confirm specific vaccines with your veterinarian.';
        subtitle.textContent = subtitleText;

        currentPlainText = buildPlainText(rows, birthDate, goHomeDate);

        results.hidden = false;
        try {
          results.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } catch (e) { /* noop */ }
      });

      if (copyBtn) {
        copyBtn.addEventListener('click', function () {
          if (!currentPlainText) return;
          var done = function () {
            var original = copyBtn.textContent;
            copyBtn.textContent = 'Copied';
            setTimeout(function () { copyBtn.textContent = original; }, 1500);
          };
          if (navigator.clipboard && navigator.clipboard.writeText) {
            navigator.clipboard.writeText(currentPlainText).then(done, function () {
              // Fallback
              fallbackCopy(currentPlainText);
              done();
            });
          } else {
            fallbackCopy(currentPlainText);
            done();
          }
        });
      }

      function fallbackCopy(text) {
        try {
          var ta = document.createElement('textarea');
          ta.value = text;
          ta.setAttribute('readonly', '');
          ta.style.position = 'absolute';
          ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
        } catch (e) { /* noop */ }
      }

      if (printBtn) {
        printBtn.addEventListener('click', function () {
          window.print();
        });
      }
    })();
  </script>

