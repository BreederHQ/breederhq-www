    .faq-icon {
      transition: transform 200ms ease;
      flex-shrink: 0;
      margin-left: 1rem;
    }

    details[open] .faq-icon {
      transform: rotate(180deg);
    }

    .faq-answer {
      padding-top: 1rem;
      color: #4b5563;
      line-height: 1.6;
    }

    .faq-answer p {
      font-size: 1.125rem;
    }
  </style>
</BaseLayout>
