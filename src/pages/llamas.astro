---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'For Breeders', url: '/#for-breeders' },
  { name: 'Llama Breeding', url: '/llamas' }
];

const faqs = [
  {
    question: 'Does BreederHQ work for llama breeders focused on more than fiber?',
    answer: 'Yes. BreederHQ works for breeding programs focused on fiber, companion, guard, pack, performance, or breeding-stock goals. The platform is built around the breeder program itself, not one narrow sale category. Whatever the purpose of your llamas, the same records (pedigree, breeding history, health, fiber) stay organized together.'
  },
  {
    question: 'How does llama breeding work in BreederHQ, since they are induced ovulators?',
    answer: 'Llamas are induced ovulators. Ovulation is triggered by the breeding event, not a predictable estrus cycle. BreederHQ supports the actual camelid breeding workflow: breeding dates, expected due date calculation (~350-day gestation), pregnancy confirmations, birthing, and cria outcome tracking, without forcing llamas through a heat-cycle detection model that does not apply.'
  },
  {
    question: 'Can I track cria records and breeding history for llamas?',
    answer: 'Yes. Breeding plans, cria records, pedigrees, and health documentation are all connected inside one system so llama breeders can keep a complete herd history from breeding decision through cria outcomes.'
  },
  {
    question: 'What about semen and embryo inventory?',
    answer: 'BreederHQ includes a full reproductive inventory system so breeders can track semen lots (straw count, sire identity, motility, storage location) and embryo lots (donor dam, sire, flush date, stage, grade, freeze method) with a complete quantity ledger across multiple storage facilities.'
  },
  {
    question: 'Can I track fiber records for my llamas?',
    answer: 'Yes. Fiber and fleece records (shearing dates, clip weights, fiber quality notes, and production context) can be kept alongside each llama record. That keeps pedigree, breeding history, and production data in one place for fiber-focused programs and for breeders who want to show production context to buyers.'
  },
  {
    question: 'Can I publish my llama program on the marketplace?',
    answer: 'Yes. Llama breeders can publish a verified breeder profile and available animals with public credibility backed by the records they already maintain in BreederHQ. Llama programs are now publicly listed on the BreederHQ Marketplace.'
  },
  {
    question: 'Does it handle ILR and LANA registration records?',
    answer: 'BreederHQ maintains records and documentation for registration. Official submission goes through ILR, LANA, or other registry systems directly. The platform keeps your pedigrees, registration numbers, and supporting records organized so the submission process is easier.'
  }
];

const featureCards = [
  { id: 'herd-records', icon: '🦙', title: 'Herd Records', desc: 'Pedigrees, registration details, cria history, photos' },
  { id: 'breeding', icon: '📅', title: 'Breeding Plans', desc: 'Camelid breeding timelines, due dates, birthing records' },
  { id: 'cria', icon: '🐣', title: 'Cria Care', desc: 'Birth records, neonatal health, nursing, and growth' },
  { id: 'fiber', icon: '🧶', title: 'Fiber Records', desc: 'Shearing, clip weights, quality notes, production context' },
  { id: 'health', icon: '🏥', title: 'Health and Genetics', desc: 'Testing, medications, documents, lineage' },
  { id: 'inventory', icon: '🧪', title: 'Reproductive Inventory', desc: 'Semen and embryo lots with storage tracking' },
  { id: 'buyers', icon: '👥', title: 'Buyers and Clients', desc: 'Inquiries, contracts, waitlists, communications' },
  { id: 'marketplace', icon: '🌐', title: 'Marketplace', desc: 'Verified breeder profile and available-animal visibility' }
];
---

<BaseLayout
  title="Llama Breeding Software | BreederHQ"
  description="Llama breeding software for companion, guard, fiber, pack, performance, and breeding-stock programs. Camelid-aware breeding plans, pedigrees, cria records, induced-ovulator workflows, reproductive inventory, health records, and buyer communication for camelid breeders."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
    Skip to content
  </a>

  <main id="main-content">
    <nav class="breadcrumb py-4 px-4 bg-gray-50" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 max-w-4xl mx-auto text-sm">
        <li><a href="/" class="text-[hsl(24,95%,53%)] hover:underline">Home</a></li>
        <li class="text-gray-400">›</li>
        <li><a href="/#for-breeders" class="text-[hsl(24,95%,53%)] hover:underline">For Breeders</a></li>
        <li class="text-gray-400">›</li>
        <li aria-current="page" class="text-gray-600">Llama Breeding</li>
      </ol>
    </nav>

    <!-- Hero + TL;DR -->
    <section class="py-12 px-4">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-5xl font-bold mb-6">Llama Breeding Software for Modern Herd Management</h1>

        <aside class="tldr-box bg-gray-100 border-l-4 border-[hsl(24,95%,53%)] p-6 my-8 rounded" role="complementary" aria-label="Page summary">
          <h2 class="text-xl font-bold mb-3">TL;DR</h2>
          <p class="text-gray-700 leading-relaxed">
            BreederHQ helps llama breeders manage pedigrees, induced-ovulator breeding records, cria outcomes,
            fiber production records, reproductive inventory, health documents, buyer communication, and a more
            credible public marketplace presence from one connected platform. Llama programs are now publicly
            listed on the BreederHQ Marketplace.
          </p>
        </aside>

        <p class="text-xl text-gray-700 leading-relaxed">
          Whether your llama program is focused on breeding stock, companion animals, guard llamas, pack animals,
          or fiber and performance goals, BreederHQ keeps the herd record and the public-facing breeder profile
          tied to the same real data.
        </p>
      </div>
    </section>

    <!-- Feature Cards Grid -->
    <section class="py-8 px-4 bg-gray-50">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl font-bold mb-6 text-center">Everything Your Llama Program Needs</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {featureCards.map(card => (
            <a href={`#${card.id}`} class="feature-card block p-4 bg-white rounded-lg shadow-sm hover:shadow-md transition border border-gray-200 hover:border-[hsl(24,95%,53%)]">
              <div class="text-3xl mb-2">{card.icon}</div>
              <h3 class="font-bold text-lg mb-1">{card.title}</h3>
              <p class="text-sm text-gray-600">{card.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Sticky Navigation -->
    <nav class="sticky-nav hidden md:block sticky top-0 bg-white border-b border-gray-200 z-40 shadow-sm">
      <div class="max-w-5xl mx-auto px-4">
        <ul class="flex space-x-6 overflow-x-auto py-3 text-sm">
          {featureCards.map(card => (
            <li>
              <a href={`#${card.id}`} class="nav-link whitespace-nowrap text-gray-600 hover:text-[hsl(24,95%,53%)] transition pb-2">
                {card.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>

    <!-- Accordion Sections -->
    <section class="py-12 px-4">
      <div class="max-w-4xl mx-auto space-y-4">

        <!-- Herd Records -->
        <details id="herd-records" class="accordion-section border border-gray-200 rounded-lg" open>
          <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
            <div class="flex items-center gap-4">
              <span class="text-3xl">🦙</span>
              <div>
                <h3 class="text-2xl font-bold">Herd Records and Pedigrees</h3>
                <p class="text-gray-600">Complete herd profiles, lineage, and organization</p>
              </div>
            </div>
            <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="accordion-content p-6 border-t border-gray-200">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">For Every Llama</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Registration numbers (ILR, LANA, and other registries)</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Microchip IDs and ear tags</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Photos, type (Classic, Woolly, Suri, Silky), color, and phenotype</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Birth date, dam and sire, purchase information</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Multi-generation pedigrees with lineage depth</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Purpose designation: fiber, companion, guard, pack, show, breeding</li>
                </ul>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-3">Herd Organization</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Active females, herdsires, crias, and geldings</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Sold, retired, and historical records</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Custom tags and herd categories</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Breeding history linked to each animal</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Show records and performance documentation</li>
                </ul>
              </div>
            </div>
          </div>
        </details>

        <!-- Breeding Plans -->
        <details id="breeding" class="accordion-section border border-gray-200 rounded-lg">
          <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
            <div class="flex items-center gap-4">
              <span class="text-3xl">📅</span>
              <div>
                <h3 class="text-2xl font-bold">Breeding Plans That Fit Camelids</h3>
                <p class="text-gray-600">Induced-ovulator workflow, due dates, and birthing records</p>
              </div>
            </div>
            <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="accordion-content p-6 border-t border-gray-200">
            <p class="text-gray-700 mb-4">
              Llamas need a camelid-aware breeding workflow, not a generic dog or horse cycle tracker. As induced
              ovulators, llamas do not have predictable estrus cycles. Ovulation is triggered by the breeding event
              itself. BreederHQ supports the real llama breeding process without forcing the wrong terminology or
              lifecycle assumptions onto your program.
            </p>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">Breeding Workflow</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Breeding events with sire and female pairing</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Expected due date calculation (~350-day gestation)</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Pregnancy confirmation and recheck records</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Breeding attempt history per female</li>
                  <li class="flex items-start"><span class="mr-2">•</span>No heat-cycle detection required, matches actual llama biology</li>
                </ul>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-3">Birthing and After</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Birthing records tied to the breeding plan</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Cria gender, type, color, and birth weight</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Weaning milestone tracking</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Post-weaning outcome recording</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Full breeding history per animal for future decisions</li>
                </ul>
              </div>
            </div>
          </div>
        </details>

        <!-- Cria Care -->
        <details id="cria" class="accordion-section border border-gray-200 rounded-lg">
          <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
            <div class="flex items-center gap-4">
              <span class="text-3xl">🐣</span>
              <div>
                <h3 class="text-2xl font-bold">Cria Care and Early Development</h3>
                <p class="text-gray-600">Birth outcomes, neonatal health, nursing, and growth milestones</p>
              </div>
            </div>
            <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="accordion-content p-6 border-t border-gray-200">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">Birth Records</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Birth date, time, and presentation</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Birth weight tracking</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Sex, type, and color at birth</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Dam and sire linkage to pedigree</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Assistance level and delivery notes</li>
                </ul>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-3">Neonatal Health</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Nursing status: nursing well, assisted, bottle fed, orphaned</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Neonatal health: thriving, watch, critical</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Early vaccinations and treatments</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Veterinary care notes and follow-up records</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Weight milestones through weaning</li>
                </ul>
              </div>
            </div>
          </div>
        </details>

        <!-- Fiber Records -->
        <details id="fiber" class="accordion-section border border-gray-200 rounded-lg">
          <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
            <div class="flex items-center gap-4">
              <span class="text-3xl">🧶</span>
              <div>
                <h3 class="text-2xl font-bold">Fiber Records</h3>
                <p class="text-gray-600">Shearing, clip weights, quality notes, and production context</p>
              </div>
            </div>
            <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="accordion-content p-6 border-t border-gray-200">
            <p class="text-gray-700 mb-4">
              Fiber-focused llama programs can keep production records alongside breeding and health history, so
              the context buyers and other breeders care about is organized in one place.
            </p>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">Fiber Records</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Shearing records with date, weight, and notes</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Fiber quality notes: softness, luster, staple length</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Type-specific notes (Woolly, Silky, Suri lock structure)</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Show ribbon and fiber evaluation results</li>
                </ul>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-3">Production Context</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Historical clip weight per animal per year</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Fiber quality trend over the animal's lifetime</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Fiber notes published to public marketplace profile</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Linked to breeding history for genetic selection context</li>
                </ul>
              </div>
            </div>
          </div>
        </details>

        <!-- Health and Genetics -->
        <details id="health" class="accordion-section border border-gray-200 rounded-lg">
          <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
            <div class="flex items-center gap-4">
              <span class="text-3xl">🏥</span>
              <div>
                <h3 class="text-2xl font-bold">Health, Documents, and Genetics</h3>
                <p class="text-gray-600">Testing, medications, vet records, and pedigree genetics</p>
              </div>
            </div>
            <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="accordion-content p-6 border-t border-gray-200">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">Health Records</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Vaccination schedules and administration history</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Medication treatment courses with dose logging</li>
                  <li class="flex items-start"><span class="mr-2">•</span>BVD and disease testing documentation</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Fecal egg counts and parasite management records</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Uploaded health certificates and vet records</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Body weight and body condition score tracking</li>
                </ul>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-3">Genetics and Registration</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>DNA typing and parentage verification records</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Genetic testing documentation</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Multi-generation pedigree with lineage depth</li>
                  <li class="flex items-start"><span class="mr-2">•</span>ILR and LANA registration number storage</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Show record and performance results</li>
                </ul>
              </div>
            </div>
          </div>
        </details>

        <!-- Reproductive Inventory -->
        <details id="inventory" class="accordion-section border border-gray-200 rounded-lg">
          <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
            <div class="flex items-center gap-4">
              <span class="text-3xl">🧪</span>
              <div>
                <h3 class="text-2xl font-bold">Reproductive Inventory</h3>
                <p class="text-gray-600">Semen and embryo lots with storage tracking and quantity ledger</p>
              </div>
            </div>
            <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="accordion-content p-6 border-t border-gray-200">
            <p class="text-gray-700 mb-4">
              Programs using AI or embryo transfer for high-value herdsires can track all reproductive assets in
              one system, connected to the animals and breeding plans they belong to. No more handwritten tank
              records or disconnected spreadsheets.
            </p>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">Semen Lots</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Sire identity, collection date, and collection method</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Straw count, format, and extender</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Pre-freeze and post-thaw motility percentages</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Health testing documentation per lot</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Accession number and lot number tracking</li>
                </ul>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-3">Embryo Lots</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Donor dam and sire linkage to animal records</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Collection date and fertilization type</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Embryo stage and grade per lot</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Freeze method and freeze date</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Genetic testing status and results</li>
                </ul>
              </div>
            </div>
            <div class="mt-4 grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">Storage Tracking</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Multiple storage providers: vet clinics, IVF labs, owner tanks</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Container and position tracking (cane, canister, goblet)</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Active and inactive container status</li>
                </ul>
              </div>
              <div>
                <h4 class="font-bold text-lg mb-3">Quantity Ledger</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Append-only transaction history per lot</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Events: received, used, transferred, shipped, disposed</li>
                  <li class="flex items-start"><span class="mr-2">•</span>Auto-depletes lot when quantity reaches zero</li>
                </ul>
              </div>
            </div>
          </div>
        </details>

        <!-- Buyers and Clients -->
        <details id="buyers" class="accordion-section border border-gray-200 rounded-lg">
          <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
            <div class="flex items-center gap-4">
              <span class="text-3xl">👥</span>
              <div>
                <h3 class="text-2xl font-bold">Buyer and Client Workflow</h3>
                <p class="text-gray-600">Inquiries, waitlists, contracts, and sales pipeline</p>
              </div>
            </div>
            <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="accordion-content p-6 border-t border-gray-200">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <h4 class="font-bold text-lg mb-3">Sales Pipeline</h4>
                <ul class="space-y-2 text-gray-700">
                  <li class="flex items-start"><span class="mr-2">•</span>Buyer inquiry tracking and response management</li>
