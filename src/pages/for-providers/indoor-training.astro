---
import BaseLayout from '../../layouts/BaseLayout.astro';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Service Providers', url: '/for-providers' },
  { name: 'Indoor Training Halls', url: '/for-providers/indoor-training' }
];
---
<BaseLayout
  title="Indoor Training Halls on BreederHQ Marketplace"
  description="List your indoor training hall, agility space, flyball lanes, scent work room, or cat play studio on the BreederHQ Marketplace. $5/month, no commissions."
  breadcrumbs={breadcrumbs}
>
<main>
  <section class="bg-gradient-to-b from-sky-50 to-white py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-4xl mb-4">🏟️</div>
      <h1 class="text-5xl font-bold tracking-tight text-gray-900 mb-6">Indoor Training Halls</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-10">
        Indoor halls and rooms for dog sports, agility, flyball, scent work, obedience, cat play, and small-animal training.
        Trainers and handlers are searching the BreederHQ Marketplace for indoor space to rent.
      </p>
      <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-sky-700 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-sky-600">
        List Your Training Hall
      </a>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">What you can list</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
          <h3 class="font-semibold text-gray-900 mb-2">Dog Sport Spaces</h3>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>Agility halls with tunnels, jumps, weave poles</li>
            <li>Flyball lanes</li>
            <li>Scent work rooms with boxes and articles</li>
            <li>Obedience and competition prep halls</li>
            <li>Multi-species and rental-by-the-hour spaces</li>
          </ul>
        </div>
        <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
          <h3 class="font-semibold text-gray-900 mb-2">Other Indoor Spaces</h3>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>Cat play studios for socialization and enrichment</li>
            <li>Small-animal training rooms (rabbits, exotics)</li>
            <li>Climate-controlled halls for year-round work</li>
            <li>Sound-dampened rooms for reactive-dog work</li>
            <li>Observation areas and crating zones</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-stone-50">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Why it works for hall owners</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-2xl mb-3">🎯</div>
          <h3 class="font-semibold text-gray-900 mb-2">High-intent traffic</h3>
          <p class="text-sm text-gray-600">Trainers searching for indoor space have a session in mind. They're not browsing. They need a hall this week.</p>
        </div>
        <div class="text-center">
          <div class="text-2xl mb-3">📐</div>
          <h3 class="font-semibold text-gray-900 mb-2">Filter by what matters</h3>
          <p class="text-sm text-gray-600">List square footage, ceiling height, flooring type, and equipment available. Trainers self-qualify before contacting you.</p>
        </div>
        <div class="text-center">
          <div class="text-2xl mb-3">🔁</div>
          <h3 class="font-semibold text-gray-900 mb-2">Recurring renters</h3>
          <p class="text-sm text-gray-600">Sport trainers and behavior pros book the same hall over and over. One trainer can mean weekly or monthly recurring rentals.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">Your listing includes</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-sky-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Subtype, species supported, square footage, ceiling height</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-sky-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Flooring type, climate control, sound dampening</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-sky-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Equipment list (jumps, tunnels, weave poles, scent boxes, mirrors)</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-sky-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Private rental availability and reactive-dog policies</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-sky-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Vaccination requirements, waivers, secure entry</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-sky-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Hourly or per-handler pricing, photos, inquiry-to-book workflow</span>
        </div>
      </div>
      <p class="text-sm text-gray-500 mt-6 text-center">
        Indoor training halls use a contact-to-book workflow: trainers send an inquiry, you confirm scheduling and arrange payment directly.
      </p>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-br from-sky-900 to-sky-800">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4 text-white"><span class="line-through opacity-60 text-2xl">$5/mo</span> Free during early access</h2>
      <p class="text-sm text-sky-200 mb-3">No commissions. No per-session fees. Cancel anytime.</p>
      <p class="text-lg text-sky-200 mb-8">Get your training hall in front of every trainer and handler searching for indoor space in your region.</p>
      <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-white text-sky-800 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-sky-50">
        List Your Training Hall
      </a>
    </div>
  </section>
</main>
</BaseLayout>
