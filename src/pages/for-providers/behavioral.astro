---
import BaseLayout from '../../layouts/BaseLayout.astro';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Service Providers', url: '/for-providers' },
  { name: 'Behavioral', url: '/for-providers/behavioral' }
];
---
<BaseLayout
  title="Behavioral Services on BreederHQ Marketplace"
  description="List your behavior modification practice on the BreederHQ Marketplace. Be seen by breeders, buyers, and pet owners searching for behavioral specialists in their area."
  breadcrumbs={breadcrumbs}
>
<main>
  <section class="bg-gradient-to-b from-emerald-50 to-white py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-4xl mb-4">🧠</div>
      <h1 class="text-5xl font-bold tracking-tight text-gray-900 mb-6">Behavioral Services</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-10">
        Behavior consultants, modification specialists, and veterinary behaviorists -
        breeders, buyers, and pet owners in your area are searching for behavioral services on the BreederHQ Marketplace.
      </p>
      <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-emerald-700 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-emerald-600">
        List Your Practice
      </a>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">What people search for</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
          <h3 class="font-semibold text-gray-900 mb-2">From Breeders</h3>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>Temperament evaluation for breeding stock</li>
            <li>Litter behavioral assessments</li>
            <li>Fear period guidance and early intervention</li>
            <li>Resource guarding prevention in young animals</li>
            <li>Behavioral screening before placement</li>
            <li>Consults for returned animals with behavior issues</li>
            <li>Breeding program temperament improvement</li>
          </ul>
        </div>
        <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
          <h3 class="font-semibold text-gray-900 mb-2">From Buyers &amp; Pet Owners</h3>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>Reactivity and leash aggression</li>
            <li>Separation anxiety treatment</li>
            <li>Fear-based behavior modification</li>
            <li>Inter-animal aggression in multi-pet homes</li>
            <li>Compulsive and repetitive behaviors</li>
            <li>New pet integration and adjustment issues</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-stone-50">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Why it works for behaviorists</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-2xl mb-3">🔄</div>
          <h3 class="font-semibold text-gray-900 mb-2">Long-term cases</h3>
          <p class="text-sm text-gray-600">Behavior modification takes time. Clients need ongoing sessions and follow-ups, making each case a multi-visit relationship.</p>
        </div>
        <div class="text-center">
          <div class="text-2xl mb-3">📍</div>
          <h3 class="font-semibold text-gray-900 mb-2">Local search</h3>
          <p class="text-sm text-gray-600">People search by location and issue type. If you specialize in what they need and you're nearby, they find you.</p>
        </div>
        <div class="text-center">
          <div class="text-2xl mb-3">⭐</div>
          <h3 class="font-semibold text-gray-900 mb-2">Verification builds trust</h3>
          <p class="text-sm text-gray-600">Upload your credentials for a verified badge. Behavioral work requires trust, and verification helps clients choose you with confidence.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">Your listing includes</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Practice profile with specializations, methods, and availability</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Coverage area and location-based discovery</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Photos of your facility and consultation space</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Flexible pricing display</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Optional verification badge for credentials</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Recommendations from your clients</span>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-br from-emerald-900 to-emerald-800">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4 text-white">$5/mo. No commissions. Cancel anytime.</h2>
      <p class="text-lg text-emerald-200 mb-8">One listing puts your practice in front of everyone searching for behavioral services on the marketplace.</p>
      <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-white text-emerald-800 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-emerald-50">
        List Your Practice
      </a>
    </div>
  </section>
</main>
</BaseLayout>
