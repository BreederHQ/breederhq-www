---
import BaseLayout from '../../layouts/BaseLayout.astro';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Service Providers', url: '/for-providers' },
  { name: 'Boarding', url: '/for-providers/boarding' }
];
---
<BaseLayout
  title="Boarding Services on BreederHQ Marketplace"
  description="List your boarding facility on the BreederHQ Marketplace. Be seen by breeders, buyers, and pet owners searching for boarding and daycare services in their area."
  breadcrumbs={breadcrumbs}
>
<main>
  <section class="bg-gradient-to-b from-emerald-50 to-white py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-4xl mb-4">🏠</div>
      <h1 class="text-5xl font-bold tracking-tight text-gray-900 mb-6">Boarding Services</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-10">
        Boarding kennels, daycare facilities, and long-term care providers -
        breeders, buyers, and pet owners in your area are searching for boarding services on the BreederHQ Marketplace.
      </p>
      <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-emerald-700 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-emerald-600">
        List Your Boarding Facility
      </a>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">What people search for</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
          <h3 class="font-semibold text-gray-900 mb-2">From Breeders</h3>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>Boarding during show weekends and circuits</li>
            <li>Care for breeding stock during travel</li>
            <li>Facilities experienced with intact animals</li>
            <li>Monitoring for pregnant or nursing females</li>
            <li>Multi-animal boarding for entire strings</li>
            <li>Separate housing for breeding pairs</li>
            <li>Exercise and enrichment programs</li>
          </ul>
        </div>
        <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
          <h3 class="font-semibold text-gray-900 mb-2">From Buyers &amp; Pet Owners</h3>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>Vacation and holiday boarding</li>
            <li>Daycare for work hours</li>
            <li>Extended stay boarding</li>
            <li>Medication administration during stays</li>
            <li>Socialization and play groups</li>
            <li>Webcam access and daily updates</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-stone-50">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Why it works for boarding facilities</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-2xl mb-3">🔄</div>
          <h3 class="font-semibold text-gray-900 mb-2">Repeat customers</h3>
          <p class="text-sm text-gray-600">Once someone trusts your facility, they come back every trip, every show weekend, every holiday. Breeders with show schedules need you regularly.</p>
        </div>
        <div class="text-center">
          <div class="text-2xl mb-3">📍</div>
          <h3 class="font-semibold text-gray-900 mb-2">Local search</h3>
          <p class="text-sm text-gray-600">People search by location and facility type. If you're convenient to their home or travel route, they find you.</p>
        </div>
        <div class="text-center">
          <div class="text-2xl mb-3">⭐</div>
          <h3 class="font-semibold text-gray-900 mb-2">Identity and credentials</h3>
          <p class="text-sm text-gray-600">Document your licenses and certifications on your profile. Identity is confirmed via Stripe Identity. BreederHQ does not validate insurance, licensing, or facility documents.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">Your listing includes</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Facility profile with amenities, capacity, and hours</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Coverage area and location-based discovery</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Photos of your facility, runs, and play areas</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Flexible pricing display</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Identity confirmation via Stripe Identity, registry passthrough where supported</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Recommendations from your clients</span>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-br from-emerald-900 to-emerald-800">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4 text-white">Free</h2>
      <p class="text-sm text-emerald-200 mb-3">No commissions. Cancel anytime.</p>
      <p class="text-lg text-emerald-200 mb-8">One listing puts your facility in front of everyone searching for boarding services on the marketplace.</p>
      <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-white text-emerald-800 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-emerald-50">
        List Your Boarding Facility
      </a>
    </div>
  </section>
</main>
</BaseLayout>
