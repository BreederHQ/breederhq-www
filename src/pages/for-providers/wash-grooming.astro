---
import BaseLayout from '../../layouts/BaseLayout.astro';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Service Providers', url: '/for-providers' },
  { name: 'Wash & Grooming Spaces', url: '/for-providers/wash-grooming' }
];
---
<BaseLayout
  title="Wash & Grooming Spaces on BreederHQ Marketplace"
  description="List your self-wash setup, grooming bay, or wash rack on the BreederHQ Marketplace and get found by owners. Free to list, no commissions."
  breadcrumbs={breadcrumbs}
>
<main>
  <section class="bg-gradient-to-b from-pink-50 to-white py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-4xl mb-4">🛁</div>
      <h1 class="text-5xl font-bold tracking-tight text-gray-900 mb-6">Wash &amp; Grooming Spaces</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-10">
        Self-wash setups, pro grooming bay rentals, dog wash bars, and dedicated wash racks for livestock or horses.
        Owners and groomers are searching the BreederHQ Marketplace for clean, well-equipped wash space.
      </p>
      <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-pink-700 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-pink-600">
        List Your Wash Space
      </a>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">What you can list</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
          <h3 class="font-semibold text-gray-900 mb-2">Companion Animal Wash</h3>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>Self-wash tubs (walk-in or raised)</li>
            <li>Pro grooming bay rentals for traveling groomers</li>
            <li>Dog wash bars with hot water and dryers</li>
            <li>Hydraulic tables and grooming arms</li>
            <li>Force dryers and stand dryers</li>
          </ul>
        </div>
        <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
          <h3 class="font-semibold text-gray-900 mb-2">Large-Animal Wash</h3>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>Equine wash racks with hot/cold water</li>
            <li>Livestock wash racks for show prep</li>
            <li>Cross-ties and tie rails</li>
            <li>Non-slip flooring and drainage</li>
            <li>Power outlets for clippers and dryers</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-stone-50">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Why it works for wash space owners</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-2xl mb-3">⏱️</div>
          <h3 class="font-semibold text-gray-900 mb-2">Quick-turn rentals</h3>
          <p class="text-sm text-gray-600">Wash sessions are short. A single bay can rent multiple times a day, and the marketplace surfaces you when local owners need a tub.</p>
        </div>
        <div class="text-center">
          <div class="text-2xl mb-3">🧴</div>
          <h3 class="font-semibold text-gray-900 mb-2">Show what's included</h3>
          <p class="text-sm text-gray-600">List station count, dryer type, supplies provided, and large-animal safety. Owners and pro groomers self-qualify.</p>
        </div>
        <div class="text-center">
          <div class="text-2xl mb-3">💼</div>
          <h3 class="font-semibold text-gray-900 mb-2">B2B grooming rentals</h3>
          <p class="text-sm text-gray-600">Mobile groomers and pet stylists rent bays by the hour. One pro groomer can mean weekly recurring revenue.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">Your listing includes</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-pink-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Subtype, species supported, station and tub count</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-pink-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Hot water available, dryer type, hydraulic table</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-pink-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Supplies included (shampoo, towels, brushes, nail tools)</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-pink-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Non-slip flooring, ear protection, aprons provided</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-pink-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Drainage appropriate for animals, large-animal safe</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-pink-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Per-session or per-hour pricing, photos, inquiry-to-book</span>
        </div>
      </div>
      <p class="text-sm text-gray-500 mt-6 text-center">
        Wash and grooming spaces use a contact-to-book workflow: owners send an inquiry, you confirm scheduling and arrange payment directly.
      </p>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-br from-pink-900 to-pink-800">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4 text-white">Free</h2>
      <p class="text-sm text-pink-200 mb-3">No commissions. No per-session fees. Cancel anytime.</p>
      <p class="text-lg text-pink-200 mb-8">Get your wash bay or grooming space in front of every owner and pro groomer searching in your region.</p>
      <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-white text-pink-800 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-pink-50">
        List Your Wash Space
      </a>
    </div>
  </section>
</main>
</BaseLayout>
