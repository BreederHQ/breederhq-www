---
import BaseLayout from '../../layouts/BaseLayout.astro';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Service Providers', url: '/for-providers' },
  { name: 'Pet Sitting', url: '/for-providers/pet-sitting' }
];
---
<BaseLayout
  title="Pet Sitting Services on BreederHQ Marketplace"
  description="List your pet sitting business on the BreederHQ Marketplace. Be seen by breeders, buyers, and pet owners searching for in-home pet care services in their area."
  breadcrumbs={breadcrumbs}
>
<main>
  <section class="bg-gradient-to-b from-emerald-50 to-white py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-4xl mb-4">🐾</div>
      <h1 class="text-5xl font-bold tracking-tight text-gray-900 mb-6">Pet Sitting Services</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-10">
        In-home sitters, daily visit providers, and overnight care specialists -
        breeders, buyers, and pet owners in your area are searching for pet sitting services on the BreederHQ Marketplace.
      </p>
      <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-emerald-700 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-emerald-600">
        List Your Pet Sitting Business
      </a>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">What people search for</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
          <h3 class="font-semibold text-gray-900 mb-2">From Breeders</h3>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>In-home care for multiple animals</li>
            <li>Monitoring pregnant or nursing females</li>
            <li>Medication and supplement administration</li>
            <li>Whelping or birthing watch support</li>
            <li>Feeding schedules for litters</li>
            <li>Daily check-ins while traveling to shows</li>
            <li>Experienced sitters comfortable with intact animals</li>
          </ul>
        </div>
        <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
          <h3 class="font-semibold text-gray-900 mb-2">From Buyers &amp; Pet Owners</h3>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>Vacation house sitting with pet care</li>
            <li>Daily drop-in visits</li>
            <li>Overnight stays in their home</li>
            <li>Medication administration</li>
            <li>Walking and exercise during visits</li>
            <li>Care for elderly or special-needs animals</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-stone-50">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Why it works for pet sitters</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-2xl mb-3">🔄</div>
          <h3 class="font-semibold text-gray-900 mb-2">Loyal clients</h3>
          <p class="text-sm text-gray-600">Once someone trusts you in their home with their animals, they never want to find someone else. Breeders with show schedules need you year-round.</p>
        </div>
        <div class="text-center">
          <div class="text-2xl mb-3">📍</div>
          <h3 class="font-semibold text-gray-900 mb-2">Local search</h3>
          <p class="text-sm text-gray-600">People search by location and service type. If you're in their neighborhood and offer what they need, they find you.</p>
        </div>
        <div class="text-center">
          <div class="text-2xl mb-3">⭐</div>
          <h3 class="font-semibold text-gray-900 mb-2">Verification builds trust</h3>
          <p class="text-sm text-gray-600">Upload your certifications and insurance for a verified badge. People are letting you into their home - verification matters.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">Your listing includes</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Profile with services, experience, and availability</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Coverage area and location-based discovery</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Photos showcasing your care and environment</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Flexible pricing display</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Optional verification badge for insurance and certifications</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Recommendations from your clients</span>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-br from-emerald-900 to-emerald-800">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4 text-white">$5/mo. No commissions. Cancel anytime.</h2>
      <p class="text-lg text-emerald-200 mb-8">One listing puts your pet sitting business in front of everyone searching for in-home care on the marketplace.</p>
      <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-white text-emerald-800 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-emerald-50">
        List Your Pet Sitting Business
      </a>
    </div>
  </section>
</main>
</BaseLayout>
