---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Service Providers', url: '/for-providers' },
  { name: 'Buck Service', url: '/for-providers/buck-service' }
];

const faqs = [
  {
    question: 'Who is the buck service category for?',
    answer: 'Goat breeders offering driveway breeding, walk-in service, or short-term buck lease arrangements with their own registered bucks. Both dairy and meat goat operations.'
  },
  {
    question: 'How much does it cost to list?',
    answer: 'Provider listings are free. No commissions, no per-inquiry fees, and no per-booking fees.'
  },
  {
    question: 'Does BreederHQ verify my buck\'s health-testing posture?',
    answer: 'No. Your stated CAE / CL / Johne\'s posture is your own attestation on your profile. BreederHQ does not independently verify lab results. Breeders self-qualify based on what you publish. See /trust for the full policy.'
  }
];
---

<BaseLayout
  title="List Your Buck Service on BreederHQ Marketplace"
  description="Provider acquisition page for goat breeders offering driveway, walk-in, or short-lease buck service. Free to list. No commissions."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <main>
    <section class="bg-gradient-to-b from-amber-50 to-white py-20">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-block bg-amber-100 text-amber-800 text-xs font-semibold uppercase tracking-wide px-3 py-1 rounded-full mb-4">For Buck Owners</div>
        <h1 class="text-5xl font-bold tracking-tight text-gray-900 mb-6">List Your Buck Service</h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-10">A buck pen that stays full pays for itself. A real listing makes you findable to breeders looking for outside service with documented genetics and a stated health-test posture.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-amber-700 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-amber-600">List Your Buck Service</a>
          <a href="/services/buck-service" class="bg-white text-amber-800 px-8 py-4 rounded-lg text-lg font-semibold border border-amber-200 hover:bg-amber-50">See the Browse Page</a>
        </div>
        <p class="text-xs text-gray-500 mt-6">Free to list. No commissions. No per-booking fees.</p>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">What Your Listing Surfaces</h2>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg"><span class="text-amber-700 font-bold mt-0.5">&#10003;</span><span class="text-sm text-gray-700"><strong class="text-gray-900">Service type.</strong> Driveway, walk-in, short-term lease.</span></div>
          <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg"><span class="text-amber-700 font-bold mt-0.5">&#10003;</span><span class="text-sm text-gray-700"><strong class="text-gray-900">Buck genetics.</strong> Pedigree, registry, sire stack, dam appraisal and production where relevant.</span></div>
          <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg"><span class="text-amber-700 font-bold mt-0.5">&#10003;</span><span class="text-sm text-gray-700"><strong class="text-gray-900">Health-test posture.</strong> Stated CAE / CL / Johne's testing dates and posture.</span></div>
          <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg"><span class="text-amber-700 font-bold mt-0.5">&#10003;</span><span class="text-sm text-gray-700"><strong class="text-gray-900">Doe intake requirements.</strong> Health-test expectations, vaccine requirements, season.</span></div>
          <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg"><span class="text-amber-700 font-bold mt-0.5">&#10003;</span><span class="text-sm text-gray-700"><strong class="text-gray-900">Service memo / breeding letter.</strong> Documentation you provide for registry transfer.</span></div>
          <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg"><span class="text-amber-700 font-bold mt-0.5">&#10003;</span><span class="text-sm text-gray-700"><strong class="text-gray-900">Refund / re-service policy.</strong> Live kid guarantee terms, re-service window.</span></div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-stone-50">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Frequently Asked Questions</h2>
        <div class="space-y-6">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl p-6 border border-stone-200">
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-sm text-gray-600">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Provider Categories</h2>
        <div class="grid md:grid-cols-3 gap-4">
          <a href="/for-providers/caprine-services" class="block bg-stone-50 rounded-xl p-5 border border-stone-200 hover:border-amber-300 hover:shadow-sm transition"><h3 class="font-semibold text-gray-900 mb-1">All Caprine Services</h3><p class="text-sm text-gray-600">Umbrella page for goat-specific providers.</p></a>
          <a href="/for-providers/goat-ai-technician" class="block bg-stone-50 rounded-xl p-5 border border-stone-200 hover:border-amber-300 hover:shadow-sm transition"><h3 class="font-semibold text-gray-900 mb-1">Goat AI Technician</h3><p class="text-sm text-gray-600">Sibling reproductive-service category.</p></a>
          <a href="/for-providers/mobile-goat-vet" class="block bg-stone-50 rounded-xl p-5 border border-stone-200 hover:border-amber-300 hover:shadow-sm transition"><h3 class="font-semibold text-gray-900 mb-1">Mobile Goat Vet</h3><p class="text-sm text-gray-600">For pre-breeding workups and pregnancy ultrasound.</p></a>
        </div>
      </div>
    </section>

    <section class="py-16 bg-gradient-to-br from-amber-900 to-amber-800">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold mb-4 text-white">List Your Buck Service</h2>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-white text-amber-800 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-amber-50">Claim Your Listing</a>
          <a href="/trust" class="bg-amber-700 text-white px-8 py-4 rounded-lg text-lg font-semibold border border-amber-600 hover:bg-amber-600">Identity &amp; Credentials Policy</a>
        </div>
        <p class="text-xs text-amber-200 mt-6">Free to list. No commissions. Cancel anytime.</p>
      </div>
    </section>
  </main>
</BaseLayout>
