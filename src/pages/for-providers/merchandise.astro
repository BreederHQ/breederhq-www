---
import BaseLayout from '../../layouts/BaseLayout.astro';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Service Providers', url: '/for-providers' },
  { name: 'Merchandise', url: '/for-providers/merchandise' }
];
---
<BaseLayout
  title="Pet Merchandise & Supplies on BreederHQ Marketplace"
  description="List your handmade goods, pet products, and supplies on the BreederHQ Marketplace. Be seen by breeders, buyers, and pet owners searching for quality pet merchandise."
  breadcrumbs={breadcrumbs}
>
<main>
  <section class="bg-gradient-to-b from-emerald-50 to-white py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-4xl mb-4">🎁</div>
      <h1 class="text-5xl font-bold tracking-tight text-gray-900 mb-6">Merchandise &amp; Supplies</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-10">
        Handmade goods creators, pet supply shops, and custom product makers -
        breeders, buyers, and pet owners are searching for quality pet merchandise on the BreederHQ Marketplace.
      </p>
      <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-emerald-700 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-emerald-600">
        List Your Products
      </a>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">What people search for</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
          <h3 class="font-semibold text-gray-900 mb-2">From Breeders</h3>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>Whelping and birthing supplies and kits</li>
            <li>Custom puppy packs and go-home bags</li>
            <li>Breed-specific collars, leads, and ID tags</li>
            <li>Branded kennel merchandise and apparel</li>
            <li>Microchip scanners and scales</li>
            <li>Show supplies and grooming equipment</li>
            <li>Bulk ordering for litters and program needs</li>
          </ul>
        </div>
        <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
          <h3 class="font-semibold text-gray-900 mb-2">From Buyers &amp; Pet Owners</h3>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>Custom collars, harnesses, and accessories</li>
            <li>Handmade treats and chews</li>
            <li>Personalized pet beds and blankets</li>
            <li>Breed-themed gifts and decor</li>
            <li>Training supplies and enrichment toys</li>
            <li>Grooming kits and care products</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-stone-50">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Why it works for merchandise sellers</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-2xl mb-3">🔄</div>
          <h3 class="font-semibold text-gray-900 mb-2">Repeat orders</h3>
          <p class="text-sm text-gray-600">Breeders order puppy packs, collars, and supplies for every litter. One breeder relationship can mean dozens of repeat orders per year.</p>
        </div>
        <div class="text-center">
          <div class="text-2xl mb-3">🎯</div>
          <h3 class="font-semibold text-gray-900 mb-2">Targeted audience</h3>
          <p class="text-sm text-gray-600">Everyone on the marketplace is an animal person. No wasted impressions, because your products are seen by people who actually buy pet merchandise.</p>
        </div>
        <div class="text-center">
          <div class="text-2xl mb-3">⭐</div>
          <h3 class="font-semibold text-gray-900 mb-2">Recommendations spread</h3>
          <p class="text-sm text-gray-600">Breeders talk to each other. One great custom collar order turns into referrals across an entire breed community.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">Your listing includes</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Storefront profile with product categories and descriptions</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Coverage area and location-based discovery</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Product photos and gallery</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Flexible pricing display</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Optional verification badge for business credentials</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-emerald-600 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Breeder recommendations from your customers</span>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-br from-emerald-900 to-emerald-800">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4 text-white"><span class="line-through opacity-60 text-2xl">$5/mo</span> Free during early access</h2>
      <p class="text-sm text-emerald-200 mb-3">No commissions. Cancel anytime.</p>
      <p class="text-lg text-emerald-200 mb-8">One listing puts your products in front of everyone browsing for pet merchandise on the marketplace.</p>
      <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-white text-emerald-800 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-emerald-50">
        List Your Products
      </a>
    </div>
  </section>
</main>
</BaseLayout>
