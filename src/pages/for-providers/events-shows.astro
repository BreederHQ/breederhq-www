---
import BaseLayout from '../../layouts/BaseLayout.astro';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Service Providers', url: '/for-providers' },
  { name: 'Event & Show Spaces', url: '/for-providers/events-shows' }
];
---
<BaseLayout
  title="Event & Show Spaces on BreederHQ Marketplace"
  description="List your trial venue, conformation ring, clinic space, or photo studio on the BreederHQ Marketplace and get found. $5/month, no commissions."
  breadcrumbs={breadcrumbs}
>
<main>
  <section class="bg-gradient-to-b from-violet-50 to-white py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-4xl mb-4">🏆</div>
      <h1 class="text-5xl font-bold tracking-tight text-gray-900 mb-6">Event &amp; Show Spaces</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-10">
        Trial venues, conformation rings, agility trial sites, fun matches, clinic spaces, photo studios, and breed club meeting spaces.
        Clubs and event organizers are searching the BreederHQ Marketplace for the right venue.
      </p>
      <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-violet-700 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-violet-600">
        List Your Event Space
      </a>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">What you can list</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
          <h3 class="font-semibold text-gray-900 mb-2">Competition Venues</h3>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>Trial venues (obedience, rally, scent, herding)</li>
            <li>Conformation rings with judging stand</li>
            <li>Agility trial sites with regulation equipment</li>
            <li>Fun match venues for novice exhibitors</li>
            <li>Breed-specialty club meeting space</li>
          </ul>
        </div>
        <div class="bg-stone-50 rounded-xl p-6 border border-stone-200">
          <h3 class="font-semibold text-gray-900 mb-2">Education &amp; Media</h3>
          <ul class="text-sm text-gray-600 space-y-2">
            <li>Clinic spaces for visiting trainers and judges</li>
            <li>Education and seminar rooms</li>
            <li>Photo studios for show photography and breed portraits</li>
            <li>Indoor and outdoor multi-day rental options</li>
            <li>RV hookups for traveling exhibitors</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-stone-50">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-8">Why it works for event venue owners</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center">
          <div class="text-2xl mb-3">📅</div>
          <h3 class="font-semibold text-gray-900 mb-2">Pre-planned demand</h3>
          <p class="text-sm text-gray-600">Clubs and trial secretaries plan their seasons months out. A discoverable venue listing wins early calendar slots.</p>
        </div>
        <div class="text-center">
          <div class="text-2xl mb-3">🅿️</div>
          <h3 class="font-semibold text-gray-900 mb-2">Show capacity up front</h3>
          <p class="text-sm text-gray-600">List capacity, ring count, parking, RV hookups, restrooms, and vendor area. Trial secretaries pick venues that match exactly.</p>
        </div>
        <div class="text-center">
          <div class="text-2xl mb-3">🌐</div>
          <h3 class="font-semibold text-gray-900 mb-2">Cross-club visibility</h3>
          <p class="text-sm text-gray-600">A single listing reaches the breed clubs, sport orgs, and event planners using BreederHQ for venue discovery.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">Your listing includes</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-violet-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Subtype, species supported, capacity, ring count</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-violet-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Indoor/outdoor, parking capacity, RV hookups, restrooms</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-violet-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Judging stand, PA system, shaded ring, lighting, warmup ring</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-violet-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Vendor area, spectator seating, registration check-in area</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-violet-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Electrical access, water access, cleanup and disposal area</span>
        </div>
        <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg">
          <span class="text-violet-700 font-bold mt-0.5">&#10003;</span>
          <span class="text-sm text-gray-700">Per-day, per-event, or flat rental pricing. Multi-day blocks supported</span>
        </div>
      </div>
      <p class="text-sm text-gray-500 mt-6 text-center">
        Event and show spaces use a per-event contact-to-book workflow: organizers send an inquiry with their dates and requirements, you confirm and arrange payment directly.
      </p>
    </div>
  </section>

  <section class="py-16 bg-gradient-to-br from-violet-900 to-violet-800">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4 text-white"><span class="line-through opacity-60 text-2xl">$5/mo</span> Free during early access</h2>
      <p class="text-sm text-violet-200 mb-3">No commissions. No per-event fees. Cancel anytime.</p>
      <p class="text-lg text-violet-200 mb-8">Get your event venue in front of breed clubs, trial secretaries, and event planners building next season's calendar.</p>
      <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-white text-violet-800 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-violet-50">
        List Your Event Space
      </a>
    </div>
  </section>
</main>
</BaseLayout>
