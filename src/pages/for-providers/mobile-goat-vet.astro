---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Service Providers', url: '/for-providers' },
  { name: 'Mobile Goat Vet', url: '/for-providers/mobile-goat-vet' }
];

const faqs = [
  {
    question: 'Who is the mobile goat vet category for?',
    answer: 'Ambulatory veterinarians and veterinary practices that include goats in their regular caseload — herd workups, biosecurity, surgical, repro, and emergency care.'
  },
  {
    question: 'How much does it cost to list?',
    answer: 'Flat $5 per month per provider account during general availability. No commissions, no per-inquiry fees. Early access listings are free.'
  },
  {
    question: 'Why a separate category from veterinary specialists?',
    answer: 'A practice that sees goats every week is a different resource than one that sees them quarterly. Goat breeders want to find the former without scrolling through the latter.'
  }
];
---

<BaseLayout
  title="List Your Mobile Goat Veterinary Practice on BreederHQ Marketplace"
  description="Provider acquisition page for ambulatory veterinarians with regular caprine caseload. Herd workups, CAE / CL / Johne's pulls, kidding emergencies. Flat $5/month. No commissions."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <main>
    <section class="bg-gradient-to-b from-amber-50 to-white py-20">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-block bg-amber-100 text-amber-800 text-xs font-semibold uppercase tracking-wide px-3 py-1 rounded-full mb-4">For Mobile Goat Vets</div>
        <h1 class="text-5xl font-bold tracking-tight text-gray-900 mb-6">List Your Mobile Goat Veterinary Practice</h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-10">Goat breeders desperately want a veterinarian who actually works goats. A real, caprine-specific listing surfaces your practice to the right caseload.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-amber-700 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-amber-600">List Your Practice</a>
          <a href="/services/mobile-goat-vet" class="bg-white text-amber-800 px-8 py-4 rounded-lg text-lg font-semibold border border-amber-200 hover:bg-amber-50">See the Browse Page</a>
        </div>
        <p class="text-xs text-gray-500 mt-6">Flat $5/month per account. No commissions. No per-booking fees.</p>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">What Your Listing Surfaces</h2>
        <div class="grid md:grid-cols-2 gap-4">
          <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg"><span class="text-amber-700 font-bold mt-0.5">&#10003;</span><span class="text-sm text-gray-700"><strong class="text-gray-900">Goat caseload depth.</strong> Approximate weekly or monthly goat appointments.</span></div>
          <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg"><span class="text-amber-700 font-bold mt-0.5">&#10003;</span><span class="text-sm text-gray-700"><strong class="text-gray-900">Service area and ambulatory range.</strong> Counties and radius.</span></div>
          <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg"><span class="text-amber-700 font-bold mt-0.5">&#10003;</span><span class="text-sm text-gray-700"><strong class="text-gray-900">Scope.</strong> Repro, ultrasound, surgical, emergency, herd workups, CVI issuance.</span></div>
          <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg"><span class="text-amber-700 font-bold mt-0.5">&#10003;</span><span class="text-sm text-gray-700"><strong class="text-gray-900">After-hours coverage.</strong> On-call posture, kidding-season availability.</span></div>
          <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg"><span class="text-amber-700 font-bold mt-0.5">&#10003;</span><span class="text-sm text-gray-700"><strong class="text-gray-900">Pricing baseline.</strong> Trip fee, mileage, minimum-call cost.</span></div>
          <div class="flex items-start gap-3 p-4 bg-stone-50 rounded-lg"><span class="text-amber-700 font-bold mt-0.5">&#10003;</span><span class="text-sm text-gray-700"><strong class="text-gray-900">Identity passthrough.</strong> Optional Stripe Identity confirmation surfaced on your profile.</span></div>
        </div>
      </div>
    </section>

    <section class="py-16 bg-stone-50">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-8 text-center">Frequently Asked Questions</h2>
        <div class="space-y-6">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl p-6 border border-stone-200">
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-sm text-gray-600">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Related Provider Categories</h2>
        <div class="grid md:grid-cols-3 gap-4">
          <a href="/for-providers/caprine-services" class="block bg-stone-50 rounded-xl p-5 border border-stone-200 hover:border-amber-300 hover:shadow-sm transition"><h3 class="font-semibold text-gray-900 mb-1">All Caprine Services</h3><p class="text-sm text-gray-600">Umbrella page for goat-specific providers.</p></a>
          <a href="/for-providers/veterinary" class="block bg-stone-50 rounded-xl p-5 border border-stone-200 hover:border-amber-300 hover:shadow-sm transition"><h3 class="font-semibold text-gray-900 mb-1">Veterinary</h3><p class="text-sm text-gray-600">Cross-species veterinary listings.</p></a>
          <a href="/for-providers/health-testing" class="block bg-stone-50 rounded-xl p-5 border border-stone-200 hover:border-amber-300 hover:shadow-sm transition"><h3 class="font-semibold text-gray-900 mb-1">Health Testing</h3><p class="text-sm text-gray-600">Lab partners for CAE / CL / Johne's pulls.</p></a>
        </div>
      </div>
    </section>

    <section class="py-16 bg-gradient-to-br from-amber-900 to-amber-800">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold mb-4 text-white">List Your Mobile Goat Veterinary Practice</h2>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="https://accounts.breederhq.com/register?intent=provider_marketplace" class="bg-white text-amber-800 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-amber-50">Claim Your Listing</a>
          <a href="/trust" class="bg-amber-700 text-white px-8 py-4 rounded-lg text-lg font-semibold border border-amber-600 hover:bg-amber-600">Identity &amp; Credentials Policy</a>
        </div>
        <p class="text-xs text-amber-200 mt-6">Flat $5/month. No commissions. Cancel anytime.</p>
      </div>
    </section>
  </main>
</BaseLayout>
