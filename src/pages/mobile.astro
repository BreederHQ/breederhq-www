---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Mobile Companion', url: '/mobile' }
];

const faqs = [
  {
    question: 'Is the BreederHQ Mobile Companion a replacement for the web app?',
    answer: 'No. The Mobile Companion is intentionally not a full alternative to the BreederHQ web platform. The web app is where you run your program: setting up breeding plans, managing your storefront, configuring contracts, running reports, working in genetics, and everything else that needs a real screen. The Mobile Companion is built for the moments you are away from your laptop, when you just need to capture something quickly or check a piece of information from the barn, the vet office, or the show ring.'
  },
  {
    question: 'What is the Mobile Companion actually for?',
    answer: 'Quick capture and quick lookup. Recording newborn weights right after a birth, logging a vet visit before you forget, snapping a receipt photo, checking an animal profile or pedigree at a show, replying to a buyer message, marking a task done. The companion is deliberately scoped to the things you need away from a desk.'
  },
  {
    question: 'What should I still use the web app for?',
    answer: 'Setting up and editing breeding plans and programs, building your marketplace storefront and listings, configuring contracts and templates, financial reporting and reconciliation, deep genetics work and pedigree analysis, waitlist management and placement decisions, settings and team configuration, and any other configuration or analysis work. If a task involves more than a tap or two, the web app is the right tool.'
  },
  {
    question: 'Is the Mobile Companion included with my subscription?',
    answer: 'Yes. The Mobile Companion is included with every BreederHQ plan at no additional cost. Download it from the App Store or Google Play and log in with the same account you use on the web.'
  },
  {
    question: 'Will my data sync between phone and computer?',
    answer: 'Yes. Anything you capture in the Mobile Companion appears immediately in the web app, and anything you set up in the web app shows up in the companion. One account, one dataset.'
  },
  {
    question: 'Does the Mobile Companion work offline?',
    answer: 'The companion needs an internet connection to sync. It is built to work well on slower connections at the barn or vet office, but it is not a fully offline tool.'
  },
  {
    question: 'What devices are supported?',
    answer: 'iPhone (iOS 15+) and Android phones (Android 10+). For tablets, iPads, and laptops, use the web app at app.breederhq.com — it works in any modern browser.'
  },
  {
    question: 'Can I get push notifications?',
    answer: 'Yes. The Mobile Companion sends push notifications for new messages, waitlist applications, payments, contract signatures, and other time-sensitive events. You choose which ones you receive in Settings.'
  }
];

const featureCards = [
  { id: 'animals', icon: '🐾', title: 'Animal Management', desc: 'Browse profiles, upload photos, check health records' },
  { id: 'health', icon: '💊', title: 'Health & Medications', desc: 'Vaccinations, health tests, medication tracking' },
  { id: 'breeding', icon: '📅', title: 'Breeding Plans & Cycles', desc: 'Track plans, record births, monitor heat cycles' },
  { id: 'offspring', icon: '🍼', title: 'Offspring & Weights', desc: 'Add offspring, record daily weights, track development' },
  { id: 'messaging', icon: '💬', title: 'Messages', desc: 'Unified inbox for buyer and client conversations' },
  { id: 'tasks', icon: '📋', title: 'Tasks & Calendar', desc: 'Daily tasks, upcoming events, and reminders' },
  { id: 'expenses', icon: '💰', title: 'Expense Tracking', desc: 'Log expenses with receipt photos on the go' },
  { id: 'contacts', icon: '👥', title: 'Contacts', desc: 'Browse contacts, view details, manage relationships' }
];
---

<BaseLayout
  title="BreederHQ Mobile Companion App | Quick-Capture Tool for Breeders"
  description="The Mobile Companion app for iOS and Android is a focused on-the-go tool that pairs with the BreederHQ web platform. Capture weights, log vet visits, check profiles, and reply to buyers from the barn, the vet, or the show ring."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
    Skip to content
  </a>

  <main id="main-content">
  <nav class="breadcrumb py-4 px-4 bg-gray-50" aria-label="Breadcrumb">
    <ol class="flex items-center space-x-2 max-w-4xl mx-auto text-sm">
      <li><a href="/" class="text-[hsl(24,95%,53%)] hover:underline">Home</a></li>
      <li class="text-gray-400">›</li>
      <li aria-current="page" class="text-gray-600">Mobile Companion</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-semibold uppercase tracking-wider text-[hsl(24,95%,53%)] mb-3">BreederHQ Mobile Companion App</p>
      <h1 class="text-5xl font-bold mb-6">The On-The-Go Companion to the BreederHQ Web App</h1>
      <p class="text-xl text-gray-700 leading-relaxed mb-6">
        A focused, in-the-moment tool for the times you are away from your laptop. Not a replacement for the BreederHQ web app — a deliberate companion to it.
      </p>

      <aside class="tldr-box bg-gray-100 border-l-4 border-[hsl(24,95%,53%)] p-6 my-8 rounded" role="complementary" aria-label="Page summary">
        <h2 class="text-xl font-bold mb-3">TL;DR</h2>
        <p class="text-gray-700 leading-relaxed">
          The BreederHQ Mobile Companion is an iOS and Android app designed for quick capture and quick lookup when you are away from your desk. Record newborn weights right after a birth, snap a receipt at the vet, pull up an animal's pedigree at a show, reply to a buyer message, mark a task done. Everything syncs instantly with the BreederHQ web app, where you do the deeper work — setting up breeding plans, managing your storefront, running reports, configuring contracts, and everything else that needs a real screen.
        </p>
      </aside>
    </div>
  </section>

  <!-- Companion vs. Web App: What's it for? -->
  <section class="py-12 px-4 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold mb-3">A Companion, Not a Replacement</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          The BreederHQ web app is where you run your breeding program. The Mobile Companion is built for the moments breeding actually happens — when you are not at your desk.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Mobile Companion -->
        <div class="bg-[hsl(24,95%,97%)] border-2 border-[hsl(24,95%,53%)] rounded-xl p-6">
          <div class="text-3xl mb-3">📱</div>
          <h3 class="text-xl font-bold mb-1">Mobile Companion</h3>
          <p class="text-sm text-gray-600 mb-4 italic">For quick capture and quick lookup, away from your desk.</p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li class="flex items-start"><span class="text-[hsl(24,95%,53%)] mr-2">✓</span>Record newborn weights at the moment of birth</li>
            <li class="flex items-start"><span class="text-[hsl(24,95%,53%)] mr-2">✓</span>Log a vaccination or medication dose at the vet</li>
            <li class="flex items-start"><span class="text-[hsl(24,95%,53%)] mr-2">✓</span>Snap an expense receipt before you lose it</li>
            <li class="flex items-start"><span class="text-[hsl(24,95%,53%)] mr-2">✓</span>Pull up an animal's profile or pedigree at a show</li>
            <li class="flex items-start"><span class="text-[hsl(24,95%,53%)] mr-2">✓</span>Reply to a buyer message from the road</li>
            <li class="flex items-start"><span class="text-[hsl(24,95%,53%)] mr-2">✓</span>Mark a task complete, log a heat date, check a reminder</li>
            <li class="flex items-start"><span class="text-[hsl(24,95%,53%)] mr-2">✓</span>Get push notifications for time-sensitive events</li>
          </ul>
        </div>

        <!-- Web App -->
        <div class="bg-stone-50 border-2 border-stone-300 rounded-xl p-6">
          <div class="text-3xl mb-3">💻</div>
          <h3 class="text-xl font-bold mb-1">BreederHQ Web App</h3>
          <p class="text-sm text-gray-600 mb-4 italic">Where you run your breeding program.</p>
          <ul class="space-y-2 text-gray-700 text-sm">
            <li class="flex items-start"><span class="text-stone-500 mr-2">✓</span>Build and edit breeding plans and programs</li>
            <li class="flex items-start"><span class="text-stone-500 mr-2">✓</span>Manage your marketplace storefront and listings</li>
            <li class="flex items-start"><span class="text-stone-500 mr-2">✓</span>Configure contracts, templates, pricing, and policies</li>
            <li class="flex items-start"><span class="text-stone-500 mr-2">✓</span>Financial reporting, invoicing, and reconciliation</li>
            <li class="flex items-start"><span class="text-stone-500 mr-2">✓</span>Genetics work, pedigree analysis, and compatibility</li>
            <li class="flex items-start"><span class="text-stone-500 mr-2">✓</span>Waitlist management and placement decisions</li>
            <li class="flex items-start"><span class="text-stone-500 mr-2">✓</span>Settings, team management, and integrations</li>
          </ul>
        </div>
      </div>

      <p class="text-center text-sm text-gray-500 mt-8 max-w-3xl mx-auto">
        One account, one dataset. The Mobile Companion captures in the moment; the web app is where you actually run things. Use the right tool for the moment.
      </p>
    </div>
  </section>

  <!-- Feature Cards Grid -->
  <section class="py-8 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold mb-2 text-center">What the Mobile Companion Covers</h2>
      <p class="text-center text-gray-600 mb-6 max-w-2xl mx-auto">A focused set of tasks designed for quick capture and quick lookup. Tap a card to see what's included.</p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {featureCards.map(card => (
          <a href={`#${card.id}`} class="feature-card block p-4 bg-white rounded-lg shadow-sm hover:shadow-md transition border border-gray-200 hover:border-[hsl(24,95%,53%)]">
            <div class="text-3xl mb-2">{card.icon}</div>
            <h3 class="font-bold text-lg mb-1">{card.title}</h3>
            <p class="text-sm text-gray-600">{card.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Sticky Navigation -->
  <nav class="sticky-nav hidden md:block sticky top-0 bg-white border-b border-gray-200 z-40 shadow-sm">
    <div class="max-w-5xl mx-auto px-4">
      <ul class="flex space-x-6 overflow-x-auto py-3 text-sm">
        {featureCards.map(card => (
          <li>
            <a href={`#${card.id}`} class="nav-link whitespace-nowrap text-gray-600 hover:text-[hsl(24,95%,53%)] transition pb-2">
              {card.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <!-- Accordion Sections -->
  <section class="py-12 px-4">
    <div class="max-w-4xl mx-auto space-y-4">

      <!-- Animals -->
      <details id="animals" class="accordion-section border border-gray-200 rounded-lg" open>
        <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
          <div class="flex items-center gap-4">
            <span class="text-3xl">🐾</span>
            <div>
              <h3 class="text-2xl font-bold">Animal Lookup &amp; Quick Updates</h3>
              <p class="text-gray-600">Pull up profiles, pedigrees, and health records when you're away from your desk</p>
            </div>
          </div>
          <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="accordion-content p-6 border-t border-gray-200">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-lg mb-3">Browse & Search</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Full animal list with search and filters</li>
                <li class="flex items-start"><span class="mr-2">•</span>Profile photos and cover images</li>
                <li class="flex items-start"><span class="mr-2">•</span>Registration numbers and microchip IDs</li>
                <li class="flex items-start"><span class="mr-2">•</span>Pedigree information</li>
                <li class="flex items-start"><span class="mr-2">•</span>Quick status at a glance</li>
              </ul>
            </div>
            <div>
              <h4 class="font-bold text-lg mb-3">Health & Media</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Vaccination records and reminders</li>
                <li class="flex items-start"><span class="mr-2">•</span>Health trait tracking</li>
                <li class="flex items-start"><span class="mr-2">•</span><a href="/workflows/medication-tracking" class="text-[hsl(24,95%,53%)] hover:underline">Medication quick-log</a>: tap to log doses from the barn or kennel</li>
                <li class="flex items-start"><span class="mr-2">•</span>Upload photos directly from camera</li>
                <li class="flex items-start"><span class="mr-2">•</span>Evidence photos for health records</li>
                <li class="flex items-start"><span class="mr-2">•</span>Share animal profiles via QR code</li>
              </ul>
            </div>
          </div>
          <div class="mt-4 bg-white border-l-4 border-[hsl(24,95%,53%)] p-5 rounded">
            <p class="text-gray-700 text-sm"><strong>At the show ring:</strong> Pull up any animal's profile, titles, and pedigree instantly. Share profiles with other breeders by scanning a QR code, with no need to exchange business cards or emails.</p>
          </div>
        </div>
      </details>

      <!-- Health & Medications -->
      <details id="health" class="accordion-section border border-gray-200 rounded-lg">
        <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
          <div class="flex items-center gap-4">
            <span class="text-3xl">💊</span>
            <div>
              <h3 class="text-2xl font-bold">Health & Medications</h3>
              <p class="text-gray-600">Vaccinations, health tests, and medication tracking from your phone</p>
            </div>
          </div>
          <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="accordion-content p-6 border-t border-gray-200">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-lg mb-3">Vaccinations & Health Tests</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Record vaccinations with date, vet, clinic, and batch number</li>
                <li class="flex items-start"><span class="mr-2">•</span>Track expiration dates and renewal reminders</li>
                <li class="flex items-start"><span class="mr-2">•</span>Health test results with outcome tracking</li>
                <li class="flex items-start"><span class="mr-2">•</span>Upload evidence photos directly from camera</li>
                <li class="flex items-start"><span class="mr-2">•</span>Core vs. non-core vaccination status at a glance</li>
              </ul>
            </div>
            <div>
              <h4 class="font-bold text-lg mb-3">Medication Tracking</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Add medications with dosage, route, and frequency</li>
                <li class="flex items-start"><span class="mr-2">•</span>Quick-log doses with one tap, wherever you are</li>
                <li class="flex items-start"><span class="mr-2">•</span>Push notifications when the next dose is due</li>
                <li class="flex items-start"><span class="mr-2">•</span>Active course progress and overdue alerts</li>
                <li class="flex items-start"><span class="mr-2">•</span>Withdrawal period tracking with clear-date countdown</li>
                <li class="flex items-start"><span class="mr-2">•</span>Controlled substance flagging</li>
              </ul>
            </div>
          </div>
          <div class="mt-4 bg-white border-l-4 border-[hsl(24,95%,53%)] p-5 rounded">
            <p class="text-gray-700 text-sm"><strong>At the vet:</strong> Record vaccinations and medications while you're still at the clinic. Tap the details in, snap a photo of the paperwork, and it's done, with no paper to transcribe later.</p>
          </div>
        </div>
      </details>

      <!-- Breeding Plans & Cycles -->
      <details id="breeding" class="accordion-section border border-gray-200 rounded-lg">
        <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
          <div class="flex items-center gap-4">
            <span class="text-3xl">📅</span>
            <div>
              <h3 class="text-2xl font-bold">Breeding Plans & Cycles</h3>
              <p class="text-gray-600">Track breeding plans, record births, and monitor heat cycles</p>
            </div>
          </div>
          <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="accordion-content p-6 border-t border-gray-200">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-lg mb-3">Breeding Plans</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>View all active breeding plans from each animal's profile</li>
                <li class="flex items-start"><span class="mr-2">•</span>Phase status with color-coded badges</li>
                <li class="flex items-start"><span class="mr-2">•</span>Record birth dates and add offspring directly</li>
                <li class="flex items-start"><span class="mr-2">•</span>Upload birth photos and videos immediately</li>
                <li class="flex items-start"><span class="mr-2">•</span>Expected and actual birth date tracking</li>
              </ul>
            </div>
            <div>
              <h4 class="font-bold text-lg mb-3">Cycle Tracking</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Record heat start and end dates</li>
                <li class="flex items-start"><span class="mr-2">•</span>3-cycle lookahead projections</li>
                <li class="flex items-start"><span class="mr-2">•</span>Countdown to next expected cycle</li>
                <li class="flex items-start"><span class="mr-2">•</span>Push notifications when cycles are expected</li>
                <li class="flex items-start"><span class="mr-2">•</span>Data syncs to breeding plans on web</li>
              </ul>
            </div>
          </div>
          <div class="mt-4 bg-white border-l-4 border-[hsl(24,95%,53%)] p-5 rounded">
            <p class="text-gray-700 text-sm"><strong>In the birthing area:</strong> When birth happens at 2 AM, record the date, add each offspring with sex, color, and weight, and snap a photo, all from your phone. No need to boot up a computer.</p>
          </div>
        </div>
      </details>

      <!-- Offspring & Weights -->
      <details id="offspring" class="accordion-section border border-gray-200 rounded-lg">
        <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
          <div class="flex items-center gap-4">
            <span class="text-3xl">🍼</span>
            <div>
              <h3 class="text-2xl font-bold">Offspring & Weight Tracking</h3>
              <p class="text-gray-600">Add offspring, record daily weights right where you are</p>
            </div>
          </div>
          <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="accordion-content p-6 border-t border-gray-200">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-lg mb-3">Offspring Groups</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>View all litters and offspring groups</li>
                <li class="flex items-start"><span class="mr-2">•</span>Add new offspring with collar colors</li>
                <li class="flex items-start"><span class="mr-2">•</span>Birth details: sex, color, weight, time</li>
                <li class="flex items-start"><span class="mr-2">•</span>Delivery type and health status</li>
                <li class="flex items-start"><span class="mr-2">•</span>Offspring media gallery</li>
              </ul>
            </div>
            <div>
              <h4 class="font-bold text-lg mb-3">Weight Recording</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Quick weight entry with increment buttons</li>
                <li class="flex items-start"><span class="mr-2">•</span>Record weights for a whole group fast (litter, foals, kids, lambs, or kits)</li>
                <li class="flex items-start"><span class="mr-2">•</span>Weight trend sparklines</li>
                <li class="flex items-start"><span class="mr-2">•</span>Automatic anomaly detection</li>
                <li class="flex items-start"><span class="mr-2">•</span>Metric and imperial toggle</li>
              </ul>
            </div>
          </div>
          <div class="mt-4 bg-white border-l-4 border-[hsl(24,95%,53%)] p-5 rounded">
            <p class="text-gray-700 text-sm"><strong>At the barn or kennel:</strong> Weigh each newborn, tap the weight, done. Quick increment buttons mean you can record an entire litter or group in under a minute. No laptop, no spreadsheet, no paper to transcribe later.</p>
          </div>
        </div>
      </details>

      <!-- Messages -->
      <details id="messaging" class="accordion-section border border-gray-200 rounded-lg">
        <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
          <div class="flex items-center gap-4">
            <span class="text-3xl">💬</span>
            <div>
              <h3 class="text-2xl font-bold">Messages</h3>
              <p class="text-gray-600">Respond to buyers and clients from anywhere</p>
            </div>
          </div>
          <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="accordion-content p-6 border-t border-gray-200">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-lg mb-3">Unified Inbox</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>All conversations in one place</li>
                <li class="flex items-start"><span class="mr-2">•</span>Buyer portal messages</li>
                <li class="flex items-start"><span class="mr-2">•</span>Marketplace inquiry threads</li>
                <li class="flex items-start"><span class="mr-2">•</span>Date-separated conversation view</li>
                <li class="flex items-start"><span class="mr-2">•</span>Unread indicators</li>
              </ul>
            </div>
            <div>
              <h4 class="font-bold text-lg mb-3">Stay Responsive</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Push notifications for new messages</li>
                <li class="flex items-start"><span class="mr-2">•</span>Reply quickly from your phone</li>
                <li class="flex items-start"><span class="mr-2">•</span>Earn the Quick Responder badge</li>
                <li class="flex items-start"><span class="mr-2">•</span>Never leave a buyer waiting</li>
                <li class="flex items-start"><span class="mr-2">•</span>Real-time sync with web inbox</li>
              </ul>
            </div>
          </div>
        </div>
      </details>

      <!-- Tasks & Calendar -->
      <details id="tasks" class="accordion-section border border-gray-200 rounded-lg">
