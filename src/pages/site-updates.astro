---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Site Updates', url: '/site-updates' }
];
---

<BaseLayout
  title="Site Updates - BreederHQ"
  description="Internal update log for the BreederHQ marketing website."
  breadcrumbs={breadcrumbs}
  noindex={true}
>
  <main>
    <section class="bg-gradient-to-b from-white to-gray-50 py-20">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl font-bold tracking-tight text-gray-900 mb-4">
          Site Updates
        </h1>
        <p class="text-lg text-gray-600">
          A running log of content changes to breederhq.com. Click any page link to review the change on the live site. Newest updates first.
        </p>
      </div>
    </section>

    <section class="py-16 bg-white">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 space-y-16">

        <!-- ========== April 28, 2026 — Outreach Hub Workflow Page ========== -->
        <article class="border-l-4 border-[hsl(24,95%,53%)] pl-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-1">April 28, 2026</h2>
          <p class="text-sm text-gray-500 mb-4">New /workflows/outreach-hub page + pricing + nav updates for the Outreach Hub</p>

          <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">/workflows/outreach-hub now markets the full outbound side of the Marketing module</h3>
          <p class="text-gray-700 mb-2">
            The marketing site previously had no public-facing page for the Outreach Hub even though five major Outreach features shipped on the platform between April 26 and April 27. Created a full <a href="/workflows/outreach-hub" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/outreach-hub</a> workflow page covering:
          </p>
          <ul class="list-disc list-inside text-gray-700 space-y-1">
            <li>Plan announcements (litter updates) and Program announcements (program news)</li>
            <li>Audience visibility — Buyers Only, Marketplace Only, or Both, per announcement</li>
            <li>Email-on-publish toggle to every eligible buyer</li>
            <li>Scout AI drafting from real program data with tone adjustment (Friendly / Professional / Excited / Concise)</li>
            <li>Scout AI Quiet Guidance — suggested announcements based on program activity (birth, weaning, titles, etc.)</li>
            <li>Facebook Page + Instagram Business publishing from the same composer with UTM tracking</li>
            <li>Audience preview before publishing + reach metrics (eligible / emailed / seen) after</li>
          </ul>
          <p class="text-gray-700 mt-3">
            Also updated:
          </p>
          <ul class="list-disc list-inside text-gray-700 space-y-1">
            <li><a href="/workflows" class="text-[hsl(24,95%,53%)] hover:underline">/workflows</a> — added the Outreach Hub card to the workflows landing page</li>
            <li><a href="/workflows/communications-hub" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/communications-hub</a> — cross-linked to Outreach Hub in the Related Workflows section</li>
            <li><a href="/pricing/compare" class="text-[hsl(24,95%,53%)] hover:underline">/pricing/compare</a> — added 7 new Pro-tier feature rows under Marketing &amp; Communications (Outreach Hub, Email-on-Publish, Marketplace Announcements, Audience &amp; Reach Metrics, Scout AI Drafting + Tone, Scout AI Quiet Guidance, Facebook &amp; Instagram Publishing, UTM Tracking)</li>
            <li>Header navigation (desktop mega menu + mobile accordion) — added Outreach Hub link under Breeders → Business</li>
          </ul>
        </article>

        <!-- ========== April 28, 2026 — Scout AI Mascot Branding ========== -->
        <article class="border-l-4 border-[hsl(24,95%,53%)] pl-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-1">April 28, 2026</h2>
          <p class="text-sm text-gray-500 mb-4">Scout AI mascot now greets visitors on the workflow page</p>

          <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">/workflows/scout-ai now features the Scout AI Companion mascot</h3>
          <p class="text-gray-700 mb-2">
            The <a href="/workflows/scout-ai" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/scout-ai</a> page now features the Scout mascots in three places: the AI Companion badge above the hero headline (centered), the search emoji paired with the "Each question has an answer in your data" callout, and the search emoji again next to the "How It Works" 3-step panel. Same brand mascots users see inside the platform when they click Ask Scout - keeps the marketing-to-product story consistent.
          </p>
        </article>

        <!-- ========== April 28, 2026 — AI Privacy Policy ========== -->
        <article class="border-l-4 border-[hsl(24,95%,53%)] pl-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-1">April 28, 2026</h2>
          <p class="text-sm text-gray-500 mb-4">New AI Privacy Policy page</p>

          <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">/ai-privacy explains how AI features handle your data</h3>
          <p class="text-gray-700 mb-2">
            Added a new <a href="/ai-privacy" class="text-[hsl(24,95%,53%)] hover:underline">/ai-privacy</a> page detailing the technical safeguards that pseudonymize stored personal information (names, emails, phones, addresses) before any AI request is made, the suppression of authentication and payment material, the carve-out for content users submit directly to AI features, our 90-day retention, and the no-model-training commitment from our AI service provider. The in-application AI Data Processing Notice now links here from the "View AI Privacy Policy" link.
          </p>
        </article>

        <!-- ========== April 28, 2026 — Breeding Intelligence Screenshot ========== -->
        <article class="border-l-4 border-[hsl(24,95%,53%)] pl-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-1">April 28, 2026</h2>
          <p class="text-sm text-gray-500 mb-4">Breeding Intelligence page now shows the actual COI + carrier-conflict UI</p>

          <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">/workflows/breeding-intelligence shows live genetic intelligence</h3>
          <p class="text-gray-700 mb-2">
            The <a href="/workflows/breeding-intelligence" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/breeding-intelligence</a> page previously showed the breeding-plan timeline — useful, but not what "intelligence" means. Replaced with the <strong>New Breeding Plan</strong> modal showing real-time Coefficient of Inbreeding calculation (9.38% Moderate Risk in the example, with common ancestors named) and live genetic carrier conflict detection — both surfaced the moment you pick a Dam and a Sire, before you commit to the plan. This is the actual intelligence buyers and breeders are paying for.
          </p>
        </article>

        <!-- ========== April 28, 2026 — Horse-specific Screenshots ========== -->
        <article class="border-l-4 border-[hsl(24,95%,53%)] pl-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-1">April 28, 2026</h2>
          <p class="text-sm text-gray-500 mb-4">Horse-specific product screenshots — Quarter Horse program</p>

          <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">/horses now shows what equine breeders actually see</h3>
          <p class="text-gray-700 mb-2">
            Until now <a href="/horses" class="text-[hsl(24,95%,53%)] hover:underline">/horses</a> described the platform's horse-specific features in prose, but every product screenshot on the site came from a dog kennel. We added a second seed tenant — <strong>Willow Creek Equine</strong>, a Quarter Horse program — and captured 8 horse-specific shots:
          </p>
          <ul class="list-disc list-inside text-gray-700 space-y-1">
            <li>Horse breeder dashboard with <strong>Mare Status Overview</strong> (Overdue / Imminent / Due / Pregnant)</li>
            <li>Quarter Horse animals list — mares, stallions, foals with breed and status</li>
            <li>Breeding plan journey with horse-specific phase pipeline (Planning → Cycle → Breeding → <strong>Birth</strong> → Weaned → Placed → Complete) and the Birth Checklist tab</li>
            <li>Horse profile detail — Currently Breeding badge, expected foaling date, AQHA Performance Horse notes</li>
            <li>Three-generation pedigree — Sundance × Juniper Star with grandparents linked</li>
            <li>Titles tab — AQHA World Champion, Superior Halter, Register of Merit with verified badges</li>
            <li>Public marketplace profile — AQHA/NRHA registries, HYPP/HERDA/PSSM1 health practices</li>
          </ul>
          <p class="text-gray-700 mt-3">
            Same screenshot capture pipeline — different seed tenant. Both <a href="/find-breeders/horses" class="text-[hsl(24,95%,53%)] hover:underline">/find-breeders/horses</a> and <a href="/horses" class="text-[hsl(24,95%,53%)] hover:underline">/horses</a> now show horse-specific UI rather than reusing dog screenshots.
          </p>
        </article>

        <!-- ========== April 28, 2026 — Product Screenshots ========== -->
        <article class="border-l-4 border-[hsl(24,95%,53%)] pl-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-1">April 28, 2026</h2>
          <p class="text-sm text-gray-500 mb-4">Real product screenshots added across the marketing site</p>

          <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">Marketing pages now show what the platform actually looks like</h3>
          <p class="text-gray-700 mb-2">
            Until now the marketing site described the platform in prose but never showed it. Buyers and breeders had to imagine the UI. We added intentional, purpose-built product screenshots — captured from a real working tenant with realistic data — to the highest-traffic marketing pages:
          </p>
          <ul class="list-disc list-inside text-gray-700 space-y-1">
            <li>Homepage — dashboard hero shot under the three-audience CTAs</li>
            <li><a href="/for-breeders" class="text-[hsl(24,95%,53%)] hover:underline">/for-breeders</a> — dashboard hero, plus a four-screenshot showcase of animals, breeding plans, offspring, and invoicing</li>
            <li><a href="/workflows" class="text-[hsl(24,95%,53%)] hover:underline">/workflows</a> — dashboard hero on the workflows landing page</li>
            <li><a href="/workflows/breeding-plans" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/breeding-plans</a> — breeding plans list with phase progress</li>
            <li><a href="/workflows/breeding-cycles" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/breeding-cycles</a> and <a href="/workflows/heat-tracking" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/heat-tracking</a> — breeding calendar</li>
            <li><a href="/workflows/offspring-care" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/offspring-care</a> — litter view with collar colors and placement state</li>
            <li><a href="/workflows/client-management" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/client-management</a> — contacts list</li>
            <li><a href="/workflows/invoicing-expenses" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/invoicing-expenses</a> — invoice ledger</li>
            <li><a href="/compare/breederhq-vs-spreadsheets" class="text-[hsl(24,95%,53%)] hover:underline">/compare/breederhq-vs-spreadsheets</a> — animals view as the spreadsheet alternative</li>
            <li><a href="/workflows/pedigrees" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/pedigrees</a> — three-generation pedigree view</li>
            <li><a href="/workflows/genetics-and-health-testing" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/genetics-and-health-testing</a> — animal genetics tab with coat-color loci</li>
            <li><a href="/workflows/breeding-intelligence" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/breeding-intelligence</a> — breeding plan journey timeline</li>
            <li><a href="/workflows/scout-ai" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/scout-ai</a> — connected genetic data Scout reasons across</li>
            <li><a href="/workflows/waitlists-and-placement" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/waitlists-and-placement</a> — approved-buyer waitlist with deposit status</li>
            <li><a href="/workflows/communications-hub" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/communications-hub</a> — unified inbox across email, DMs, and portal messages</li>
            <li><a href="/workflows/client-portal" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/client-portal</a> — buyer portal home branded as the breeder's kennel</li>
            <li><a href="/dogs" class="text-[hsl(24,95%,53%)] hover:underline">/dogs</a> — animal profile detail view</li>
            <li><a href="/find-breeders/dogs" class="text-[hsl(24,95%,53%)] hover:underline">/find-breeders/dogs</a> and <a href="/buyers/why-breederhq-marketplace" class="text-[hsl(24,95%,53%)] hover:underline">/buyers/why-breederhq-marketplace</a> — public breeder profile in marketplace</li>
            <li>Homepage — replaced the stylized "Verified Breeder Profile" mockup with the real marketplace profile screenshot</li>
          </ul>
          <p class="text-gray-700 mt-3">
            All screenshots come from a curated demo tenant ("Cedar Ridge Kennels") that's automatically seeded for screenshot capture, so we can refresh them any time the UI changes. Screenshots are served as WebP with PNG fallback for performance.
          </p>
        </article>

        <!-- ========== April 27, 2026 — Data Deletion page ========== -->
        <article class="border-l-4 border-[hsl(24,95%,53%)] pl-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-1">April 27, 2026</h2>
          <p class="text-sm text-gray-500 mb-4">New Data Deletion page (required for Meta App Review)</p>

          <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">Data Deletion Instructions page added</h3>
          <p class="text-gray-700 mb-2">
            New page at <a href="/data-deletion" class="text-[hsl(24,95%,53%)] hover:underline">/data-deletion</a>
            documenting how breeders can delete their BreederHQ account, disconnect a Facebook or Instagram
            account, and request a data export. Required by Meta as part of submitting BreederHQ's app
            for App Review (which unlocks the new direct-publish-to-Facebook-and-Instagram features in the
            Outreach Hub). Covers: quick options, how to disconnect a social account from inside BreederHQ
            or directly on Facebook, what we store from connected social accounts, the full account-deletion
            process, what persists after deletion, and how to export your data first.
          </p>
        </article>

        <!-- ========== April 27, 2026 ========== -->
        <article class="border-l-4 border-[hsl(24,95%,53%)] pl-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-1">April 27, 2026</h2>
          <p class="text-sm text-gray-500 mb-4">SEO indexing fixes &mdash; homepage canonical + footer expansion</p>

          <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">Homepage canonical normalized</h3>
          <p class="text-gray-700">
            Google flagged the homepage with "Duplicate, Google chose different
            canonical than user" — we declared <code>https://breederhq.com/</code>
            (with trailing slash) while every other page on the site uses no
            trailing slash. Fixed the canonical/og:url builder so the homepage
            now matches the rest of the site at <code>https://breederhq.com</code>.
          </p>

          <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">Footer expanded with previously orphan pages</h3>
          <p class="text-gray-700 mb-2">
            Search Console showed 24 sitemap-listed pages were unknown to
            Google because nothing prominent linked to them. Added them to the
            site-wide footer so every page links to them and crawlers will
            actually find them:
          </p>
          <ul class="list-disc list-inside text-gray-700 space-y-1">
            <li>New <strong>Find Breeders</strong> column with all 7
              <a href="/find-breeders" class="text-[hsl(24,95%,53%)] hover:underline">/find-breeders/*</a>
              landing pages</li>
            <li>New workflow links: <a href="/workflows/heat-tracking" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/heat-tracking</a>,
              <a href="/workflows/pedigrees" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/pedigrees</a>,
              <a href="/workflows/client-management" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/client-management</a>,
              <a href="/workflows/embed-on-your-website" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/embed-on-your-website</a>,
              and an <a href="/workflows" class="text-[hsl(24,95%,53%)] hover:underline">All Workflows</a> index link</li>
            <li>Compare anchors: <a href="/compare/best-breeding-software" class="text-[hsl(24,95%,53%)] hover:underline">/compare/best-breeding-software</a>
              and <a href="/compare/breederhq-vs-spreadsheets" class="text-[hsl(24,95%,53%)] hover:underline">/compare/breederhq-vs-spreadsheets</a></li>
            <li><a href="/privacy" class="text-[hsl(24,95%,53%)] hover:underline">/privacy</a> and
              <a href="/terms" class="text-[hsl(24,95%,53%)] hover:underline">/terms</a> resources links</li>
          </ul>
        </article>

        <!-- ========== April 26, 2026 — Embed Widget marketing page ========== -->
        <article class="border-l-4 border-[hsl(24,95%,53%)] pl-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-1">April 26, 2026</h2>
          <p class="text-sm text-gray-500 mb-4">Embed Widget workflow page added (/workflows/embed-on-your-website)</p>

          <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">Marketplace Embed Widget marketed as a workflow surface</h3>
          <p class="text-gray-700 mb-2">
            BreederHQ now offers an embeddable widget that breeders paste onto their personal websites
            (Squarespace, Wix, WordPress, or custom HTML) to render their live BreederHQ Breeding Programs
            and Animal Listings. The marketing site introduces it as a new workflow page.
          </p>
          <ul class="list-disc list-inside text-gray-700 space-y-2">
            <li>
              <a href="/workflows/embed-on-your-website" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/embed-on-your-website</a>:
              new full-length workflow page covering how the widget works, what visitors see, design considerations
              (theme matching, isolation, performance), the live-preview affordance, and 8 FAQs answering installation,
              theming, performance, technical-skill, scoping, and pricing questions. Free for every Identity-Verified BreederHQ breeder.
            </li>
            <li>
              <a href="/workflows" class="text-[hsl(24,95%,53%)] hover:underline">/workflows</a>:
              workflow index gains the new entry between Communications Hub and Invoicing &amp; Expenses,
              titled "Embed on Your Website."
            </li>
          </ul>
        </article>

        <!-- ========== April 26, 2026 (earlier) — Scout AI Repro Insight ========== -->
        <article class="border-l-4 border-[hsl(24,95%,53%)] pl-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-1">April 26, 2026</h2>
          <p class="text-sm text-gray-500 mb-4">Scout AI Repro Insight messaging on /workflows/scout-ai and /workflows/heat-tracking</p>

          <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">Scout AI Repro Insight introduced as a marketed surface</h3>
          <p class="text-gray-700 mb-2">
            Phase 1 of Scout AI's reproductive expert-assessment surface shipped to the platform &mdash;
            a canine progesterone trend assessment that compares the current cycle to past cycles, watches for split heats, stalled cycles, and anomalies, and returns a structured second opinion. Marketing site updated to position the feature.
          </p>
          <ul class="list-disc list-inside text-gray-700 space-y-2">
            <li>
              <a href="/workflows/scout-ai" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/scout-ai</a>:
              new "Scout AI Repro Insight" section with example assessment and a "what it catches that math doesn't" list (split heats, stalled cycles, anovulatory cycles, history comparisons). Three new FAQs covering what Repro Insight is, whether it costs extra, and species support.
            </li>
            <li>
              <a href="/workflows/heat-tracking" class="text-[hsl(24,95%,53%)] hover:underline">/workflows/heat-tracking</a>:
              expanded the progesterone testing FAQ to mention the chart-from-first-reading and projection coaching, plus a new sentence in the closing CTA section linking to the Scout AI workflow page. Updated the "reproductive vet" FAQ to position Repro Insight as a second opinion, not a replacement.
            </li>
          </ul>
          <p class="text-gray-700 mt-3">
            Repro Insight is gated to Pro and Enterprise plans (BREEDING_PRO entitlement). Currently canine only &mdash; equine support is on the roadmap.
          </p>
        </article>

        <!-- ========== April 26, 2026 ========== -->
        <article class="border-l-4 border-[hsl(24,95%,53%)] pl-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-1">April 26, 2026</h2>
          <p class="text-sm text-gray-500 mb-4">Buyer-side transparency messaging across four /buyers pages</p>

          <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">Direct buyer-breeder interaction emphasized</h3>
          <p class="text-gray-700 mb-2">
            Updated four buyer-facing pages to make BreederHQ's positioning explicit:
            buyers should be evaluating and speaking with the actual breeder, not clicking
            through an anonymous checkout funnel that hides the breeder behind a marketplace brand.
          </p>
          <ul class="list-disc list-inside text-gray-700 space-y-2">
            <li>
              <a href="/buyers/why-breederhq-marketplace" class="text-[hsl(24,95%,53%)] hover:underline">/buyers/why-breederhq-marketplace</a>:
              new "Why breeder transparency matters" section and a highlighted
              "Direct breeder connection" card. Card backgrounds restyled for
              visual hierarchy.
            </li>
            <li>
              <a href="/buyers/using-the-marketplace" class="text-[hsl(24,95%,53%)] hover:underline">/buyers/using-the-marketplace</a>:
              new TL;DR sentence, an amber "Important" callout in Getting Started,
              and a "this should feel like a conversation, not a checkout" box in
              the Contacting a breeder section.
            </li>
            <li>
              <a href="/buyers/evaluate-breeders" class="text-[hsl(24,95%,53%)] hover:underline">/buyers/evaluate-breeders</a>:
              new TL;DR sentence, an amber "Marketplace note" callout in the
              transparency section, and a new warning-sign bullet about platforms
              that discourage direct interaction before payment.
            </li>
            <li>
              <a href="/buyers/red-flags" class="text-[hsl(24,95%,53%)] hover:underline">/buyers/red-flags</a>:
              expanded TL;DR to cover hidden-breeder buying flows, a new
              "The breeder feels hidden behind the platform" subsection under
              Communication red flags, and a closing paragraph in
              "How professional tools help identify good breeders" reinforcing
              direct buyer-breeder interaction.
            </li>
          </ul>
        </article>

        <!-- ========== April 25, 2026 ========== -->
        <article class="border-l-4 border-[hsl(24,95%,53%)] pl-6">
          <h2 class="text-2xl font-bold text-gray-900 mb-1">April 25, 2026</h2>
          <p class="text-sm text-gray-500 mb-4">Marketplace SEO landing pages + species-page → marketplace internal linking + meta description trims</p>

          <h3 class="text-lg font-semibold text-gray-900 mt-4 mb-2">New "Find Breeders" landing pages</h3>
          <p class="text-gray-700 mb-2">
            New section at <a href="/find-breeders" class="text-[hsl(24,95%,53%)] hover:underline">/find-breeders</a>
            with one landing page per species, each targeting buyer-intent search
            queries ("find dog breeders", "find horse breeders", etc.) and routing
            visitors directly into the BreederHQ Marketplace:
          </p>
          <ul class="list-disc list-inside text-gray-700 space-y-1">
            <li><a href="/find-breeders" class="text-[hsl(24,95%,53%)] hover:underline">/find-breeders</a> — index page</li>
            <li><a href="/find-breeders/dogs" class="text-[hsl(24,95%,53%)] hover:underline">/find-breeders/dogs</a></li>
