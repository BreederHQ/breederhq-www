            <li><a href="/find-breeders/horses" class="text-[hsl(24,95%,53%)] hover:underline">/find-breeders/horses</a></li>
            <li><a href="/find-breeders/goats" class="text-[hsl(24,95%,53%)] hover:underline">/find-breeders/goats</a></li>
            <li><a href="/find-breeders/rabbits" class="text-[hsl(24,95%,53%)] hover:underline">/find-breeders/rabbits</a></li>
            <li><a href="/find-breeders/sheep" class="text-[hsl(24,95%,53%)] hover:underline">/find-breeders/sheep</a></li>
          </ul>

          <h3 class="text-lg font-semibold text-gray-900 mt-6 mb-2">Marketplace links added to species + audience pages</h3>
          <p class="text-gray-700 mb-2">
