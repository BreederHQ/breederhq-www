---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Search', url: '/search' }
];
---

<BaseLayout
  title="Search - BreederHQ"
  description="Search across BreederHQ articles, workflows, species pages, comparisons, and buyer guides."
  breadcrumbs={breadcrumbs}
  noindex={true}
>
  <main data-pagefind-ignore="all" class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 mb-2">
      Search BreederHQ
    </h1>
    <p class="text-gray-600 mb-8">
      Search across articles, workflows, species pages, comparisons, and buyer guides.
    </p>

    <form id="search-form" role="search" class="mb-8">
      <label for="search-input" class="sr-only">Search BreederHQ</label>
      <div class="relative">
        <input
          id="search-input"
          name="q"
          type="search"
          inputmode="search"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          placeholder="Search articles, workflows, species, comparisons..."
          class="w-full rounded-lg border border-stone-300 bg-white px-4 py-3 pr-12 text-base text-gray-900 placeholder:text-gray-400 focus:border-[hsl(24,95%,53%)] focus:outline-none focus:ring-2 focus:ring-[hsl(24,95%,53%)]/30"
        />
        <button
          type="submit"
          class="absolute right-2 top-1/2 -translate-y-1/2 inline-flex items-center justify-center rounded-md p-2 text-gray-500 hover:bg-stone-100 hover:text-[hsl(24,95%,53%)] focus:outline-none focus:ring-2 focus:ring-[hsl(24,95%,53%)]/30"
          aria-label="Search"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-4.35-4.35M11 18a7 7 0 1 1 0-14 7 7 0 0 1 0 14Z" />
          </svg>
        </button>
      </div>
    </form>

    <div id="search-status" class="text-sm text-gray-500 mb-4" aria-live="polite"></div>
    <ol id="search-results" class="space-y-6"></ol>

    <div id="search-empty" class="hidden text-center py-12">
      <p class="text-gray-600 mb-4">No results found.</p>
      <p class="text-sm text-gray-500">
        Try different keywords, or browse the
        <a href="/articles" class="text-[hsl(24,95%,53%)] hover:underline">articles</a>,
        <a href="/workflows/breeding-cycles" class="text-[hsl(24,95%,53%)] hover:underline">workflows</a>,
        or <a href="/buyers" class="text-[hsl(24,95%,53%)] hover:underline">buyer guides</a>.
      </p>
    </div>

    <div id="search-initial" class="text-center py-12">
      <p class="text-gray-600 mb-4">Type a search term to begin.</p>
      <p class="text-sm text-gray-500">
        Popular topics:
        <a href="/search?q=progesterone" class="text-[hsl(24,95%,53%)] hover:underline">progesterone</a>,
        <a href="/search?q=heat+cycle" class="text-[hsl(24,95%,53%)] hover:underline">heat cycle</a>,
        <a href="/search?q=waitlist" class="text-[hsl(24,95%,53%)] hover:underline">waitlist</a>,
        <a href="/search?q=contracts" class="text-[hsl(24,95%,53%)] hover:underline">contracts</a>,
        <a href="/search?q=pedigree" class="text-[hsl(24,95%,53%)] hover:underline">pedigree</a>.
      </p>
    </div>
  </main>

  <!--
    Pagefind runtime is loaded from /pagefind/pagefind.js, which is generated
    by `pagefind --site dist/client --output-subdir pagefind` after astro build.
    In `astro dev` this file does not exist, so the page shows a graceful
    "Search is only available in the production build" message.
  -->
  <script is:inline>
    (function () {
      var form = document.getElementById('search-form');
      var input = document.getElementById('search-input');
      var status = document.getElementById('search-status');
      var results = document.getElementById('search-results');
      var empty = document.getElementById('search-empty');
      var initial = document.getElementById('search-initial');

      if (!form || !input || !status || !results || !empty || !initial) return;

      var pagefindPromise = null;
      function loadPagefind() {
        if (!pagefindPromise) {
          pagefindPromise = import('/pagefind/pagefind.js')
            .then(function (mod) {
              if (mod && typeof mod.init === 'function') {
                return mod.init().then(function () { return mod; });
              }
              return mod;
            })
            .catch(function (err) {
              pagefindPromise = null;
              throw err;
            });
        }
        return pagefindPromise;
      }

      function escapeHtml(value) {
        return String(value)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function renderResults(items) {
        results.innerHTML = items.map(function (item) {
          var title = item.meta && item.meta.title ? item.meta.title : item.url;
          var url = item.url;
          var excerpt = item.excerpt || '';
          return (
            '<li class="border-b border-stone-200 pb-5">' +
              '<a href="' + escapeHtml(url) + '" class="block group">' +
                '<h2 class="text-lg font-semibold text-[hsl(24,95%,53%)] group-hover:underline mb-1">' + escapeHtml(title) + '</h2>' +
                '<p class="text-xs text-gray-500 mb-2">' + escapeHtml(url) + '</p>' +
                '<p class="text-sm text-gray-700 leading-relaxed">' + excerpt + '</p>' +
              '</a>' +
            '</li>'
          );
        }).join('');
      }

      var debounceTimer = null;
      var lastQuery = '';

      async function runSearch(query) {
        query = (query || '').trim();
        if (!query) {
          initial.classList.remove('hidden');
          empty.classList.add('hidden');
          results.innerHTML = '';
          status.textContent = '';
          return;
        }

        initial.classList.add('hidden');
        status.textContent = 'Searching...';

        try {
          var pagefind = await loadPagefind();
          var search = await pagefind.search(query);
          var rawItems = await Promise.all(search.results.slice(0, 25).map(function (r) { return r.data(); }));

          if (rawItems.length === 0) {
            results.innerHTML = '';
            empty.classList.remove('hidden');
            status.textContent = 'No results for "' + query + '".';
            return;
          }

          empty.classList.add('hidden');
          renderResults(rawItems);
          status.textContent = rawItems.length === 1
            ? '1 result for "' + query + '".'
            : rawItems.length + ' results for "' + query + '".';
        } catch (err) {
          console.error('Pagefind search failed', err);
          results.innerHTML = '';
          empty.classList.add('hidden');
          status.textContent = 'Search is only available in the production build. Run `npm run build && npm run preview` to test locally.';
        }
      }

      function pushQueryToUrl(query) {
        if (query === lastQuery) return;
        lastQuery = query;
        var url = new URL(window.location.href);
        if (query) {
          url.searchParams.set('q', query);
        } else {
          url.searchParams.delete('q');
        }
        window.history.replaceState({}, '', url.toString());
      }

      input.addEventListener('input', function () {
        if (debounceTimer) clearTimeout(debounceTimer);
        var query = input.value;
        debounceTimer = setTimeout(function () {
          pushQueryToUrl(query);
          runSearch(query);
        }, 180);
      });

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        if (debounceTimer) clearTimeout(debounceTimer);
        var query = input.value;
        pushQueryToUrl(query);
        runSearch(query);
      });

      // Initial query from URL (?q=...) - powers shareable search URLs
      var params = new URLSearchParams(window.location.search);
      var initialQuery = params.get('q') || '';
      if (initialQuery) {
        input.value = initialQuery;
        lastQuery = initialQuery;
        runSearch(initialQuery);
      }
      input.focus();
    })();
  </script>
</BaseLayout>
