---
import BaseLayout from '../layouts/BaseLayout.astro';

// Demo / smoke-test page for the marketplace embed widget (MPL-077).
// Mimics a generic breeder's personal website so we can validate end-to-end
// that the widget renders, JSON-LD injects, the SEO mirror behaves, and
// outbound links carry attribution — exactly as they will on a real
// breeder's Squarespace/Wix/WordPress site.
//
// IMPORTANT: this page is `noindex` (set via BaseLayout below). It must
// NEVER be linked from the public site nav and must never be indexed —
// Googlebot would associate the demo's fake breeder content with the
// breederhq.com domain.
//
// To replace the placeholder snippet:
// 1. Generate the real snippet in Commerce → Embed on My Website (or via
//    `npm run embed:snippet:dev -- --slug <Tenant.slug>`).
// 2. Paste it inside the comment-marked block below.
// 3. Commit + push; Vercel auto-redeploys.
---

<BaseLayout
  title="Embed Widget Demo (Internal) | BreederHQ"
  description="Internal smoke-test page demonstrating the BreederHQ marketplace embed widget rendered on a mock breeder website."
  noindex={true}
>
  <main>

    <!-- ============================================ -->
    <!-- DEMO BANNER                                  -->
    <!-- ============================================ -->
    <div class="bg-amber-100 border-b-2 border-amber-500 px-4 py-3 text-center">
      <p class="text-sm text-amber-900">
        🧪 <strong>Internal demo page.</strong>
        This is a mock breeder website used to smoke-test the BreederHQ embed widget.
        The "breeder" below is fictional. Not indexed by search engines.
      </p>
    </div>

    <!-- ============================================ -->
    <!-- FAKE BREEDER HERO                            -->
    <!-- (Mimics a generic Squarespace-style site)    -->
    <!-- ============================================ -->
    <header class="bg-stone-100 border-b border-stone-200">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-6 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-full bg-amber-700 grid place-items-center text-white font-bold">SF</div>
          <span class="text-xl font-semibold text-stone-900">Smith Family Border Collies</span>
        </div>
        <nav class="hidden md:flex items-center gap-6 text-sm text-stone-700">
          <a href="#" class="hover:text-stone-900">Home</a>
          <a href="#" class="hover:text-stone-900">About</a>
          <a href="#our-dogs" class="hover:text-stone-900">Our Dogs</a>
          <a href="#" class="hover:text-stone-900">Litters</a>
          <a href="#" class="hover:text-stone-900">Contact</a>
        </nav>
      </div>
    </header>

    <section class="bg-gradient-to-b from-stone-100 to-white py-20">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-5xl font-bold text-stone-900 mb-4">
          Working Border Collies, Bred in Vermont
        </h1>
        <p class="text-xl text-stone-700 max-w-2xl mx-auto">
          A small family kennel raising health-tested working dogs from
          proven herding lines. Every puppy is raised in our home with
          love and structure.
        </p>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- FAKE "ABOUT" SECTION                         -->
    <!-- ============================================ -->
    <section class="py-16 bg-white">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-stone-700">
        <h2 class="text-3xl font-bold text-stone-900 mb-6">About Us</h2>
        <p class="mb-4">
          We've been breeding Border Collies for over fifteen years from our
          farm in Vermont's Green Mountains. Our dogs work sheep on the
          weekends and curl up on the couch in the evenings — that balance
          is what we breed for.
        </p>
        <p class="mb-4">
          Every breeding pair is health-tested through OFA, hips, eyes, and
          the standard breed panels. We work with our reproductive vet on
          every cycle, and we keep clear records of every test, every breeding,
          and every placement.
        </p>
        <p>
          We believe in transparency. That's why we list every program,
          every current litter, and every available animal on BreederHQ —
          so prospective owners can verify what we say before they ever
          send a deposit.
        </p>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- THE EMBED WIDGET — whole storefront mode     -->
    <!-- ============================================ -->
    <section id="our-dogs" class="py-12 bg-stone-50">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-stone-900 mb-2 text-center">
          Our Programs &amp; Available Dogs
        </h2>
        <p class="text-center text-stone-600 mb-10">
          Live data from our BreederHQ profile, updated automatically.
        </p>

        <!--
          ─── EMBED WIDGET — WHOLE STOREFRONT ────────────────────────────────
          Snippet generated from Commerce → Embed on My Website on
          app-dev.breederhq.com (Aaron, 2026-04-26).

          NOTE: the source-of-truth Settings page emitted a snippet
          pointing at `embed.breederhq.com` (prod CDN) because of a
          prod-defaulting bug. The fix landed in commit a1097d25 but
          hadn't redeployed when the snippet was generated. Pointing
          the script at embed-dev.breederhq.com for the demo since dev
          is the only CDN that currently has the bundle.

          When prod CDN has the bundle and we have a real prod tenant
          to demo, regenerate the snippet from the prod Settings page
          and paste it here.
        -->
        <div id="breederhq-widget"></div>
        <script is:inline src="https://embed-dev.breederhq.com/v1/widget.js" data-breeder="dev-hogwarts" async></script>

        <!-- Until the snippet is pasted, render a soft placeholder so the
             page doesn't look broken when viewed before deploy. -->
        <div id="embed-placeholder" class="rounded-2xl border-2 border-dashed border-stone-300 bg-white p-12 text-center">
          <div class="text-6xl mb-4">📦</div>
          <h3 class="text-xl font-semibold text-stone-900 mb-2">Embed Widget Drop Zone</h3>
          <p class="text-stone-600 max-w-md mx-auto">
            The BreederHQ widget renders here once the snippet is pasted.
            This placeholder will be replaced by the real widget on deploy.
          </p>
        </div>
        <script is:inline>
          // Hide the placeholder once the real widget mounts. The widget
          // claims #breederhq-widget and attaches Shadow DOM to it, so we
          // can detect mount via a brief poll for shadowRoot.
          (function () {
            var poll = 0;
            var timer = setInterval(function () {
              var container = document.getElementById('breederhq-widget');
              var placeholder = document.getElementById('embed-placeholder');
              if (container && container.shadowRoot && placeholder) {
                placeholder.style.display = 'none';
                clearInterval(timer);
                return;
              }
              if (poll++ > 40) {
                // 40 * 250ms = 10s; widget didn't mount. Leave the
                // placeholder visible so the page surfaces the gap.
                clearInterval(timer);
              }
            }, 250);
          })();
        </script>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- A SECOND EMBED — per-program mode            -->
    <!-- (Demonstrates multi-instance contract)       -->
    <!-- ============================================ -->
    <section class="py-12 bg-white">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-stone-900 mb-2 text-center">
          Just Our Working Line
        </h2>
        <p class="text-center text-stone-600 mb-10">
          A second embed on the same page, scoped to one specific program.
          Tests the multi-instance contract.
        </p>

        <!--
          ─── EMBED WIDGET — SINGLE PROGRAM ──────────────────────────────────
          REPLACE with a `data-program="<program-slug>"` snippet. The
          container below has a different id (the bundle creates a fresh
          adjacent container when #breederhq-widget is already claimed).
        -->

        <!-- TODO(aaron): paste a per-program <script> tag here. Expected:
               <script src="https://embed-dev.breederhq.com/v1/widget.js"
                       data-program="<program-slug>" async></script>
        -->

        <div id="embed-placeholder-2" class="rounded-2xl border-2 border-dashed border-stone-300 bg-stone-50 p-12 text-center">
          <div class="text-4xl mb-3">📦</div>
          <p class="text-stone-600 max-w-md mx-auto">
            Single-program embed drop zone. Will render the second widget
            instance once the snippet is pasted.
          </p>
        </div>
      </div>
    </section>

    <!-- ============================================ -->
    <!-- FAKE FOOTER                                  -->
    <!-- ============================================ -->
    <footer class="bg-stone-900 text-stone-300 py-12 mt-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 text-center">
        <p class="font-semibold text-white mb-2">Smith Family Border Collies</p>
        <p class="text-sm text-stone-400 mb-4">
          Green Mountains, Vermont · Established 2010
        </p>
        <p class="text-xs text-stone-500 max-w-xl mx-auto">
          🧪 This is a demo page hosted by BreederHQ for internal smoke-testing of the marketplace embed widget.
          Smith Family Border Collies is a fictional breeder. The widget above renders live data from a real
          BreederHQ tenant for testing purposes only.
        </p>
      </div>
    </footer>

  </main>
</BaseLayout>
