---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Free Tools', url: '/free-tools' }
];

// Single source of truth for the hub's last-reviewed date. Update when the
// hub copy or tool list is meaningfully revised; flows into the JSON-LD
// datePublished/dateModified below.
const lastReviewedISO = '2026-05-16';

const liveTools = [
  {
    slug: 'breeding-planner',
    name: 'Breeding Planner',
    description: 'Project upcoming heat cycles, breeding windows, and the open time between them for dogs, horses, goats, sheep, and cattle.',
    bullets: [
      'Up to 3 females, any mix of dogs, horses, goats, sheep, and cattle',
      'Projects three upcoming cycles from a single last-heat date, no history required',
      'Gantt chart of pre-heat, breeding, gestation, birthing, and offspring-care phases, plus the open windows between them across all your animals'
    ],
    href: '/free-tools/breeding-planner'
  }
];

const comingSoonTools = [
  {
    name: 'COI Calculator',
    description: 'Calculate coefficient of inbreeding from any pedigree. Paste registration numbers or upload a 5-generation PDF.'
  },
  {
    name: 'Whelping Kit Checklist',
    description: 'Print-friendly checklist of every supply you will need before the litter arrives. Species-specific.'
  },
  {
    name: 'Stud Fee Comparison Tool',
    description: 'Compare stud fees against pick-of-litter and split-litter alternatives. See the breakeven math.'
  },
  {
    name: 'Puppy Weight Tracker',
    description: 'Log daily weights and see growth curves vs. breed averages. CSV export.'
  }
];

const collectionPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://breederhq.com/free-tools#collection',
  'name': 'Free Tools for Breeders',
  'description': 'Free utilities for professional breeders. Use them standalone or alongside the full BreederHQ platform.',
  'url': 'https://breederhq.com/free-tools',
  'isPartOf': {
    '@id': 'https://breederhq.com/#organization'
  },
  'mainEntity': {
    '@type': 'ItemList',
    'itemListElement': liveTools.map((tool, idx) => ({
      '@type': 'ListItem',
      'position': idx + 1,
      'name': tool.name,
      'url': `https://breederhq.com${tool.href}`,
      'description': tool.description
    }))
  },
  'datePublished': lastReviewedISO,
  'dateModified': lastReviewedISO
};
---

<BaseLayout
  title="Free Tools for Breeders | BreederHQ"
  description="Free utilities for professional breeders. Use them standalone or alongside the full BreederHQ platform. No signup, no email gate, no catch."
  breadcrumbs={breadcrumbs}
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(collectionPageSchema)} />

  <main>
    <nav class="breadcrumb py-4 px-4 bg-gray-50" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 max-w-4xl mx-auto text-sm">
        <li><a href="/" class="text-[hsl(24,95%,53%)] hover:underline">Home</a></li>
        <li class="text-gray-400">›</li>
        <li aria-current="page" class="text-gray-600">Free Tools</li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="bg-gradient-to-b from-stone-50 to-white pt-12 pb-10 px-4">
      <div class="max-w-4xl mx-auto">
        <span class="inline-flex items-center text-[10px] font-bold uppercase tracking-widest text-amber-800 border border-amber-300 bg-amber-50 px-2 py-0.5 rounded mb-4">
          BreederHQ Free Tools
        </span>
        <h1 class="text-5xl font-bold tracking-tight text-gray-900 leading-tight mb-3">
          Free Tools for Breeders
        </h1>
        <p class="text-lg text-gray-600 max-w-3xl leading-relaxed mb-4">
          Use them standalone or alongside the full BreederHQ platform.
        </p>
        <p class="text-gray-700 leading-relaxed max-w-3xl">
          We build free tools breeders can use today, no signup or email required. The full BreederHQ platform extends each of these with real-time data, multi-animal tracking, integrated breeding programs, and a marketplace. These tools work without it.
        </p>
      </div>
    </section>

    <!-- Available Now -->
    <section class="pt-10 pb-12 px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">Available Now</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {liveTools.map(tool => (
            <a
              href={tool.href}
              class="group block bg-white rounded-xl border border-gray-300 hover:border-amber-400 shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 p-6"
            >
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-xl font-bold text-gray-900 group-hover:text-amber-700 transition">
                  {tool.name}
                </h3>
                <span class="inline-flex items-center text-[10px] font-bold uppercase tracking-wider text-amber-800 border border-amber-300 bg-amber-50 px-2 py-0.5 rounded">
                  Free, no signup
                </span>
              </div>
              <p class="text-gray-700 leading-relaxed mb-4">
                {tool.description}
              </p>
              <ul class="space-y-2 mb-5">
                {tool.bullets.map(b => (
                  <li class="flex items-start gap-2 text-sm text-gray-700">
                    <span class="text-amber-500 mt-0.5 shrink-0">&#10003;</span>
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
              <span class="inline-flex items-center text-sm font-semibold text-amber-700 group-hover:text-amber-800">
                Open the Tool <span class="ml-1 transition-transform group-hover:translate-x-0.5">&rarr;</span>
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Coming Soon -->
    <section class="pt-2 pb-16 px-4 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">Coming Soon</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {comingSoonTools.map(tool => (
            <div class="block bg-gray-50 rounded-xl border border-gray-200 p-6 opacity-80">
              <div class="flex items-center justify-between mb-3">
                <h3 class="text-xl font-bold text-gray-700">
                  {tool.name}
                </h3>
                <span class="inline-flex items-center text-[10px] font-bold uppercase tracking-wider text-gray-500 border border-gray-300 bg-white px-2 py-0.5 rounded">
                  Coming soon
                </span>
              </div>
              <p class="text-gray-600 leading-relaxed">
                {tool.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why We Give These Away -->
    <section class="py-12 px-4 bg-stone-50 border-y border-stone-200">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">Why We Give These Away</h2>
        <div class="space-y-4 text-gray-700 leading-relaxed">
          <p>
            Most breeder software hides utility behind paywalls and trial limits. We do not. These tools work standalone, no account required.
          </p>
          <p>
            If they are useful and you want more, multi-animal tracking, integrated breeding programs, a marketplace, and a client portal, the full BreederHQ platform extends each of these tools with real data flowing across your whole program. If they are useful as standalones and you never sign up, that is fine too.
          </p>
        </div>
      </div>
    </section>

    <!-- Closing CTA -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-3xl mx-auto">
        <div class="rounded-xl border-2 border-amber-300 bg-amber-50/40 p-8 md:p-10 shadow-sm">
          <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-3">
            Want These Tools Connected?
          </h2>
          <p class="text-gray-700 leading-relaxed mb-6">
            The full BreederHQ platform extends every free tool with real-time data across your entire breeding program.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="https://accounts.breederhq.com/register?intent=breeder_dashboard"
              class="inline-flex items-center justify-center bg-[hsl(24,95%,53%)] hover:bg-[hsl(24,95%,48%)] text-white font-semibold px-6 py-3 rounded-lg shadow-sm hover:shadow transition"
            >
              Get Started Free
            </a>
            <a
              href="/for-breeders"
              class="inline-flex items-center justify-center bg-white hover:bg-amber-50 text-amber-800 border border-amber-300 font-semibold px-6 py-3 rounded-lg transition"
            >
              See the Platform
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
