---
import GeoPage from '../../../components/GeoPage.astro';
import { fetchServiceListings } from '../../../lib/marketplaceListings';
const listings = await fetchServiceListings('livestock-services', { state: 'Oklahoma' });
const breadcrumbs = [{ name: 'Home', url: '/' }, { name: 'Livestock Services', url: '/services/livestock-services' }, { name: 'Oklahoma', url: '/services/livestock-services/oklahoma' }];
const faqs = [
  { question: 'What livestock services concentrate in Oklahoma?', answer: 'Oklahoma is one of the largest cattle states by some measures and home to a substantial sheep, goat, and Boer goat industry. The state hosts the OSU College of Veterinary Medicine, anchoring specialist livestock services. Cattle ranching dominates the western half of the state; small-farm goat, sheep, and pork operations cluster across the eastern half.' },
  { question: 'What about OSU veterinary medicine?', answer: 'OSU Veterinary Medical Hospital in Stillwater is a major livestock specialist center — advanced repro, surgical, herd health, and food animal medicine. Many cattle ranches in the region run AI and ET programs in coordination with OSU.' },
  { question: 'What about Boer goats?', answer: 'Oklahoma is one of the top Boer goat states. Goat producers cluster across the eastern half of the state and use AI, embryo transfer, hoof trimming, and herd health services on an established calendar.' }
];
const service = { name: 'Livestock Services in Oklahoma', description: 'Cattle AI/ET, sheep shearing, Boer goat services, herd health, and breeding work across Oklahoma.', serviceType: 'Livestock Services', areaServed: 'Oklahoma', offerDescription: 'Statewide livestock services directory.', offerUrl: '/services/livestock-services/oklahoma' };
const regions = [
  { name: 'Western Oklahoma (Woodward, Elk City, Clinton)', note: 'Large-scale cattle ranching. Branding, preg-check, AI work.' },
  { name: 'Stillwater & North Central (OSU)', note: 'OSU vet school. Specialist breeding, surgical, food animal medicine.' },
  { name: 'Southeast Oklahoma (McAlester, Hugo, Idabel)', note: 'Cattle, pasture, and small farm operations.' },
  { name: 'Central / South Oklahoma (Pauls Valley, Ardmore)', note: 'Mixed cattle, goat, and pleasure-livestock operations.' },
  { name: 'Eastern Oklahoma / Ozarks (Tahlequah, Muskogee)', note: 'Small farms, goat dairy, and pleasure livestock.' }
];
const specialties = [
  { label: 'Cattle AI & Embryo Transfer', detail: 'OSU-coordinated and ranch-direct breeding services.' },
  { label: 'Boer Goat Services', detail: 'AI, ET, hoof trimming, and breed-specific herd health.' },
  { label: 'Sheep Shearing', detail: 'Spring circuit shearing.' },
  { label: 'Branding & Working', detail: 'Spring branding circuit support across western Oklahoma.' },
  { label: 'Pregnancy Checking', detail: 'Fall preg-checking work.' },
  { label: 'Herd Health', detail: 'Working herd programs.' }
];
const relatedCards = [
  { href: '/services/livestock-services', emoji: '🐄', title: 'All Livestock Services', note: 'Browse the full livestock category.' },
  { href: '/services/farriers/oklahoma', emoji: '🔨', title: 'Farriers in Oklahoma', note: 'Quarter Horse country farriers.' },
  { href: '/services/livestock-services/texas', emoji: '🐄', title: 'Livestock Services in Texas', note: 'Adjacent cattle country.' }
];
---
<GeoPage title="Livestock Services in Oklahoma | BreederHQ Marketplace" description="Find livestock service providers in Oklahoma. Cattle AI and ET, Boer goat services, sheep shearing, branding, preg checking, and herd health across western Oklahoma, OSU, and statewide." breadcrumbs={breadcrumbs} faqs={faqs} service={service} category="Livestock Services" location="Oklahoma" categorySlug="livestock-services" parentHref="/services/livestock-services" parentLabel="Livestock Services" introHeading="Livestock Services in Oklahoma" introBody="Find livestock service providers across Oklahoma on BreederHQ Marketplace. Oklahoma is one of the largest cattle states in the country, home to a substantial Boer goat industry, and anchored by the OSU College of Veterinary Medicine in Stillwater. Working livestock services span large-scale ranches in the western half and small-farm operations across the eastern half." regionsHeading="Livestock Service Markets Across Oklahoma" regionsIntro="Five corridors with different livestock industries." regions={regions} specialtiesHeading="Livestock Service Specialties in Oklahoma" specialtiesIntro="OSU and the Boer goat industry add specialty layers absent from most cattle-state markets." specialties={specialties} relatedCards={relatedCards} providerHref="/for-providers/livestock" providerLabel="Are you a livestock service provider in Oklahoma?"  listings={listings} listingsUnit="provider" />
