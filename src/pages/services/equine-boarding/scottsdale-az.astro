---
import GeoPage from '../../../components/GeoPage.astro';
import { fetchServiceListings } from '../../../lib/marketplaceListings';
const listings = await fetchServiceListings('equine-boarding', { city: 'Scottsdale', state: 'AZ' });
const breadcrumbs = [{ name: 'Home', url: '/' }, { name: 'Equine Boarding', url: '/services/equine-boarding' }, { name: 'Scottsdale, AZ', url: '/services/equine-boarding/scottsdale-az' }];
const faqs = [
  { question: 'What makes Scottsdale a distinct equine market?', answer: 'Scottsdale is the Arabian horse capital of the world. The Scottsdale Arabian Horse Show (held each February at WestWorld) is the largest Arabian event in the world. Beyond Arabians, the Scottsdale corridor supports hunter/jumper, dressage, polo at Cave Creek, and Western pleasure populations. WestWorld also hosts a year-round event calendar across multiple disciplines.' },
  { question: 'What about boarding for Arabian show horses?', answer: 'Arabian training and show barns cluster in Scottsdale, Paradise Valley, Cave Creek, and Wickenburg. These facilities specialize in halter conformation, English pleasure, country pleasure, native costume, and the broader Arabian show disciplines. Many facilities have direct relationships with Scottsdale Show stabling.' },
  { question: 'What about heat and turnout?', answer: 'Summer temperatures in the Phoenix metro regularly exceed 110°F. Most boarding facilities provide shade structures, misters, and overnight or early-morning turnout schedules. Confirm summer turnout policies before booking; daytime turnout in July is unsafe.' }
];
const service = { name: 'Equine Boarding in Scottsdale, AZ', description: 'Arabian, hunter/jumper, dressage, and Western pleasure boarding in Scottsdale and the Phoenix metro.', serviceType: 'Equine Boarding', areaServed: 'Scottsdale, AZ', offerDescription: 'Scottsdale-area equine boarding directory.', offerUrl: '/services/equine-boarding/scottsdale-az' };
const regions = [
  { name: 'Scottsdale / Paradise Valley', note: 'Arabian show barn corridor. Premium training facilities, ring time, in-house grooming and prep.' },
  { name: 'Cave Creek / Carefree', note: 'Polo, hunter/jumper, and mixed-discipline facilities with larger lots.' },
  { name: 'Wickenburg', note: 'Team roping capital, Quarter Horse and Arabian breeding facilities. Working ranch-adjacent.' },
  { name: 'Rio Verde / North Scottsdale', note: 'Higher-elevation desert. Trail and pleasure facilities.' },
  { name: 'Phoenix Metro / Mesa / Gilbert', note: 'Mixed pleasure and pleasure-show facilities. More accessible pricing.' }
];
const specialties = [
  { label: 'Arabian Show Barn', detail: 'Halter conformation, English pleasure, native costume training board.' },
  { label: 'Hunter/Jumper', detail: 'Show-circuit training board with WestWorld ring access.' },
  { label: 'Polo Facility', detail: 'Cave Creek and Phoenix polo string boarding.' },
  { label: 'Western Pleasure', detail: 'AQHA and breed-specific training board.' },
  { label: 'Layup & Retirement', detail: 'Desert layup and retirement facilities for snowbird arrangements.' }
];
const relatedCards = [
  { href: '/services/farriers/arizona', emoji: '🔨', title: 'Farriers in Arizona', note: 'Arabian and show-circuit farriers.' },
  { href: '/services/equine-services', emoji: '🐎', title: 'Equine Services', note: 'Trainers, vets, bodyworkers.' },
  { href: '/services/equine-boarding/wellington-fl', emoji: '🏇', title: 'Equine Boarding in Wellington', note: 'Adjacent winter equestrian market.' }
];
---
<GeoPage title="Equine Boarding in Scottsdale, AZ | BreederHQ Marketplace" description="Find equine boarding in Scottsdale Arizona. Arabian show barns, hunter/jumper training, polo at Cave Creek, Western pleasure, and layup facilities across the Phoenix metro and Wickenburg." breadcrumbs={breadcrumbs} faqs={faqs} service={service} category="Equine Boarding" location="Scottsdale, AZ" categorySlug="equine-boarding" parentHref="/services/equine-boarding" parentLabel="Equine Boarding" introHeading="Equine Boarding in Scottsdale, AZ" introBody="Find equine boarding in Scottsdale and the surrounding Phoenix metro on BreederHQ Marketplace. Scottsdale is the Arabian capital of the world, anchored by WestWorld and the Scottsdale Arabian Horse Show, with deep secondary populations in hunter/jumper, dressage, polo at Cave Creek, and Western pleasure across the metro and out to Wickenburg." regionsHeading="Boarding Markets in the Scottsdale Corridor" regionsIntro="Five distinct sub-markets, anchored by the Arabian show industry." regions={regions} specialtiesHeading="Boarding Specialties in Scottsdale" specialtiesIntro="The Arabian show industry drives most premium specialization; secondary disciplines round out the market." specialties={specialties} relatedCards={relatedCards} providerHref="/for-providers/equine" providerLabel="Operate a Scottsdale-area boarding facility?"  listings={listings} listingsUnit="facility" />
