---
import GeoPage from '../../../components/GeoPage.astro';
import { fetchServiceListings } from '../../../lib/marketplaceListings';
const listings = await fetchServiceListings('equine-boarding', { city: 'Aiken', state: 'SC' });
const breadcrumbs = [{ name: 'Home', url: '/' }, { name: 'Equine Boarding', url: '/services/equine-boarding' }, { name: 'Aiken, SC', url: '/services/equine-boarding/aiken-sc' }];
const faqs = [
  { question: 'Why is Aiken known for equine boarding?', answer: 'Aiken has been a winter training destination since the 1880s. Soft sandy soils, year-round mild winters, a tight equine community, and a tradition that runs back to the Whitney era make Aiken one of the most concentrated training environments in the country. Thoroughbred trainers, eventers, polo players, steeplechase riders, and dressage riders winter here.' },
  { question: 'What are the major equine sub-markets in Aiken?', answer: 'The historic Aiken Training Track and the Whitney Field hunt country still anchor the Thoroughbred and foxhunting communities. Bruce\'s Field and Hitchcock Woods support eventing and steeplechase. The polo grounds at Whitney Field and New Bridge support deep polo populations. The Three Runs Plantation, Sandhurst Estates, and other newer equestrian communities have built modern boarding around the historic core.' },
  { question: 'Is Aiken seasonal?', answer: 'Less seasonal than Wellington. Many winter boarders return year after year and some maintain year-round arrangements. Summer slows down but is not empty; local horses, training facilities, and steeplechase operations run year-round.' }
];
const service = { name: 'Equine Boarding in Aiken, SC', description: 'Winter training boarding, eventing, Thoroughbred, polo, and steeplechase facilities in Aiken.', serviceType: 'Equine Boarding', areaServed: 'Aiken, SC', offerDescription: 'Aiken-area equine boarding directory.', offerUrl: '/services/equine-boarding/aiken-sc' };
const regions = [
  { name: 'Aiken Training Track Corridor', note: 'Thoroughbred winter training. Historic training barns with track access.' },
  { name: 'Whitney Field / Hitchcock Woods', note: 'Foxhunting and trail boarding. Old Aiken hunt country.' },
  { name: 'Three Runs Plantation', note: 'Modern equestrian community with eventing and dressage facilities.' },
  { name: 'Bridle Creek / Sandhurst Estates', note: 'Newer equine communities with boarding integrated into residential lots.' },
  { name: 'Bruce\'s Field & Steeplechase Course', note: 'Eventing and steeplechase boarding with course access.' },
  { name: 'New Bridge & Polo Country', note: 'Polo string boarding for the Aiken polo season.' }
];
const specialties = [
  { label: 'Winter Training Board', detail: 'Thoroughbred training board with track access.' },
  { label: 'Eventing Training Board', detail: 'Cross-country schooling, gallop tracks, dressage rings.' },
  { label: 'Polo Facility', detail: 'String boarding with polo grounds access.' },
  { label: 'Foxhunt Boarding', detail: 'Whitney Field hunt and Aiken Hounds country access.' },
  { label: 'Year-Round Boarding', detail: 'Local-population facilities for permanent residents.' }
];
const relatedCards = [
  { href: '/services/farriers/south-carolina', emoji: '🔨', title: 'Farriers in South Carolina', note: 'Aiken winter training farriers.' },
  { href: '/services/equine-boarding/wellington-fl', emoji: '🏇', title: 'Equine Boarding in Wellington', note: 'Adjacent winter equestrian market.' },
  { href: '/services/equine-services', emoji: '🐎', title: 'Equine Services', note: 'Trainers, vets, and clinicians.' }
];
---
<GeoPage title="Equine Boarding in Aiken, SC | BreederHQ Marketplace" description="Find equine boarding in Aiken South Carolina. Winter training facilities for Thoroughbreds, eventers, polo players, and foxhunters. Three Runs Plantation, Bridle Creek, Aiken Training Track corridor." breadcrumbs={breadcrumbs} faqs={faqs} service={service} category="Equine Boarding" location="Aiken, SC" categorySlug="equine-boarding" parentHref="/services/equine-boarding" parentLabel="Equine Boarding" introHeading="Equine Boarding in Aiken, SC" introBody="Find equine boarding in Aiken on BreederHQ Marketplace. Aiken has been a winter training destination since the 1880s, with one of the deepest concentrations of Thoroughbred, eventing, polo, steeplechase, and foxhunt training in the United States. Soft sandy soils, mild winters, and a tradition that runs back to the Whitney era make Aiken a year-round equine community with a seasonal training surge." regionsHeading="Boarding Markets in Aiken" regionsIntro="Six distinct sub-markets, anchored by the historic training track and hunt country." regions={regions} specialtiesHeading="Boarding Specialties in Aiken" specialtiesIntro="Aiken's traditions drive specialization toward training board across disciplines." specialties={specialties} relatedCards={relatedCards} providerHref="/for-providers/equine" providerLabel="Operate an Aiken-area boarding facility?"  listings={listings} listingsUnit="facility" />
