---
import GeoPage from '../../../components/GeoPage.astro';
import { fetchServiceListings } from '../../../lib/marketplaceListings';
const listings = await fetchServiceListings('equine-boarding', { city: 'Houston', state: 'TX' });
const breadcrumbs = [{ name: 'Home', url: '/' }, { name: 'Equine Boarding', url: '/services/equine-boarding' }, { name: 'Houston, TX', url: '/services/equine-boarding/houston-tx' }];
const faqs = [
  { question: 'Where do horse owners board in the Houston area?', answer: 'The major Houston-area equine corridors are Magnolia, Tomball, Hockley, and Waller in the northwest (deep hunter/jumper, dressage, and breeding); Brookshire and Katy further west; The Woodlands, Spring, and Conroe in the north; and Brenham and the Brazos Valley west of Houston for breeding and ranch facilities. Each corridor has its own discipline base and pricing.' },
  { question: 'What about summer heat and turnout?', answer: 'Houston summers are hot and humid, often 95°F+ for months. Most boarding facilities run early-morning or overnight turnout schedules in summer with shade structures and large troughs. Confirm summer turnout policy before booking — full-day daytime turnout is unsafe.' },
  { question: 'What disciplines concentrate around Houston?', answer: 'Hunter/jumper at Great Southwest Equestrian Center (Katy) and the Magnolia corridor; dressage clustered around Magnolia and Tomball; cutting and reining throughout Waller and the Brazos Valley; breeding facilities along the Brazos River; and pleasure and trail across the suburban edge.' }
];
const service = { name: 'Equine Boarding in Houston, TX', description: 'Hunter/jumper, dressage, cutting/reining, and breeding boarding in the Houston metro and Brazos Valley.', serviceType: 'Equine Boarding', areaServed: 'Houston, TX', offerDescription: 'Houston-area equine boarding directory.', offerUrl: '/services/equine-boarding/houston-tx' };
const regions = [
  { name: 'Magnolia / Tomball / Hockley', note: 'Densest hunter/jumper and dressage market. Training board facilities with arenas.' },
  { name: 'Waller / Brookshire / Katy', note: 'Cutting, reining, breeding facilities. Great Southwest Equestrian Center.' },
  { name: 'The Woodlands / Spring / Conroe', note: 'Hunter/jumper, pleasure, and trail facilities.' },
  { name: 'Brenham / Brazos Valley', note: 'Breeding and Thoroughbred training. Texas A&M Vet School-adjacent.' },
  { name: 'Pearland / Friendswood / South Houston', note: 'Pleasure, pleasure-show, and trail.' }
];
const specialties = [
  { label: 'Hunter/Jumper Training Board', detail: 'Magnolia and Katy circuit training with ring access.' },
  { label: 'Dressage Training Board', detail: 'Tomball and Magnolia dressage facilities.' },
  { label: 'Cutting & Reining', detail: 'Waller and Brookshire performance training.' },
  { label: 'Breeding Facility', detail: 'Mare/foal care, stallion services, foaling.' },
  { label: 'Layup & Rehab', detail: 'Post-surgical and rest-period boarding.' }
];
const relatedCards = [
  { href: '/services/farriers/texas', emoji: '🔨', title: 'Farriers in Texas', note: 'Houston-area farriers.' },
  { href: '/services/equine-boarding/dallas-tx', emoji: '🏇', title: 'Equine Boarding in Dallas', note: 'DFW cutting and reining corridor.' },
  { href: '/services/equine-services', emoji: '🐎', title: 'Equine Services', note: 'Trainers, vets, and bodyworkers.' }
];
---
<GeoPage title="Equine Boarding in Houston, TX | BreederHQ Marketplace" description="Find equine boarding in the Houston metro. Hunter/jumper at Magnolia and Katy, dressage at Tomball, cutting/reining at Waller, and breeding facilities in the Brazos Valley." breadcrumbs={breadcrumbs} faqs={faqs} service={service} category="Equine Boarding" location="Houston, TX" categorySlug="equine-boarding" parentHref="/services/equine-boarding" parentLabel="Equine Boarding" introHeading="Equine Boarding in Houston, TX" introBody="Find equine boarding across the Houston metro on BreederHQ Marketplace. Houston anchors a deep hunter/jumper and dressage population in the Magnolia and Tomball corridor, cutting and reining barns through Waller and Brookshire, and a major Thoroughbred breeding industry along the Brazos Valley. Texas A&M Vet School at College Station anchors corrective and therapeutic case access." regionsHeading="Boarding Markets Around Houston" regionsIntro="Five distinct corridors with very different discipline mixes." regions={regions} specialtiesHeading="Boarding Specialties Around Houston" specialtiesIntro="Houston's discipline range produces specialization across hunter/jumper, dressage, cutting/reining, and breeding." specialties={specialties} relatedCards={relatedCards} providerHref="/for-providers/equine" providerLabel="Operate a Houston-area boarding facility?"  listings={listings} listingsUnit="facility" />
