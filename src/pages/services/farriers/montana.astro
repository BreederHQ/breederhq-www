---
import GeoPage from '../../../components/GeoPage.astro';
import { fetchServiceListings } from '../../../lib/marketplaceListings';
const listings = await fetchServiceListings('farriers', { state: 'Montana' });
const breadcrumbs = [{ name: 'Home', url: '/' }, { name: 'Farriers', url: '/services/farriers' }, { name: 'Montana', url: '/services/farriers/montana' }];
const faqs = [
  { question: 'Where does farrier demand concentrate in Montana?', answer: 'Montana is ranch and working horse country. The Billings and Bozeman corridors hold the densest farrier markets. Cattle ranches across eastern Montana support working farriers on longer circuits. The Bitterroot Valley (Hamilton, Stevensville) supports growing pleasure and trail populations. Big Sky and resort areas support dude ranch and trail outfitter work.' },
  { question: 'What about ranch and working horse shoeing?', answer: 'Montana ranch farriers cover practical, durable working shoeing for cow horses, ranch horses, and rodeo stock. Many run longer service-area circuits than coastal-state farriers — 100-mile driving radii are normal. AFA certification is less common in rural Montana; deep practical experience is the working credential.' },
  { question: 'What about endurance and trail?', answer: 'Western Montana supports endurance riding and a deep trail culture. Endurance farriers focus on conditioning shoeing balanced for long-distance terrain. Glue-ons and barefoot trim work are common.' }
];
const service = { name: 'Farriers in Montana', description: 'Ranch, rodeo, trail, and endurance farriers across Montana.', serviceType: 'Farrier and Hoof Care', areaServed: 'Montana', offerDescription: 'Statewide farrier directory.', offerUrl: '/services/farriers/montana' };
const regions = [
  { name: 'Billings & Eastern Montana', note: 'Cattle country. Working ranch and rodeo horse shoeing.' },
  { name: 'Bozeman & Gallatin Valley', note: 'Mixed pleasure, ranch, and growing sport horse population.' },
  { name: 'Bitterroot Valley (Hamilton, Stevensville)', note: 'Trail, pleasure, and growing eventing community.' },
  { name: 'Big Sky / Yellowstone Corridor', note: 'Dude ranch, outfitter, and trail country.' },
  { name: 'Helena & Western Montana', note: 'Mixed pleasure, ranch, and trail.' }
];
const specialties = [
  { label: 'Ranch Shoeing', detail: 'Durable working shoes for cattle work.' },
  { label: 'Rodeo & Roping', detail: 'Speed and grip work for rodeo athletes.' },
  { label: 'Endurance & Trail', detail: 'Long-distance conditioning shoeing.' },
  { label: 'Routine Trim', detail: 'Pasture, pleasure, retired cycles.' }
];
const relatedCards = [
  { href: '/services/farriers', emoji: '🔨', title: 'All Farriers', note: 'Browse the full farrier category.' },
  { href: '/services/livestock-services/montana', emoji: '🐄', title: 'Livestock Services in Montana', note: 'Cattle and livestock support.' },
  { href: '/services/farriers/wyoming', emoji: '🔨', title: 'Farriers in Wyoming', note: 'Adjacent ranch country.' }
];
---
<GeoPage title="Farriers in Montana | BreederHQ Marketplace" description="Find farriers in Montana. Ranch and working horse specialists, rodeo and roping farriers, endurance and trail farriers across the Bitterroot Valley, Bozeman, and statewide." breadcrumbs={breadcrumbs} faqs={faqs} service={service} category="Farriers" location="Montana" categorySlug="farriers" parentHref="/services/farriers" parentLabel="Farriers" introHeading="Farriers in Montana" introBody="Find farriers across Montana on BreederHQ Marketplace. Montana is ranch and working horse country — cattle ranches across the eastern half of the state, rodeo and roping populations statewide, dude ranches and trail outfitters in the Big Sky and Yellowstone corridors, and growing sport horse and endurance communities around Bozeman and the Bitterroot Valley." regionsHeading="Regional Farrier Markets in Montana" regionsIntro="Five distinct corridors with different working horse populations." regions={regions} specialtiesHeading="Farrier Specialties in Montana" specialtiesIntro="Ranch and working horse work dominate; specialty work clusters around growing sport horse communities." specialties={specialties} relatedCards={relatedCards} providerHref="/for-providers/farriers" providerLabel="Are you a farrier in Montana?"  listings={listings} listingsUnit="farrier" />
