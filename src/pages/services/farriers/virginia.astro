---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ListingsSection from '../../../components/ListingsSection.astro';
import { fetchServiceListings } from '../../../lib/marketplaceListings';
const listings = await fetchServiceListings('farriers', { state: 'Virginia' });
const breadcrumbs = [{ name: 'Home', url: '/' }, { name: 'Farriers', url: '/services/farriers' }, { name: 'Virginia', url: '/services/farriers/virginia' }];
const faqs = [
  { question: 'Where does farrier demand concentrate in Virginia?', answer: 'Three corridors. Northern Virginia hunt country (Middleburg, Upperville, The Plains, Warrenton) anchors foxhunting, eventing, and hunter/jumper. Central Virginia (Charlottesville, Keswick, Gordonsville) supports the Keswick Hunt and a strong eventing community. The Piedmont and Southside (Lynchburg, Roanoke) hold pleasure and trail populations. Colonial Downs at New Kent runs Thoroughbred meets.' },
  { question: 'What about Middleburg and hunt country?', answer: 'Middleburg and Upperville sit at the heart of one of the oldest foxhunting traditions in the United States. Farriers in Loudoun and Fauquier counties work with the Orange County, Piedmont, and Middleburg hunts, plus a high-performance hunter/jumper and eventing population. Demand for therapeutic and corrective work is heavy.' },
  { question: 'What about eventing in Virginia?', answer: 'Virginia is one of the deepest eventing states. The Virginia Horse Center in Lexington, Morven Park, Great Meadow, and the eventing circuit drive demand for performance shoeing balanced for cross-country, stadium, and dressage.' }
];
const service = { name: 'Farriers in Virginia', description: 'Find AFA-certified farriers, hunt country specialists, eventing performance shoers, racetrack plate farriers, and corrective farriers across Virginia.', serviceType: 'Farrier and Hoof Care', areaServed: 'Virginia', offerDescription: 'Statewide farrier directory.', offerUrl: '/services/farriers/virginia' };
const regions = [
  { name: 'Northern Virginia Hunt Country (Middleburg, Upperville, The Plains, Warrenton, Marshall)', note: 'Foxhunting, eventing, hunter/jumper. Deep CJF and therapeutic representation. Orange County, Piedmont, Middleburg hunts.' },
  { name: 'Central Virginia (Charlottesville, Keswick, Gordonsville, Orange)', note: 'Keswick Hunt, Foxfield Races, eventing, and dressage. Morven Park clinics.' },
  { name: 'Shenandoah Valley (Lexington, Staunton, Front Royal)', note: 'Virginia Horse Center, eventing, and trail country.' },
  { name: 'Tidewater & Eastern Shore (Williamsburg, Suffolk, Accomack)', note: 'Pleasure, trail, and Colonial Downs-adjacent training.' },
  { name: 'Southwest Virginia (Roanoke, Lynchburg, Galax)', note: 'Pleasure, trail, and pleasure-show population.' }
];
const specialties = [
  { label: 'Routine Trimming', detail: 'Pleasure, pasture, retired, and trim-only cycles.' },
  { label: 'Hunt Country Shoeing', detail: 'Foxhunting field horses, performance hunter/jumper work.' },
  { label: 'Eventing Performance', detail: 'Cross-country grip, stadium, dressage balance work.' },
  { label: 'Racetrack Plate Work', detail: 'Colonial Downs at New Kent training and racing plates.' },
  { label: 'Corrective & Therapeutic', detail: 'AFA-TE work, glue-ons, pads, bar shoes.' }
];
---
<BaseLayout title="Farriers in Virginia | BreederHQ Marketplace" description="Find AFA-certified farriers in Virginia. Middleburg hunt country, Charlottesville eventing, Virginia Horse Center, Colonial Downs plate work, and statewide." breadcrumbs={breadcrumbs} faqs={faqs} service={service}>
  <main>
    <nav class="breadcrumb py-4 px-4 bg-stone-50 border-b border-stone-200" aria-label="Breadcrumb"><ol class="flex items-center space-x-2 max-w-5xl mx-auto text-sm"><li><a href="/" class="text-amber-700 hover:underline">Home</a></li><li class="text-gray-400" aria-hidden="true">›</li><li><a href="/services" class="text-amber-700 hover:underline">Services</a></li><li class="text-gray-400" aria-hidden="true">›</li><li><a href="/services/farriers" class="text-amber-700 hover:underline">Farriers</a></li><li class="text-gray-400" aria-hidden="true">›</li><li aria-current="page" class="text-gray-600">Virginia</li></ol></nav>
    <section class="py-14 px-4 bg-gradient-to-b from-amber-50 to-white"><div class="max-w-4xl mx-auto"><p class="text-sm font-semibold text-amber-700 uppercase tracking-wide mb-3">Farriers · Virginia</p><h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 mb-5">Farriers in Virginia</h1><p class="text-lg text-gray-700 leading-relaxed mb-6">Find farriers across Virginia on BreederHQ Marketplace. Virginia anchors one of the oldest foxhunting traditions in the country in the Middleburg corridor, a deep eventing community across the Piedmont and Shenandoah Valley, and Thoroughbred racing at Colonial Downs. Farrier demand is heavy in therapeutic and performance work.</p><a href={listings.browseUrl} class="inline-flex items-center gap-2 bg-amber-700 text-white px-5 py-3 rounded-lg font-semibold hover:bg-amber-600 transition">Browse Farriers in Virginia <span aria-hidden="true">→</span></a></div></section>

    <ListingsSection listings={listings} noun="Farriers" unit="farrier" scopeLabel="in Virginia" bg="white" />

    <section class="py-12 px-4 bg-white"><div class="max-w-4xl mx-auto"><h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">Regional Farrier Markets in Virginia</h2><div class="grid sm:grid-cols-2 gap-4">{regions.map((r) => (<div class="bg-stone-50 border border-stone-200 rounded-xl p-5"><h3 class="font-semibold text-gray-900 mb-2">{r.name}</h3><p class="text-sm text-gray-700 leading-relaxed">{r.note}</p></div>))}</div></div></section>
    <section class="py-12 px-4 bg-stone-50"><div class="max-w-4xl mx-auto"><h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">Farrier Specialties in Virginia</h2><div class="grid sm:grid-cols-2 gap-4">{specialties.map((s) => (<div class="bg-white border border-stone-200 rounded-lg p-4"><h3 class="font-semibold text-gray-900 mb-1">{s.label}</h3><p class="text-sm text-gray-700">{s.detail}</p></div>))}</div></div></section>
    <section class="py-12 px-4 bg-white"><div class="max-w-5xl mx-auto"><h2 class="text-2xl font-bold text-gray-900 mb-5">Related on BreederHQ</h2><div class="grid sm:grid-cols-3 gap-4"><a href="/services/farriers" class="block bg-stone-50 border border-stone-200 rounded-lg p-4 hover:border-amber-400 transition"><div class="text-xl mb-1">🔨</div><div class="font-semibold text-gray-900">All Farriers</div></a><a href="/services/farriers/kentucky" class="block bg-stone-50 border border-stone-200 rounded-lg p-4 hover:border-amber-400 transition"><div class="text-xl mb-1">🔨</div><div class="font-semibold text-gray-900">Farriers in Kentucky</div></a><a href="/services/equine-services" class="block bg-stone-50 border border-stone-200 rounded-lg p-4 hover:border-amber-400 transition"><div class="text-xl mb-1">🐎</div><div class="font-semibold text-gray-900">Equine Services</div></a></div></div></section>
    <section class="py-10 px-4 bg-white border-t border-stone-200"><div class="max-w-4xl mx-auto"><a href="/for-providers/farriers" class="flex items-center justify-between gap-4 bg-emerald-50 border border-emerald-200 rounded-lg p-5 hover:border-emerald-400 transition"><div><p class="font-semibold text-gray-900">Are you a farrier in Virginia?</p><p class="text-sm text-gray-600">List your practice on BreederHQ.</p></div><span class="text-emerald-700 font-semibold whitespace-nowrap">For Providers →</span></a></div></section>
  </main>
</BaseLayout>
