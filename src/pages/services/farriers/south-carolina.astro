---
import GeoPage from '../../../components/GeoPage.astro';
import { fetchServiceListings } from '../../../lib/marketplaceListings';
const listings = await fetchServiceListings('farriers', { state: 'South Carolina' });
const breadcrumbs = [{ name: 'Home', url: '/' }, { name: 'Farriers', url: '/services/farriers' }, { name: 'South Carolina', url: '/services/farriers/south-carolina' }];
const faqs = [
  { question: 'Where does farrier demand concentrate in South Carolina?', answer: 'Aiken is the heart of the South Carolina equine economy: winter training capital for Thoroughbreds, eventers, polo players, and steeplechase. Camden is a historic hunt and steeplechase community. Tryon (Tryon International Equestrian Center, partly NC/partly SC-adjacent) drives hunter/jumper and dressage. The Carolina sandhills (Pinehurst-adjacent) support pleasure and trail.' },
  { question: 'Why is Aiken unusual?', answer: 'Aiken has been a winter training destination since the 1880s. Trial-grade racing footing, soft sandy turf, year-round mild winters, and a tight equine community attract Thoroughbred trainers, eventers, polo players, and dressage riders. Aiken farriers serve some of the most demanding work in the country.' },
  { question: 'What about steeplechase and polo in SC?', answer: 'Camden hosts the Carolina Cup steeplechase, and Aiken supports a deep polo community. Steeplechase shoeing and polo plate work are distinct specialties: the former focuses on grip and soundness over varied terrain, the latter on durability under high-speed direction changes.' }
];
const service = { name: 'Farriers in South Carolina', description: 'Aiken winter training, Camden steeplechase, Tryon hunter/jumper, and pleasure farriers across South Carolina.', serviceType: 'Farrier and Hoof Care', areaServed: 'South Carolina', offerDescription: 'Statewide farrier directory.', offerUrl: '/services/farriers/south-carolina' };
const regions = [
  { name: 'Aiken & Aiken County', note: 'Winter training capital. Thoroughbred, eventing, polo, steeplechase, dressage. Deep CJF and therapeutic representation.' },
  { name: 'Camden & Kershaw County', note: 'Historic hunt and steeplechase community. Carolina Cup.' },
  { name: 'Upstate (Tryon-adjacent, Spartanburg, Greenville)', note: 'TIEC-adjacent hunter/jumper and dressage.' },
  { name: 'Lowcountry (Charleston, Beaufort)', note: 'Pleasure, trail, and growing eventing community.' },
  { name: 'Midlands (Columbia, Lexington)', note: 'Mixed pleasure, pleasure-show, and trail.' }
];
const specialties = [
  { label: 'Winter Training', detail: 'Aiken Thoroughbred and eventing winter training work.' },
  { label: 'Steeplechase & Polo', detail: 'Carolina Cup, Aiken polo specialties.' },
  { label: 'Eventing Performance', detail: 'Cross-country grip, stadium, dressage balance.' },
  { label: 'Hunter/Jumper', detail: 'Tryon, Aiken circuit shoeing.' },
  { label: 'Corrective & Therapeutic', detail: 'AFA-TE work, glue-ons, pads, bar shoes.' }
];
const relatedCards = [
  { href: '/services/farriers', emoji: '🔨', title: 'All Farriers', note: 'Browse the full farrier category.' },
  { href: '/services/equine-boarding/aiken-sc', emoji: '🏇', title: 'Equine Boarding in Aiken', note: 'Winter training and year-round boarding.' },
  { href: '/services/farriers/georgia', emoji: '🔨', title: 'Farriers in Georgia', note: 'Adjacent equine corridor.' }
];
