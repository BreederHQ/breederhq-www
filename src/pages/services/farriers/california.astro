---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ListingsSection from '../../../components/ListingsSection.astro';
import { fetchServiceListings } from '../../../lib/marketplaceListings';
const listings = await fetchServiceListings('farriers', { state: 'California' });
const breadcrumbs = [{ name: 'Home', url: '/' }, { name: 'Farriers', url: '/services/farriers' }, { name: 'California', url: '/services/farriers/california' }];
const faqs = [
  { question: 'Where does the farrier demand concentrate in California?', answer: 'Five distinct corridors. Southern California (Thermal, San Juan Capistrano, Rancho Santa Fe, Del Mar) anchors hunter/jumper and dressage. Northern California (Woodside, Sonoma, Napa, Petaluma) holds eventing and dressage country. Central California (Temecula, Santa Ynez, Paso Robles) supports cutting, reining, and sport horse breeding. The San Diego corridor (Del Mar, Rancho Santa Fe) supports polo and high-performance show horses. The Sacramento Valley and Gold Country support working ranches.' },
  { question: 'What about racetrack plate work?', answer: 'Santa Anita, Del Mar, Golden Gate Fields, and Los Alamitos run year-round Thoroughbred and Quarter Horse meets. California plate farriers work on tight schedules tied to race meets, breeze days, and training-track work. Many travel between Northern and Southern California tracks seasonally.' },
  { question: 'What about Thermal during the winter circuit?', answer: 'The Desert Circuit at Thermal (HITS, AIM Equine) runs January through March and brings show-circuit farriers from across the country. Locally-based farriers in the Coachella Valley handle year-round work plus the seasonal surge.' }
];
const service = { name: 'Farriers in California', description: 'Find AFA-certified farriers, racetrack plate specialists, performance shoers, and corrective farriers across California.', serviceType: 'Farrier and Hoof Care', areaServed: 'California', offerDescription: 'Statewide farrier directory.', offerUrl: '/services/farriers/california' };
const regions = [
  { name: 'Southern California (Thermal, San Juan Capistrano, Rancho Santa Fe, Del Mar)', note: 'HITS Desert Circuit, hunter/jumper and dressage. Polo at Del Mar and Empire Polo Club. Strong CJF representation.' },
  { name: 'Northern California (Woodside, Sonoma, Napa, Petaluma, Half Moon Bay)', note: 'Eventing, dressage, and hunter/jumper. Mid-density market with active sport horse population.' },
  { name: 'Central Coast (Santa Ynez, Paso Robles, San Luis Obispo)', note: 'Sport horse breeding, reining, ranch horse, and growing eventing community.' },
  { name: 'Sacramento Valley & Gold Country (Auburn, Grass Valley, Loomis)', note: 'Working ranches, trail, endurance, and pleasure horses.' },
  { name: 'San Diego County (Del Mar, Rancho Santa Fe, Bonsall, Fallbrook)', note: 'High-performance show, polo, and breeding operations.' },
  { name: 'Central Valley (Fresno, Bakersfield, Visalia)', note: 'Ranch, dairy, working horse country with growing barrel racing population.' }
];
const specialties = [
  { label: 'Routine Trimming', detail: 'Pleasure, pasture, retired, and trim-only on 5 to 8 week cycles.' },
  { label: 'Hunter/Jumper Performance', detail: 'Thermal, Sonoma, Woodside circuit shoeing.' },
  { label: 'Racetrack Plate Work', detail: 'Santa Anita, Del Mar, Golden Gate, Los Alamitos training and racing.' },
  { label: 'Dressage', detail: 'Balanced performance shoeing for movement and soundness.' },
  { label: 'Reining & Western Performance', detail: 'Sliding plates and discipline-specific work.' },
  { label: 'Corrective & Therapeutic', detail: 'AFA-TE work, glue-ons, pads, bar shoes.' }
];
---
<BaseLayout title="Farriers in California | BreederHQ Marketplace" description="Find AFA-certified farriers in California: performance, racetrack, dressage, and corrective specialists at Del Mar and statewide. Browse near you." breadcrumbs={breadcrumbs} faqs={faqs} service={service}>
  <main>
    <nav class="breadcrumb py-4 px-4 bg-stone-50 border-b border-stone-200" aria-label="Breadcrumb"><ol class="flex items-center space-x-2 max-w-5xl mx-auto text-sm"><li><a href="/" class="text-amber-700 hover:underline">Home</a></li><li class="text-gray-400" aria-hidden="true">›</li><li><a href="/services" class="text-amber-700 hover:underline">Services</a></li><li class="text-gray-400" aria-hidden="true">›</li><li><a href="/services/farriers" class="text-amber-700 hover:underline">Farriers</a></li><li class="text-gray-400" aria-hidden="true">›</li><li aria-current="page" class="text-gray-600">California</li></ol></nav>
    <section class="py-14 px-4 bg-gradient-to-b from-amber-50 to-white"><div class="max-w-4xl mx-auto"><p class="text-sm font-semibold text-amber-700 uppercase tracking-wide mb-3">Farriers · California</p><h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 mb-5">Farriers in California</h1><p class="text-lg text-gray-700 leading-relaxed mb-6">Find farriers across California on BreederHQ Marketplace. California's farrier markets span the HITS Desert Circuit at Thermal, the Santa Anita and Del Mar racetracks, the eventing and dressage population in Sonoma and Woodside, and a deep sport horse breeding industry from the Central Coast through San Diego County.</p><a href={listings.browseUrl} class="inline-flex items-center gap-2 bg-amber-700 text-white px-5 py-3 rounded-lg font-semibold hover:bg-amber-600 transition">Browse Farriers in California <span aria-hidden="true">→</span></a></div></section>

    <ListingsSection listings={listings} noun="Farriers" unit="farrier" scopeLabel="in California" bg="white" />

    <section class="py-12 px-4 bg-white"><div class="max-w-4xl mx-auto"><h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">Regional Farrier Markets in California</h2><div class="grid sm:grid-cols-2 gap-4">{regions.map((r) => (<div class="bg-stone-50 border border-stone-200 rounded-xl p-5"><h3 class="font-semibold text-gray-900 mb-2">{r.name}</h3><p class="text-sm text-gray-700 leading-relaxed">{r.note}</p></div>))}</div></div></section>
    <section class="py-12 px-4 bg-stone-50"><div class="max-w-4xl mx-auto"><h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-3">Farrier Specialties in California</h2><div class="grid sm:grid-cols-2 gap-4">{specialties.map((s) => (<div class="bg-white border border-stone-200 rounded-lg p-4"><h3 class="font-semibold text-gray-900 mb-1">{s.label}</h3><p class="text-sm text-gray-700">{s.detail}</p></div>))}</div></div></section>
    <section class="py-12 px-4 bg-white"><div class="max-w-5xl mx-auto"><h2 class="text-2xl font-bold text-gray-900 mb-5">Related on BreederHQ</h2><div class="grid sm:grid-cols-3 gap-4"><a href="/services/farriers" class="block bg-stone-50 border border-stone-200 rounded-lg p-4 hover:border-amber-400 transition"><div class="text-xl mb-1">🔨</div><div class="font-semibold text-gray-900">All Farriers</div></a><a href="/services/equine-boarding/san-diego-ca" class="block bg-stone-50 border border-stone-200 rounded-lg p-4 hover:border-amber-400 transition"><div class="text-xl mb-1">🏇</div><div class="font-semibold text-gray-900">Equine Boarding in San Diego</div></a><a href="/services/equine-services" class="block bg-stone-50 border border-stone-200 rounded-lg p-4 hover:border-amber-400 transition"><div class="text-xl mb-1">🐎</div><div class="font-semibold text-gray-900">Equine Services</div></a></div></div></section>
    <section class="py-10 px-4 bg-white border-t border-stone-200"><div class="max-w-4xl mx-auto"><a href="/for-providers/farriers" class="flex items-center justify-between gap-4 bg-emerald-50 border border-emerald-200 rounded-lg p-5 hover:border-emerald-400 transition"><div><p class="font-semibold text-gray-900">Are you a farrier in California?</p><p class="text-sm text-gray-600">List your practice on BreederHQ.</p></div><span class="text-emerald-700 font-semibold whitespace-nowrap">For Providers →</span></a></div></section>
  </main>
</BaseLayout>
