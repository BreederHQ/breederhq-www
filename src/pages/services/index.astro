---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Services', url: '/services' }
];

// Sections follow docs/MARKETPLACE-ARCHITECTURE.md — full taxonomy distributed
// across cards. Hubs that exist as real pages get direct links; everything else
// links to the matching /for-providers/<category> until Phase 2 buyer hubs ship.

const equineLivestock = [
  {
    id: 'farriers',
    emoji: '🔨',
    label: 'Farriers',
    href: '/services/farriers',
    summary: 'Routine trimming, performance shoeing, racetrack plate work, sale prep, corrective and therapeutic hoof care. AFA-credential aware.',
    regions: [
      { href: '/services/farriers/kentucky', label: 'Kentucky' }
    ]
  },
  {
    id: 'equine-boarding',
    emoji: '🏇',
    label: 'Equine Boarding',
    href: '/services/equine-boarding',
    summary: 'Pasture board, full-care stall board, training board, layup, and breeding facilities.',
    regions: [
      { href: '/services/equine-boarding/lexington-ky', label: 'Lexington, KY' },
      { href: '/services/equine-boarding/ocala-fl', label: 'Ocala, FL' }
    ]
  },
  {
    id: 'equine-services',
    emoji: '🐎',
    label: 'Equine Services',
    href: '/services/equine-services',
    summary: 'Training, lessons, sale prep, fitness, equine massage, and equine bodywork across discipline-specific programs.'
  },
  {
    id: 'equine-repro',
    emoji: '🧬',
    label: 'Equine Reproduction',
    href: '/services/equine-repro',
    summary: 'Theriogenologists, AI (fresh, cooled, frozen), embryo transfer, stallion collection, and foaling specialists.'
  },
  {
    id: 'livestock-services',
    emoji: '🐄',
    label: 'Livestock Services',
    href: '/services/livestock-services',
    summary: 'Working livestock support across goats, sheep, alpacas, llamas, and cattle: AI and pregnancy work, shearing, hoof trimming, herd health.'
  },
  {
    id: 'caprine-services',
    emoji: '🐐',
    label: 'Caprine Services',
    href: '/services/caprine-services',
    summary: 'Goat-specific specialists: disbudding & tattoo, hoof, fecal lab, DHIR tester, linear appraisal, buck service, AI tech, mobile goat vet, transport.',
    regions: [
      { href: '/services/disbudding-tattoo', label: 'Disbudding & Tattoo' },
      { href: '/services/goat-hoof-trimming', label: 'Hoof Trimming' },
      { href: '/services/buck-service', label: 'Buck Service' },
      { href: '/services/mobile-goat-vet', label: 'Mobile Goat Vet' }
    ]
  }
];

const careTraining = [
  {
    id: 'dog-training',
    emoji: '🎓',
    label: 'Dog Training',
    href: '/services/dog-training',
    summary: 'Obedience, sport, working, behavior modification, and breed-specific training. Credential and methodology aware.'
  },
  {
    id: 'behavioral',
    emoji: '🧠',
    label: 'Behavioral',
    href: '/services/behavioral',
    summary: 'Reactivity, aggression, separation anxiety, and behavior modification specialists.'
  },
  {
    id: 'show-handling',
    emoji: '🏅',
    label: 'Show Handling',
    href: '/services/show-handling',
    summary: 'AKC and UKC professional handlers, conformation ring training, and show grooming specialists.'
  },
  {
    id: 'grooming',
    emoji: '✂️',
    label: 'Grooming',
    href: '/services/grooming',
    summary: 'Breed-specific, show, and specialty grooming. Mobile and salon. Includes equine and livestock grooming.'
  },
  {
    id: 'boarding',
    emoji: '🏠',
    label: 'Boarding',
    href: '/services/boarding',
    summary: 'Overnight and short-term boarding for dogs, cats, exotics, livestock, horses, and in-home arrangements.'
  },
  {
    id: 'pet-sitting',
    emoji: '🐾',
    label: 'Pet Sitting',
    href: '/services/pet-sitting',
    summary: 'Credentialed in-home sitters, drop-in visits, and overnight care. PSI and species-specialty aware.'
  }
];

const medical = [
  {
    id: 'veterinary',
    emoji: '🩺',
    label: 'Veterinary Specialists',
    href: '/services/veterinary-specialists',
    summary: 'Reproductive vets, equine vets, exotic animal specialists, sports medicine, and theriogenologists.'
  },
  {
    id: 'health-testing',
    emoji: '🧬',
    label: 'Health Testing',
    href: '/services/health-testing',
    summary: 'OFA, PennHIP, CHIC, CERF, and genetic panels. Veterinary geneticists, repro vets, and specialist clinics.'
  },
  {
    id: 'rehabilitation',
    emoji: '💪',
    label: 'Rehabilitation',
    href: '/services/rehabilitation',
    summary: 'Canine and equine physical therapy, post-surgical care, hydrotherapy, and sports medicine recovery.'
  },
  {
    id: 'nutrition',
    emoji: '🥗',
    label: 'Nutrition',
    href: '/services/nutrition',
    summary: 'Animal nutritionists, raw and BARF specialists, performance feeding, and species-specific diet planning.'
  }
];

const logistics = [
  {
    id: 'transport',
    emoji: '🚐',
    label: 'Transport',
    href: '/services/transport',
    summary: 'USDA-compliant ground and air transport for puppies, adult dogs, horses, livestock, and exotic animals.'
  },
  {
    id: 'photography',
    emoji: '📸',
    label: 'Photography',
    href: '/services/photography',
    summary: 'Litter photography, show photography, equine portraiture, and breeder marketing media.'
  }
];

const facilityTypes = [
  { emoji: '🐎', label: 'Equine Facilities', href: '/facilities/equine' },
  { emoji: '🐄', label: 'Livestock Facilities', href: '/facilities/livestock' },
  { emoji: '🏟️', label: 'Indoor Training Halls', href: '/facilities/indoor-training' },
  { emoji: '🏠', label: 'Boarding Facilities', href: '/facilities/boarding' },
  { emoji: '🛁', label: 'Wash & Grooming Spaces', href: '/facilities/wash-grooming' },
  { emoji: '🏆', label: 'Event & Show Spaces', href: '/facilities/events-shows' },
  { emoji: '🌳', label: 'Dog Parks & Play Spots', href: '/facilities/dog-parks' },
  { emoji: '✨', label: 'Specialty Facilities', href: '/facilities/specialty' }
];

const regionalSpotlights = [
  {
    href: '/services/equine-boarding/lexington-ky',
    label: 'Horse Boarding in Lexington, KY',
    note: 'Bluegrass equine ecosystem, Keeneland, Kentucky Horse Park.'
  },
  {
    href: '/services/equine-boarding/ocala-fl',
    label: 'Horse Boarding in Ocala, FL',
    note: 'Marion County Thoroughbred industry, World Equestrian Center, HITS winter circuit.'
  },
  {
    href: '/services/farriers/kentucky',
    label: 'Farriers in Kentucky',
    note: 'Statewide farrier directory rooted in the deepest equine economy in the United States.'
  }
];
---

<BaseLayout
  title="Services on BreederHQ Marketplace | Find Providers Across Every Animal Category"
  description="Find providers on BreederHQ Marketplace: training, grooming, boarding, farriers, transport, and facilities. Built for breeders and owners. Browse now."
  breadcrumbs={breadcrumbs}
>
  <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
    Skip to content
  </a>

  <main id="main-content">
    <nav class="breadcrumb py-4 px-4 bg-stone-50 border-b border-stone-200" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 max-w-5xl mx-auto text-sm">
        <li><a href="/" class="text-amber-700 hover:underline">Home</a></li>
        <li class="text-gray-400" aria-hidden="true">›</li>
        <li aria-current="page" class="text-gray-600">Services</li>
      </ol>
    </nav>

    <!-- Hero -->
    <section class="py-14 px-4 bg-gradient-to-b from-amber-50 to-white">
      <div class="max-w-4xl mx-auto">
        <p class="text-sm font-semibold text-amber-700 uppercase tracking-wide mb-3">BreederHQ Marketplace</p>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 mb-5">
          Services for Breeders, Animal Owners, and Pet Households
        </h1>
        <p class="text-lg text-gray-700 leading-relaxed mb-6">
          Browse providers by category, region, and specialty. Every listing carries structured professional identity: credentials, methodologies, species expertise, and coverage area. Find the right specialist instead of scrolling through a generic directory.
        </p>
        <a href="https://marketplace.breederhq.com/services" class="inline-flex items-center gap-2 bg-amber-700 text-white px-5 py-3 rounded-lg font-semibold hover:bg-amber-600 transition">
          Browse All Services
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>

    <!-- Equine & Livestock Specialists -->
    <section id="equine-livestock" class="py-12 px-4 bg-white scroll-mt-20">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">Equine &amp; Livestock Specialists</h2>
        <p class="text-gray-600 mb-6">Specialist ecosystems where BreederHQ runs deepest. Regional spotlights live inside the relevant cards.</p>
        <div class="grid sm:grid-cols-2 gap-4">
          {equineLivestock.map((c) => (
            <a id={c.id} href={c.href} class="block bg-stone-50 border border-stone-200 rounded-xl p-5 hover:border-amber-500 hover:shadow-sm transition scroll-mt-20">
              <div class="flex items-baseline gap-2 mb-1">
                <span class="text-xl">{c.emoji}</span>
                <h3 class="text-lg font-semibold text-gray-900">{c.label}</h3>
              </div>
              <p class="text-sm text-gray-700 leading-relaxed mb-3">{c.summary}</p>
              {c.regions && (
                <div class="flex flex-wrap gap-2 mb-2">
                  {c.regions.map((r) => (
                    <a href={r.href} class="text-xs px-2 py-1 bg-white border border-stone-200 rounded text-amber-700 hover:border-amber-400">{r.label}</a>
                  ))}
                </div>
              )}
              <p class="text-sm font-semibold text-amber-700">Browse {c.label} →</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Care & Training -->
    <section class="py-12 px-4 bg-stone-50">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">Care &amp; Training</h2>
        <p class="text-gray-600 mb-6">Training, behavior, handling, grooming, boarding, and pet care providers.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {careTraining.map((c) => (
            <a id={c.id} href={c.href} class="block bg-white border border-stone-200 rounded-xl p-5 hover:border-amber-500 hover:shadow-sm transition scroll-mt-20">
              <div class="flex items-baseline gap-2 mb-1">
                <span class="text-xl">{c.emoji}</span>
                <h3 class="text-lg font-semibold text-gray-900">{c.label}</h3>
              </div>
              <p class="text-sm text-gray-700 leading-relaxed mb-3">{c.summary}</p>
              <p class="text-sm font-semibold text-amber-700">Browse {c.label} →</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Medical -->
    <section class="py-12 px-4 bg-white">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">Medical</h2>
        <p class="text-gray-600 mb-6">Veterinary, health testing, rehabilitation, and nutrition specialists.</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {medical.map((c) => (
            <a id={c.id} href={c.href} class="block bg-stone-50 border border-stone-200 rounded-xl p-5 hover:border-amber-500 hover:shadow-sm transition scroll-mt-20">
              <div class="flex items-baseline gap-2 mb-1">
                <span class="text-xl">{c.emoji}</span>
                <h3 class="text-base font-semibold text-gray-900">{c.label}</h3>
              </div>
              <p class="text-xs text-gray-700 leading-relaxed mb-2">{c.summary}</p>
              <p class="text-xs font-semibold text-amber-700">Browse →</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Logistics & Media -->
    <section class="py-12 px-4 bg-stone-50">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">Logistics &amp; Media</h2>
        <p class="text-gray-600 mb-6">Animal transport and professional photography.</p>
        <div class="grid sm:grid-cols-2 gap-4">
          {logistics.map((c) => (
            <a id={c.id} href={c.href} class="block bg-white border border-stone-200 rounded-xl p-5 hover:border-amber-500 hover:shadow-sm transition scroll-mt-20">
              <div class="flex items-baseline gap-2 mb-1">
                <span class="text-xl">{c.emoji}</span>
                <h3 class="text-lg font-semibold text-gray-900">{c.label}</h3>
              </div>
              <p class="text-sm text-gray-700 leading-relaxed mb-3">{c.summary}</p>
              <p class="text-sm font-semibold text-amber-700">Browse {c.label} →</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Facilities (integrated peer branch) -->
    <section id="facilities" class="py-14 px-4 bg-gradient-to-br from-amber-50 to-stone-50 scroll-mt-20">
      <div class="max-w-5xl mx-auto">
        <div class="flex items-baseline justify-between mb-2 flex-wrap gap-2">
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">Facilities</h2>
          <a href="/facilities" class="text-sm font-semibold text-amber-700 hover:underline">Explore all facility types →</a>
        </div>
        <p class="text-gray-700 leading-relaxed mb-6 max-w-3xl">
          Bookable physical infrastructure: arenas, kennels, indoor halls, wash bays, event venues, dog parks, and specialty spaces. BreederHQ models facilities as a first-class branch of the marketplace, distinct from provider services.
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {facilityTypes.map((f) => (
            <a href={f.href} class="block bg-white border border-stone-200 rounded-lg p-3 hover:border-amber-400 hover:shadow-sm transition">
              <div class="text-xl mb-1">{f.emoji}</div>
              <div class="text-sm font-medium text-gray-900">{f.label}</div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Regional Spotlights -->
    <section id="regions" class="py-12 px-4 bg-white scroll-mt-20">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">Regional Pages</h2>
        <p class="text-gray-600 mb-6">Selective state and metro pages with real local content. Geo coverage lives on each parent category hub, not in nav.</p>
        <div class="grid sm:grid-cols-3 gap-4 mb-6">
          {regionalSpotlights.map((r) => (
            <a href={r.href} class="block bg-stone-50 border border-stone-200 rounded-xl p-5 hover:border-amber-500 hover:shadow-sm transition">
              <h3 class="font-semibold text-gray-900 mb-1">{r.label}</h3>
              <p class="text-sm text-gray-600 leading-relaxed">{r.note}</p>
            </a>
          ))}
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3 text-sm">
          <a href="/services/farriers#regions" class="block bg-white border border-stone-200 rounded-lg p-3 hover:border-amber-400 transition">
            <p class="font-semibold text-gray-900">Farriers by State</p>
            <p class="text-xs text-gray-500 mt-1">20 state directories</p>
          </a>
          <a href="/services/equine-boarding" class="block bg-white border border-stone-200 rounded-lg p-3 hover:border-amber-400 transition">
            <p class="font-semibold text-gray-900">Equine Boarding Metros</p>
            <p class="text-xs text-gray-500 mt-1">10 ecosystem metros</p>
          </a>
          <a href="/services/dog-training" class="block bg-white border border-stone-200 rounded-lg p-3 hover:border-amber-400 transition">
            <p class="font-semibold text-gray-900">Dog Training Metros</p>
            <p class="text-xs text-gray-500 mt-1">10 metro pages</p>
          </a>
          <a href="/services/livestock-services" class="block bg-white border border-stone-200 rounded-lg p-3 hover:border-amber-400 transition">
            <p class="font-semibold text-gray-900">Livestock by State</p>
            <p class="text-xs text-gray-500 mt-1">10 state pages</p>
          </a>
        </div>
      </div>
    </section>

    <!-- Provider cross-link -->
    <section class="py-12 px-4 bg-stone-50">
      <div class="max-w-4xl mx-auto">
        <a href="/for-providers" class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-emerald-500 hover:shadow-sm transition">
          <h3 class="text-xl font-semibold text-gray-900 mb-2">For Service Providers</h3>
          <p class="text-gray-700 leading-relaxed">
            List your business on BreederHQ Marketplace. Flat-fee, no commission. Acquisition pages exist for every service category, plus eight first-class facility types.
          </p>
          <p class="text-sm font-semibold text-emerald-700 mt-4">For Providers Overview →</p>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
