---
import BaseLayout from '../../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Services', url: '/services' }
];

const categories = [
  {
    href: '/services/equine-boarding',
    label: 'Equine Boarding',
    summary: 'Pasture board, full-care stall board, training board, layup, and breeding facilities.',
    audience: 'For horse owners, breeders, eventers, sport horse competitors, and racing operations.',
    status: 'live'
  },
  {
    href: '/services/farriers',
    label: 'Farriers',
    summary: 'Routine trimming, performance shoeing, racetrack plate work, sale prep, and corrective and therapeutic hoof care. AFA-credential aware.',
    audience: 'For horse owners and breeding operations hiring trimmers, shoers, and specialists.',
    status: 'live'
  },
  {
    href: '/services/dog-training',
    label: 'Dog Training',
    summary: 'Obedience, sport, working, and behavior modification trainers. Credential and methodology aware.',
    audience: 'For dog owners and breeders placing puppies into training programs.',
    status: 'planned'
  },
  {
    href: '/services/livestock-services',
    label: 'Livestock Services',
    summary: 'Working livestock support across goats, sheep, alpacas, llamas, and cattle: AI and pregnancy work, shearing, hoof trimming, and herd health.',
    audience: 'For livestock breeders and small-farm operators.',
    status: 'planned'
  }
];

const liveCategories = categories.filter((c) => c.status === 'live');
const plannedCategories = categories.filter((c) => c.status === 'planned');

const regionalSpotlights = [
  {
    href: '/services/equine-boarding/lexington-ky',
    label: 'Horse Boarding in Lexington, KY',
    note: 'Bluegrass equine ecosystem, Keeneland, Kentucky Horse Park, hospital proximity.'
  },
  {
    href: '/services/equine-boarding/ocala-fl',
    label: 'Horse Boarding in Ocala, FL',
    note: 'Marion County Thoroughbred industry, World Equestrian Center, HITS Ocala winter circuit.'
  },
  {
    href: '/services/farriers/kentucky',
    label: 'Farriers in Kentucky',
    note: 'Statewide farrier directory rooted in the deepest equine economy in the United States.'
  }
];
---

<BaseLayout
  title="Services on BreederHQ Marketplace | Specialist Directory for Breeders and Animal Owners"
  description="Find specialist services on BreederHQ Marketplace: equine boarding, farriers, dog training, and livestock services. Built for breeders and animal owners who need credential-aware, ecosystem-aware professionals, not generic directory listings."
  breadcrumbs={breadcrumbs}
>
  <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
    Skip to content
  </a>

  <main id="main-content">
    <nav class="breadcrumb py-4 px-4 bg-stone-50 border-b border-stone-200" aria-label="Breadcrumb">
      <ol class="flex items-center space-x-2 max-w-5xl mx-auto text-sm">
        <li><a href="/" class="text-amber-700 hover:underline">Home</a></li>
        <li class="text-gray-400" aria-hidden="true">›</li>
        <li aria-current="page" class="text-gray-600">Services</li>
      </ol>
    </nav>

    <!-- Hero / Positioning -->
    <section class="py-16 px-4 bg-gradient-to-b from-amber-50 to-white">
      <div class="max-w-4xl mx-auto">
        <p class="text-sm font-semibold text-amber-700 uppercase tracking-wide mb-3">BreederHQ Marketplace</p>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 mb-5">
          Services Built for Breeders and Animal Owners
        </h1>
        <p class="text-xl text-gray-700 leading-relaxed mb-4">
          BreederHQ Marketplace is a specialist directory. Provider profiles show credentials, coverage area, working specialty, species and breed focus, and the ecosystem the provider actually operates in. The categories below are intentionally narrow: deep coverage of work that breeders and serious animal owners hire for, instead of the long-tail generic pet-services catalog.
        </p>
        <p class="text-lg text-gray-700 leading-relaxed">
          We are building category by category, region by region. Every listing is real.
        </p>
      </div>
    </section>

    <!-- Live categories -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Live Service Categories</h2>
        <p class="text-lg text-gray-700 leading-relaxed mb-8">
          Categories with editorial directories, schema-grounded content, and an open provider listing path.
        </p>
        <div class="grid sm:grid-cols-2 gap-5">
          {liveCategories.map((c) => (
            <a href={c.href} class="block bg-stone-50 border border-stone-200 rounded-xl p-6 hover:border-amber-500 hover:shadow-sm transition">
              <h3 class="text-xl font-semibold text-gray-900 mb-2">{c.label}</h3>
              <p class="text-gray-700 leading-relaxed mb-3">{c.summary}</p>
              <p class="text-sm text-gray-500">{c.audience}</p>
              <p class="text-sm font-semibold text-amber-700 mt-4">Browse {c.label} →</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Regional spotlights -->
    <section class="py-16 px-4 bg-stone-50">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Regional Spotlights</h2>
        <p class="text-lg text-gray-700 leading-relaxed mb-8">
          Editorially deep regional pages anchored on the actual equine and breeding economies of each region. These are the prototype pages for the geographic directory rolling out across the marketplace.
        </p>
        <div class="grid sm:grid-cols-3 gap-4">
          {regionalSpotlights.map((r) => (
            <a href={r.href} class="block bg-white border border-stone-200 rounded-xl p-5 hover:border-amber-500 hover:shadow-sm transition">
              <h3 class="font-semibold text-gray-900 mb-1">{r.label}</h3>
              <p class="text-sm text-gray-600 leading-relaxed">{r.note}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Planned categories -->
    <section class="py-16 px-4 bg-white">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl font-bold text-gray-900 mb-3">Categories in Development</h2>
        <p class="text-lg text-gray-700 leading-relaxed mb-8">
          Specialist categories the marketplace is being built to cover. Provider acquisition pages exist where applicable; the public directory pages will follow as coverage warrants.
        </p>
        <div class="grid sm:grid-cols-2 gap-5">
          {plannedCategories.map((c) => (
            <div class="bg-stone-50 border border-stone-200 rounded-xl p-6">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="text-xl font-semibold text-gray-900">{c.label}</h3>
                <span class="text-xs font-semibold uppercase tracking-wide text-amber-700 bg-amber-100 px-2 py-1 rounded">In Development</span>
              </div>
              <p class="text-gray-700 leading-relaxed mb-3">{c.summary}</p>
              <p class="text-sm text-gray-500">{c.audience}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Trust + Providers cross-link -->
    <section class="py-16 px-4 bg-gradient-to-b from-white to-amber-50">
      <div class="max-w-4xl mx-auto">
        <div class="grid sm:grid-cols-2 gap-6">
          <a href="/trust" class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-amber-500 hover:shadow-sm transition">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">How Trust &amp; Verification Works</h3>
            <p class="text-gray-700 leading-relaxed">
              How BreederHQ verifies identity, credentials, and reviews on the marketplace, and how a breeder-focused trust system differs from Yelp, Rover, and Thumbtack.
            </p>
            <p class="text-sm font-semibold text-amber-700 mt-4">Read Trust &amp; Verification →</p>
          </a>
          <a href="/for-providers" class="block bg-white border border-stone-200 rounded-xl p-6 hover:border-amber-500 hover:shadow-sm transition">
            <h3 class="text-xl font-semibold text-gray-900 mb-2">For Service Providers</h3>
            <p class="text-gray-700 leading-relaxed">
              List your business on BreederHQ Marketplace. Flat-fee, no commission. Provider acquisition pages by category, including farriers, equine services, veterinary, training, transport, and more.
            </p>
            <p class="text-sm font-semibold text-amber-700 mt-4">For Providers Overview →</p>
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
