          <p class="font-semibold text-gray-900">Mountain</p>
          <p class="text-xs text-gray-500">CO, WY, MT, ID, UT, NV, NM, AZ</p>
        </a>
        <a href="https://marketplace.breederhq.com/services/farriers?region=west" class="bg-white border border-stone-200 rounded-lg p-4 hover:border-amber-400 hover:shadow-sm">
          <p class="font-semibold text-gray-900">West Coast</p>
          <p class="text-xs text-gray-500">CA, OR, WA, AK, HI</p>
        </a>
      </div>

      <p class="text-xs text-gray-500 mt-6 italic">
        Regional links route into the live marketplace and filter by state group. State-level landing pages will follow as farrier density warrants them.
      </p>
    </div>
  </section>

  <!-- ========== 8. FAQ (rendered visually; schema injected via BaseLayout `faqs` prop) ========== -->
  <section class="py-16 bg-white">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-3">Frequently asked questions</h2>
      <p class="text-lg text-gray-700 mb-8">Straight answers for horse owners and breeders comparing farriers.</p>

      <div class="space-y-6">
        {faqs.map((faq) => (
          <div class="border-l-4 border-amber-600 pl-5">
            <h3 class="text-lg font-semibold text-gray-900 mb-2">{faq.question}</h3>
            <p class="text-gray-700 leading-relaxed">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== 9. PROVIDER CTA ========== -->
  <section class="py-16 bg-gradient-to-br from-amber-900 to-amber-800">
