---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'For Service Providers', url: '/for-providers' }
];

const faqs = [
  {
    question: 'How much does a service listing cost?',
    answer: 'Service listings are free. No commissions, no hidden fees, no per-lead charges. Cancel anytime.'
  },
  {
    question: 'What types of services can I list?',
    answer: 'Veterinary (especially reproductive specialists), training, photography, transport, grooming, boarding, private dog parks (rentable yards, fields, swim spots, agility areas), and other breeder-specific services.'
  },
  {
    question: 'Do I need a BreederHQ breeding subscription?',
    answer: 'No. Service provider listings are completely separate from breeder subscriptions. You do not need to be a breeder to list your services.'
  },
  {
    question: 'How does identity and credential display work?',
    answer: 'You can complete identity verification through Stripe Identity (a service operated by Stripe, Inc.), which adds an "Identity confirmed via Stripe Identity" indicator to your profile. For credentials issued by organizations that maintain a public registry (OFA, AKC, AFA, state licensing boards), BreederHQ may query the registry and display a "Confirmed via [registry] registry" passthrough indicator. Anything else is your own attestation. BreederHQ does not verify, vet, or vouch for credentials. See /trust for the full policy.'
  },
  {
    question: 'Can I pause my listing?',
    answer: 'Yes. Pause and resume anytime from your dashboard. Your listing data is preserved while paused.'
  },
  {
    question: 'What kind of ROI can I expect?',
    answer: 'One new breeder client typically generates $500 to $3,000 in annual revenue depending on your service type. A single new client can be worth the subscription many times over.'
  },
  {
    question: 'How is this different from Yelp or Google Business?',
    answer: 'Those platforms are great for reaching general consumers and you should keep using them. BreederHQ is a complementary channel that puts you in front of professional breeders specifically: an audience that needs specialized services on a recurring basis and is hard to reach through general-purpose directories.'
  }
];
---

<BaseLayout
  title="Animal Service Provider Listings | Reach Breeders, No Commissions | BreederHQ"
  description="Reach breeders searching for vet, training, photography, transport, and grooming services. No commissions. List on the BreederHQ Marketplace."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>

  <main>

    <!-- ============================================ -->
    <!-- HERO                                         -->
    <!-- ============================================ -->
    <section class="bg-gradient-to-b from-emerald-50 to-white py-20">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <img src="/marketplace-logo.png" alt="BreederHQ Marketplace" class="h-40 w-auto mx-auto mb-8" />
          <h1 class="text-5xl font-bold tracking-tight text-gray-900 sm:text-6xl leading-tight mb-6">
            Be Seen by the People<br />
            <span class="text-emerald-700">Who Need Your Services.</span>
          </h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-10 leading-relaxed">
            The BreederHQ Marketplace puts your services in front of a growing community of
            professional breeders, people shopping for animals, and pet owners looking for
            trusted providers in their area. One listing. Maximum visibility.
          </p>
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="https://accounts.breederhq.com/register?intent=provider_marketplace"
              class="bg-emerald-700 text-white px-8 py-4 rounded-lg text-lg font-semibold hover:bg-emerald-600 w-full sm:w-auto"
            >
              List Your Services
            </a>
            <a
              href="https://accounts.breederhq.com/login"
              class="text-gray-600 px-8 py-4 text-lg font-medium hover:text-emerald-700 w-full sm:w-auto"
            >
              Already listed? Sign In &rarr;
            </a>
          </div>
        </div>
      </div>
    </section>


    <!-- ============================================ -->
    <!-- WHY BREEDERS ARE DIFFERENT                   -->
    <!-- ============================================ -->
    <section class="py-16 bg-white">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">
            More Visibility, More Clients
          </h2>
          <p class="text-lg text-gray-600 max-w-2xl mx-auto">
            Your listing is visible to everyone on the BreederHQ Marketplace, and the audience keeps growing.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">

          <div class="text-center">
            <div class="w-16 h-16 rounded-full bg-emerald-100 flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">👀</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">A Growing Audience</h3>
            <p class="text-sm text-gray-600">
              Professional breeders, people shopping for animals, and pet owners looking for services -
              the marketplace audience grows every day, and your listing is visible to all of them.
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 rounded-full bg-emerald-100 flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">📍</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Local Discovery</h3>
            <p class="text-sm text-gray-600">
              People search by service type, location, and species.
              If you're in their area and offer what they need, they find you -
              whether they're a breeder or a first-time pet owner.
            </p>
          </div>

          <div class="text-center">
            <div class="w-16 h-16 rounded-full bg-emerald-100 flex items-center justify-center mx-auto mb-4">
              <span class="text-2xl">🔄</span>
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">Repeat Business Built In</h3>
            <p class="text-sm text-gray-600">
              Many clients on the platform need services on a recurring basis -
              not one-time visits. Breeders especially come back cycle after cycle,
              and recommend you to their network.
            </p>
          </div>

        </div>

        <!-- Revenue callout -->
        <div class="mt-12 bg-emerald-50 border border-emerald-200 rounded-xl p-8 text-center max-w-2xl mx-auto">
          <p class="text-2xl font-bold text-gray-900 mb-2">
            $500 - $3,000+
          </p>
          <p class="text-gray-600">
            Typical annual revenue from a single breeder client, depending on your service type.
          </p>
        </div>
      </div>
    </section>


    <!-- ============================================ -->
    <!-- THE PROBLEM TODAY                            -->
    <!-- ============================================ -->
    <section class="py-16 bg-stone-50">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">
            Another Place to Be Found
          </h2>
          <p class="text-lg text-gray-600">
            You're already listed on Google, maybe Yelp, maybe Thumbtack. BreederHQ is one more place where people looking for animal services can find you, especially the ones who don't search on those platforms.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white rounded-xl p-6 border border-stone-200">
            <h3 class="font-semibold text-gray-900 mb-2">Word of Mouth</h3>
            <p class="text-sm text-gray-600 mb-2">High trust, but slow to build and geographically limited. You can't control it.</p>
            <span class="text-xs text-amber-600 font-medium">Works, but doesn't grow</span>
          </div>
          <div class="bg-white rounded-xl p-6 border border-stone-200">
            <h3 class="font-semibold text-gray-900 mb-2">Facebook Groups</h3>
            <p class="text-sm text-gray-600 mb-2">Direct breeder access, but self-promotion is banned in most groups. Gets you labeled as spam.</p>
            <span class="text-xs text-red-500 font-medium">Risky reputation-wise</span>
          </div>
          <div class="bg-white rounded-xl p-6 border border-stone-200">
            <h3 class="font-semibold text-gray-900 mb-2">Breed Club Advertising</h3>
            <p class="text-sm text-gray-600 mb-2">Targeted, but expensive ($500-$2,000/year per club), limited reach, mostly print-based.</p>
            <span class="text-xs text-amber-600 font-medium">Expensive per lead</span>
          </div>
          <div class="bg-white rounded-xl p-6 border border-stone-200">
            <h3 class="font-semibold text-gray-900 mb-2">Google / Yelp / Thumbtack</h3>
            <p class="text-sm text-gray-600 mb-2">Great for general consumers, but breeders with specialized needs don't search there for breeding-specific services.</p>
            <span class="text-xs text-amber-600 font-medium">Doesn't reach this audience</span>
          </div>
        </div>

        <div class="mt-10 text-center">
          <p class="text-lg text-gray-700 font-medium">
            Free to list, and one more place where people can find you.
          </p>
        </div>
      </div>
    </section>


    <!-- ============================================ -->
    <!-- WHAT YOU GET                                  -->
    <!-- ============================================ -->
    <section class="py-20 bg-white" id="listings">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">
            What You Get on BreederHQ
          </h2>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto mt-2">
            How service listings work: what is on the listing, who sees it, and how it shows up in search.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">

          <div class="bg-stone-50 rounded-xl p-8 border border-stone-200">
            <h3 class="text-lg font-bold text-gray-900 mb-4">Your Service Listing</h3>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-start gap-2">
                <span class="text-emerald-600 mt-0.5 font-bold">&#10003;</span>
                Professional profile with your services, coverage area, and credentials
              </li>
              <li class="flex items-start gap-2">
                <span class="text-emerald-600 mt-0.5 font-bold">&#10003;</span>
                Flexible pricing display (fixed price, starting at, or contact for quote)
              </li>
              <li class="flex items-start gap-2">
                <span class="text-emerald-600 mt-0.5 font-bold">&#10003;</span>
                Photos, descriptions, and service area details
              </li>
              <li class="flex items-start gap-2">
                <span class="text-emerald-600 mt-0.5 font-bold">&#10003;</span>
                Pause and resume anytime; your data is preserved
              </li>
            </ul>
          </div>

          <div class="bg-stone-50 rounded-xl p-8 border border-stone-200">
            <h3 class="text-lg font-bold text-gray-900 mb-4">Targeted Visibility</h3>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-start gap-2">
                <span class="text-emerald-600 mt-0.5 font-bold">&#10003;</span>
                Visible to breeders and buyers actively using the platform
              </li>
              <li class="flex items-start gap-2">
                <span class="text-emerald-600 mt-0.5 font-bold">&#10003;</span>
                Searchable by service type, location, and species specialization
              </li>
              <li class="flex items-start gap-2">
                <span class="text-emerald-600 mt-0.5 font-bold">&#10003;</span>
                Identity and credential indicators on your profile (Stripe Identity, registry passthrough)
              </li>
              <li class="flex items-start gap-2">
                <span class="text-emerald-600 mt-0.5 font-bold">&#10003;</span>
                Breeder recommendations, so your best clients vouch for you publicly
              </li>
            </ul>
          </div>

          <div class="bg-stone-50 rounded-xl p-8 border border-stone-200">
            <h3 class="text-lg font-bold text-gray-900 mb-4">Service Types</h3>
            <div class="grid grid-cols-2 gap-3 text-sm">
              <a href="/for-providers/veterinary" class="flex items-center gap-2 hover:text-emerald-700">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-base">🩺</div>
                <span class="text-gray-700">Veterinary</span>
              </a>
              <a href="/for-providers/training" class="flex items-center gap-2 hover:text-emerald-700">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-base">🎓</div>
                <span class="text-gray-700">Training</span>
              </a>
              <a href="/for-providers/photography" class="flex items-center gap-2 hover:text-emerald-700">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-base">📸</div>
                <span class="text-gray-700">Photography</span>
              </a>
              <a href="/for-providers/transport" class="flex items-center gap-2 hover:text-emerald-700">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-base">🚐</div>
                <span class="text-gray-700">Transport</span>
              </a>
              <a href="/for-providers/grooming" class="flex items-center gap-2 hover:text-emerald-700">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-base">✂️</div>
                <span class="text-gray-700">Grooming</span>
              </a>
              <a href="/for-providers/boarding" class="flex items-center gap-2 hover:text-emerald-700">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-base">🏠</div>
                <span class="text-gray-700">Boarding</span>
              </a>
            </div>

            <h4 class="text-sm font-bold text-gray-900 mt-6 mb-3 uppercase tracking-wide">Facilities</h4>
            <p class="text-xs text-gray-600 mb-3">Eight categories cover every kind of bookable animal facility. <a href="/facilities" class="text-emerald-700 font-medium hover:underline">See all &rarr;</a></p>
            <div class="grid grid-cols-2 gap-3 text-sm">
              <a href="/for-providers/dog-parks" class="flex items-center gap-2 hover:text-emerald-700">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-base">🌳</div>
                <span class="text-gray-700">Dog Parks &amp; Play Spots</span>
              </a>
              <a href="/for-providers/equine" class="flex items-center gap-2 hover:text-emerald-700">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-base">🐎</div>
                <span class="text-gray-700">Equine Facilities</span>
              </a>
              <a href="/for-providers/livestock" class="flex items-center gap-2 hover:text-emerald-700">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-base">🐄</div>
                <span class="text-gray-700">Livestock Facilities</span>
              </a>
              <a href="/for-providers/indoor-training" class="flex items-center gap-2 hover:text-emerald-700">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-base">🏟️</div>
                <span class="text-gray-700">Indoor Training Halls</span>
              </a>
              <a href="/for-providers/boarding-facilities" class="flex items-center gap-2 hover:text-emerald-700">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-base">🏠</div>
                <span class="text-gray-700">Boarding Facilities</span>
              </a>
              <a href="/for-providers/wash-grooming" class="flex items-center gap-2 hover:text-emerald-700">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-base">🛁</div>
                <span class="text-gray-700">Wash &amp; Grooming Spaces</span>
              </a>
              <a href="/for-providers/events-shows" class="flex items-center gap-2 hover:text-emerald-700">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-base">🏆</div>
                <span class="text-gray-700">Event &amp; Show Spaces</span>
              </a>
              <a href="/for-providers/specialty-facilities" class="flex items-center gap-2 hover:text-emerald-700">
                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center text-base">✨</div>
                <span class="text-gray-700">Specialty Facilities</span>
              </a>
            </div>
          </div>

          <div class="bg-stone-50 rounded-xl p-8 border border-stone-200" id="pricing">
            <h3 class="text-lg font-bold text-gray-900 mb-4">Pricing</h3>
            <div class="bg-emerald-100 border border-emerald-300 rounded-lg p-3 mb-4 text-center">
              <p class="text-sm font-semibold text-emerald-800">
                Free to list
              </p>
            </div>
            <ul class="space-y-3 text-sm text-gray-600">
              <li class="flex items-start gap-2">
                <span class="text-emerald-600 mt-0.5 font-bold">&#10003;</span>
                No listing fee; no commissions
              </li>
              <li class="flex items-start gap-2">
                <span class="text-emerald-600 mt-0.5 font-bold">&#10003;</span>
                No per-lead charges, no hidden fees
              </li>
              <li class="flex items-start gap-2">
                <span class="text-emerald-600 mt-0.5 font-bold">&#10003;</span>
                One new breeder client pays for the listing for years
              </li>
              <li class="flex items-start gap-2">
                <span class="text-emerald-600 mt-0.5 font-bold">&#10003;</span>
                Cancel anytime; no contracts, no lock-in
              </li>
            </ul>
          </div>

        </div>
      </div>
    </section>


    <!-- ============================================ -->
    <!-- IDENTITY & CREDENTIALS                       -->
    <!-- ============================================ -->
    <section class="py-20 bg-stone-50" id="trust">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-14">
          <h2 class="text-3xl font-bold text-gray-900 mb-4">
            Identity and Credentials on Your Profile
          </h2>
          <p class="text-lg text-gray-600 max-w-3xl mx-auto">
            BreederHQ does not verify or vouch for providers. What appears on your profile comes from three layers buyers can see and weigh for themselves.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 mb-10">
          <div class="bg-white rounded-xl border border-stone-200 p-6">
            <div class="text-xs uppercase tracking-wider text-gray-500 font-semibold mb-2">Layer 1</div>
            <h3 class="font-bold text-gray-900 mb-2">Identity confirmation (Stripe Identity)</h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              You can complete identity verification through Stripe Identity, a service operated by Stripe, Inc. If Stripe confirms your identity, your profile shows <em>&ldquo;Identity confirmed via Stripe Identity&rdquo;</em> with the date.
            </p>
          </div>
          <div class="bg-white rounded-xl border border-stone-200 p-6">
            <div class="text-xs uppercase tracking-wider text-gray-500 font-semibold mb-2">Layer 2</div>
            <h3 class="font-bold text-gray-900 mb-2">Public-registry passthrough</h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              For credentials issued by organizations with a public registry (OFA, AKC, AFA, state licensing boards), BreederHQ may query the registry and display <em>&ldquo;Confirmed via [registry] registry&rdquo;</em> with the query date and a link to the source record.
            </p>
          </div>
          <div class="bg-white rounded-xl border border-stone-200 p-6">
            <div class="text-xs uppercase tracking-wider text-gray-500 font-semibold mb-2">Layer 3</div>
            <h3 class="font-bold text-gray-900 mb-2">Your own attestation</h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              For credentials without a Layer 2 passthrough, what appears on your profile is your own attestation. You may upload supporting documents. BreederHQ does not open, read, or vouch for any uploaded document.
            </p>
          </div>
        </div>

        <div class="bg-white rounded-xl border border-stone-200 p-6 text-center">
          <p class="text-sm text-gray-600">
            BreederHQ may also display <strong>Profile Indicators</strong> based on your account history on the platform (joined date, typical response time, completed transactions, open disputes). Indicators are facts, not endorsements.
            <a href="/trust" class="text-emerald-700 hover:underline ml-1">Read the full Identity &amp; Credentials policy &rarr;</a>
          </p>
        </div>
      </div>
    </section>


    <!-- ============================================ -->
    <!-- WHERE PROVIDER LISTINGS APPEAR (demand graph)-->
    <!-- ============================================ -->
    <section class="py-16 bg-white">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-3">Where Provider Listings Appear on BreederHQ Marketplace</h2>
        <p class="text-gray-600 max-w-3xl mb-8">
          Listings here surface in the consumer-facing service directories on breederhq.com and on the marketplace itself. Breeders, buyers, and pet owners reach providers through the same specialist directories, not a generic catch-all.
        </p>
        <div class="grid md:grid-cols-3 gap-5">
          <a href="/services" class="block bg-stone-50 rounded-xl p-5 border border-stone-200 hover:border-amber-500 transition">
            <p class="text-xs uppercase tracking-wider text-amber-700 font-semibold mb-2">Services Hub</p>
            <h3 class="text-base font-semibold text-gray-900 mb-1">All Marketplace Services</h3>
            <p class="text-sm text-gray-600">The specialist-first directory across equine, livestock, and professional animal services.</p>
            <p class="text-sm font-semibold text-amber-700 mt-3">/services &rarr;</p>
          </a>
          <a href="/services/farriers" class="block bg-stone-50 rounded-xl p-5 border border-stone-200 hover:border-amber-500 transition">
            <p class="text-xs uppercase tracking-wider text-amber-700 font-semibold mb-2">Live Category</p>
            <h3 class="text-base font-semibold text-gray-900 mb-1">Farriers Directory</h3>
            <p class="text-sm text-gray-600">Trimmers, shoers, and specialists. AFA-credential aware. State-level rollout underway.</p>
            <p class="text-sm font-semibold text-amber-700 mt-3">/services/farriers &rarr;</p>
          </a>
          <a href="/services/equine-boarding" class="block bg-stone-50 rounded-xl p-5 border border-stone-200 hover:border-amber-500 transition">
            <p class="text-xs uppercase tracking-wider text-amber-700 font-semibold mb-2">Live Category</p>
            <h3 class="text-base font-semibold text-gray-900 mb-1">Equine Boarding Directory</h3>
            <p class="text-sm text-gray-600">Full-care, pasture, training, and breeding facilities. Regional hubs in Lexington KY and Ocala FL.</p>
            <p class="text-sm font-semibold text-amber-700 mt-3">/services/equine-boarding &rarr;</p>
          </a>
        </div>
        <p class="text-sm text-gray-500 mt-6 max-w-3xl">
          Additional categories are added as coverage warrants. Provider acquisition pages for veterinary, training, transport, grooming, boarding, livestock, photography, handling, and facilities are listed in the Service Providers menu above.
        </p>
      </div>
    </section>


    <!-- ============================================ -->
    <!-- FAQ                                          -->
    <!-- ============================================ -->
    <section class="py-16 bg-stone-50">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">Frequently Asked Questions</h2>
        <div class="space-y-6">
          {faqs.map((faq) => (
            <div class="bg-white rounded-xl border border-stone-200 p-6">
              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-sm text-gray-600">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ============================================ -->
    <!-- FINAL CTA                                    -->
    <!-- ============================================ -->
    <section class="py-20 bg-gradient-to-br from-emerald-900 to-emerald-800">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold mb-4 text-white">
          Be seen where animal people are looking.
        </h2>
        <p class="text-lg text-emerald-200 mb-10 max-w-2xl mx-auto">
          Breeders, buyers, and pet owners are all on the BreederHQ Marketplace.
          Free to list. Get your services in front of them.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
