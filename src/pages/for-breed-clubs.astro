              <h3 class="font-semibold text-gray-900 mb-2">{faq.question}</h3>
              <p class="text-sm text-gray-600">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ============================================ -->
    <!-- FINAL CTA                                    -->
    <!-- ============================================ -->
    <section class="py-20 bg-gradient-to-br from-amber-900 via-orange-800 to-[hsl(24,95%,40%)]">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl font-bold mb-4 text-white">
          Your breed's history deserves better than a PDF.
        </h2>
        <p class="text-lg text-amber-100 mb-10 max-w-2xl mx-auto">
          Let's talk about what your club needs. Thirty minutes. No commitment.
          If it's a fit, we'll move fast. If it's not, you'll have learned
          something about where the tools are going.
        </p>

        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/contact?topic=breed-club-partnership"
            class="bg-white text-orange-900 px-8 py-4 rounded-lg text-lg font-semibold hover:bg-amber-50 w-full sm:w-auto"
          >
            Talk to Us About Partnering
          </a>
          <a
            href="mailto:clubs@breederhq.com?subject=Breed%20Club%20Partnership%20Inquiry"
            class="border-2 border-amber-300 text-amber-100 px-8 py-4 rounded-lg text-lg font-semibold hover:border-white hover:text-white w-full sm:w-auto"
          >
            Email clubs@breederhq.com
          </a>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
