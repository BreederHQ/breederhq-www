export const updateMeta = {
  date: '2026-06-26',
  title: 'New conquesting LP: /compare/dogbreederpro-alternative (Cluster C, LP plan §C3)',
  tags: ['marketplace', 'seo', 'compare', 'conquesting', 'lp-cluster'],
