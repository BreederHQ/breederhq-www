---
// src/pages/_site-updates/2026-07-22-provider-listings-free.astro
export const updateMeta = {
  date: '2026-07-22',
  title: 'Provider listings are permanently free — scrub remaining "$5/mo" copy',
  tags: ['marketplace', 'providers', 'pricing'],
};
---
<article class="border-l-4 border-[hsl(24,95%,53%)] pl-6">
  <h2 class="text-2xl font-bold text-gray-900 mb-1">July 22, 2026</h2>
  <p class="text-sm text-gray-500 mb-4">
    Marketplace service-provider listings are now permanently free (no listing fee, no commissions).
    Removed the last two provider-facing "$5/mo" / "during early access" pricing references on the
    marketing site so it matches the free-forever offer providers see in the app:
  </p>
  <ul class="text-sm text-gray-500 list-disc pl-5 space-y-1">
    <li>Header "List Your Services" menu item — "$5/mo" &rarr; "Free".</li>
    <li><a href="/services/farriers" class="text-[hsl(24,95%,53%)] hover:underline">/services/farriers</a> CTA — "Free during early access" &rarr; "Free to list — no fees, no commissions".</li>
  </ul>
  <p class="text-sm text-gray-500 mt-3">
    The <code>/for-providers/*</code> category pages and <code>/pricing</code> already stated
    "free, no commissions," so no further pricing changes were needed there.
  </p>
</article>
