---
export const prerender = false;
import '../../styles/global.css';

const DEMO_PASSWORD = import.meta.env.DEMO_PASSWORD;
let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const password = formData.get('password') as string;

  if (DEMO_PASSWORD && password === DEMO_PASSWORD) {
    Astro.cookies.set('bhq_demo_access', DEMO_PASSWORD, {
      httpOnly: true,
      secure: import.meta.env.PROD,
      sameSite: 'lax',
      maxAge: 60 * 60 * 24 * 7, // 7 days
      path: '/',
    });
    return Astro.redirect('/demo');
  }
  error = 'Incorrect password. Please try again.';
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BreederHQ — Private Preview</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body class="min-h-screen bg-gray-50 flex items-center justify-center px-4">
    <div class="w-full max-w-sm">
      <!-- Logo -->
      <div class="text-center mb-8">
        <img src="/logo.png" alt="BreederHQ" class="h-16 w-auto mx-auto mb-6" />
        <h1 class="text-2xl font-bold text-gray-900">Private Walkthrough</h1>
        <p class="mt-2 text-sm text-gray-500">
          Enter the password shared with you to access the product demo.
        </p>
      </div>

      <!-- Login Card -->
      <form method="POST" class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
        {error && (
          <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-600">
            {error}
          </div>
        )}

        <div class="mb-5">
          <label for="password" class="block text-sm font-medium text-gray-700 mb-1.5">
            Password
          </label>
          <input
            id="password"
            name="password"
            type="password"
            required
            autofocus
            class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
            placeholder="Enter access password"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-primary hover:bg-primary/90 text-white font-semibold py-2.5 px-4 rounded-lg transition-colors text-sm cursor-pointer"
        >
          Continue &rarr;
        </button>
      </form>

      <p class="text-center text-xs text-gray-400 mt-6">
        &copy; {new Date().getFullYear()} BreederHQ &mdash; Confidential
      </p>
    </div>
  </body>
</html>
