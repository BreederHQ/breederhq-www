---
export const prerender = false;
import '../../styles/global.css';

const DEMO_PASSWORD = import.meta.env.DEMO_PASSWORD;

// Auth check — redirect to login if no valid cookie
const cookie = Astro.cookies.get('bhq_demo_access');
if (!cookie || cookie.value !== DEMO_PASSWORD) {
  return Astro.redirect('/demo/login');
}

// VIDEO CONFIG — Add Loom video IDs here (from the share URL).
// Loom's embed handles titles/thumbnails automatically.
const videos = [
  'beeeb6b6887e4a9b991cf3e749309374',  // Introductions
  '8c1d61de2282405aae72421d567ba581',  // Platform Overview
  'f874dd7e90a44889a4c470b0b5863e18',  // Mare Status Board
  'b7232325737c449fa32ddaa06f8c2e5e',  // Cycle Progress
  '786e7c5e3f1c42f3a05660204b74ff85',  // Understanding Breeding Plans
  'fb36d09c92784b6ba8153b3c684857f9',  // Medication Management
  '90cbab4a86f0452db960195f75584f17',  // Pre-Foaling Monitoring
  '90b64e098e8f4d129c61ed7b59028572',  // Enhancing Breeder Protocols
  '46b876b3c30f46aabefa41475855bc12',  // Genetics Lab
  '1ab1a1ccb1664d73a13b963907f6f7ab',  // Data Reporting
  'cd365bb3888f46268c2a022af60f9432',  // Commerce
  'e820f90ac3b941ab887a07e728d8d83d',  // Demo Closing
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BreederHQ — Product Walkthrough</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body class="min-h-screen bg-gray-50 flex flex-col">
    <!-- Header -->
    <header class="bg-white border-b border-gray-200">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/">
          <img src="/logo.png" alt="BreederHQ" class="h-12 w-auto" />
        </a>
        <span class="text-xs text-gray-400 font-medium uppercase tracking-wider">
          Private Preview
        </span>
      </div>
    </header>

    <!-- Hero -->
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-6">
      <h1 class="text-3xl font-bold text-gray-900">Product Walkthrough</h1>
      <p class="mt-2 text-gray-500 max-w-2xl">
        A hands-on look at BreederHQ — breeding program management software
        built for serious breeders. Click any video below to watch.
      </p>
    </div>

    <!-- Video Grid -->
    <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-16 flex-1">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {videos.map((id) => (
          <div class="rounded-xl overflow-hidden shadow-sm border border-gray-200">
            <iframe
              src={`https://www.loom.com/embed/${id}`}
              style="aspect-ratio: 16/9; width: 100%; display: block;"
              frameborder="0"
              allowfullscreen
              loading="lazy"
              allow="fullscreen"
            ></iframe>
          </div>
        ))}
      </div>
    </main>

    <!-- Footer -->
    <footer class="border-t border-gray-200 bg-white py-6 mt-auto">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-xs text-gray-400">
        &copy; {new Date().getFullYear()} BreederHQ &mdash; Confidential. Please do not share.
      </div>
    </footer>

  </body>
</html>
