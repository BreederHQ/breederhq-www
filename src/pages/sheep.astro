---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'For Breeders', url: '/#for-breeders' },
  { name: 'Sheep Breeding', url: '/sheep' }
];

const faqs = [
  {
    question: 'Can it track tupping groups?',
    answer: 'Yes. Create a tupping group with one ram and multiple ewes, set exposure dates, then confirm pregnancies individually. Each confirmed ewe gets her own breeding plan for lambing tracking. Track group pregnancy rates and analytics.'
  },
  {
    question: 'Does it handle twins and triplets?',
    answer: 'Yes. Each lamb tracked individually with dam and sire linked.'
  },
  {
    question: 'What about NSIP data?',
    answer: 'Performance data can be tracked for NSIP submission.'
  },
  {
    question: 'Can I track fleece records and lab results?',
    answer: 'Yes. Full fiber production tracking: gross and clean fleece weights with automatic yield calculation, fleece grading (Prime through Reject), staple length, and lab test results including micron analysis, CV%, comfort factor, and staple strength. Track micron trends over time to see if fiber quality is improving, stable, or coarsening. Lifetime production history per animal.'
  },
  {
    question: 'Can I batch-deworm the whole flock at once?',
    answer: 'Yes. Select multiple animals, choose the medication (Ivermectin, SafeGuard, etc.), and log it once. Each animal gets its own treatment record with individual tracking and lot/batch numbers.'
  },
  {
    question: 'Can I try it before paying?',
    answer: 'Yes. Join our early adopter program for full access. Visit our Coming Soon page for details.'
  }
];

const featureCards = [
  { id: 'sheep-records', icon: '🐑', title: 'Sheep Records', desc: 'Complete flock profiles, pedigrees, registration' },
  { id: 'breeding', icon: '📅', title: 'Breeding', desc: 'Tupping groups, seasonal cycles, lambing records' },
  { id: 'health', icon: '🏥', title: 'Health & Genetics', desc: 'Scrapie genotyping, OPP, vaccinations' },
  { id: 'performance', icon: '📊', title: 'Performance', desc: 'NSIP data, weights, reproductive efficiency' },
  { id: 'fiber', icon: '🧶', title: 'Fiber & Wool', desc: 'Shearing, fleece grading, micron analysis, production analytics' },
  { id: 'clients', icon: '👥', title: 'Clients & Buyer CRM', desc: 'Sales pipeline, lead scoring, waitlists, contracts' },
  { id: 'medications', icon: '💊', title: 'Medications', desc: 'Batch deworming, treatment courses, health reports' }
];
---

<BaseLayout
  title="Sheep Breeding Software | BreederHQ"
  description="Sheep breeding software for flocks of all sizes. Fiber/wool production tracking, tupping groups, lambing management, NSIP data, micron analysis. Built for fiber and meat operations."
  breadcrumbs={breadcrumbs}
  faqs={faqs}
>
  <a href="#main-content" class="skip-link sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:shadow-lg focus:rounded">
    Skip to content
  </a>

  <main id="main-content">
  <nav class="breadcrumb py-4 px-4 bg-gray-50" aria-label="Breadcrumb">
    <ol class="flex items-center space-x-2 max-w-4xl mx-auto text-sm">
      <li><a href="/" class="text-[hsl(24,95%,53%)] hover:underline">Home</a></li>
      <li class="text-gray-400">›</li>
      <li><a href="/#for-breeders" class="text-[hsl(24,95%,53%)] hover:underline">For Breeders</a></li>
      <li class="text-gray-400">›</li>
      <li aria-current="page" class="text-gray-600">Sheep Breeding</li>
    </ol>
  </nav>

  <!-- Hero + TL;DR -->
  <section class="py-12 px-4">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-5xl font-bold mb-6">Sheep Breeding Software for Flocks of All Sizes</h1>

      <aside class="tldr-box bg-gray-100 border-l-4 border-[hsl(24,95%,53%)] p-6 my-8 rounded" role="complementary" aria-label="Page summary">
        <h2 class="text-xl font-bold mb-3">TL;DR</h2>
        <p class="text-gray-700 leading-relaxed">
          Sheep breeding software for fiber and meat operations managing seasonal breeding, lambing intensity, OPP testing, NSIP data, and multiple lamb tracking. Built for flocks with 20+ sheep that need performance tracking and organized breeding records.
        </p>
      </aside>
    </div>
  </section>

  <!-- Feature Cards Grid -->
  <section class="py-8 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-bold mb-6 text-center">Everything Your Flock Needs</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {featureCards.map(card => (
          <a href={`#${card.id}`} class="feature-card block p-4 bg-white rounded-lg shadow-sm hover:shadow-md transition border border-gray-200 hover:border-[hsl(24,95%,53%)]">
            <div class="text-3xl mb-2">{card.icon}</div>
            <h3 class="font-bold text-lg mb-1">{card.title}</h3>
            <p class="text-sm text-gray-600">{card.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Sticky Navigation -->
  <nav class="sticky-nav hidden md:block sticky top-0 bg-white border-b border-gray-200 z-40 shadow-sm">
    <div class="max-w-5xl mx-auto px-4">
      <ul class="flex space-x-6 overflow-x-auto py-3 text-sm">
        {featureCards.map(card => (
          <li>
            <a href={`#${card.id}`} class="nav-link whitespace-nowrap text-gray-600 hover:text-[hsl(24,95%,53%)] transition pb-2">
              {card.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <!-- Accordion Sections -->
  <section class="py-12 px-4">
    <div class="max-w-4xl mx-auto space-y-4">

      <!-- Sheep Records -->
      <details id="sheep-records" class="accordion-section border border-gray-200 rounded-lg" open>
        <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
          <div class="flex items-center gap-4">
            <span class="text-3xl">🐑</span>
            <div>
              <h3 class="text-2xl font-bold">Sheep Records</h3>
              <p class="text-gray-600">Complete flock management</p>
            </div>
          </div>
          <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="accordion-content p-6 border-t border-gray-200">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-lg mb-3">For Every Sheep</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Registration numbers and scrapie tags</li>
                <li class="flex items-start"><span class="mr-2">•</span>Ear tags and electronic IDs</li>
                <li class="flex items-start"><span class="mr-2">•</span>Photos and descriptions</li>
                <li class="flex items-start"><span class="mr-2">•</span>Birth and purchase information</li>
                <li class="flex items-start"><span class="mr-2">•</span>Multi-generation pedigrees</li>
              </ul>
            </div>
            <div>
              <h4 class="font-bold text-lg mb-3">Flock Organization</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Active ewes and rams</li>
                <li class="flex items-start"><span class="mr-2">•</span>Growing lambs by age group</li>
                <li class="flex items-start"><span class="mr-2">•</span>Breeding groups</li>
                <li class="flex items-start"><span class="mr-2">•</span>Retired and sold animals</li>
                <li class="flex items-start"><span class="mr-2">•</span>Custom tags and categories</li>
              </ul>
            </div>
          </div>
        </div>
      </details>

      <!-- Breeding -->
      <details id="breeding" class="accordion-section border border-gray-200 rounded-lg">
        <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
          <div class="flex items-center gap-4">
            <span class="text-3xl">📅</span>
            <div>
              <h3 class="text-2xl font-bold">Breeding Management</h3>
              <p class="text-gray-600">Seasonal cycles, breeding groups, lambing records</p>
            </div>
          </div>
          <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="accordion-content p-6 border-t border-gray-200">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-lg mb-3">Tupping Groups</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Assign one ram to a group of ewes</li>
                <li class="flex items-start"><span class="mr-2">•</span>Set exposure start and end dates</li>
                <li class="flex items-start"><span class="mr-2">•</span>Expected lambing date calculator (147 days)</li>
                <li class="flex items-start"><span class="mr-2">•</span>Pregnancy confirmation per ewe</li>
                <li class="flex items-start"><span class="mr-2">•</span>Auto-creates individual breeding plans when confirmed</li>
                <li class="flex items-start"><span class="mr-2">•</span>Group pregnancy rate and analytics</li>
              </ul>
            </div>
            <div>
              <h4 class="font-bold text-lg mb-3">Lambing Records</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Multiple lambs per birth (twins, triplets+)</li>
                <li class="flex items-start"><span class="mr-2">•</span>Birth weights and presentations</li>
                <li class="flex items-start"><span class="mr-2">•</span>Dam and sire linked automatically</li>
                <li class="flex items-start"><span class="mr-2">•</span>Lambing difficulty notes</li>
                <li class="flex items-start"><span class="mr-2">•</span>Fostering and grafting records</li>
                <li class="flex items-start"><span class="mr-2">•</span>Ram rotation between groups</li>
              </ul>
            </div>
          </div>
          <div class="mt-4 bg-white border-l-4 border-[hsl(24,95%,53%)] p-5 rounded">
            <p class="text-gray-700 text-sm"><strong>How tupping groups work:</strong> Create a group, assign ewes and a ram, set the exposure window. After exposure ends, confirm pregnancies individually. Each confirmed ewe automatically gets her own breeding plan for lambing tracking. No extra data entry-the system flows naturally from group breeding to individual management.</p>
          </div>
        </div>
      </details>

      <!-- Health & Testing -->
      <details id="health" class="accordion-section border border-gray-200 rounded-lg">
        <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
          <div class="flex items-center gap-4">
            <span class="text-3xl">🏥</span>
            <div>
              <h3 class="text-2xl font-bold">Health & Genetics</h3>
              <p class="text-gray-600">Scrapie genotyping, health markers, vaccinations</p>
            </div>
          </div>
          <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="accordion-content p-6 border-t border-gray-200">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-lg mb-3">Genetic Health Markers</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Scrapie genotyping (RR/QR/QQ for USDA compliance)</li>
                <li class="flex items-start"><span class="mr-2">•</span>OPP susceptibility tracking</li>
                <li class="flex items-start"><span class="mr-2">•</span>Spider Lamb Syndrome markers</li>
                <li class="flex items-start"><span class="mr-2">•</span>CL and Johne's status</li>
                <li class="flex items-start"><span class="mr-2">•</span>Fecundity genes (FecB, Inverdale)</li>
              </ul>
            </div>
            <div>
              <h4 class="font-bold text-lg mb-3">Routine Care</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Vaccination schedules (CDT, etc.)</li>
                <li class="flex items-start"><span class="mr-2">•</span>Deworming protocols</li>
                <li class="flex items-start"><span class="mr-2">•</span>Hoof trimming records</li>
                <li class="flex items-start"><span class="mr-2">•</span>Veterinary visits</li>
                <li class="flex items-start"><span class="mr-2">•</span><a href="/workflows/medication-tracking" class="text-[hsl(24,95%,53%)] hover:underline">Medication tracking</a> with batch deworming support</li>
              </ul>
            </div>
          </div>
        </div>
      </details>

      <!-- Performance -->
      <details id="performance" class="accordion-section border border-gray-200 rounded-lg">
        <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
          <div class="flex items-center gap-4">
            <span class="text-3xl">📊</span>
            <div>
              <h3 class="text-2xl font-bold">Performance Tracking</h3>
              <p class="text-gray-600">NSIP data, weights, reproductive efficiency</p>
            </div>
          </div>
          <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="accordion-content p-6 border-t border-gray-200">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-lg mb-3">Growth Data</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Birth weights</li>
                <li class="flex items-start"><span class="mr-2">•</span>Weaning weights (60-90 day)</li>
                <li class="flex items-start"><span class="mr-2">•</span>Post-weaning weights</li>
                <li class="flex items-start"><span class="mr-2">•</span>Average daily gain calculations</li>
                <li class="flex items-start"><span class="mr-2">•</span>Growth charts</li>
              </ul>
            </div>
            <div>
              <h4 class="font-bold text-lg mb-3">NSIP-Ready Data</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Performance data organization</li>
                <li class="flex items-start"><span class="mr-2">•</span>EBV tracking fields</li>
                <li class="flex items-start"><span class="mr-2">•</span>Reproductive efficiency metrics</li>
                <li class="flex items-start"><span class="mr-2">•</span>Lambing percentage tracking</li>
                <li class="flex items-start"><span class="mr-2">•</span>Export to Pedigree Master format</li>
              </ul>
            </div>
          </div>
        </div>
      </details>

      <!-- Fiber Records -->
      <details id="fiber" class="accordion-section border border-gray-200 rounded-lg">
        <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
          <div class="flex items-center gap-4">
            <span class="text-3xl">🧶</span>
            <div>
              <h3 class="text-2xl font-bold">Fiber & Wool Production</h3>
              <p class="text-gray-600">Shearing records, fleece grading, micron analysis, production analytics</p>
            </div>
          </div>
          <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="accordion-content p-6 border-t border-gray-200">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-lg mb-3">Shearing Records</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Gross and clean fleece weights</li>
                <li class="flex items-start"><span class="mr-2">•</span>Automatic yield calculation</li>
                <li class="flex items-start"><span class="mr-2">•</span>Fleece grading (Prime, Choice, Standard, Utility, Reject)</li>
                <li class="flex items-start"><span class="mr-2">•</span>Staple length tracking</li>
                <li class="flex items-start"><span class="mr-2">•</span>Shearing dates and shearer notes</li>
                <li class="flex items-start"><span class="mr-2">•</span>Year-over-year comparisons</li>
              </ul>
            </div>
            <div>
              <h4 class="font-bold text-lg mb-3">Lab Tests & Quality</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Micron analysis (average fiber diameter)</li>
                <li class="flex items-start"><span class="mr-2">•</span>Coefficient of variation (CV%)</li>
                <li class="flex items-start"><span class="mr-2">•</span>Comfort factor percentage</li>
                <li class="flex items-start"><span class="mr-2">•</span>Staple strength measurements</li>
                <li class="flex items-start"><span class="mr-2">•</span>Micron trend analysis (improving, stable, or coarsening)</li>
                <li class="flex items-start"><span class="mr-2">•</span>Color and uniformity grading</li>
              </ul>
            </div>
          </div>
          <div class="mt-4 bg-white border-l-4 border-[hsl(24,95%,53%)] p-5 rounded">
            <h4 class="font-bold text-lg mb-2">Fiber Production Analytics</h4>
            <p class="text-gray-700 text-sm">Lifetime fiber production history per animal, year-over-year trend charts, and flock-level production statistics. Track which bloodlines produce the finest fiber, identify animals whose micron counts are trending in the right direction, and make breeding decisions based on actual production data-not guesswork.</p>
          </div>
        </div>
      </details>

      <!-- Clients & Sales -->
      <details id="clients" class="accordion-section border border-gray-200 rounded-lg">
        <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
          <div class="flex items-center gap-4">
            <span class="text-3xl">👥</span>
            <div>
              <h3 class="text-2xl font-bold">Clients & Buyer CRM</h3>
              <p class="text-gray-600">Sales pipeline, lead scoring, waitlists, contracts</p>
            </div>
          </div>
          <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="accordion-content p-6 border-t border-gray-200">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-lg mb-3">Buyer Management</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Contact database</li>
                <li class="flex items-start"><span class="mr-2">•</span>Waitlist positions</li>
                <li class="flex items-start"><span class="mr-2">•</span>Breed/type preferences</li>
                <li class="flex items-start"><span class="mr-2">•</span>Communication history</li>
                <li class="flex items-start"><span class="mr-2">•</span>Deposit tracking</li>
              </ul>
            </div>
            <div>
              <h4 class="font-bold text-lg mb-3">Sales Records</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Sales linked to animals</li>
                <li class="flex items-start"><span class="mr-2">•</span>Contract generation</li>
                <li class="flex items-start"><span class="mr-2">•</span>Registration transfer tracking</li>
                <li class="flex items-start"><span class="mr-2">•</span>Health certificate records</li>
                <li class="flex items-start"><span class="mr-2">•</span>Revenue reporting</li>
              </ul>
            </div>
          </div>
          <div class="mt-4 bg-white border-l-4 border-[hsl(24,95%,53%)] p-5 rounded">
            <h4 class="font-bold text-lg mb-2">Buyer CRM</h4>
            <p class="text-gray-700 text-sm">Full sales pipeline with drag-and-drop stages, lead scoring, email templates, task management, and conversion analytics. <a href="/workflows/client-management" class="text-[hsl(24,95%,53%)] hover:underline">Learn more</a></p>
          </div>
        </div>
      </details>

      <!-- Medication Tracking -->
      <details id="medications" class="accordion-section border border-gray-200 rounded-lg">
        <summary class="accordion-header flex items-center justify-between p-6 cursor-pointer bg-gray-50 hover:bg-gray-100 rounded-lg">
          <div class="flex items-center gap-4">
            <span class="text-3xl">💊</span>
            <div>
              <h3 class="text-2xl font-bold">Medication Tracking</h3>
              <p class="text-gray-600">Batch deworming, treatment courses, health reports</p>
            </div>
          </div>
          <svg class="accordion-icon w-6 h-6 text-gray-500 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="accordion-content p-6 border-t border-gray-200">
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold text-lg mb-3">Batch Flock Treatments</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Deworm the entire flock in one entry</li>
                <li class="flex items-start"><span class="mr-2">•</span>Each animal gets its own treatment record</li>
                <li class="flex items-start"><span class="mr-2">•</span>Lot and batch numbers for traceability</li>
                <li class="flex items-start"><span class="mr-2">•</span>Common sheep medication templates (Ivermectin, Fenbendazole, Penicillin G, etc.)</li>
              </ul>
            </div>
            <div>
              <h4 class="font-bold text-lg mb-3">Individual Treatment Courses</h4>
              <ul class="space-y-2 text-gray-700">
                <li class="flex items-start"><span class="mr-2">•</span>Course-based tracking with dose check-off</li>
                <li class="flex items-start"><span class="mr-2">•</span>Next-dose reminders and overdue alerts</li>
                <li class="flex items-start"><span class="mr-2">•</span>Adverse reaction documentation</li>
                <li class="flex items-start"><span class="mr-2">•</span>Full health report PDFs and secure vet sharing</li>
              </ul>
            </div>
          </div>
          <p class="mt-4 text-sm text-gray-500">
            <a href="/workflows/medication-tracking" class="text-[hsl(24,95%,53%)] hover:underline">Learn more about medication tracking →</a>
          </p>
        </div>
      </details>

    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 px-4 bg-[hsl(24,95%,53%)] text-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-4xl font-bold mb-4">Ready to organize your flock?</h2>
      <p class="text-xl mb-8 opacity-90">Join our early adopter program for access.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/coming-soon" class="inline-block bg-white text-[hsl(24,95%,53%)] px-8 py-4 rounded-lg font-bold text-lg hover:bg-gray-100 transition text-center" style="min-height: 44px;">
          Get Early Access
        </a>
