---
import '../styles/global.css';
import Header from '../components/HeaderV2.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import PaidQuerySnapshot from '../components/PaidQuerySnapshot.astro';
import TrackingInit from '../components/TrackingInit.astro';

interface Props {
  title: string;
  description: string;
  breadcrumbs?: Array<{ name: string; url: string }>;
  faqs?: Array<{ question: string; answer: string }>;
  howTo?: {
    name: string;
    description: string;
    steps: Array<{ name: string; text: string }>;
  };
  /**
   * Optional Article / BlogPosting structured data for long-form posts under
   * /articles/*. When provided, BaseLayout emits Schema.org BlogPosting JSON-LD
   * with author, datePublished, publisher, and mainEntityOfPage. This is what
   * makes founder posts and editorial content eligible for Google News, Discover,
   * and AI agent citations.
   */
  article?: {
    headline: string;
    description: string;
    datePublished: string; // ISO 8601 date, e.g. "2026-04-29"
    dateModified?: string; // optional, defaults to datePublished
    author: {
      name: string;
      role?: string;
      url?: string;
    };
    image?: string; // optional hero/social image; falls back to ogImage
  };
  /**
   * Optional Service / Offer structured data for category/offering landing pages
   * (e.g. /for-providers/dog-parks). When provided, BaseLayout emits Schema.org
   * Service JSON-LD with provider, areaServed, and a nested Offer block. This is
   * the right schema for "we sell this category of service" pages — distinct
   * from the site-wide SoftwareApplication schema which describes the platform.
   */
  service?: {
    name: string;
    description: string;
    serviceType: string; // e.g. "Private Dog Park Hosting"
    /** ISO 4217 currency code, defaults to USD */
    priceCurrency?: string;
    /** Numeric price; combine with priceCurrency. Omit for "contact for quote" pages */
    price?: string;
    /** e.g. "MONTH" for $5/month recurring */
    priceUnit?: 'MONTH' | 'YEAR' | 'HOUR' | 'DAY';
    /** Free text describing the offer in human-readable form */
    offerDescription?: string;
    /** Country, region, or city; defaults to "United States" */
    areaServed?: string;
    /** Optional URL where buyers can take action on the offer */
    offerUrl?: string;
  };
  /**
   * Optional Product / Offer structured data for subscription-tier pricing
   * pages. When provided, BaseLayout emits Schema.org Product JSON-LD with
   * a nested AggregateOffer covering the listed tier prices. This is what
   * lets ChatGPT, Claude, Perplexity and Google Merchant Listings extract
   * "BreederHQ costs $X-$Y / month" as a structured fact instead of having
   * to scrape the rendered HTML cards.
   */
  product?: {
    name: string;
    description: string;
    brand?: string;
    image?: string;
    offers: Array<{
      name: string;
      price: number;
      priceCurrency?: string;
      billingPeriod?: 'MONTH' | 'YEAR';
      description?: string;
      url?: string;
      availability?: 'InStock' | 'PreOrder';
    }>;
  };
  noindex?: boolean;
  hideLogo?: boolean;
  /**
   * Optional canonical URL override. When provided, the page declares this URL
   * as its canonical instead of its own path. Use for funnel/landing pages that
   * exist primarily for SEO keyword targeting but should consolidate ranking
   * signals into a different "real" page (e.g. an authority landing page that
   * canonicals into the actual tool). Pass a full absolute URL.
   */
  canonicalOverride?: string;
  /**
   * Optional per-page Open Graph image. When omitted, the global default
   * (https://breederhq.com/og-image.jpg) is used. Per-page values let species
   * pages, find-breeders pages, and similar share with a more relevant
   * preview image on social platforms.
   */
  ogImage?: string;
}

const { title, description, breadcrumbs, faqs, howTo, article, service, product, noindex, hideLogo, ogImage: ogImageProp, canonicalOverride } = Astro.props;
// Astro is configured with `trailingSlash: 'never'`, so every page's canonical
// URL must be slash-free - including the homepage. Without this normalization
// the homepage canonical was `https://breederhq.com/` (with slash) while every
// other page was slash-free, and Google flagged it as a duplicate-canonical
// mismatch (chose the slash-free version itself). 2026-04-27.
const currentUrl = Astro.url.pathname === '/' ? '' : Astro.url.pathname.replace(/\/$/, '');
const fullUrl = `https://breederhq.com${currentUrl}`;
// Canonical defaults to this page's own URL. Funnel/landing pages may pass
// `canonicalOverride` to consolidate ranking signals into a different page.
const canonicalUrl = canonicalOverride || fullUrl;
const ogImage = ogImageProp || 'https://breederhq.com/og-image.jpg'; // Default OG image
const breederHQOrganizationId = 'https://breederhq.com/#organization';

// Facebook Business Manager domain verification. When set, FB links the domain
// to our Page so link previews show "BreederHQ" attribution instead of
// "Link unavailable". Code is issued by Business Settings → Brand Safety →
// Domains. No-op until PUBLIC_FB_DOMAIN_VERIFICATION is configured in Vercel.
const fbDomainVerification = import.meta.env.PUBLIC_FB_DOMAIN_VERIFICATION;

// Schema.org Organization - critical for AI assistants
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": breederHQOrganizationId,
  "name": "BreederHQ",
  "url": "https://breederhq.com",
  "logo": "https://breederhq.com/logo.png",
  "description": "Professional breeding program management software with an integrated marketplace. Breeders manage their complete programs on-platform, and their real program data powers their marketplace profiles.",
  "foundingDate": "2024",
  // sameAs: external profiles that describe the BreederHQ Organization entity.
  // Each URL must be a legitimate, owner-controlled Organization/Company/Business
  // profile. Do NOT add personal profiles here — those belong in founder.sameAs.
  // TODOs (confirm if/when accounts are created): YouTube, TikTok, Crunchbase,
  // G2, Capterra, AlternativeTo, Product Hunt.
  "sameAs": [
    "https://x.com/Breeder_HQ",
    "https://www.linkedin.com/company/breederhq/",
    "https://www.facebook.com/BreederHQ/",
    "https://www.instagram.com/breederhq.app",
    "https://github.com/BreederHQ"
  ],
  // TODO: Add a PostalAddress when BreederHQ's registered or mailing address is confirmed.
  "founder": [
    {
      "@type": "Person",
      "@id": "https://breederhq.com/#aaron-payne",
      "name": "Aaron Payne",
      "jobTitle": "Co-Founder",
      "sameAs": [
        "https://www.linkedin.com/in/aaron-payne-63b3508/"
      ]
    },
    {
      "@type": "Person",
      "@id": "https://breederhq.com/#carie-chapman-barber",
      "name": "Carie Chapman Barber",
      "jobTitle": "Co-Founder",
      "sameAs": [
        "https://www.linkedin.com/in/carie-chapman-barber/"
      ]
    }
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "email": "support@breederhq.com"
  }
};

// Schema.org SoftwareApplication for all pages - comprehensive feature list for AI
const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "BreederHQ",
  "applicationCategory": "BusinessApplication",
  "applicationSubCategory": "Animal Breeding Management Software",
  "operatingSystem": "Web",
  "description": "Professional breeding management software for dog, cat, horse, goat, rabbit, and sheep breeders. Complete breeding program management with pedigree tracking and COI calculation, health testing records, breeding cycle tracking, genetics tools including offspring simulator and best match finder, client portal with e-signatures and Stripe payments, waitlist management, invoicing and expense tracking, and an integrated marketplace where identity is confirmed via Stripe Identity and credentials are surfaced as public-registry passthrough or provider self-attestation.",
  "url": "https://breederhq.com",
  // NOTE: Intentionally NO `offers` block. Adding an Offer to SoftwareApplication
  // activates Google's Merchant Listings classifier site-wide, which then demands
  // shippingDetails + hasMerchantReturnPolicy + price + currency on every page —
  // fields that don't apply to a SaaS platform. Validated 2026-05-13: dropping
  // this `offers` block clears 117 Merchant Listings warnings across the site
  // while keeping SoftwareApplication schema fully valid for AI-search visibility.
  "featureList": [
    "Pedigree tracking with automatic COI calculation",
    "Multi-locus genetics tracking across coat color (including E, K, A, B, D, M, S), coat type, performance, temperament, eye color, and health markers",
    "Offspring genetics simulator with Monte Carlo simulation",
    "Best match finder algorithm for optimal breeding pairs",
    "Breeding goal planner for coat, health, and physical traits",
    "Punnett square analysis for inheritance visualization",
    "8-phase breeding plan lifecycle management",
    "Heat cycle tracking with species-specific timelines",
    "Health testing record management (OFA, PennHIP, Embark)",
    "Scout AI Genetics Scanner - upload any lab PDF and auto-extract test results",
    "Vaccination protocols with expiration alerts",
    "Medication tracking with treatment courses and dose logging",
    "Withdrawal period countdown for competition compliance",
    "Health report PDF export and secure vet sharing",
    "Health incident and procedure record-keeping with timeline updates and document attachments",
    "Scout AI-powered document upload with auto-extraction",
    "Batch medication for herd treatments",
    "Client portal with 24/7 access",
    "E-signature agreements with status tracking",
    "Pay Now via Stripe integration",
    "Waitlist management with automated notifications",
    "Invoicing with line items and deposits",
    "Expense tracking across 12 categories",
    "Financial dashboard with MTD metrics",
    "Communications hub with unified inbox",
    "Email and message templates",
    "Real-time messaging",
    "Titles and achievements tracking",
    "Competition results for Shows, Trials, Races",
    "Cross-tenant animal linking via GAID",
    "Integrated marketplace with listings powered by real program data",
    "Identity confirmation via Stripe Identity passthrough",
    "Public-registry passthrough for credentials issued by OFA, AKC, AFA, and similar bodies",
    "Profile Indicators (typical response time, completed transactions, open disputes) calculated from platform account history",
    "Multi-species: dogs, cats, horses, goats, alpacas, llamas, rabbits, sheep, cattle",
    "Breed club registry and stud book management",
    "Breed club member directory with Stripe-powered dues and renewals",
    "Automatic offspring registration workflow for breed clubs",
    "Breed club health compliance tracking with automated reminders",
    "Cross-tenant stud book search with opt-in network visibility"
  ],
  "provider": {
    "@id": breederHQOrganizationId
  }
  // TODO: Add aggregateRating when customer reviews are available
  // Example:
  // "aggregateRating": {
  //   "@type": "AggregateRating",
  //   "ratingValue": "4.9",
  //   "ratingCount": "47",
  //   "bestRating": "5",
  //   "worstRating": "1"
  // }
};

// BreadcrumbList schema if breadcrumbs provided
let breadcrumbSchema;
if (breadcrumbs && breadcrumbs.length > 0) {
  breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbs.map((crumb, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": crumb.name,
      "item": `https://breederhq.com${crumb.url}`
    }))
  };
}

// FAQPage schema if FAQs provided
let faqSchema;
if (faqs && faqs.length > 0) {
  faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  };
}

// HowTo schema for workflow/tutorial pages
let howToSchema;
if (howTo && howTo.steps && howTo.steps.length > 0) {
  howToSchema = {
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": howTo.name,
    "description": howTo.description,
    "step": howTo.steps.map((step, index) => ({
      "@type": "HowToStep",
      "position": index + 1,
      "name": step.name,
      "text": step.text
    }))
  };
}

// Service / Offer schema for category/offering landing pages (e.g. dog parks,
// other rentable facility types). Distinct from the site-wide
// SoftwareApplication schema — this describes a specific service offered on
// the page, with a price, a provider, and an area served. Drives Google's
// Service rich results and gives AI assistants a structured representation
// of what we actually sell on this page.
let serviceSchema;
if (service) {
  const offer: Record<string, unknown> = {
    "@type": "Offer",
    "priceCurrency": service.priceCurrency || "USD",
    ...(service.price !== undefined ? { "price": service.price } : {}),
    ...(service.priceUnit ? { "priceSpecification": {
      "@type": "UnitPriceSpecification",
      "price": service.price,
      "priceCurrency": service.priceCurrency || "USD",
      "unitCode": service.priceUnit
    } } : {}),
    ...(service.offerDescription ? { "description": service.offerDescription } : {}),
    ...(service.offerUrl ? { "url": service.offerUrl } : {}),
    "availability": "https://schema.org/InStock"
  };
  serviceSchema = {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": service.name,
    "description": service.description,
    "serviceType": service.serviceType,
    "provider": {
      "@id": breederHQOrganizationId
    },
    "areaServed": {
      "@type": "Country",
      "name": service.areaServed || "United States"
    },
    "offers": offer
  };
}

// Product / AggregateOffer schema for subscription pricing pages. Lets AI
// engines and Merchant Listings extract "BreederHQ pricing is $X/mo" as a
// structured fact instead of scraping the rendered cards.
let productSchema;
if (product && product.offers && product.offers.length > 0) {
  const prices = product.offers.map(o => o.price);
  const lowPrice = Math.min(...prices);
  const highPrice = Math.max(...prices);
  productSchema = {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": product.name,
    "description": product.description,
    "brand": {
      "@type": "Brand",
      "name": product.brand || "BreederHQ"
    },
    ...(product.image ? { "image": product.image } : {}),
    "offers": {
      "@type": "AggregateOffer",
      "priceCurrency": "USD",
      "lowPrice": lowPrice.toFixed(2),
      "highPrice": highPrice.toFixed(2),
      "offerCount": product.offers.length,
      "offers": product.offers.map(offer => ({
        "@type": "Offer",
        "name": offer.name,
        "price": offer.price.toFixed(2),
        "priceCurrency": offer.priceCurrency || "USD",
        "availability": `https://schema.org/${offer.availability || "InStock"}`,
        ...(offer.description ? { "description": offer.description } : {}),
        ...(offer.url ? { "url": offer.url } : {}),
        ...(offer.billingPeriod ? {
          "priceSpecification": {
            "@type": "UnitPriceSpecification",
            "price": offer.price.toFixed(2),
            "priceCurrency": offer.priceCurrency || "USD",
            "unitCode": offer.billingPeriod,
            "billingDuration": 1
          }
        } : {})
      }))
    }
  };
}

// BlogPosting schema for /articles/* and similar long-form editorial pages.
// Strong SEO signal for Google News, Discover, and AI agent citations.
let articleSchema;
if (article) {
  articleSchema = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": article.headline,
    "description": article.description,
    "datePublished": article.datePublished,
    "dateModified": article.dateModified || article.datePublished,
    "image": article.image || ogImage,
    "author": {
      "@type": "Person",
      "name": article.author.name,
      ...(article.author.role ? { "jobTitle": article.author.role } : {}),
      ...(article.author.url ? { "url": article.author.url } : {})
    },
    "publisher": {
      "@id": breederHQOrganizationId
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": fullUrl
    }
  };
}
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <!--
      AI/LLM context discovery. Matches the pattern used by
      marketplace.breederhq.com so ChatGPT, Claude, Perplexity, and other
      AI engines can find our llms.txt and machine-readable pricing without
      crawling the JS-rendered pricing page.
    -->
    <link rel="alternate" type="text/plain" title="LLM Context" href="/llms.txt" />
    <link rel="alternate" type="text/markdown" title="Pricing (machine-readable)" href="/pricing.md" />
    {fbDomainVerification && (
      <meta name="facebook-domain-verification" content={fbDomainVerification} />
    )}

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="BreederHQ" />
    {article && (
      <>
        <meta property="article:published_time" content={article.datePublished} />
        <meta property="article:modified_time" content={article.dateModified || article.datePublished} />
        <meta property="article:author" content={article.author.name} />
      </>
    )}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Schema.org Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
    {breadcrumbSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}
    {faqSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    )}
    {howToSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
    )}
    {serviceSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    )}
    {articleSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    )}
    {productSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
    )}

    <!--
      Paid-traffic query snapshot. MUST render immediately before <Analytics />
      so the inline snapshot script runs before the async gtag.js loader has
      a chance to strip gclid from the URL (GA4 does this by design via
      history.replaceState, which also mutates the Performance Navigation
      Timing entry — so we cannot rely on either to recover gclid later).
      Writes window.__BHQ_INBOUND_QUERY__; PaidTrafficHero.astro reads from
      that global to forward gclid + utm_* onto signup links.
    -->
    <PaidQuerySnapshot />

    <!-- Analytics Scripts -->
    <Analytics />
  </head>
  <body>
    <Header hideLogo={hideLogo} />
    <!--
      Pagefind site search (free, static, client-side, no external service).
      The wrapper marks this region as the searchable body. Pagefind indexes
      ONLY content inside data-pagefind-body when at least one page declares
      it, which scopes search to real page content and excludes nav, footer,
      analytics, and other boilerplate. The /search page is excluded via
      data-pagefind-ignore on its own root.
    -->
    <div data-pagefind-body>
      <slot />
    </div>
    <Footer />

    <!-- Tracking Initialization -->
    <TrackingInit />
  </body>
</html>
