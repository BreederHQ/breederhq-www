---
// src/components/PaidTrafficHero.astro
//
// Conditional above-the-fold hero CTA shown only to paid-traffic visitors
// (anyone arriving with gclid / gbraid / wbraid / utm_source / utm_campaign
// in the query string). Organic visitors see the page unchanged — keeps the
// existing SEO scroll-depth / time-on-page signals intact while giving
// Google Ads traffic a single, prominent trial CTA that doesn't require
// scrolling past the TL;DR + 7 feature accordions to reach.
//
// Also runs a tiny inline script that rewrites every
// accounts.breederhq.com/register anchor on the page to preserve the
// inbound query string (gclid + utm_*). Without this, the cross-domain GA4
// _gl linker still carries the client_id (so account_created attributes in
// GA4), but Google Ads loses its direct gclid → conversion linkage, and
// keyword-level conversion reporting in Ads breaks.
//
// Usage (in a species page after the H1, before the TL;DR aside):
//
//   <PaidTrafficHero
//     headline="Start Your 14-Day Free Trial"
//     subhead="Built for serious dog breeders. No credit card pressure for the trial period."
//   />
//
// The script block uses is:inline per breederhq-www's tracking-script
// convention (CLAUDE.md). It is not an analytics integration — it's a
// link-rewriter that supports analytics — but the same is:inline pattern
// applies because it manipulates DOM at runtime against env-provided URLs.

interface Props {
  headline?: string;
  subhead?: string;
  /** Optional override for the primary CTA destination. Defaults to
   *  /register?intent=breeder_dashboard so account_created fires for the
   *  breeder funnel. */
  registerHref?: string;
  /** When true, the visible reveal-block is suppressed entirely and only
   *  the query-string-rewrite script is mounted. Use this on pages whose
   *  existing organic hero is already strong enough for paid traffic
   *  (e.g. /for-breeders, where a prominent trial CTA already sits below
   *  the H1) — the page stays visually identical, but every signup link
   *  silently gains gclid + utm_* forwarding so Google Ads keeps its
   *  campaign + keyword attribution intact. */
  scriptOnly?: boolean;
}

const {
  headline = "Start Your 14-Day Free Trial",
  subhead = "No card required to start. Cancel anytime during the trial.",
  registerHref = "https://accounts.breederhq.com/register?intent=breeder_dashboard",
  scriptOnly = false,
} = Astro.props;
---

{!scriptOnly && (
  <!-- Hidden by default; revealed by the inline script below ONLY when
       the visitor arrives with paid-traffic markers in the URL. Organic
       visitors see no extra hero. data-paid-hero is the script's hook. -->
  <aside
    data-paid-hero
    hidden
    class="my-8 rounded-lg border-2 border-[hsl(24,95%,53%)] bg-orange-50 p-6 md:p-8"
    aria-label="Start a free trial"
  >
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-2">{headline}</h2>
        <p class="text-gray-700">{subhead}</p>
      </div>
      <a
        data-paid-hero-cta
        href={registerHref}
        class="inline-block whitespace-nowrap rounded-lg bg-[hsl(24,95%,53%)] px-8 py-4 text-lg font-bold text-white transition hover:bg-[hsl(24,95%,47%)]"
        style="min-height: 44px;"
      >
        Start 14-Day Free Trial →
      </a>
    </div>
  </aside>
)}

<script is:inline>
  (function () {
    // Read the inbound query from the early-mounted snapshot
    // (PaidQuerySnapshot.astro). Falling back to window.location.search
    // covers pages that forget to mount the snapshot component, but
    // gclid will likely already be stripped by gtag.js in that case —
    // so any page that needs full Ads attribution MUST mount
    // <PaidQuerySnapshot /> in <head> or at the very top of <body>
    // before <Analytics />.
    var inboundQuery =
      (typeof window.__BHQ_INBOUND_QUERY__ === "string"
        ? window.__BHQ_INBOUND_QUERY__
        : window.location.search) || "";

    function run() {
      try {
        var params = new URLSearchParams(inboundQuery);
        // Paid-traffic markers: Google Ads click id (gclid), app+web
        // variants (gbraid/wbraid), and standard UTM source/campaign.
        // Presence of ANY of these flips the page into paid-traffic mode.
        var isPaid =
          params.has("gclid") ||
          params.has("gbraid") ||
          params.has("wbraid") ||
          params.has("utm_source") ||
          params.has("utm_campaign");

        if (isPaid) {
          var hero = document.querySelector("[data-paid-hero]");
          if (hero) {
            hero.hidden = false;
          }
        }

        // ALWAYS rewrite every accounts.breederhq.com/register anchor on
        // the page to preserve the inbound query string, regardless of
        // whether the visitor is paid traffic. Organic visitors with no
        // query string get an unchanged href; paid visitors get gclid +
        // utm_* forwarded to the signup flow so Ads can attribute the
        // conversion to the exact campaign + keyword that drove the click.
        if (inboundQuery && inboundQuery.length > 1) {
          var anchors = document.querySelectorAll(
            'a[href^="https://accounts.breederhq.com/register"]'
          );
          for (var i = 0; i < anchors.length; i++) {
            var a = anchors[i];
            var href = a.getAttribute("href");
            if (!href) continue;
            var sep = href.indexOf("?") === -1 ? "?" : "&";
            // Strip the leading "?" from inboundQuery; href's own
            // separator (sep) handles the join.
            a.setAttribute("href", href + sep + inboundQuery.substring(1));
          }
        }
      } catch (e) {
        // Best-effort. If anything throws (very old browser, etc.) the
        // page still renders with its default state.
      }
    }

    // The component is positioned near the top of <main>, which means
    // most signup anchors are parsed AFTER this script tag. If we ran
    // synchronously here, querySelectorAll would find zero anchors. Wait
    // for the full DOM to parse before scanning.
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", run);
    } else {
      run();
    }
  })();
</script>
