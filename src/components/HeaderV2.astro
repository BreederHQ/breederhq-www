            <a href="/workflows/client-portal" class="block px-3 py-1.5 text-sm text-gray-700 hover:bg-stone-50 rounded">Client Portal</a>
            <a href="/workflows/outreach-hub" class="block px-3 py-1.5 text-sm text-gray-700 hover:bg-stone-50 rounded">Outreach Hub</a>
