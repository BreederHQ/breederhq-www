---
// SpeciesSwitcher: a row of pills letting the buyer jump to the species-specific
// "best X breeding software" comparison page they actually care about.
//
// Used at the top of every /compare/best-{species}-breeding-software page.
// The `active` prop highlights the current page; species without a live page
// render as a disabled pill so buyers still see that other species exist
// (helps cross-page discovery + internal linking for SEO).
//
// Props:
//   - active: which species pill is "you are here"
//
// To add a new species comparison page: drop it in the `species` array below
// with `href` pointing to the new /compare path. To mark a species as
// not-yet-live, set `href` to null.

interface Props {
  active: 'dogs' | 'cats' | 'horses' | 'goats' | 'rabbits' | 'sheep' | 'alpacas' | 'llamas' | 'cattle';
}

const { active } = Astro.props;

const species: Array<{
  key: Props['active'];
  label: string;
  emoji: string;
  href: string | null;
}> = [
  { key: 'dogs',     label: 'Dogs',     emoji: '🐕', href: '/compare/best-dog-breeding-software' },
  { key: 'cats',     label: 'Cats',     emoji: '🐈', href: '/compare/best-cat-breeding-software' },
  { key: 'horses',   label: 'Horses',   emoji: '🐎', href: '/compare/best-horse-breeding-software' },
  { key: 'goats',    label: 'Goats',    emoji: '🐐', href: '/compare/best-goat-breeding-software' },
  { key: 'rabbits',  label: 'Rabbits',  emoji: '🐇', href: '/compare/best-rabbit-breeding-software' },
  { key: 'sheep',    label: 'Sheep',    emoji: '🐑', href: '/compare/best-sheep-breeding-software' },
  { key: 'alpacas',  label: 'Alpacas',  emoji: '🦙', href: null },
  { key: 'llamas',   label: 'Llamas',   emoji: '🦙', href: null },
  { key: 'cattle',   label: 'Cattle',   emoji: '🐄', href: null },
];
---

<nav aria-label="Compare by species" class="species-switcher my-6">
  <p class="text-sm font-semibold text-gray-600 mb-2 uppercase tracking-wide">Compare by species</p>
  <ul class="flex flex-wrap gap-2">
    {species.map((s) => {
      const isActive = s.key === active;
      const baseClasses = 'inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-medium border transition';
      if (isActive) {
        return (
          <li>
            <span
              aria-current="page"
              class={`${baseClasses} bg-[hsl(24,95%,53%)] text-white border-[hsl(24,95%,53%)]`}
            >
              <span aria-hidden="true">{s.emoji}</span>
              {s.label}
            </span>
          </li>
        );
      }
      if (s.href) {
        return (
          <li>
            <a
              href={s.href}
              class={`${baseClasses} bg-white text-gray-800 border-gray-300 hover:border-[hsl(24,95%,53%)] hover:text-[hsl(24,95%,53%)]`}
            >
              <span aria-hidden="true">{s.emoji}</span>
              {s.label}
            </a>
          </li>
        );
      }
      return (
        <li>
          <span
            class={`${baseClasses} bg-gray-50 text-gray-400 border-gray-200 cursor-not-allowed`}
            title="Coming soon"
          >
            <span aria-hidden="true">{s.emoji}</span>
            {s.label}
            <span class="text-xs ml-1">(soon)</span>
          </span>
        </li>
      );
    })}
  </ul>
</nav>
